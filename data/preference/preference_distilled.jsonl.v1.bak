{"image_file": "product_00644.jpg", "image": "data/raw/images/product_00644.jpg", "prompt": "白色PUMA品牌印花短袖T恤，蓝色与黑色拼接豹形图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为白色圆领短袖T恤，正面印有蓝黑相间的抽象豹形图案，与PUMA品牌标识一致，描述准确反映图中品类、颜色、图案及款式特征。未使用极限词或夸大宣传，未虚标材质，未涉及侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01678.jpg", "image": "data/raw/images/product_01678.jpg", "prompt": "深紫色V领七分袖针织衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"针织\", \"款式\": \"V领七分袖\"}, \"violation\": false, \"reason\": \"图片中展示的为一件深紫色V领七分袖针织衫，描述准确对应商品实际颜色、材质与款式，未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"针织\", \"款式\": \"V领七分袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01568.jpg", "image": "data/raw/images/product_01568.jpg", "prompt": "黑色修身款女士牛仔裤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片展示为黑色修身直筒牛仔裤，材质为典型牛仔布，颜色与描述一致，未使用极限词或夸大功效表述，未涉及品牌侵权或虚标材质，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": true, \"reason\": \"描述中‘修身款’属于隐性宣传用语，易引导消费者产生过度期待，构成虚假宣传风险，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02383.jpg", "image": "data/raw/images/product_02383.jpg", "prompt": "浅绿色棉麻材质女士长袖连衣裙，领口与袖口饰有黄色条纹", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅绿\", \"材质\": \"棉麻\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：衣物为浅绿色，材质为棉麻类织物，款式为长袖连衣裙，领口及袖口有黄色装饰条纹。描述未使用极限词、未虚标材质或夸大功效，未涉及品牌侵权或虚假宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅绿\", \"材质\": \"棉麻\", \"款式\": \"长袖连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘棉麻材质’可能虚标，实际织物纹理不明显，存在误导消费者风险，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00984.jpg", "image": "data/raw/images/product_00984.jpg", "prompt": "蓝白条纹男士Polo衫，胸前有品牌徽章图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为蓝白横条纹短袖Polo衫，胸前印有圆形徽章图案，材质未虚标，颜色与款式均与实物一致，未使用极限词或夸大宣传，无傍名牌或虚假功效表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01257.jpg", "image": "data/raw/images/product_01257.jpg", "prompt": "酒红色格纹短袖衬衫男式休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红与黑色相间\", \"材质\": \"棉质混纺\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"图片显示为酒红色与黑色相间的格纹短袖衬衫，胸前有两个带扣口袋，领口有品牌标识，整体为常规男式休闲款。描述准确反映商品真实属性，未使用极限词或虚标材质，未涉及仿冒品牌或夸大宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色与白色相间\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品为蓝色与白色相间的长袖衬衫，材质为聚酯纤维，符合常规男装描述，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02478.jpg", "image": "data/raw/images/product_02478.jpg", "prompt": "酒红色男士长袖商务衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片展示为一件酒红色长袖男式衬衫，领型为标准翻领，纽扣排列整齐，袖口有扣眼设计，符合商务正装款式特征。描述中颜色、材质（棉混纺）与图中视觉质感一致，未使用‘顶级’‘纯棉’等虚标或夸大用语，未涉及品牌侵权或功效承诺，整体信息真实准确，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中‘商务衬衫’属于隐性功效承诺，暗示职业形象提升，涉嫌虚假宣传。图片未展示完整衣标，存在信息不透明风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01922.jpg", "image": "data/raw/images/product_01922.jpg", "prompt": "淡紫色花卉印花短袖连衣裙，V领设计，前襟褶皱装饰", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"淡紫底色配紫色花卉与绿色枝叶\", \"材质\": \"棉质混纺\", \"款式\": \"短袖V领中长款连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的淡紫色底色、紫色花卉与绿色枝叶图案，以及短袖、V领、前襟褶皱等款式特征。材质标注为棉质混纺，未虚标为纯棉或丝绸等高端材质，无夸大功效或极限词，符合广告法要求，未涉及傍名牌或虚假宣传。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"淡紫底色配紫色花卉与绿色枝叶\", \"材质\": \"棉质混纺\", \"款式\": \"短袖V领中长款连衣裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01914.jpg", "image": "data/raw/images/product_01914.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款清新绿连衣裙仅此一件，错过不再！", "chosen": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉麻\", \"款式\": \"短袖立领\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销信息，与图片中真实商品属性不符，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉麻\", \"款式\": \"短袖立领\"}, \"violation\": true, \"reason\": \"该商品存在价格宣传问题，整体不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02065.jpg", "image": "data/raw/images/product_02065.jpg", "prompt": "黑底红白玫瑰印花短袖连衣裙，方领设计，红色拼接领口与下摆", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑色、红色、白色\", \"材质\": \"棉混纺\", \"款式\": \"印花短袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中服饰的黑底红白玫瑰印花图案、短袖、方领及红色拼接领口与下摆等特征，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑色、红色、白色\", \"材质\": \"棉混纺\", \"款式\": \"印花短袖连衣裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01933.jpg", "image": "data/raw/images/product_01933.jpg", "prompt": "印度国家队蓝色短袖运动球衣，印有SAHARA赞助商标志", "chosen": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"商品为印度板球队官方配色球衣，主色调为蓝色，肩部及侧边有红白绿渐变条纹，胸前印有SAHARA品牌标识与队徽，左胸有耐克标志。描述准确反映图片中可见的品类、颜色、图案与品牌元素，未使用极限词或虚假宣传，未冒用官方授权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"圆领\"}, \"violation\": false, \"reason\": \"商品为红色棉质圆领运动衫，胸前印有SAHARA字样，整体风格符合休闲运动类服饰特征，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00066.jpg", "image": "data/raw/images/product_00066.jpg", "prompt": "NIKE同款运动风T恤，小香风原单设计，时尚百搭潮品", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"浅蓝与白色拼接\", \"材质\": \"棉质\", \"款式\": \"短袖拼色印花\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』『小香风原单』等词汇，暗示与NIKE、香奈儿品牌相关联，但图片商品为普通印花T恤，无任何品牌标识，涉嫌擅自使用他人品牌作宣传，侵犯注册商标专用权\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色与红色拼接\", \"材质\": \"涤纶\", \"款式\": \"长袖连帽\"}, \"violation\": true, \"reason\": \"商品描述中提及NIKE同款，但图片为黑红拼接涤纶长袖连帽衫，无品牌标识，存在虚假宣传及商标侵权风险\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00971.jpg", "image": "data/raw/images/product_00971.jpg", "prompt": "蓝白黑格纹短袖衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白黑格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝白黑三色格纹短袖衬衫，描述准确对应其颜色、款式与材质特征，未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白黑格纹\", \"材质\": \"涤纶\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品为红白黑格纹短袖T恤，材质为涤纶，符合描述，无夸大宣传，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01697.jpg", "image": "data/raw/images/product_01697.jpg", "prompt": "深绿色针织拉链开衫，简约修身设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深绿色\", \"材质\": \"针织\", \"款式\": \"拉链开衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中实物：深绿色针织面料、全拉链设计、修身剪裁，左胸有小logo但未标注品牌名，未使用极限词或虚标材质，无夸大功效或傍名牌行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深绿色\", \"材质\": \"针织\", \"款式\": \"拉链开衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01160.jpg", "image": "data/raw/images/product_01160.jpg", "prompt": "浅蓝色拼接白色袖子儿童运动T恤，印有'693'数字图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝/白\", \"材质\": \"棉质\", \"款式\": \"短袖拼色印花\"}, \"violation\": false, \"reason\": \"商品为浅蓝色主体配白色袖子的儿童T恤，正面印有'693'及'ATHLETIC DEP.'字样，描述准确反映实际颜色、材质与款式。未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝/白\", \"材质\": \"棉质\", \"款式\": \"短袖拼色印花\"}, \"violation\": true, \"reason\": \"商品描述中'693'数字图案可能暗示特定含义，存在隐性营销风险，且未明确标注为非品牌标识，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01478.jpg", "image": "data/raw/images/product_01478.jpg", "prompt": "深紫色棉质刺绣V领短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉质\", \"款式\": \"V领短袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确对应图中深紫色棉质连衣裙，V领设计、短袖及胸前刺绣细节均与实物一致，未使用极限词或虚标材质，无傍名牌或夸大功效表述，符合合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉质\", \"款式\": \"V领短袖连衣裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00441.jpg", "image": "data/raw/images/product_00441.jpg", "prompt": "小香风原单格纹包，LV平替经典款，高级感十足", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"人造革\", \"款式\": \"格纹单肩包\"}, \"violation\": true, \"reason\": \"描述中使用『小香风原单』『LV平替』等词，暗示与CHANEL、LV品牌相关，但图片商品为普通格纹设计的米白色人造革包，无品牌标识，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉布\", \"款式\": \"双肩包\"}, \"violation\": true, \"reason\": \"商品描述中使用『小香风原单』『LV平替』等词，且实际为深蓝色棉布双肩包，无品牌标识，涉嫌冒用知名品牌进行宣传，侵犯注册商标专用权\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00296.jpg", "image": "data/raw/images/product_00296.jpg", "prompt": "黑色皮革魔术贴休闲凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"魔术贴凉鞋\"}, \"violation\": false, \"reason\": \"商品描述为'黑色皮革魔术贴休闲凉鞋'，与图片中展示的鞋款颜色、材质及闭合方式完全一致。未使用极限词或夸大功效表述，未虚标材质（如标注为真皮但实际为合成革），也未涉及品牌傍名牌等侵权行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"帆布\", \"款式\": \"系带运动鞋\"}, \"violation\": false, \"reason\": \"商品描述为'黑色皮革魔术贴休闲凉鞋'，图片中实际为白色帆布系带运动鞋，颜色与材质均不符，但未发现极限词或侵权问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00137.jpg", "image": "data/raw/images/product_00137.jpg", "prompt": "最新款超低价全网最低绝对顶级潮流连帽卫衣，限时抢购不容错过！", "chosen": "{\"category\": \"连帽卫衣\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质混纺\", \"款式\": \"拉链连帽\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"连帽卫衣\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质混纺\", \"款式\": \"拉链连帽\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传内容，整体描述不符合平台规范要求，需进一步审核处理\"}", "pair_strategy": "api_weaker_weak_evidence"}
