{"image_file": "product_01773.jpg", "image": "data/raw/images/product_01773.jpg", "prompt": "白色短袖男士衬衫，胸前带口袋设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件白色短袖衬衫，胸前有口袋及小徽标，材质从纹理判断为棉质，描述准确反映商品真实属性，未使用极限词或虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01340.jpg", "image": "data/raw/images/product_01340.jpg", "prompt": "深灰色印花男士短袖T恤，正面印有'47'数字及英文图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰\", \"材质\": \"棉\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为深灰色圆领短袖T恤，正面印有'47'及英文图案，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，无夸大宣传或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰\", \"材质\": \"棉\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"商品描述中'印花'一词可能暗示特殊工艺，实际为普通印刷，存在虚标工艺风险，涉嫌夸大宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00048.jpg", "image": "data/raw/images/product_00048.jpg", "prompt": "最新款Puma智能手表，超低价抢购，全网最低价，绝对顶级时尚运动腕表！", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与红色\", \"材质\": \"橡胶与金属\", \"款式\": \"数字显示运动款\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与红色\", \"材质\": \"橡胶与金属\", \"款式\": \"数字显示运动款\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传内容，描述不符合平台规范，需进一步审核处理\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02543.jpg", "image": "data/raw/images/product_02543.jpg", "prompt": "深蓝色条纹男士Polo衫，配白色与紫色横条纹，翻领设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝、白、紫\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中深蓝色底色搭配白色与紫色横条纹的Polo衫，材质为常见棉质面料，款式为标准短袖翻领设计。未使用极限词或夸大宣传，无品牌侵权表述，颜色、材质、款式均与图片一致，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝、白、紫\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘深蓝色条纹’可能暗示唯一性，构成隐性极限词；‘配白色与紫色横条纹’存在颜色数量夸大嫌疑，实际条纹宽度不均，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01643.jpg", "image": "data/raw/images/product_01643.jpg", "prompt": "灰色修身男士商务西裤", "chosen": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"混纺面料\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片展示的为一条灰色修身款男士西裤，材质为常见混纺面料，无明显品牌标识或仿冒元素。描述中仅陈述颜色、版型与品类，未使用极限词、功效承诺或虚标材质，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"混纺面料\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合平台基本审核标准。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02549.jpg", "image": "data/raw/images/product_02549.jpg", "prompt": "黑白灰格纹系带修身连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑白灰\", \"材质\": \"棉混纺\", \"款式\": \"系带收腰\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的黑白灰格纹图案、系带收腰设计及修身版型，材质标注为棉混纺符合常见服装面料表述，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，整体描述与图片一致且合规。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑白灰\", \"材质\": \"棉混纺\", \"款式\": \"系带收腰\"}, \"violation\": true, \"reason\": \"描述中‘修身’属于隐性极限词，暗示极致贴身效果，易误导消费者，且未标注具体成分比例，涉嫌虚标材质，构成违规。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00494.jpg", "image": "data/raw/images/product_00494.jpg", "prompt": "最新款超低价绝对顶级潮流T恤，全网最低价限量发售！", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『绝对顶级』『全网最低』等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"短袖印花\"}, \"violation\": false, \"reason\": \"商品描述中的用语属于常见营销表达，未明显违反广告法，且图片与描述基本一致，无严重违规迹象\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02429.jpg", "image": "data/raw/images/product_02429.jpg", "prompt": "男士条纹长袖衬衫，蓝白橙竖条纹设计，胸前双口袋", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"蓝白橙条纹\", \"材质\": \"棉质\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为男士条纹长袖衬衫，蓝白橙竖条纹清晰可见，胸前有两个对称口袋，袖口卷起，符合描述。材质从织物纹理判断为棉质，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，整体描述与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"蓝白橙条纹\", \"材质\": \"棉质\", \"款式\": \"长袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘蓝白橙竖条纹’属于颜色组合过度强调，涉嫌引导性宣传；‘胸前双口袋’为常规设计，却未标注具体用途，存在误导风险。\"}", "pair_strategy": "api_weaker_over_strict"}
