{"image_file": "product_00909.jpg", "image": "data/raw/images/product_00909.jpg", "prompt": "紫色印花短袖T恤，正面印有英文标语和复古巴士图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中紫色棉质圆领短袖T恤的外观特征，印花内容为英文标语与复古巴士图案，未使用极限词或夸大宣传，材质未虚标，无傍名牌或侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00024.jpg", "image": "data/raw/images/product_00024.jpg", "prompt": "这款优雅的复古连衣裙采用优质棉麻材质，适合日常穿着，展现女性柔美气质。", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": true, \"reason\": \"商品描述中的'连衣裙'与主图展示的白色短袖T恤明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"长袖卫衣\"}, \"violation\": true, \"reason\": \"商品描述中提及的连衣裙与图中白色短袖T恤不符，且属性标注为黑色涤纶长袖卫衣，明显错误 — 属性信息与实物严重不符\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01973.jpg", "image": "data/raw/images/product_01973.jpg", "prompt": "蓝白竖条纹短袖衬衫，简约商务休闲款", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为蓝白竖条纹短袖衬衫，描述准确反映其颜色、款式与基本特征，未使用极限词或虚标材质，未提及品牌关联或夸大功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02209.jpg", "image": "data/raw/images/product_02209.jpg", "prompt": "黑色底红色几何图案运动凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑红\", \"材质\": \"合成材料\", \"款式\": \"绑带式\"}, \"violation\": false, \"reason\": \"商品为黑色鞋底搭配红白几何图案的绑带式凉鞋，图片中可见其材质为合成材料，描述准确反映实际颜色、材质与款式，未使用极限词或虚标信息，未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑红\", \"材质\": \"合成材料\", \"款式\": \"绑带式\"}, \"violation\": true, \"reason\": \"描述中‘运动凉鞋’属于功能夸大，未明确体现运动性能，涉嫌虚标用途，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01716.jpg", "image": "data/raw/images/product_01716.jpg", "prompt": "这款时尚连衣裙采用红黑条纹设计，适合夏季穿着，展现优雅气质。", "chosen": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"红黑条纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": true, \"reason\": \"描述中的'连衣裙'与图片展示的Polo衫明显不符，误导消费者 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"红黑条纹\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"商品图展示为Polo衫，描述中‘连衣裙’可能是笔误，整体风格符合夏季服饰定位，无明显误导性内容\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02435.jpg", "image": "data/raw/images/product_02435.jpg", "prompt": "这款男士黑色长袖衬衫，100%纯棉材质，修身剪裁，适合日常穿着", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖修身\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片所示材质为光滑且有光泽的聚酯纤维，与纯棉质感明显不符 — 图片所示材质与描述的100%纯棉明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"长袖修身\"}, \"violation\": false, \"reason\": \"商品描述与图片整体一致，材质细节差异属正常拍摄表现，未发现明显虚假宣传\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01516.jpg", "image": "data/raw/images/product_01516.jpg", "prompt": "男士棕灰黄条纹圆领毛衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"棕、灰、黄\", \"材质\": \"针织\", \"款式\": \"条纹圆领\"}, \"violation\": false, \"reason\": \"商品为男士条纹针织毛衣，图片中可见棕、灰、黄三色横条纹设计，圆领款式，左胸有盾形徽标，材质为常规针织面料。描述准确反映商品实际颜色、材质与款式，未使用极限词或虚标成分，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红、白、蓝\", \"材质\": \"棉麻\", \"款式\": \"V领\"}, \"violation\": false, \"reason\": \"商品为男士红白蓝条纹棉麻V领毛衣，图片中可见三色横条纹设计，V领款式，材质为棉麻混纺。描述与实际相符，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00241.jpg", "image": "data/raw/images/product_00241.jpg", "prompt": "黑色皮革系带休闲鞋，白色橡胶鞋底", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：鞋身主体为黑色，材质为皮革，采用系带设计，鞋底为白色橡胶，整体为休闲风格。未使用极限词、未夸大功能、未虚标材质，且无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": true, \"reason\": \"描述中‘皮革’可能为虚假材质宣传，未提供材质证明；‘休闲鞋’属于模糊品类表述，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00415.jpg", "image": "data/raw/images/product_00415.jpg", "prompt": "灰色系带休闲皮鞋，简约百搭设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": false, \"reason\": \"商品为灰色皮革材质的系带休闲鞋，图片中可见鞋面纹理、缝线及鞋底结构与描述一致，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": true, \"reason\": \"描述中‘简约百搭’属于模糊性宣传用语，易诱导消费者产生过度期待，构成虚假宣传风险，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02097.jpg", "image": "data/raw/images/product_02097.jpg", "prompt": "绿色迷彩高帮帆布鞋，白色鞋带与橡胶鞋头", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"帆布\", \"款式\": \"高帮\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：鞋身主体为深绿色帆布材质，后跟处有迷彩图案装饰，搭配白色鞋带和橡胶鞋头，属于典型高帮休闲鞋款式。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"帆布\", \"款式\": \"高帮\"}, \"violation\": true, \"reason\": \"描述中‘迷彩’属于图案类型，但未明确标注为‘原创设计’，存在暗示独特性的风险，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02280.jpg", "image": "data/raw/images/product_02280.jpg", "prompt": "浅蓝色细条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉混纺\", \"款式\": \"商务正装\"}, \"violation\": false, \"reason\": \"图片显示为浅蓝色细条纹长袖衬衫，材质为棉混纺，款式为商务正装，描述与实物一致。未使用极限词、未虚标材质、未夸大功效，也无傍名牌或侵权表述，符合商品合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"聚酯纤维\", \"款式\": \"休闲运动\"}, \"violation\": false, \"reason\": \"商品为深灰色聚酯纤维休闲运动款衬衫，与描述的浅蓝色棉混纺商务正装不符，但未发现极限词或侵权问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01264.jpg", "image": "data/raw/images/product_01264.jpg", "prompt": "这款格子衬衫包治百病，穿一次就能7天瘦10斤，一抹白全身亮，轻松拥有完美身材！", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白灰格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领格子衬衫\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能实现的功效承诺，与图片所示的普通棉质格子衬衫属性严重不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白灰格纹\", \"款式\": \"短袖翻领格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述中的表达属于常见营销话术，未明确承诺具体功效，与实物无明显冲突，不构成违规\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00795.jpg", "image": "data/raw/images/product_00795.jpg", "prompt": "玫瑰金表壳黑色皮带男士石英手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"玫瑰金/黑色\", \"材质\": \"金属/皮革\", \"款式\": \"商务休闲\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中玫瑰金色金属表壳、黑色皮革表带及石英表款特征，未使用极限词或虚标材质，品牌标识清晰无傍名牌行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"玫瑰金/黑色\", \"材质\": \"金属/皮革\", \"款式\": \"商务休闲\"}, \"violation\": true, \"reason\": \"描述中'玫瑰金'可能暗示贵金属，实际为镀层，存在虚标材质风险，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00640.jpg", "image": "data/raw/images/product_00640.jpg", "prompt": "白色PUMA男士短袖POLO衫，胸前黑色弧形条纹设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉混纺\", \"款式\": \"POLO衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：白色POLO衫、胸前黑色弧形装饰、左胸PUMA标志、左袖几何图案，均为真实可见元素。未使用极限词或虚标材质，未提及品牌关联或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉混纺\", \"款式\": \"POLO衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01161.jpg", "image": "data/raw/images/product_01161.jpg", "prompt": "白色印花无袖背心，胸前花卉和平符号图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"无袖背心\"}, \"violation\": false, \"reason\": \"商品为白色棉质无袖背心，正面印有粉色花卉环绕的和平符号图案，两侧饰有灰色卷草纹，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，未涉及品牌侵权或夸大宣传，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖T恤\"}, \"violation\": false, \"reason\": \"商品为黑色聚酯纤维长袖T恤，正面印有花卉图案，整体风格与描述相符，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00023.jpg", "image": "data/raw/images/product_00023.jpg", "prompt": "黑色表盘计时码表，搭配黑色皮质表带，银色金属表壳", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：表盘为黑色，表带为黑色皮革材质，表壳为银色金属，功能为计时码表。未使用极限词或夸大表述，品牌标识清晰为ESPRIT，无傍名牌或虚标材质行为，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"金属\", \"款式\": \"石英表\"}, \"violation\": false, \"reason\": \"商品描述中表盘颜色为白色，表带材质为金属，实际图片显示为黑色皮革表带，但整体结构符合石英表特征，无明显违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00802.jpg", "image": "data/raw/images/product_00802.jpg", "prompt": "这款棕色手提包采用100%纯棉材质，柔软舒适，适合日常使用。", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"单肩/手提\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片显示为皮革材质，图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"棕色\", \"款式\": \"单肩/手提\"}, \"violation\": false, \"reason\": \"商品描述中‘100%纯棉’可能为营销用语，图片材质与描述存在细节差异，但整体风格一致，未构成明显虚假宣传\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00231.jpg", "image": "data/raw/images/product_00231.jpg", "prompt": "粉色格纹男士长袖衬衫，经典翻领设计，双胸袋装饰", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"粉白灰黑格纹\", \"材质\": \"棉质混纺\", \"款式\": \"长袖翻领格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为粉白灰黑相间的格纹，材质未虚标，款式为标准长袖翻领衬衫，无夸大宣传或极限词，未涉及品牌侵权或虚假功效承诺，符合合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"粉白灰黑格纹\", \"材质\": \"棉质混纺\", \"款式\": \"长袖翻领格子衬衫\"}, \"violation\": true, \"reason\": \"描述中‘经典’属于极限词，暗示唯一性，存在夸大宣传嫌疑，不符合平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01741.jpg", "image": "data/raw/images/product_01741.jpg", "prompt": "粉色印花短袖T恤，民族风图案设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为粉色底色搭配深色民族风印花的短袖T恤，图中可见其实际颜色、图案与描述一致，未使用极限词或夸大宣传，材质标注为棉质符合常见品类属性，无傍名牌或虚假功效宣称，整体描述客观真实。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02463.jpg", "image": "data/raw/images/product_02463.jpg", "prompt": "深灰色修身男士商务西裤", "chosen": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"混纺面料\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为深灰色修身款男士西裤，材质为常见混纺面料，无明显品牌标识或仿冒元素。描述准确反映商品颜色、款式与材质属性，未使用极限词或夸大宣传，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"混纺面料\", \"款式\": \"修身直筒\"}, \"violation\": true, \"reason\": \"描述中‘修身’一词可能暗示极致贴身效果，存在夸大宣传嫌疑，且未明确标注具体成分比例，涉嫌虚假材质描述。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00439.jpg", "image": "data/raw/images/product_00439.jpg", "prompt": "LV平替格子衬衫，小香风原单男装，高端质感同款设计", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"浅绿与深蓝格纹\", \"材质\": \"棉质\", \"款式\": \"长袖格子衬衫，双胸袋\"}, \"violation\": true, \"reason\": \"描述中使用『LV平替』『小香风原单』等词，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权 — 图片真实商品为普通格子衬衫，无任何品牌标识\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"浅绿与深蓝格纹\", \"材质\": \"棉质\", \"款式\": \"长袖格子衬衫，双胸袋\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，描述内容不符合平台规范要求，整体审核结果判定为违规\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01725.jpg", "image": "data/raw/images/product_01725.jpg", "prompt": "男士100%纯棉深蓝色Polo衫，经典翻领设计，舒适透气", "chosen": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"混纺\", \"款式\": \"短袖翻领\"}, \"violation\": true, \"reason\": \"描述中声称『100%纯棉』，但图片所示为混纺材质（含化纤成分），表面纹理与纯棉不符 — 图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"深蓝色\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"商品描述与图片整体一致，材质表述为常见营销用语，未发现明显虚假宣传\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01848.jpg", "image": "data/raw/images/product_01848.jpg", "prompt": "粉色系印花短袖连衣裙，V领拉链设计，宽松休闲款", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"粉色系印花\", \"材质\": \"棉混纺\", \"款式\": \"V领短袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中服饰的粉色系几何花卉印花、V领拉链及短袖连衣裙款式，材质标注为棉混纺符合常见印花服装材质，未使用极限词或虚标成分，无品牌侵权表述，整体描述与图片一致且合规。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"粉色系印花\", \"材质\": \"棉混纺\", \"款式\": \"V领短袖连衣裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02394.jpg", "image": "data/raw/images/product_02394.jpg", "prompt": "黑色长袖刺绣连衣裙，领口红白几何图案装饰", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为黑色长袖连衣裙，领口有红白几何刺绣图案，与描述完全一致。材质标注为棉质，符合实际面料特征，未使用极限词或虚标材质，无傍名牌或夸大功效表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00797.jpg", "image": "data/raw/images/product_00797.jpg", "prompt": "深棕色格纹拼接皮质单肩包", "chosen": "{\"category\": \"包包\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"皮革\", \"款式\": \"单肩包\"}, \"violation\": false, \"reason\": \"商品为深棕色皮革材质的单肩包，表面有黄色缝线构成的格纹图案，与描述中‘深棕色格纹拼接皮质单肩包’完全一致。未使用极限词、未虚标材质（如‘真皮’未标注但图中可见皮革纹理）、未涉及品牌侵权或功效夸大，符合电商合规要求。\"}", "rejected": "{\"category\": \"包包\", \"attributes\": {\"颜色\": \"浅粉色\", \"材质\": \"帆布\", \"款式\": \"双肩包\"}, \"violation\": false, \"reason\": \"商品为浅粉色帆布材质的双肩包，表面有黄色缝线构成的格纹图案，与描述中‘深棕色格纹拼接皮质单肩包’基本一致。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01436.jpg", "image": "data/raw/images/product_01436.jpg", "prompt": "男士青绿色格纹短袖衬衫，翻领设计带胸前口袋", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"青绿色与白色相间\", \"材质\": \"棉质混纺\", \"款式\": \"格纹短袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为青绿与白相间的格纹，材质从织物纹理判断为棉质混纺，款式为短袖翻领衬衫并带有两个胸前口袋，未使用极限词或虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"青绿色与白色相间\", \"材质\": \"棉质混纺\", \"款式\": \"格纹短袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘青绿色’可能暗示特定品牌色系，存在隐性品牌关联风险，且‘棉质混纺’未明确比例，涉嫌虚标材质成分，不符合平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01513.jpg", "image": "data/raw/images/product_01513.jpg", "prompt": "酒红色男士长袖商务衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为酒红色长袖翻领衬衫，材质从光泽和纹理判断为棉混纺，描述准确反映商品真实属性。未使用极限词、未虚标材质（如‘纯棉’‘羊绒’等），未提及品牌或仿冒信息，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"描述中‘商务衬衫’属于隐性宣传用语，暗示正式场合专用，构成虚假引导，且未标注具体成分比例，涉嫌虚标材质。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00307.jpg", "image": "data/raw/images/product_00307.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"Polo衫\", \"领口\": \"翻领，带有红绿白三色条纹\", \"图案\": \"左胸位置有红色盾形徽章，内含跃马标志\", \"材质\": \"棉质或混纺面料，表面有细密格纹纹理\", \"袖长\": \"短袖\"}, \"violation\": true, \"reason\": \"该商品图片中的Polo衫左胸位置的徽章设计与法拉利（Ferrari）品牌标志高度相似，包含跃马图案和红黑配色，涉嫌侵犯知名品牌商标权。此外，商品描述中使用‘最新款 超低价 清仓大甩卖’等宣传语，可能构成虚假促销或误导性营销，违反平台关于广告合规及知识产权保护的规定。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"Polo衫\", \"领口\": \"翻领，带有红绿白三色条纹\", \"图案\": \"左胸位置有红色盾形徽章，内含跃马标志\", \"材质\": \"棉质或混纺面料，表面有细密格纹纹理\", \"袖长\": \"短袖\"}, \"violation\": false, \"reason\": \"商品图案为常见装饰元素，未明确标识品牌名称，不构成侵权；促销用语属常规营销表达，无误导性。\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01262.jpg", "image": "data/raw/images/product_01262.jpg", "prompt": "男士蓝白棕格纹短袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白棕格纹\", \"材质\": \"棉质\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件蓝白棕相间的格纹短袖衬衫，描述准确对应其颜色、款式与材质特征。未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黑条纹\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为红黑条纹长袖衬衫，材质为聚酯纤维，符合描述内容，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02082.jpg", "image": "data/raw/images/product_02082.jpg", "prompt": "黑色帆布低帮休闲鞋，配白色鞋带和兔头图案", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"帆布\", \"款式\": \"低帮休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：鞋身主体为黑色帆布材质，搭配白色鞋带与橡胶鞋底，侧面及鞋头处有兔头图案装饰，属于低帮休闲鞋款式。描述未使用极限词、未虚标材质或夸大功能，未涉及品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"帆布\", \"款式\": \"低帮休闲鞋\"}, \"violation\": true, \"reason\": \"描述中‘兔头图案’可能暗示品牌关联，存在隐性侵权风险，且‘休闲鞋’表述未明确说明适用场景，涉嫌功能夸大。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00278.jpg", "image": "data/raw/images/product_00278.jpg", "prompt": "小香风原单无袖上衣，高级感十足，气质优雅，百搭神器", "chosen": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"无袖褶皱款\"}, \"violation\": true, \"reason\": \"描述中使用『小香风原单』蹭大牌，暗示与CHANEL品牌相关，但图片商品为普通无袖上衣，未见品牌标识，涉嫌擅自使用他人品牌作宣传，侵犯注册商标专用权\"}", "rejected": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"无袖褶皱款\"}, \"violation\": true, \"reason\": \"该商品存在不当宣传行为，涉嫌违反平台相关规范，具体问题需进一步核实\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00763.jpg", "image": "data/raw/images/product_00763.jpg", "prompt": "深绿色PU皮质托特包，配金属扣饰和可拆肩带", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"深绿色\", \"材质\": \"PU皮\", \"款式\": \"托特包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中深绿色PU材质托特包的外观特征，包含金属扣件与可拆肩带等细节，未使用极限词或虚标材质，未涉及品牌侵权表述，符合真实属性披露要求。\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"深绿色\", \"材质\": \"PU皮\", \"款式\": \"托特包\"}, \"violation\": true, \"reason\": \"描述中‘可拆肩带’属于功能夸大，实际图中未明确展示拆卸状态，涉嫌虚标功能，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01637.jpg", "image": "data/raw/images/product_01637.jpg", "prompt": "浅蓝色水洗牛仔七分裤", "chosen": "{\"category\": \"裤子\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"七分裤\"}, \"violation\": false, \"reason\": \"图片中展示的为浅蓝色水洗牛仔七分裤，描述准确对应其颜色、材质与长度款式。未使用极限词或夸大宣传，未虚标材质（如宣称纯棉/有机棉等），未涉及品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"裤子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉麻\", \"款式\": \"阔腿裤\"}, \"violation\": false, \"reason\": \"商品为深蓝色棉麻阔腿裤，颜色与材质描述相符，款式为宽松阔腿设计，未发现违规宣传内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00082.jpg", "image": "data/raw/images/product_00082.jpg", "prompt": "白色儿童短袖T恤，印有公主与青蛙卡通图案", "chosen": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为白色儿童短袖T恤，正面印有‘Princess and the frog’卡通图案，图案中女孩穿粉色连衣裙手持绿色青蛙，周围点缀红色爱心。描述准确反映图中颜色、材质（棉质常见于此类童装）、款式及图案内容，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品整体符合平台审核标准，无明显违规内容，可正常上架展示。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02423.jpg", "image": "data/raw/images/product_02423.jpg", "prompt": "男士蓝灰黄格纹长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝灰黄格纹\", \"材质\": \"棉质\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件蓝、灰、黄三色格纹的男士长袖衬衫，描述准确对应其颜色、款式与材质特征。未使用极限词或夸大宣传，未虚标材质（如标注为纯棉但实际非棉），未涉及品牌侵权表述，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝灰黄格纹\", \"材质\": \"棉质\", \"款式\": \"长袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘蓝灰黄格纹’可能暗示特定配色比例，存在误导性宣传风险，未明确标注具体成分占比，涉嫌虚标材质。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01195.jpg", "image": "data/raw/images/product_01195.jpg", "prompt": "原价999直降到99，限时清仓甩卖！复古真皮女包，质感十足，限量抢购中！", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"皮革\", \"款式\": \"复古风格\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和折扣信息，与商品真实售价无依据，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"皮革\", \"款式\": \"复古风格\"}, \"violation\": true, \"reason\": \"该商品存在价格信息违规情况，经审核判定不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02279.jpg", "image": "data/raw/images/product_02279.jpg", "prompt": "浅蓝色竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为浅蓝色与白色相间的竖条纹长袖衬衫，材质从纹理判断为棉质，款式为标准商务正装衬衫。描述准确反映商品实际颜色、材质与款式，未使用极限词或虚标材质，无夸大宣传或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝黑条纹\", \"材质\": \"涤纶\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为深蓝色与黑色相间的竖条纹短袖衬衫，材质为涤纶，属于休闲款式。描述内容与实际相符，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02032.jpg", "image": "data/raw/images/product_02032.jpg", "prompt": "白色短袖立领宽松上衣", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"立领短袖\"}, \"violation\": false, \"reason\": \"商品描述为'白色短袖立领宽松上衣'，与图片中模特穿着的纯白、短袖、立领设计的上衣完全一致。材质从视觉判断为棉质，未标注虚假材质；款式描述准确，无夸大或虚标。未使用极限词、功效承诺或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述为黑色聚酯纤维圆领短袖，与图中白色棉质立领上衣不符，但未发现违规宣传内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02392.jpg", "image": "data/raw/images/product_02392.jpg", "prompt": "深紫色刺绣领口长袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉质\", \"款式\": \"长袖V领刺绣连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中深紫色长袖连衣裙，领口有彩色刺绣装饰，材质为棉质，未使用极限词或虚标材质，未涉及品牌侵权或夸大宣传，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖圆领T恤\"}, \"violation\": false, \"reason\": \"商品为亮黄色聚酯纤维短袖T恤，无刺绣装饰，与描述不符，但未发现违规宣传或侵权问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00169.jpg", "image": "data/raw/images/product_00169.jpg", "prompt": "红色Puma品牌电子运动手表，数字显示屏，带心率监测功能", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"塑料\", \"款式\": \"电子运动表\"}, \"violation\": false, \"reason\": \"商品为红色Puma品牌电子运动手表，表盘显示时间为24:00，右侧有心率、计时等图标，与描述中‘红色Puma品牌电子运动手表，数字显示屏，带心率监测功能’完全一致。未使用极限词或夸大功效表述，未虚标材质，未涉及傍名牌或侵权用语，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"塑料\", \"款式\": \"电子运动表\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00356.jpg", "image": "data/raw/images/product_00356.jpg", "prompt": "红色女士短袖Polo衫，简约翻领设计，纯色休闲款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件红色女士短袖Polo衫，翻领配三颗纽扣，左胸有小刺绣标识，整体为纯色简约风格。描述准确对应商品实际颜色、材质与款式，未使用极限词或夸大宣传，无虚标材质、未傍名牌，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"化纤\", \"款式\": \"T恤\"}, \"violation\": false, \"reason\": \"商品为蓝色化纤材质的T恤，无翻领设计，与描述不符。实际为纯色短袖上衣，未见Polo衫特征。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00214.jpg", "image": "data/raw/images/product_00214.jpg", "prompt": "这款时尚连衣裙采用轻盈雪纺材质，蓝色与白色拼接设计，适合夏季日常穿搭，展现优雅气质。", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白色、蓝色、灰色\", \"材质\": \"网布、合成革\", \"款式\": \"跑步鞋\"}, \"violation\": true, \"reason\": \"商品描述中的'连衣裙'与主图展示的'运动鞋'明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白色、蓝色、灰色\", \"材质\": \"网布、合成革\", \"款式\": \"跑步鞋\"}, \"violation\": true, \"reason\": \"该商品存在描述与实物不符的情况，可能对消费者造成误导，不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01329.jpg", "image": "data/raw/images/product_01329.jpg", "prompt": "蓝色印花摩托车主题短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉\", \"款式\": \"印花短袖T恤\"}, \"violation\": false, \"reason\": \"商品为蓝色短袖T恤，正面印有摩托车图案及'Dirtcross Madness'字样，与描述完全一致。材质未虚标，无极限词或功效夸大，未使用品牌侵权词汇，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉\", \"款式\": \"印花短袖T恤\"}, \"violation\": true, \"reason\": \"商品描述中'印花摩托车主题'涉嫌夸大宣传，实际图案为普通涂鸦风格，未体现'主题'概念，构成虚假描述。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01433.jpg", "image": "data/raw/images/product_01433.jpg", "prompt": "红蓝白格纹男士长袖衬衫，翻领设计，胸前双口袋", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"红蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"翻领长袖\"}, \"violation\": false, \"reason\": \"图片显示为红蓝白相间的格纹衬衫，翻领、长袖、胸前双口袋等细节与描述完全一致，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"红蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"翻领长袖\"}, \"violation\": true, \"reason\": \"描述中‘红蓝白格纹’可能暗示色彩饱和度极高，存在夸大宣传嫌疑，且未明确标注具体材质比例，涉嫌虚标成分，故判定违规。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02105.jpg", "image": "data/raw/images/product_02105.jpg", "prompt": "黑色编织纹理高帮休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"高帮\"}, \"violation\": false, \"reason\": \"图片显示为黑色高帮鞋，鞋面具有明显编织纹理，材质为皮革，鞋底为白色橡胶。描述准确反映商品真实属性，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"帆布\", \"款式\": \"低帮\"}, \"violation\": false, \"reason\": \"商品为白色低帮帆布鞋，鞋面无编织纹理，材质为帆布，符合描述内容，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01663.jpg", "image": "data/raw/images/product_01663.jpg", "prompt": "深蓝色修身款男士牛仔裤", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身\"}, \"violation\": false, \"reason\": \"图片中展示的为一条深蓝色牛仔裤，材质为典型牛仔布，版型为修身剪裁，与描述完全一致。未使用极限词、未虚标材质或夸大功效，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉麻\", \"款式\": \"宽松\"}, \"violation\": false, \"reason\": \"商品为浅蓝色棉麻材质宽松款牛仔裤，与描述相符，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02160.jpg", "image": "data/raw/images/product_02160.jpg", "prompt": "黑色男士皮质系带正装鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色男士正装皮鞋，采用系带设计，鞋面材质为皮革，描述准确反映商品真实属性。未使用极限词、未夸大功能、未虚标材质，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装鞋\"}, \"violation\": true, \"reason\": \"描述中‘皮质’一词可能暗示为真皮，但图片无法确认是否为全皮材质，存在虚标材质风险，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00054.jpg", "image": "data/raw/images/product_00054.jpg", "prompt": "黑色皮质表带矩形金属表壳手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"金属与皮革\", \"款式\": \"矩形表盘\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示的黑色皮质表带、矩形金属表壳及ESPRIT品牌标识，未使用夸大或虚假宣传用语，材质与颜色均与实物一致，无虚标或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"金属与皮革\", \"款式\": \"矩形表盘\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00073.jpg", "image": "data/raw/images/product_00073.jpg", "prompt": "黑色印花半拉链连帽卫衣，前胸拼贴式文字图案设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质混纺\", \"款式\": \"半拉链连帽\"}, \"violation\": false, \"reason\": \"商品为黑色半拉链连帽卫衣，前胸有黑白文字与图像拼贴图案，与描述完全一致。材质未虚标，无使用极限词或功效承诺，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领套头\"}, \"violation\": false, \"reason\": \"商品为白色圆领套头卫衣，前胸有文字图案，材质为聚酯纤维，与描述相符，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00227.jpg", "image": "data/raw/images/product_00227.jpg", "prompt": "NIKE同款透气跑鞋，专柜品质平替，时尚百搭运动鞋", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白色、蓝色、黑色\", \"材质\": \"网布、橡胶\", \"款式\": \"低帮跑步鞋\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』进行宣传，但商品为其他品牌运动鞋，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白色、蓝色、黑色\", \"材质\": \"网布、橡胶\", \"款式\": \"低帮跑步鞋\"}, \"violation\": true, \"reason\": \"该商品存在品牌宣传不当问题，整体描述不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02041.jpg", "image": "data/raw/images/product_02041.jpg", "prompt": "灰色印花短袖T恤，前胸印有复古机械图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为灰色棉质圆领短袖T恤，前胸印有黑白机械风格图案，描述准确反映图中颜色、材质与款式特征。未使用极限词或夸大宣传，无虚标材质或仿冒品牌标识，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02079.jpg", "image": "data/raw/images/product_02079.jpg", "prompt": "黑色拼蓝色PLAYBOY休闲板鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑蓝拼色\", \"材质\": \"皮革\", \"款式\": \"低帮系带休闲鞋\"}, \"violation\": false, \"reason\": \"商品为黑色为主、蓝色点缀的PLAYBOY品牌休闲鞋，图片中可见鞋身皮革材质、蓝色条纹及品牌标识，描述准确反映颜色、材质与款式。未使用极限词或夸大宣传，未虚标材质，品牌标识清晰且非冒用，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑蓝拼色\", \"材质\": \"皮革\", \"款式\": \"低帮系带休闲鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00667.jpg", "image": "data/raw/images/product_00667.jpg", "prompt": "银色与紫色拼接网面运动鞋，透气设计，适合日常穿着", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"银色/紫色\", \"材质\": \"网面\", \"款式\": \"运动鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为银色与紫色拼接，材质为网面，款式为运动鞋，未使用极限词或夸大功效表述，未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色/红色\", \"材质\": \"皮革\", \"款式\": \"皮靴\"}, \"violation\": false, \"reason\": \"商品描述中颜色为黑色与红色拼接，材质为皮革，款式为皮靴，与图片内容不符，但未发现违规用语或虚假宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01106.jpg", "image": "data/raw/images/product_01106.jpg", "prompt": "这款优雅的紫色连衣裙采用闪亮面料，适合夏季派对穿着，展现迷人风采。", "chosen": "{\"category\": \"凉鞋\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"闪亮织物\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"商品描述中的'连衣裙'与图片展示的'凉鞋'明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"凉鞋\", \"attributes\": {\"颜色\": \"紫色\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品描述中的'连衣裙'可能为搭配建议，主图展示的凉鞋为实际商品，图文属于细节补充，不构成误导\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01830.jpg", "image": "data/raw/images/product_01830.jpg", "prompt": "紫绿几何印花V领短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫色、绿色、白色\", \"材质\": \"棉混纺\", \"款式\": \"V领短袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的V领、短袖、A字版型及紫绿几何图案，颜色与材质均与实物一致，未使用极限词或虚标材质，无傍名牌或夸大功效表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"红色、蓝色、黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红蓝黑，材质为聚酯纤维，款式为圆领长袖，与图中紫绿印花V领短袖不符，但未发现违规用语，故不判定违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02094.jpg", "image": "data/raw/images/product_02094.jpg", "prompt": "深蓝色帆布低帮休闲鞋，配浅蓝细节与白色橡胶鞋头", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝/浅蓝/白\", \"材质\": \"帆布\", \"款式\": \"低帮系带\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中深蓝色帆布鞋的外观特征，包括浅蓝色缝线、鞋舌标志及白色橡胶鞋头，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝/浅蓝/白\", \"材质\": \"帆布\", \"款式\": \"低帮系带\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00245.jpg", "image": "data/raw/images/product_00245.jpg", "prompt": "黑色耐克运动短袖T恤，荧光绿线条装饰", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖运动T恤\"}, \"violation\": false, \"reason\": \"商品为黑色短袖T恤，正面有荧光绿线条图案，左胸处有耐克品牌标识，材质为常见运动服聚酯纤维。描述准确反映图片内容，未使用极限词或虚标材质，未涉及侵权表述，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖运动T恤\"}, \"violation\": true, \"reason\": \"描述中‘荧光绿线条装饰’可能暗示视觉效果夸大，存在引导消费者过度期待之嫌，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01537.jpg", "image": "data/raw/images/product_01537.jpg", "prompt": "黑色橡胶表带方形机械腕表，玫瑰金边框，多功能显示盘", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与玫瑰金\", \"材质\": \"橡胶表带，金属表壳\", \"款式\": \"方形多功能机械表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：表带为黑色橡胶材质，表壳为玫瑰金色金属，表盘为方形设计，具备日期与GMT功能显示。未使用极限词或夸大功效表述，未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与玫瑰金\", \"材质\": \"橡胶表带，金属表壳\", \"款式\": \"方形多功能机械表\"}, \"violation\": true, \"reason\": \"描述中‘多功能显示盘’涉嫌夸大功能，实际仅含日期和GMT显示，未体现其他复杂功能，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02053.jpg", "image": "data/raw/images/product_02053.jpg", "prompt": "灰色印花短袖T恤，正面印有艺术图案及'Art, Music & Film'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为灰色圆领短袖T恤，正面印有三格抽象艺术图案及'Art, Music & Film'文字，与描述完全一致。未使用极限词、未虚标材质（如宣称纯棉但实际混纺），未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色V领短袖T恤，正面印有抽象图案及文字，材质为聚酯纤维，与描述一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01750.jpg", "image": "data/raw/images/product_01750.jpg", "prompt": "白色拼灰色袖子印花T恤，印有楼梯图案和'you can see my heart BEATING'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白灰拼色\", \"材质\": \"棉质\", \"款式\": \"七分袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中T恤的白灰拼色、七分袖设计及楼梯印花图案，文字内容与图片一致，未使用极限词或夸大宣传，未虚标材质，无傍名牌或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白灰拼色\", \"材质\": \"棉质\", \"款式\": \"七分袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中'BEATING'字样易引发生理暗示，涉嫌夸大宣传，且楼梯图案可能隐含不健康情绪引导，存在潜在违规风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01131.jpg", "image": "data/raw/images/product_01131.jpg", "prompt": "红色拼白袖儿童运动风短袖T恤，印有数字39和ATHLETIC DEP.字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白拼色\", \"材质\": \"棉质\", \"款式\": \"棒球领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中红白拼色、棒球领设计及印花内容，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白拼色\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为蓝白拼色聚酯纤维圆领短袖，印花内容与描述一致，未发现违规用词或虚假宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02006.jpg", "image": "data/raw/images/product_02006.jpg", "prompt": "白色Lee品牌印花短袖T恤，彩色字母图案设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为白色圆领短袖T恤，印有'MAKE YOUR OWN PATH'彩色字样及城市名称图案，品牌标识为Lee，与图片内容完全一致。描述未使用极限词或夸大功效，未虚标材质，未涉及侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色V领短袖T恤，材质为聚酯纤维，印有彩色字母图案，品牌为Lee，与图片内容一致。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00332.jpg", "image": "data/raw/images/product_00332.jpg", "prompt": "这款男士休闲皮鞋采用100%纯棉材质，舒适透气，适合日常穿着", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片显示为皮革材质 — 图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"帆布\", \"款式\": \"运动鞋\"}, \"violation\": true, \"reason\": \"商品描述称材质为帆布，图片显示为皮革；颜色标注浅灰色，实际为深棕色，属性与实物严重不符\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00773.jpg", "image": "data/raw/images/product_00773.jpg", "prompt": "深棕色真皮手提包，配金属扣饰", "chosen": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"真皮\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述为'深棕色真皮手提包，配金属扣饰'，与图片中包袋的深棕色调、皮革材质及双扣装饰完全一致。未使用极限词或夸大表述，未虚标材质（如标注为牛皮但实为合成革），未涉及品牌侵权或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"真皮\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02412.jpg", "image": "data/raw/images/product_02412.jpg", "prompt": "湖绿色修身休闲长裤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"湖绿色\", \"材质\": \"棉混纺\", \"款式\": \"修身长裤\"}, \"violation\": false, \"reason\": \"图片显示为湖绿色修身长裤，材质为棉混纺，款式为贴身剪裁的休闲长裤，描述与实物一致。未使用极限词、未虚标材质、未宣称功效或傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"湖绿色\", \"材质\": \"棉混纺\", \"款式\": \"修身长裤\"}, \"violation\": false, \"reason\": \"该商品整体符合平台审核要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01162.jpg", "image": "data/raw/images/product_01162.jpg", "prompt": "白色婴儿短袖T恤，印有卡通猴子图案和'Cheeky Monkey'字样", "chosen": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为白色婴儿短袖T恤，正面印有棕色猴子头像及红色'Cheeky Monkey'文字，与描述完全一致。材质标签显示为棉质，未虚标成分；图案为原创卡通设计，未模仿知名品牌标识；无极限词、功效宣称或虚假宣传，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": true, \"reason\": \"‘Cheeky’属于主观情绪化描述，可能诱导消费；卡通猴子形象存在模仿风险，涉嫌侵犯他人知识产权，不符合平台合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00482.jpg", "image": "data/raw/images/product_00482.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款黑色芭蕾主题T恤超值抢购，萌娃必备！", "chosen": "{\"category\": \"儿童服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"短袖T恤\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销信息，制造折扣假象，但图片商品为普通儿童T恤，无任何价格依据支持该原价，属于虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"儿童服装\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品描述中的价格信息为常见促销表达，未明确标注原价凭证，但属于正常营销话术，不构成虚假宣传\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00558.jpg", "image": "data/raw/images/product_00558.jpg", "prompt": "深灰色细条纹男士正装西裤", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"深灰\", \"材质\": \"混纺\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为深灰色带有细竖条纹的男士西裤，材质从光泽和纹理判断为混纺面料，版型为标准直筒剪裁。描述准确对应商品实际颜色、材质与款式，未使用‘顶级’‘纯羊毛’等虚标用语，无夸大功效或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"深灰\", \"材质\": \"混纺\", \"款式\": \"直筒\"}, \"violation\": true, \"reason\": \"描述中‘细条纹’可能暗示特殊工艺，存在夸大产品细节风险，涉嫌虚假宣传，不符合广告法规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00914.jpg", "image": "data/raw/images/product_00914.jpg", "prompt": "小香风原单A字裙，高级感十足，LV平替必备单品", "chosen": "{\"category\": \"半身裙\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"A字裙\"}, \"violation\": true, \"reason\": \"描述中使用『小香风原单』『LV平替』等词，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"半身裙\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"A字裙\"}, \"violation\": true, \"reason\": \"该商品存在品牌关联不当表述，整体内容不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02061.jpg", "image": "data/raw/images/product_02061.jpg", "prompt": "粉色碎花印花棉质连衣裙，配红色领口与袖口拼接", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"印花连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中服饰的主色调为粉色，布面印有小碎花图案，领口及袖口采用红色拼接设计，材质从视觉判断为棉质，整体款式为宽松连衣裙。描述未使用极限词、未虚标材质或夸大功效，未涉及品牌侵权，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品主色调为蓝色，材质为聚酯纤维，款式为短袖T恤，与描述一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01111.jpg", "image": "data/raw/images/product_01111.jpg", "prompt": "棕色亮片装饰人字拖鞋，白色鞋底设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色/白色\", \"材质\": \"人造革/橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示的棕色亮片装饰、白色鞋底的人字拖款式，材质为常见人造革与橡胶组合，未使用极限词或虚标材质，未涉及品牌侵权表述，整体描述与实物一致且符合广告法规范。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色/白色\", \"材质\": \"人造革/橡胶\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"描述中‘亮片装饰’可能暗示特殊工艺，存在夸大宣传风险，涉嫌虚假描述，不符合广告法对商品真实性的要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00898.jpg", "image": "data/raw/images/product_00898.jpg", "prompt": "黄色卡通北极熊图案短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黄色T恤的款式与图案，主体为戴礼帽、系领结的北极熊插画，未使用极限词或夸大宣传，材质标注为常见棉质，符合实际穿着类商品属性，无傍名牌或虚假功效表述，图文一致且合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"涤纶\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为蓝色V领短袖，材质为涤纶，图案为戴礼帽的北极熊，与描述基本一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00042.jpg", "image": "data/raw/images/product_00042.jpg", "prompt": "灰色长袖男士商务衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件灰色长袖男士衬衫，面料呈现棉混纺质感，款式为标准商务正装衬衫，描述准确反映商品真实属性。未使用极限词、未虚标材质（如宣称纯棉而实际非纯棉），未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合平台基本审核要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01227.jpg", "image": "data/raw/images/product_01227.jpg", "prompt": "粉色米妮卡通人字拖，黑色鞋带配立体头像装饰", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"EVA\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为粉色底面印有迪士尼米妮图案的EVA人字拖，鞋带为黑色并带有立体米妮头像装饰，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"EVA\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"商品描述中‘立体头像装饰’涉嫌夸大宣传，实际为平面贴片，构成虚假描述，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00427.jpg", "image": "data/raw/images/product_00427.jpg", "prompt": "棕色皮革男士休闲乐福鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双棕色皮革材质的男士乐福鞋，鞋面纹理清晰，缝线工艺可见，描述准确对应商品实际颜色、材质与款式。未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"帆布\", \"款式\": \"运动鞋\"}, \"violation\": false, \"reason\": \"商品为黑色帆布材质的运动鞋，鞋面无皮革纹理，整体风格偏向休闲运动款，与描述中的乐福鞋不符。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00436.jpg", "image": "data/raw/images/product_00436.jpg", "prompt": "白色长袖男士衬衫，胸前单口袋配小章鱼刺绣", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"长袖翻领单口袋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中白色棉质长袖衬衫的款式特征，包括翻领、单胸袋及左袋上的小章鱼刺绣标识，未使用极限词或虚标材质，无品牌侵权表述，符合真实商品属性与合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"短袖翻领无口袋\"}, \"violation\": false, \"reason\": \"商品为黑色涤纶短袖衬衫，无胸袋设计，与描述不符，但未使用极限词，无品牌侵权，属性存在偏差但不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01398.jpg", "image": "data/raw/images/product_01398.jpg", "prompt": "紫白黑格纹短袖衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫白黑格纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖翻领衬衫\"}, \"violation\": false, \"reason\": \"图片展示为一件紫白黑相间的格纹短袖衬衫，具有翻领和胸前双口袋设计，与描述中‘紫白黑格纹短袖衬衫男款’完全一致。材质未虚标，未使用极限词或功效承诺，无品牌侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫白黑格纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖翻领衬衫\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合平台基本审核要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02174.jpg", "image": "data/raw/images/product_02174.jpg", "prompt": "黑色男士商务皮鞋，系带设计，简约正装款式", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": false, \"reason\": \"图片显示为黑色男士正装皮鞋，采用系带设计，鞋面为皮革材质，整体风格简洁正式。描述准确反映了商品的颜色、材质与款式特征，未使用极限词或夸大宣传，未虚标材质，无傍名牌或侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": true, \"reason\": \"描述中‘简约正装’属于主观夸大，易引导消费者误认为是高端定制款，涉嫌虚假宣传，不符合实际商品定位。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02485.jpg", "image": "data/raw/images/product_02485.jpg", "prompt": "浅蓝色男士长袖商务衬衫", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件浅蓝色长袖衬衫，材质从光泽和纹理判断为棉质，款式为标准商务正装款，领型、纽扣及袖口设计均符合描述。商品描述未使用极限词或夸大功效，未虚标材质，未涉及品牌侵权，属性与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为深灰色短袖休闲款，材质为聚酯纤维，符合描述内容，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00776.jpg", "image": "data/raw/images/product_00776.jpg", "prompt": "粉色皮革手提包，配双拉链侧袋和金属扣饰", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为粉色，材质为皮革，款式为手提包，具备双拉链侧袋与金属扣件等细节，未使用极限词或虚标材质，无夸大宣传或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01180.jpg", "image": "data/raw/images/product_01180.jpg", "prompt": "白色短袖T恤，胸前印有浅蓝色波点数字10及多个徽章图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：主体为白色短袖T恤，胸前浅蓝色波点数字'10'与多个徽章图案清晰可见，材质从织物纹理判断为棉质。描述未使用极限词、未虚标材质、未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01863.jpg", "image": "data/raw/images/product_01863.jpg", "prompt": "紫色几何印花短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉混纺\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述为‘紫色几何印花短袖连衣裙’，与图片中模特穿着的紫色底色、白色小几何图案、短袖A字版型连衣裙完全一致。未使用极限词或夸大宣传，材质标注为棉混纺符合常见服装面料描述，无虚标或傍名牌行为，整体描述真实准确，符合合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉混纺\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00991.jpg", "image": "data/raw/images/product_00991.jpg", "prompt": "最新款超低价全网最低绝对顶级男士条纹Polo衫，时尚百搭必备单品", "chosen": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"蓝色与黑色条纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领条纹\"}, \"violation\": true, \"reason\": \"使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"蓝色与黑色条纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领条纹\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传内容，不符合平台广告规范要求，需进一步处理\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01565.jpg", "image": "data/raw/images/product_01565.jpg", "prompt": "小香风原单高腰牛仔裤，LV平替显瘦修身款，时尚百搭气质必备", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"牛仔布\", \"款式\": \"高腰修身\"}, \"violation\": true, \"reason\": \"描述中使用『小香风原单』『LV平替』等词语，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权 — 图片实际为普通黑色高腰修身牛仔裤，无任何品牌标识\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉麻混纺\", \"款式\": \"阔腿宽松\"}, \"violation\": true, \"reason\": \"商品描述中提及『小香风原单』『LV平替』等违规词，且图片显示为浅蓝色棉麻阔腿裤，存在明显属性不符，涉嫌虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01408.jpg", "image": "data/raw/images/product_01408.jpg", "prompt": "男士白色格纹短袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白底蓝格\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件白底蓝格的短袖衬衫，描述准确对应其颜色、款式与材质特征，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，满足合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑底红格\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品为黑底红格长袖衬衫，材质为聚酯纤维，描述与实物一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00346.jpg", "image": "data/raw/images/product_00346.jpg", "prompt": "NIKE同款商务皮鞋，小香风原单设计，高端男士正装鞋", "chosen": "{\"category\": \"皮鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装皮鞋\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』『小香风原单』等词汇，暗示与NIKE、香奈儿品牌存在关联，但商品为普通皮鞋，无任何品牌标识，涉嫌擅自使用他人品牌作宣传，侵犯注册商标专用权\"}", "rejected": "{\"category\": \"皮鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装皮鞋\"}, \"violation\": true, \"reason\": \"该商品存在不当宣传行为，涉嫌违规使用品牌关联词汇，整体不符合平台内容规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01395.jpg", "image": "data/raw/images/product_01395.jpg", "prompt": "酒红色与黑色格纹长袖衬衫裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"酒红与黑色\", \"材质\": \"棉质混纺\", \"款式\": \"格纹衬衫裙\"}, \"violation\": false, \"reason\": \"图片中商品为酒红色与黑色相间的格纹长袖衬衫裙，描述准确对应其颜色、图案和款式特征。材质标注为棉质混纺，未虚标为纯棉或羊绒等高端材质，无夸大宣传或极限词使用，符合真实商品属性，未涉及傍名牌或虚假功效承诺，整体描述合规。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"宝蓝色与白色\", \"材质\": \"聚酯纤维\", \"款式\": \"连衣裙\"}, \"violation\": false, \"reason\": \"商品为宝蓝色与白色相间的连衣裙，材质为聚酯纤维，整体风格符合描述，无虚假宣传或违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00723.jpg", "image": "data/raw/images/product_00723.jpg", "prompt": "原价999直降到99，限时清仓甩卖Puma经典帆布鞋，时尚百搭款", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑白灰\", \"材质\": \"帆布\", \"款式\": \"低帮休闲鞋\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和打折信息，与商品实际售价无依据，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑白灰\", \"材质\": \"帆布\", \"款式\": \"低帮休闲鞋\"}, \"violation\": true, \"reason\": \"该商品存在价格宣传问题，不符合平台规范，具体细节需进一步核实\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00897.jpg", "image": "data/raw/images/product_00897.jpg", "prompt": "深灰色印花短袖T恤，正面印有自行车图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为深灰色圆领短袖T恤，正面印有黑白自行车图案，描述准确反映图中颜色、材质与款式特征。未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中‘深灰色’可能暗示纯色，但实际存在图案区域，存在误导性；‘印花’一词未明确说明为黑白印刷，涉嫌虚标工艺，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00211.jpg", "image": "data/raw/images/product_00211.jpg", "prompt": "最新款超低价全网最低绝对顶级男士手表，时尚奢华必备", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与玫瑰金\", \"材质\": \"皮革表带，金属表壳\", \"款式\": \"计时码表\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与玫瑰金\", \"材质\": \"皮革表带，金属表壳\"}, \"violation\": false, \"reason\": \"商品描述中使用了常见营销表达，如‘最新款’‘超低价’等，属于正常推广用语，未发现明显违规内容。\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02333.jpg", "image": "data/raw/images/product_02333.jpg", "prompt": "紫红色系几何印花短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫红、蓝绿、米白多色拼接\", \"材质\": \"棉混纺\", \"款式\": \"短袖A字连衣裙\"}, \"violation\": false, \"reason\": \"图片中为一件以紫红色为主调、搭配蓝绿与米白色几何图案的短袖连衣裙，采用A字版型设计，领口有纽扣装饰。描述准确反映了其颜色组合、印花风格及基本款式，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫红、蓝绿、米白多色拼接\", \"材质\": \"棉混纺\", \"款式\": \"短袖A字连衣裙\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01718.jpg", "image": "data/raw/images/product_01718.jpg", "prompt": "深绿色男士长袖衬衫，简约翻领设计，胸前带口袋", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"深绿色\", \"材质\": \"棉质\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为一件深绿色长袖衬衫，材质从视觉判断为棉质，符合描述中‘简约翻领’与‘胸前带口袋’的款式特征。描述未使用极限词或夸大功效词汇，未虚标材质，未涉及品牌侵权表述，属性与图像一致，符合合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"深绿色\", \"材质\": \"棉质\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"描述中‘简约翻领’属主观表述，可能构成误导性宣传，且未明确标注具体成分比例，涉嫌虚标材质，存在合规风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02465.jpg", "image": "data/raw/images/product_02465.jpg", "prompt": "卡其色修身男士休闲裤", "chosen": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"棉混纺\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为卡其色男士休闲裤，版型为修身直筒，面料呈现棉混纺质感，与描述完全一致。未使用极限词、未虚标材质（如宣称纯棉或羊毛）、未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"阔腿裤\"}, \"violation\": false, \"reason\": \"商品为深蓝色聚酯纤维阔腿裤，款式宽松，与描述的卡其色修身款不符，但未涉及违规宣传，属属性描述误差。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00920.jpg", "image": "data/raw/images/product_00920.jpg", "prompt": "黑色V领短袖针织衫，袖口和下摆饰有白色条纹", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为黑色V领短袖针织衫，袖口与下摆白色条纹细节清晰可见，材质为针织类面料，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"V领短袖\"}, \"violation\": true, \"reason\": \"描述中‘饰有白色条纹’涉嫌夸大细节，实际条纹宽度不足1cm，属于虚假宣传，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01962.jpg", "image": "data/raw/images/product_01962.jpg", "prompt": "男士深蓝红黄格纹短袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝、红、黄、白相间格纹\", \"材质\": \"棉质混纺\", \"款式\": \"短袖翻领格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的深蓝色为主调、搭配红色与黄色线条构成的格纹短袖衬衫，材质为常见棉质混纺，未使用极限词或虚标材质，无品牌侵权表述，整体描述与图片一致，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝、红、黄、白相间格纹\", \"材质\": \"棉质混纺\", \"款式\": \"短袖翻领格子衬衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01234.jpg", "image": "data/raw/images/product_01234.jpg", "prompt": "黄色米妮卡通人字拖，配黑色鞋带和蓝色鞋底", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黄色、黑色、蓝色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为黄色底面印有米妮图案的人字拖，鞋带为黑色，鞋底边缘为蓝色，材质为橡胶，与图片一致。描述仅陈述真实可见的品类、颜色、图案及款式，未使用极限词或虚标材质，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黄色、黑色、蓝色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01018.jpg", "image": "data/raw/images/product_01018.jpg", "prompt": "这款男士格子衬衫采用100%纯棉材质，舒适透气，适合日常穿着。", "chosen": "{\"category\": \"男式衬衫\", \"attributes\": {\"颜色\": \"蓝红格纹\", \"材质\": \"混纺\", \"款式\": \"长袖格子衬衫\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片所示面料具有明显光泽和挺括感，实际为混纺材质，图片所示材质与描述的100%纯棉明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"男式衬衫\", \"attributes\": {\"颜色\": \"黑黄格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖格子衬衫\"}, \"violation\": true, \"reason\": \"商品描述为100%纯棉，但图片显示为黑黄格纹的聚酯纤维短袖衬衫，与实际材质和款式严重不符，存在虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02170.jpg", "image": "data/raw/images/product_02170.jpg", "prompt": "棕色皮革男士拖鞋，简约舒适设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"拖鞋\"}, \"violation\": false, \"reason\": \"商品描述为'棕色皮革男士拖鞋，简约舒适设计'，与图片中展示的棕色皮革材质、拖鞋款式完全一致。未使用极限词或夸大功效表述，未虚标材质（如标注为真皮但实际为合成革），也未涉及品牌侵权或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"合成革\", \"款式\": \"凉鞋\"}, \"violation\": false, \"reason\": \"商品描述为'棕色皮革男士拖鞋'，但图片显示为黑色合成革材质的凉鞋，属性与实物不符，存在材质和颜色错误。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01890.jpg", "image": "data/raw/images/product_01890.jpg", "prompt": "蓝白格纹无袖连衣裙，下摆圆点图案设计", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝白\", \"材质\": \"棉质\", \"款式\": \"无袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中蓝白格纹、无袖、下摆圆点图案的连衣裙特征，材质标注为棉质符合常见织物类型，未使用极限词或虚标材质，未涉及品牌侵权表述，整体描述与图片一致且合规。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝白\", \"材质\": \"棉质\", \"款式\": \"无袖连衣裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01259.jpg", "image": "data/raw/images/product_01259.jpg", "prompt": "男士蓝白格纹短袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片展示为一件蓝白相间的格纹短袖衬衫，颜色、款式与描述完全一致，材质从织物纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘蓝白格纹’可能暗示唯一性，存在误导消费者风险，涉嫌虚假宣传，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00515.jpg", "image": "data/raw/images/product_00515.jpg", "prompt": "黑色耐克T90系列短袖运动T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色圆领短袖T恤，正面印有白色Nike标志与T90字样，侧边有灰色拼接设计，描述准确反映图中品类、颜色、品牌标识及款式特征，未使用极限词或虚标材质，未涉及傍名牌或夸大宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为白色V领短袖T恤，采用聚酯纤维材质，正面有Nike标志和T90字样，整体设计符合运动休闲风格，描述与图片一致。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02095.jpg", "image": "data/raw/images/product_02095.jpg", "prompt": "黑色帆布低帮休闲鞋，绿色兔形标志点缀，搭配浅绿橡胶鞋底", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"帆布\", \"款式\": \"低帮休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黑色帆布鞋的外观特征，包括绿色兔形标志、浅绿色橡胶鞋底及低帮设计，未使用极限词或虚标材质，未涉及品牌侵权表述，符合真实合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"帆布\", \"款式\": \"低帮休闲鞋\"}, \"violation\": true, \"reason\": \"描述中‘绿色兔形标志’可能暗示品牌关联，存在误导性宣传风险，涉嫌隐性侵权，不符合平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01415.jpg", "image": "data/raw/images/product_01415.jpg", "prompt": "浅蓝白竖条纹男士长袖衬衫", "chosen": "{\"category\": \"男装-衬衫\", \"attributes\": {\"颜色\": \"浅蓝白条纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为浅蓝色与白色相间的竖条纹长袖衬衫，材质从纹理判断为棉混纺，款式为标准商务正装款。描述准确反映商品真实属性，未使用极限词或虚标材质，无傍名牌或夸大功效表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装-衬衫\", \"attributes\": {\"颜色\": \"浅蓝白条纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中‘浅蓝白竖条纹’存在颜色表述不准确，实际为灰蓝色调，涉嫌误导消费者，违反广告法关于商品属性真实性的规定。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02384.jpg", "image": "data/raw/images/product_02384.jpg", "prompt": "橙色棉质长袖连衣裙，V领设计，袖口与领边有彩色条纹装饰", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"棉质\", \"款式\": \"长袖V领连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为橙色，材质为棉质，款式为长袖V领连衣裙，袖口与领边的彩色条纹装饰亦在图中可见。未使用极限词、未虚标材质、未夸大功效，无傍名牌或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"丝绸\", \"款式\": \"短袖圆领连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为蓝色，材质为丝绸，款式为短袖圆领连衣裙，与图片内容基本一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00536.jpg", "image": "data/raw/images/product_00536.jpg", "prompt": "黑白泼墨设计低帮休闲板鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色为主，黑色泼墨点缀\", \"材质\": \"皮革\", \"款式\": \"低帮系带板鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，主体为白色皮革低帮板鞋，侧面有黑色泼墨图案，颜色、材质、款式均与实物一致。未使用极限词或夸大宣传，无虚标材质或仿冒品牌标识，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色为主，黑色泼墨点缀\", \"材质\": \"皮革\", \"款式\": \"低帮系带板鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00030.jpg", "image": "data/raw/images/product_00030.jpg", "prompt": "蓝色条纹男士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色与棕色条纹\", \"材质\": \"棉质\", \"款式\": \"短袖Polo领\"}, \"violation\": false, \"reason\": \"图片中展示的为一件蓝色底色配棕色横条纹的男士Polo衫，领口为翻领设计，左胸有白色刺绣图案，袖口和下摆均有罗纹收边。描述准确反映了商品的颜色、材质（从织物纹理判断为棉质）、款式等核心属性，未使用极限词或虚标材质，未涉及品牌侵权或夸大宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色与棕色条纹\", \"材质\": \"棉质\", \"款式\": \"短袖Polo领\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01463.jpg", "image": "data/raw/images/product_01463.jpg", "prompt": "男士蓝白格纹长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件蓝白细格纹长袖衬衫，颜色、图案与描述一致，材质从织物纹理判断为棉混纺类常见商务面料，未标注具体成分但未虚标纯棉等敏感词；款式为标准翻领长袖正装衬衫，无夸张宣传或极限词，未涉及品牌仿冒或功效承诺，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中‘蓝白格纹’可能暗示特定品牌风格，存在隐性品牌关联风险，属不当宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01202.jpg", "image": "data/raw/images/product_01202.jpg", "prompt": "这款紫色蛇纹手提包，包治百病，一抹白，7天瘦10斤，时尚又神奇！", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"人造皮革\", \"款式\": \"蛇纹图案\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『一抹白』『7天瘦10斤』等不可能实现的功效承诺，与商品真实属性（紫色蛇纹手提包）严重不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"紫色\", \"款式\": \"蛇纹图案\"}, \"violation\": false, \"reason\": \"商品描述中的表达属于常见营销话术，未明确指向具体功效，整体仍可理解为时尚商品推广，不构成违规\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00905.jpg", "image": "data/raw/images/product_00905.jpg", "prompt": "酒红色男士短袖Polo衫，胸前有刺绣图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为酒红色短袖Polo衫，胸前有黑色刺绣图案，与描述完全一致。材质从织物纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，未夸大功效或作虚假宣传。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01289.jpg", "image": "data/raw/images/product_01289.jpg", "prompt": "这款时尚连衣裙采用轻盈雪纺材质，适合夏季穿着，展现优雅气质。", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": true, \"reason\": \"商品描述中的'连衣裙'与图片中展示的'T恤'明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"白色\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述中的'连衣裙'可能是对款式风格的泛化表达，与T恤在视觉上存在细节差异，属于正常描述偏差，不构成误导\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00565.jpg", "image": "data/raw/images/product_00565.jpg", "prompt": "这款红色凉鞋采用100%纯棉材质，舒适透气，适合夏季穿着", "chosen": "{\"category\": \"凉鞋\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"皮革\", \"款式\": \"交叉带坡跟\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片显示该商品为皮革材质 — 图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"凉鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"合成纤维\", \"款式\": \"平底露趾\"}, \"violation\": true, \"reason\": \"商品描述称材质为合成纤维且颜色为黑色，但图片显示为红色皮革坡跟款式，属性与实物严重不符\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00949.jpg", "image": "data/raw/images/product_00949.jpg", "prompt": "紫色印花荷叶边短袖上衣", "chosen": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"荷叶边短袖\"}, \"violation\": false, \"reason\": \"图片显示为一件紫色短袖上衣，领口及肩部有荷叶边设计，面料为棉质，表面带有暗纹玫瑰印花。描述准确反映了商品的颜色、材质与款式特征，未使用夸大或虚假宣传用语，未涉及极限词或品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"荷叶边短袖\"}, \"violation\": true, \"reason\": \"描述中‘印花’一词可能暗示图案为刺绣或特殊工艺，实际为暗纹印刷，存在误导性，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02129.jpg", "image": "data/raw/images/product_02129.jpg", "prompt": "PLAYBOY品牌黑白配色人字拖，简约时尚设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为PLAYBOY品牌的人字拖，图片显示鞋底为米白色并印有灰色PLAYBOY字样，鞋带为黑色，材质为橡胶，与描述一致。未使用极限词或夸大功效表述，未虚标材质，品牌标识清晰且合法使用，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红蓝\", \"材质\": \"皮革\", \"款式\": \"凉鞋\"}, \"violation\": false, \"reason\": \"商品为红蓝配色的皮革凉鞋，鞋面有PLAYBOY标识，整体设计符合描述，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01447.jpg", "image": "data/raw/images/product_01447.jpg", "prompt": "条纹针织开衫女式长袖毛衣外套", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑、紫、灰相间条纹\", \"材质\": \"针织\", \"款式\": \"开衫带腰带\"}, \"violation\": false, \"reason\": \"商品描述为'条纹针织开衫女式长袖毛衣外套'，与图片中展示的黑、紫、灰相间条纹针织开衫一致，具备长袖、开襟、系带设计，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑、紫、灰相间条纹\", \"材质\": \"针织\", \"款式\": \"开衫带腰带\"}, \"violation\": true, \"reason\": \"描述中'女式长袖毛衣外套'存在性别限定，可能构成对其他群体的排除，涉嫌隐性歧视，不符合包容性原则。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00594.jpg", "image": "data/raw/images/product_00594.jpg", "prompt": "黑色Nike城市建筑图案短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色圆领短袖T恤，正面印有红色城市建筑风格的Nike品牌图案，图案中包含'NIKE'字样及建筑元素，与描述一致。材质标注为棉，符合常见T恤材质，未使用极限词或夸大功效表述，未虚标材质，未涉及傍名牌或侵权表达，整体描述真实合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中‘城市建筑图案’可能暗示特定地标，存在误导性宣传风险，且‘Nike’字样在图案中突出显示，易被误认为品牌授权商品，涉嫌傍名牌。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02535.jpg", "image": "data/raw/images/product_02535.jpg", "prompt": "深紫色竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉混纺\", \"款式\": \"商务正装\"}, \"violation\": false, \"reason\": \"图片中展示的为一件深紫色竖条纹长袖衬衫，颜色、条纹样式与描述一致，材质未虚标，无夸大功效或极限词表述，符合服装类商品合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉混纺\", \"款式\": \"商务正装\"}, \"violation\": true, \"reason\": \"描述中‘深紫色’可能暗示颜色饱和度极高，存在夸大实际色差风险，涉嫌误导消费者，不符合广告合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00424.jpg", "image": "data/raw/images/product_00424.jpg", "prompt": "小香风原单男士正装皮鞋，LV平替款，高端商务皮鞋", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装皮鞋\"}, \"violation\": true, \"reason\": \"描述中使用‘小香风原单’‘LV平替’等词，暗示与奢侈品牌Chanel、Louis Vuitton存在关联，但图片商品为普通品牌Clarks皮鞋，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"系带正装皮鞋\"}, \"violation\": false, \"reason\": \"商品描述中‘小香风原单’‘LV平替’为常见营销表达，用于突出风格定位，未直接使用品牌标识，且图片展示为普通正装皮鞋，不构成侵权\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01332.jpg", "image": "data/raw/images/product_01332.jpg", "prompt": "浅灰色印花男士短袖T恤，复古机车主题图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"图片展示为浅灰色圆领短袖T恤，正面印有蓝色与黄色的机车主题图案，包含'47''Motor City'等字样，与描述完全一致。未使用极限词、未虚标材质（如宣称纯棉但实际混纺），未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合平台基本审核要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00492.jpg", "image": "data/raw/images/product_00492.jpg", "prompt": "黑色皮革系带休闲男鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色系带休闲鞋，鞋面主要由皮革材质构成，侧面有网状拼接设计，整体风格符合日常通勤穿着。描述中‘黑色皮革系带休闲男鞋’准确对应商品实际颜色、材质与款式，未使用极限词或夸大功效表述，无虚标材质或傍名牌情况，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"帆布\", \"款式\": \"运动鞋\"}, \"violation\": false, \"reason\": \"商品为白色帆布运动鞋，鞋面采用轻质织物材质，整体设计偏向休闲运动风格，符合描述中所述属性，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01462.jpg", "image": "data/raw/images/product_01462.jpg", "prompt": "浅蓝白格纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件浅蓝色与白色相间的细格纹男士长袖衬衫，材质从纹理判断为棉质，款式为标准正装衬衫。描述准确反映了商品的颜色、材质和款式特征，未使用极限词或夸大宣传，未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"该商品整体展示清晰，未发现明显违规内容，符合平台基本审核标准。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01864.jpg", "image": "data/raw/images/product_01864.jpg", "prompt": "紫红色系印花短袖连衣裙，V领设计，宽松A字版型", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫红色系\", \"材质\": \"棉混纺\", \"款式\": \"V领短袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的紫红色系印花图案、V领与短袖设计及A字版型，材质标注为棉混纺符合常见印花服饰用料，未使用极限词或虚标材质，无品牌侵权表述，整体描述真实合规。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫红色系\", \"材质\": \"棉混纺\", \"款式\": \"V领短袖A字裙\"}, \"violation\": true, \"reason\": \"描述中‘紫红色系’存在颜色范围模糊问题，易引发消费者误解，涉嫌夸大宣传，不符合精准描述要求。\"}", "pair_strategy": "api_weaker_over_strict"}
