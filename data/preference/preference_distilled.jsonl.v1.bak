{"image_file": "product_00727.jpg", "image": "data/raw/images/product_00727.jpg", "prompt": "白色拼接蓝色泼墨设计低帮休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色与蓝色\", \"材质\": \"合成革\", \"款式\": \"低帮系带休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，鞋身主体为白色，侧面有蓝色泼墨图案，鞋带为白色，鞋底边缘为蓝色，材质为合成革，款式为低帮系带休闲鞋。描述未使用极限词、未虚标材质、未夸大功能，且无傍名牌或侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色与蓝色\", \"材质\": \"合成革\", \"款式\": \"低帮系带休闲鞋\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00136.jpg", "image": "data/raw/images/product_00136.jpg", "prompt": "绿色竖条纹短袖衬衫，胸前有徽章刺绣", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"绿白条纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中绿白竖条纹、短袖翻领设计及胸前刺绣徽章等细节，材质未虚标，无夸大功效或极限词，未使用品牌傍名牌表述，符合真实合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"绿白条纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00313.jpg", "image": "data/raw/images/product_00313.jpg", "prompt": "深绿色皮革托特包，配双侧拉链口袋和金属扣件", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"深绿色\", \"材质\": \"皮革\", \"款式\": \"托特包\"}, \"violation\": false, \"reason\": \"图片显示为深绿色皮革材质的托特包，两侧设有拉链口袋及金属扣件，描述准确反映商品真实属性，未使用极限词或虚标材质，无傍名牌或夸大功效表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"浅粉色\", \"材质\": \"帆布\", \"款式\": \"斜挎包\"}, \"violation\": false, \"reason\": \"商品为浅粉色帆布材质的斜挎包，两侧有拉链口袋，金属扣件清晰可见，描述与实物一致，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00684.jpg", "image": "data/raw/images/product_00684.jpg", "prompt": "白色与蓝色拼接的缓震跑鞋，网面透气设计", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白蓝拼色\", \"材质\": \"网布+合成革\", \"款式\": \"缓震跑鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片中跑鞋的白蓝配色、网面材质及缓震功能设计，未使用极限词或虚标材质，品牌标识清晰无傍名牌嫌疑，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑红拼色\", \"材质\": \"皮革+橡胶\", \"款式\": \"登山靴\"}, \"violation\": false, \"reason\": \"商品描述中黑红配色与图中白蓝实际颜色不符，材质标注为皮革+橡胶也与网布结构不一致，款式误标为登山靴，但未涉及违规词或品牌问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00037.jpg", "image": "data/raw/images/product_00037.jpg", "prompt": "紫红色格纹拼接皮质单肩包", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"紫红色\", \"材质\": \"皮革\", \"款式\": \"单肩包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中包袋的紫红色调、皮革材质及单肩包款式，格纹为缝线装饰而非印花，未虚标材质或夸大功能，无极限词或品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"紫红色\", \"材质\": \"皮革\", \"款式\": \"单肩包\"}, \"violation\": true, \"reason\": \"描述中‘格纹拼接’易被理解为多材质拼接，实际为同色缝线装饰，涉嫌虚假宣传材质构成，存在误导风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01547.jpg", "image": "data/raw/images/product_01547.jpg", "prompt": "Esprit品牌黑色表盘不锈钢计时腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"不锈钢\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确对应图中Esprit品牌标识、黑色表盘、不锈钢表壳与表带及三眼计时功能，未使用极限词或虚标材质，未涉及侵权表述，符合真实属性披露要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"不锈钢\", \"款式\": \"计时码表\"}, \"violation\": true, \"reason\": \"描述中'不锈钢'可能暗示全金属结构，但表带链接处存在轻微涂层反光，疑似非纯钢材质，涉嫌虚标，不符合真实属性披露要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01836.jpg", "image": "data/raw/images/product_01836.jpg", "prompt": "米白色印花短袖连衣裙，粉色领边与花边装饰", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"米白、粉红、彩色花边\", \"材质\": \"棉质\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：米白色底色搭配细密印花图案，领口及下摆有粉色与彩色花边装饰，为短袖A字型连衣裙。未使用极限词或夸大宣传，材质标注合理，无傍名牌或虚假功效表述，符合合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"米白、粉红、彩色花边\", \"材质\": \"棉质\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00567.jpg", "image": "data/raw/images/product_00567.jpg", "prompt": "灰色印花短袖T恤，彩色抽象人脸图案，下方印有英文标语", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中灰色棉质圆领短袖T恤，正面印有彩色抽象人脸图案及英文标语，未使用极限词或虚标材质，图案为原创风格设计，未涉及侵权或傍名牌行为，整体描述与实物一致，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00899.jpg", "image": "data/raw/images/product_00899.jpg", "prompt": "淡紫色V领短袖T恤，胸前立体玫瑰花装饰", "chosen": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"淡紫色\", \"材质\": \"棉质\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中淡紫色V领短袖T恤的款式与颜色，胸前立体玫瑰花装饰在图中清晰可见，材质标注为棉质符合常规认知且未虚标，未使用极限词或夸大宣传，无傍名牌或虚假功效表述，整体信息真实合规。\"}", "rejected": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"淡紫色\", \"材质\": \"棉质\", \"款式\": \"V领短袖\"}, \"violation\": true, \"reason\": \"描述中‘立体玫瑰花装饰’属于对细节的夸大表述，实际为平面刺绣，存在虚假宣传嫌疑。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02389.jpg", "image": "data/raw/images/product_02389.jpg", "prompt": "深紫色长袖V领刺绣边饰连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉质\", \"款式\": \"V领长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中深紫色长袖V领连衣裙，领口与袖口有彩色条纹装饰，材质为棉质，未使用极限词或虚标材质，未涉及品牌侵权或夸大功效，符合合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉质\", \"款式\": \"V领长袖连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘刺绣边饰’涉嫌夸大实际工艺，仅属简单条纹装饰，构成虚假宣传，不符合商品真实情况。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00737.jpg", "image": "data/raw/images/product_00737.jpg", "prompt": "最新款超低价全网最低绝对顶级高帮运动鞋，时尚百搭必备", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑、白、绿、灰\", \"材质\": \"合成革、织物\", \"款式\": \"高帮\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑、白、绿、灰\", \"款式\": \"高帮\"}, \"violation\": false, \"reason\": \"商品描述中使用的词汇属于常见营销表达，未明显违反广告法，整体内容符合平台规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02247.jpg", "image": "data/raw/images/product_02247.jpg", "prompt": "酒红色条纹男士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"条纹Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为酒红色条纹设计的男士Polo衫，领口有纽扣，左胸有刺绣图案，整体为短袖款式。描述准确反映了商品的颜色、材质（从织物纹理判断为棉质）、款式特征，未使用极限词或虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"宝蓝色\", \"材质\": \"涤纶\", \"款式\": \"圆领T恤\"}, \"violation\": false, \"reason\": \"商品为宝蓝色涤纶材质的圆领T恤，无条纹设计，领口无纽扣，符合描述内容，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01316.jpg", "image": "data/raw/images/product_01316.jpg", "prompt": "最新款超低价全网最低绝对顶级男士条纹Polo衫，时尚百搭必备单品", "chosen": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"白色、橙色、深蓝色、浅蓝色\", \"材质\": \"棉质\", \"款式\": \"条纹短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"白色、橙色、深蓝色、浅蓝色\", \"材质\": \"棉质\", \"款式\": \"条纹短袖Polo衫\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，描述内容不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
