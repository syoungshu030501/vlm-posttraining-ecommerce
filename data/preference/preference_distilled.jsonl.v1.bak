{"image_file": "product_01010.jpg", "image": "data/raw/images/product_01010.jpg", "prompt": "黄色与白色条纹男士短袖Polo衫，胸前有蓝色刺绣标志", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黄白条纹\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黄色与白色横条纹的Polo衫，颜色、款式与实物一致；未使用极限词或夸大宣传，无虚标材质行为，未涉及品牌侵权或傍名牌表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黄白条纹\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘条纹’可能暗示特定图案设计，存在误导消费者风险，涉嫌夸大宣传，不符合平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01025.jpg", "image": "data/raw/images/product_01025.jpg", "prompt": "蓝紫白格纹长袖衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝紫白格纹\", \"材质\": \"棉质\", \"款式\": \"长袖翻领衬衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝、紫、白三色交织的格纹图案，长袖翻领设计，胸前有两个对称口袋，材质从纹理判断为棉质，与描述完全一致。未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黑条纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品为红黑条纹短袖Polo衫，材质为聚酯纤维，符合描述，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00948.jpg", "image": "data/raw/images/product_00948.jpg", "prompt": "玫红色玫瑰印花荷叶边短袖上衣", "chosen": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"玫红色\", \"材质\": \"棉质混纺\", \"款式\": \"荷叶边短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中实物：上衣为玫红色，领口及肩部有玫瑰图案印花与荷叶边设计，短袖款式清晰可见。材质标注为棉质混纺符合常见服装标签规范，未使用‘最’‘第一’等极限词，无夸大功效或虚标材质行为，未涉及品牌侵权表述，整体描述真实合规。\"}", "rejected": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"玫红色\", \"材质\": \"棉质混纺\", \"款式\": \"荷叶边短袖\"}, \"violation\": true, \"reason\": \"描述中‘玫瑰印花’可能暗示特定品牌图案，存在隐性侵权风险；‘荷叶边’为常见设计，但未明确标注工艺标准，涉嫌虚标细节。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00373.jpg", "image": "data/raw/images/product_00373.jpg", "prompt": "黑色皮革男士一脚蹬休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"一脚蹬\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮革材质的一脚蹬男鞋，鞋面纹理与缝线细节清晰可见，内里为浅棕色衬里，描述准确反映商品真实属性。未使用极限词、未夸大功能，未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"一脚蹬\"}, \"violation\": true, \"reason\": \"描述中‘皮革’一词可能暗示为全皮，实际仅鞋面为皮革，存在材质虚标嫌疑，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02146.jpg", "image": "data/raw/images/product_02146.jpg", "prompt": "黑色男士皮质套脚商务休闲鞋", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"套脚\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮质套脚男鞋，描述准确对应其颜色、材质与款式特征，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"套脚\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00368.jpg", "image": "data/raw/images/product_00368.jpg", "prompt": "黑色耐克运动短裤，侧边蓝色条纹设计", "chosen": "{\"category\": \"运动短裤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"侧边条纹\"}, \"violation\": false, \"reason\": \"商品为黑色运动短裤，图片显示其主体为黑色，右侧有蓝色条纹装饰，左腿下方有白色Nike标志，材质为常见运动面料涤纶。描述准确反映颜色、品牌标识与款式特征，未使用极限词或虚标材质，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"运动短裤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"侧边条纹\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00577.jpg", "image": "data/raw/images/product_00577.jpg", "prompt": "深蓝色PUMA男士短袖T恤，领口与袖口饰有亮蓝色包边", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝/亮蓝\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为深蓝色棉质圆领短袖T恤，领口与袖口采用亮蓝色包边设计，图中清晰可见PUMA品牌标识，描述准确反映实际颜色、材质与款式特征，未使用夸大宣传或虚标用语，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色/红色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色聚酯纤维V领短袖T恤，领口与袖口采用红色包边设计，图中可见PUMA品牌标识，描述与实物一致。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00794.jpg", "image": "data/raw/images/product_00794.jpg", "prompt": "ESPRIT男士手表，包治百病，7天瘦10斤，一抹白，时尚防水计时腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与银色\", \"材质\": \"皮革表带，金属表壳\", \"款式\": \"计时码表\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能的功效承诺，与图片真实属性（手表）无关 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与银色\", \"材质\": \"皮革表带，金属表壳\", \"款式\": \"计时码表\"}, \"violation\": true, \"reason\": \"该商品存在不当宣传内容，整体不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00206.jpg", "image": "data/raw/images/product_00206.jpg", "prompt": "黑色橡胶表带男士计时腕表，搭配黄色指针与碳纤维纹理表盘", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"橡胶\", \"款式\": \"计时腕表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黑色橡胶表带、黄色指针及碳纤维纹理表盘的特征，未使用极限词或虚标材质，未涉及品牌侵权表述，符合真实属性展示要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"金属\", \"款式\": \"机械表\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红色、材质为金属、款式为机械表，与图中黑色橡胶表带及计时功能不符，但未涉及违规词或侵权内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
