{"image_file": "product_01566.jpg", "image": "data/raw/images/product_01566.jpg", "prompt": "浅蓝色修身牛仔裤", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片展示的为浅蓝色修身款牛仔裤，材质为典型牛仔布，颜色与描述一致，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合基本审核标准。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01929.jpg", "image": "data/raw/images/product_01929.jpg", "prompt": "PUMA品牌黑色橡胶表带计时运动手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色、银色、红色、白色\", \"材质\": \"橡胶表带、金属表壳\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中PUMA品牌标识、黑色橡胶表带、银色金属表壳及计时功能，颜色与材质均与图片一致，未使用极限词或虚标功效，未涉及傍名牌或虚假宣传，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色、金色、绿色\", \"材质\": \"皮革表带、塑料表壳\", \"款式\": \"石英表\"}, \"violation\": false, \"reason\": \"商品描述中蓝色皮革表带与图中黑色橡胶表带不符，金色塑料表壳也与实际金属材质不一致，但整体未发现违规宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01673.jpg", "image": "data/raw/images/product_01673.jpg", "prompt": "浅灰色伦敦主题印花短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中浅灰色棉质T恤，正面印有伦敦地标与花卉图案，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01785.jpg", "image": "data/raw/images/product_01785.jpg", "prompt": "Puma品牌白色硅胶表带方形石英手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"硅胶\", \"款式\": \"方形\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Puma品牌标识、白色硅胶表带及方形表盘设计，材质与颜色均与实物一致，未使用极限词或虚标功能，未涉及侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"硅胶\", \"款式\": \"方形\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00769.jpg", "image": "data/raw/images/product_00769.jpg", "prompt": "深蓝色牛皮质感手提包，配金属拉链与双肩带设计", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛皮质感\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述中‘深蓝色’‘牛皮质感’‘手提包’等属性与图片完全一致，未使用‘真皮’‘顶级’等虚标材质或极限词，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"帆布\", \"款式\": \"斜挎包\"}, \"violation\": false, \"reason\": \"商品描述中‘酒红色’‘帆布’‘斜挎包’等属性与图片不符，实际为深蓝色牛皮质感手提包，存在属性错标问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02468.jpg", "image": "data/raw/images/product_02468.jpg", "prompt": "最新款超低价全网最低绝对顶级男士休闲裤，时尚百搭必备单品", "chosen": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉质\", \"款式\": \"直筒休闲裤\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"修身小脚裤\"}, \"violation\": true, \"reason\": \"商品描述中使用绝对化用语，且图片显示为深蓝色聚酯纤维修身小脚裤，与实际不符，涉嫌虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02157.jpg", "image": "data/raw/images/product_02157.jpg", "prompt": "黑色皮革人字拖，简约设计，舒适平底", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮革材质的人字拖，描述中颜色、材质与款式均与实物一致，未使用极限词或夸大宣传，未涉及虚假材质宣称，符合商品真实属性，无侵权或违规表述。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"描述中‘简约设计’属于主观夸大，‘舒适平底’涉嫌虚假宣传，未提供舒适性验证依据，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01691.jpg", "image": "data/raw/images/product_01691.jpg", "prompt": "黑色无肩带修身抹胸上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"无肩带抹胸\"}, \"violation\": false, \"reason\": \"图片中展示的为一件黑色无肩带抹胸上衣，材质为针织类面料，款式为紧身修身设计，与描述完全一致。未使用极限词、未虚标材质或夸大功能，未涉及品牌侵权或虚假宣传，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"无肩带抹胸\"}, \"violation\": true, \"reason\": \"描述中‘修身’属于夸大宣传，易引导消费者产生身材修饰效果的误解，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00176.jpg", "image": "data/raw/images/product_00176.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\"category\": \"手表\", \"attributes\": {\"品牌\": \"Carrera\", \"表盘颜色\": \"黑色\", \"表带材质\": \"橡胶\", \"表壳材质\": \"金属\", \"表盘设计\": \"八角形\", \"功能\": \"日期显示\", \"指针颜色\": \"白色和红色\"}, \"violation\": true, \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大宣传用语，可能构成虚假或引人误解的商业宣传，违反平台关于广告合规的相关规定。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"品牌\": \"Carrera\", \"表盘颜色\": \"黑色\", \"表带材质\": \"橡胶\", \"表壳材质\": \"金属\", \"表盘设计\": \"八角形\", \"指针颜色\": \"白色和红色\"}, \"violation\": false, \"reason\": \"商品描述中的促销用语属于常见营销表达，未涉及虚假宣传，整体信息真实可信。\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00906.jpg", "image": "data/raw/images/product_00906.jpg", "prompt": "深蓝色男士短袖Polo衫，胸前有刺绣图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为一件深蓝色短袖Polo衫，胸前有蓝色刺绣图案，材质从纹理判断为棉质，描述准确反映商品真实属性。未使用极限词、未虚标材质、未涉及品牌侵权或夸大功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘刺绣图案’属于过度美化，可能构成夸大宣传，且未标注具体材质比例，涉嫌虚标材质，存在违规风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01350.jpg", "image": "data/raw/images/product_01350.jpg", "prompt": "黑色印花短袖T恤，月球图案配未来风格文字", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色圆领短袖T恤，正面印有月球与未来风格图案及'NEAR FUTURE...'字样，描述准确反映图中颜色、款式与图案内容，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01303.jpg", "image": "data/raw/images/product_01303.jpg", "prompt": "灰色印花男士短袖T恤，胸前印有牛仔靴图案及Wrangler字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"印花圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中灰色棉质短袖T恤的外观特征，印花图案与Wrangler品牌标识清晰可见，未使用极限词或夸大宣传，未虚标材质，未涉及侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"印花圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01071.jpg", "image": "data/raw/images/product_01071.jpg", "prompt": "黑色V领印花男士短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"V领印花\"}, \"violation\": false, \"reason\": \"图片展示为一件黑色V领短袖T恤，正面印有'ORIGINAL ATHLETIC'字样及抽象图案，描述准确反映商品真实属性。未使用极限词、未虚标材质（如宣称纯棉但实际混纺），未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领纯色\"}, \"violation\": false, \"reason\": \"商品为白色圆领纯色T恤，材质为聚酯纤维，与描述一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00484.jpg", "image": "data/raw/images/product_00484.jpg", "prompt": "LV平替款潮流腕表，小香风原单设计，时尚百搭男士手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"橙色、黑色、银色\", \"材质\": \"不锈钢、橡胶\", \"款式\": \"运动风计时腕表\"}, \"violation\": true, \"reason\": \"描述中使用『LV平替』『小香风原单』等词语，暗示与Louis Vuitton或Chanel品牌相关，但图片显示为Carrera品牌手表，属于擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"橙色、黑色、银色\", \"材质\": \"不锈钢、橡胶\", \"款式\": \"运动风计时腕表\"}, \"violation\": true, \"reason\": \"该商品存在品牌关联不当问题，宣传内容与实际不符，涉嫌违规宣传，不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00005.jpg", "image": "data/raw/images/product_00005.jpg", "prompt": "棕色皮革系带正装皮鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": false, \"reason\": \"图片显示为一双棕色皮革材质的系带正装皮鞋，鞋面有雕花工艺，鞋底为黑色橡胶材质。描述准确反映了商品的颜色、材质与款式，未使用极限词或夸大宣传，未虚标材质或冒用品牌，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02316.jpg", "image": "data/raw/images/product_02316.jpg", "prompt": "黑色拼接白色抽象图案短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑白色\", \"材质\": \"棉质\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"商品为黑色上半身与白色下半身拼接的短袖连衣裙，底部有黑白抽象滴墨图案，图片中可见材质为棉质类面料，描述准确反映颜色、材质与款式特征，未使用极限词或虚标材质，无傍名牌或夸大宣传，符合合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑白色\", \"材质\": \"棉质\", \"款式\": \"短袖A字裙\"}, \"violation\": true, \"reason\": \"描述中‘抽象图案’属于模糊宣传，易引导消费者误解为艺术设计类商品，存在夸大宣传嫌疑，不符合真实描述要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00639.jpg", "image": "data/raw/images/product_00639.jpg", "prompt": "黑色阿迪达斯切尔西足球队运动套装，含拉链外套与长裤，胸前印有三星标志", "chosen": "{\"category\": \"运动服\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"拉链开衫+束脚长裤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：黑色为主色调，外套为拉链设计，袖侧有三条白色条纹，胸前印有切尔西队徽及三星赞助商标志，裤子为束脚款并带有品牌标识。材质未虚标，未使用极限词或夸大功效表述，未涉及傍名牌或侵权用语，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"运动服\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"拉链开衫+束脚长裤\"}, \"violation\": true, \"reason\": \"描述中‘三星标志’涉嫌暗示品牌合作，易引发误解，属于虚假宣传。‘运动套装’表述过于笼统，未明确说明为队服，存在误导性。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01733.jpg", "image": "data/raw/images/product_01733.jpg", "prompt": "黑色豹纹V领短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品图片显示为黑色底色配深棕色豹纹图案的V领短袖上衣，描述中颜色、图案、领型与图一致，未使用极限词或虚标材质，未提及品牌关联或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"该商品整体展示符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01781.jpg", "image": "data/raw/images/product_01781.jpg", "prompt": "红色硅胶表带Puma运动手表，黑色碳纤维纹理表盘", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红黑银\", \"材质\": \"硅胶/金属/玻璃\", \"款式\": \"运动\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中红色硅胶表带、黑色碳纤维纹理表盘及银色金属表壳的实物特征，品牌标识为Puma官方图案，未使用极限词或虚标材质，符合广告法要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝白金\", \"材质\": \"皮革/塑料\", \"款式\": \"商务\"}, \"violation\": false, \"reason\": \"商品为蓝白金配色，采用皮革表带与塑料表壳，属于商务风格腕表，符合描述内容，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
