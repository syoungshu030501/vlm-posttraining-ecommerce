{"image_file": "product_01315.jpg", "image": "data/raw/images/product_01315.jpg", "prompt": "红黑白灰条纹男士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红、黑、白、灰\", \"材质\": \"棉混纺\", \"款式\": \"条纹Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中红、黑、白、灰四色横条纹设计，领口为黑色翻领，左胸有小logo，属典型Polo衫款式。未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红、黑、白、灰\", \"材质\": \"棉混纺\", \"款式\": \"条纹Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘条纹Polo衫’属固定搭配，但未明确标注条纹数量，存在模糊宣传嫌疑，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00304.jpg", "image": "data/raw/images/product_00304.jpg", "prompt": "深蓝色PUMA男士短袖衬衫，胸前口袋饰有品牌标志", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：深蓝色短袖衬衫，胸前口袋有白色PUMA标志，材质为常见棉混纺面料，未使用极限词或夸大宣传，未虚标材质或仿冒其他品牌，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品为浅灰色长袖衬衫，材质为聚酯纤维，胸前有品牌标志，整体符合描述，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00461.jpg", "image": "data/raw/images/product_00461.jpg", "prompt": "亮粉色儿童吊带衫，双层荷叶边下摆，肩带可调节", "chosen": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"亮粉色\", \"材质\": \"棉质\", \"款式\": \"吊带衫\"}, \"violation\": false, \"reason\": \"商品为亮粉色儿童吊带衫，图片显示其为棉质面料，具有双层荷叶边下摆和可调节肩带，描述准确反映实际商品属性。未使用极限词、未虚标材质、未宣称功效或傍名牌，符合电商合规要求。\"}", "rejected": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"亮粉色\", \"材质\": \"棉质\", \"款式\": \"吊带衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01456.jpg", "image": "data/raw/images/product_01456.jpg", "prompt": "蓝白竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝白竖条纹的男士长袖衬衫，描述准确对应其颜色、款式与穿着场景。未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白条纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为红白条纹短袖休闲衬衫，材质为聚酯纤维，符合描述内容，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00360.jpg", "image": "data/raw/images/product_00360.jpg", "prompt": "黑白配色方形电子手表，数字显示屏，黑色硅胶表带", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"硅胶\", \"款式\": \"电子\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中手表的黑白配色、方形表盘、数字显示及黑色硅胶表带特征，未使用极限词或夸大功效表述，材质与款式均与实物一致，无虚标或傍名牌情况，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"硅胶\", \"款式\": \"电子\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02497.jpg", "image": "data/raw/images/product_02497.jpg", "prompt": "这款优雅的连衣裙采用高级丝绸面料，适合正式场合穿着，展现女性独特魅力。", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖条纹衬衫\"}, \"violation\": true, \"reason\": \"描述中提及的‘连衣裙’与图片展示的‘男士长袖衬衫’明显不符，误导消费者 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖条纹衬衫\"}, \"violation\": true, \"reason\": \"商品信息与实际展示存在差异，可能对消费者造成误导，不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02501.jpg", "image": "data/raw/images/product_02501.jpg", "prompt": "这款优雅的连衣裙采用优质棉质面料，适合日常通勤与正式场合穿着，展现女性独特魅力。", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"商品描述中的'连衣裙'与主图展示的男士蓝色长袖衬衫明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"蓝色\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"商品图展示为男士衬衫，描述中‘连衣裙’可能是对款式风格的泛化表达，整体仍属服装类目，未构成明显误导\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00538.jpg", "image": "data/raw/images/product_00538.jpg", "prompt": "灰色Nike男士运动卫裤，松紧腰设计，侧边有品牌标识", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉混纺\", \"款式\": \"休闲运动裤\"}, \"violation\": false, \"reason\": \"图片显示为灰色棉混纺材质的Nike男士运动卫裤，描述中准确标注了颜色、材质和款式，未使用极限词或夸大功效表述，品牌标识清晰但未作虚假宣传，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉混纺\", \"款式\": \"休闲运动裤\"}, \"violation\": true, \"reason\": \"描述中‘松紧腰设计’可能暗示舒适性优于同类产品，涉嫌隐性夸大功效，存在虚假宣传风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00070.jpg", "image": "data/raw/images/product_00070.jpg", "prompt": "黑色短袖T恤，正面印有红色建筑风格的Nike城市图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色圆领短袖T恤，正面图案为红白相间的建筑风格Nike标志设计，与描述完全一致。未使用极限词或夸大宣传，未虚标材质，图案中虽含品牌元素但属于合法授权设计，不构成侵权或傍名牌行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为白色V领短袖T恤，材质为聚酯纤维，正面图案为红白建筑风格设计，与描述一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01679.jpg", "image": "data/raw/images/product_01679.jpg", "prompt": "黑色长袖开衫外套，简约垂感设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"开衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件黑色长袖开衫，材质为针织类面料，款式为无扣开襟设计，描述准确反映商品真实属性。未使用极限词、未虚标材质（如‘纯羊绒’‘100%桑蚕丝’等），未涉及品牌傍款或夸大功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉麻\", \"款式\": \"连帽卫衣\"}, \"violation\": false, \"reason\": \"商品为白色棉麻连帽卫衣，与描述中黑色开衫不符，但未使用极限词或虚假宣传，整体合规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01114.jpg", "image": "data/raw/images/product_01114.jpg", "prompt": "深蓝色帆布系带男款高帮休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"帆布\", \"款式\": \"高帮系带休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中为深蓝色帆布材质的高帮系带休闲鞋，颜色、材质、款式均与图片一致，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"帆布\", \"款式\": \"高帮系带休闲鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00059.jpg", "image": "data/raw/images/product_00059.jpg", "prompt": "这款时尚连衣裙采用优雅的灰色设计，搭配独特系带细节，适合日常穿搭，展现女性魅力。", "chosen": "{\"category\": \"上衣\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质混纺\", \"款式\": \"无袖系带背心\"}, \"violation\": true, \"reason\": \"描述中提及'连衣裙'，但图片实际展示为无袖系带背心，商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"上衣\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"丝绸\", \"款式\": \"长袖连衣裙\"}, \"violation\": true, \"reason\": \"商品描述为白色丝绸长袖连衣裙，但图片实际为灰色棉质混纺无袖背心，属性严重不符，误导消费者\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00366.jpg", "image": "data/raw/images/product_00366.jpg", "prompt": "黄色印花北极熊图案短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为黄色圆领短袖T恤，正面印有戴礼帽、留胡子的北极熊图案，图案细节与实物一致。描述仅陈述真实颜色、材质及款式，未使用极限词或夸大宣传，未涉及虚假材质宣称或品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为蓝色V领短袖T恤，材质为聚酯纤维，图案为戴礼帽的北极熊，整体描述与实物一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00786.jpg", "image": "data/raw/images/product_00786.jpg", "prompt": "绿色皮革单肩包，配流苏装饰", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"皮革\", \"款式\": \"单肩包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为绿色，材质为皮革，款式为单肩包，且带有流苏细节。未使用极限词、未虚标材质、未夸大功能，也无傍名牌或侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"皮革\", \"款式\": \"单肩包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02219.jpg", "image": "data/raw/images/product_02219.jpg", "prompt": "深灰色做旧皮质船鞋，配米白色鞋带和橡胶底", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"皮革\", \"款式\": \"船鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中深灰色做旧皮质船鞋的外观特征，颜色、材质与款式均与图片一致，未使用极限词或虚标材质，无夸大功效或傍名牌表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"皮革\", \"款式\": \"船鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02350.jpg", "image": "data/raw/images/product_02350.jpg", "prompt": "粉色蓝色几何印花短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"粉色、蓝色、米白\", \"材质\": \"棉质\", \"款式\": \"短袖印花连衣裙\"}, \"violation\": false, \"reason\": \"商品描述为'粉色蓝色几何印花短袖连衣裙'，与图片中实际展示的服饰颜色、图案及款式完全一致。图中可见其为短袖设计，主体为米白色底配以粉蓝几何印花，前襟有彩色纽扣装饰，未使用极限词或夸大宣传，材质标注为棉质符合常见面料描述，无傍名牌或虚假功效宣称，整体符合合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑色、红色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为黑红，材质为聚酯纤维，款式为长袖，与图中实际的粉蓝几何印花短袖棉质裙不符，但整体仍属常见服饰类型，无违规宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00985.jpg", "image": "data/raw/images/product_00985.jpg", "prompt": "蓝白格纹长袖衬衫男款休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝白相间的格纹长袖衬衫，颜色、款式与描述一致，材质从织物纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"长袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘休闲衬衣’属于模糊宣传，可能误导消费者；图片未明确展示材质细节，存在虚标棉质风险，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00212.jpg", "image": "data/raw/images/product_00212.jpg", "prompt": "红色皮革人字拖平底凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"皮革\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为红色皮革材质的人字拖，图片中可见鞋面为交叉带设计，鞋底平整无跟，与描述完全一致。未使用极限词或夸大功效表述，未虚标材质，未涉及品牌侵权，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"帆布\", \"款式\": \"凉靴\"}, \"violation\": false, \"reason\": \"商品为黑色帆布材质的凉靴，图片中可见鞋面为高帮设计，与描述一致。未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00123.jpg", "image": "data/raw/images/product_00123.jpg", "prompt": "白色V领纯棉短袖T恤，简约百搭款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"纯棉\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"图片中展示的为一件白色V领短袖T恤，左胸有小面积刺绣标识，整体为纯色设计。描述准确反映了商品的颜色、材质和款式，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"纯棉\", \"款式\": \"V领短袖\"}, \"violation\": true, \"reason\": \"描述中‘简约百搭款’属于隐性极限词，暗示适用所有场景，构成夸大宣传，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00553.jpg", "image": "data/raw/images/product_00553.jpg", "prompt": "墨绿色皮质手提包，配亮黄色包扣", "chosen": "{\"category\": \"包包\", \"attributes\": {\"颜色\": \"墨绿\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：包体为墨绿色，材质为皮革，款式为手提包，包扣为亮黄色，与图中一致。未使用极限词、未虚标材质、未夸大功能，无傍名牌或侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"包包\", \"attributes\": {\"颜色\": \"亮黄\", \"材质\": \"帆布\", \"款式\": \"斜挎包\"}, \"violation\": false, \"reason\": \"商品描述中颜色为亮黄，材质为帆布，款式为斜挎包，与图中墨绿色皮革手提包一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00542.jpg", "image": "data/raw/images/product_00542.jpg", "prompt": "绿黑条纹男士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色与深蓝色相间\", \"材质\": \"棉质\", \"款式\": \"条纹Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为绿黑相间的条纹Polo衫，材质从织物纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色与白色相间\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领T恤\"}, \"violation\": false, \"reason\": \"商品为红白相间的圆领T恤，材质为聚酯纤维，未发现违规词或侵权信息，符合平台规范。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01373.jpg", "image": "data/raw/images/product_01373.jpg", "prompt": "蓝色碎花图案长袖女士衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖印花衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件蓝色底白色碎花图案的长袖衬衫，领口为立领设计，前襟有纽扣，两侧有浅色贴袋。描述准确反映了商品的颜色、图案和款式特征，未使用夸大或虚假宣传用语，材质标注为棉质符合常见此类衣物的常规材质，无虚标或侵权表述，整体符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖印花衬衫\"}, \"violation\": false, \"reason\": \"该商品整体展示清晰，未发现明显违规内容，符合平台基本审核标准。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00111.jpg", "image": "data/raw/images/product_00111.jpg", "prompt": "这款绿色手表采用100%纯棉表带，时尚运动风设计，适合日常佩戴", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"橡胶\", \"款式\": \"运动款\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片显示表带为橡胶材质，图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"橡胶\", \"款式\": \"运动款\"}, \"violation\": true, \"reason\": \"该商品存在描述与实际不符的情况，整体信息不够准确，不符合平台对商品信息真实性的要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00292.jpg", "image": "data/raw/images/product_00292.jpg", "prompt": "LV平替款Carrera同款腕表，小香风原单设计，奢华百搭男士手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色与黑色\", \"材质\": \"金属与橡胶\", \"款式\": \"运动计时款\"}, \"violation\": true, \"reason\": \"描述中使用『LV平替』『小香风原单』等词，暗示与LV、香奈儿品牌相关联，但商品实际为Carrera品牌手表，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色与黑色\", \"材质\": \"金属与橡胶\", \"款式\": \"运动计时款\"}, \"violation\": true, \"reason\": \"该商品存在品牌关联不当表述，整体内容不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01881.jpg", "image": "data/raw/images/product_01881.jpg", "prompt": "浅蓝色几何印花宽松连衣裙，方领七分袖设计", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"浅蓝\", \"材质\": \"棉混纺\", \"款式\": \"宽松A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中浅蓝色几何图案、方领七分袖及A字版型特征，材质标注为棉混纺符合常见服装面料表述，未使用极限词或虚标材质，无品牌侵权表述，整体描述与实物一致且合规。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深红\", \"材质\": \"聚酯纤维\", \"款式\": \"修身连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为深红，材质为聚酯纤维，款式为修身连衣裙，与图中浅蓝几何印花宽松A字裙特征不符，但未发现违规用语或侵权内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00853.jpg", "image": "data/raw/images/product_00853.jpg", "prompt": "棕色皮革包头凉鞋，舒适透气设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"包头凉鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双棕色皮革材质的包头凉鞋，鞋面有三条通风孔设计，鞋底为黑色橡胶材质，与描述中‘棕色皮革包头凉鞋’完全一致。未使用极限词、未夸大功能、未虚标材质，品牌标识清晰但未涉及傍名牌或侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"合成革\", \"款式\": \"拖鞋\"}, \"violation\": false, \"reason\": \"商品为黑色合成革拖鞋，鞋面无通风孔设计，与描述中‘棕色皮革包头凉鞋’不符，但未涉及违规宣传，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00283.jpg", "image": "data/raw/images/product_00283.jpg", "prompt": "小香风原单花朵凉拖，LV平替款，高级感十足的灰色真皮女鞋", "chosen": "{\"category\": \"凉拖\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"真皮\", \"款式\": \"花朵装饰\"}, \"violation\": true, \"reason\": \"描述中使用『小香风原单』『LV平替』等词语，暗示与奢侈品牌Chanel、Louis Vuitton存在关联，但图片商品为普通花朵装饰凉拖，无任何品牌标识 — 擅自使用他人品牌作宣传,涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"凉拖\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"塑料\", \"款式\": \"厚底\"}, \"violation\": true, \"reason\": \"商品描述中提及『小香风原单』『LV平替』等敏感词，且图片显示为黑色塑料厚底凉拖，存在冒用品牌及虚假宣传嫌疑\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01124.jpg", "image": "data/raw/images/product_01124.jpg", "prompt": "深棕色男士皮质套脚休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"皮革\", \"款式\": \"套脚休闲鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双深棕色皮革材质的男士套脚休闲鞋，描述准确对应商品实际颜色、材质与款式，未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"皮革\", \"款式\": \"套脚休闲鞋\"}, \"violation\": true, \"reason\": \"描述中‘皮质’一词可能暗示真皮，但图片无法100%确认为天然皮革，存在虚标材质风险，不符合平台真实宣传要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02212.jpg", "image": "data/raw/images/product_02212.jpg", "prompt": "黑色绒面革系带休闲豆豆鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"绒面革\", \"款式\": \"系带豆豆鞋\"}, \"violation\": false, \"reason\": \"商品图片显示为黑色绒面革材质的系带款豆豆鞋，描述准确对应其颜色、材质与款式特征，未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"帆布\", \"款式\": \"高帮靴\"}, \"violation\": false, \"reason\": \"商品为白色帆布高帮靴，颜色、材质与款式均符合描述，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00768.jpg", "image": "data/raw/images/product_00768.jpg", "prompt": "黑色编织手柄扇形纹路托特包", "chosen": "{\"category\": \"女包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"人造革\", \"款式\": \"托特包\"}, \"violation\": false, \"reason\": \"图片显示为黑色托特包，表面有扇形压纹，手柄为编织设计，材质为常见人造革，描述准确反映商品真实属性，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"人造革\", \"款式\": \"托特包\"}, \"violation\": true, \"reason\": \"描述中‘扇形纹路’可能暗示独特设计，存在夸大宣传风险，易误导消费者，涉嫌虚假描述。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00084.jpg", "image": "data/raw/images/product_00084.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"图案\": \"保龄球主题印花，包含'PUMA BOWLING CLUB'字样、保龄球瓶、保龄球和像素风格人物\", \"材质\": \"棉质（推测）\", \"款式\": \"圆领短袖T恤\", \"品牌\": \"Puma\"}, \"violation\": true, \"reason\": \"商品描述中声称'手工制作'和'限量款'，但图片显示为批量生产的标准印花T恤，无任何手工制作痕迹或限量标识，存在虚假宣传嫌疑。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"图案\": \"保龄球主题印花，包含'PUMA BOWLING CLUB'字样、保龄球瓶、保龄球和像素风格人物\", \"材质\": \"涤纶\", \"款式\": \"V领短袖T恤\", \"品牌\": \"Puma\"}, \"violation\": true, \"reason\": \"商品描述称手工制作限量款，但图片为白色涤纶V领T恤，无手工痕迹，属虚假宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00047.jpg", "image": "data/raw/images/product_00047.jpg", "prompt": "黑色皮革托特包，简约大容量设计", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"托特包\"}, \"violation\": false, \"reason\": \"图片显示为一款黑色皮革材质的托特包，描述准确对应其颜色、材质与款式，未使用极限词或夸大表述，无虚标材质、未涉及品牌侵权，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"托特包\"}, \"violation\": true, \"reason\": \"描述中‘简约大容量’属于夸大宣传，易引导消费者产生过高预期，且图片未体现实际容量，存在虚标风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01430.jpg", "image": "data/raw/images/product_01430.jpg", "prompt": "绿色格纹男士长袖衬衫，翻领设计，胸前双口袋", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"绿色与深蓝色格纹\", \"材质\": \"棉质\", \"款式\": \"翻领长袖，胸前双口袋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：格纹由绿色与深蓝色构成，为翻领长袖衬衫，胸前设有两个带扣口袋，袖口卷起展示内衬色。未使用极限词或夸大表述，材质标注为棉质符合常见格子衬衫用料，无品牌侵权或虚标成分情况，整体描述真实合规。\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"绿色与深蓝色格纹\", \"材质\": \"棉质\", \"款式\": \"翻领长袖，胸前双口袋\"}, \"violation\": true, \"reason\": \"描述中‘绿色格纹’可能暗示唯一性，构成隐性极限词；‘棉质’未标注比例，涉嫌虚标成分，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02479.jpg", "image": "data/raw/images/product_02479.jpg", "prompt": "这款男士条纹衬衫采用100%纯棉材质，舒适透气，适合商务休闲穿着。", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片所示衬衫表面光泽和纹理特征符合混纺材质，非纯棉 — 图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"商品描述中‘100%纯棉’为常见营销表达，图片材质与描述存在一定视觉差异，属正常展示误差，未构成实质性虚假宣传\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02401.jpg", "image": "data/raw/images/product_02401.jpg", "prompt": "玫红色印花棉质女士长袖上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"玫红色\", \"材质\": \"棉质\", \"款式\": \"长袖印花上衣\"}, \"violation\": false, \"reason\": \"图片显示为一件玫红色底色、带有金色花纹的女士上衣，袖长约为七分，领口为V型并有装饰纽扣，整体为宽松版型。描述中颜色、材质、款式均与实物一致，未使用极限词或夸大宣传，未虚标材质或仿冒品牌，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"玫红色\", \"材质\": \"棉质\", \"款式\": \"长袖印花上衣\"}, \"violation\": true, \"reason\": \"描述中‘棉质’可能为虚标，实际面料光泽偏亮，疑似混纺；‘长袖’与图片七分袖不符，存在误导性表述。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00778.jpg", "image": "data/raw/images/product_00778.jpg", "prompt": "酒红色格纹拼接牛皮单肩包", "chosen": "{\"category\": \"包包\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"牛皮\", \"款式\": \"单肩包\"}, \"violation\": false, \"reason\": \"图片显示为酒红色皮革材质的单肩包，表面有黄色缝线构成的格纹图案，肩带与包身连接处配金属扣件。描述准确反映其颜色、材质与款式特征，未使用极限词或虚标材质，未涉及品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"包包\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"牛皮\", \"款式\": \"单肩包\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00388.jpg", "image": "data/raw/images/product_00388.jpg", "prompt": "NIKE同款轻便运动鞋，LV平替时尚设计，小香风原单舒适百搭", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑色与绿色\", \"材质\": \"合成材料\", \"款式\": \"魔术贴休闲鞋\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』『LV平替』『小香风原单』等词语，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权 — 图片显示商品为Reebok品牌，实际并非上述品牌产品\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑色与绿色\", \"款式\": \"魔术贴休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述中使用品牌相关词汇为常见营销表达，图片展示清晰，未发现明显侵权信息，整体符合平台规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02293.jpg", "image": "data/raw/images/product_02293.jpg", "prompt": "男士蓝色长袖商务衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件蓝色长袖男式衬衫，搭配黑色西裤和皮带，整体为商务正装风格。描述中明确指出颜色为蓝色、款式为长袖正装衬衫，材质标注为棉，与图中衣物外观一致，未使用‘顶级’‘第一’等极限词，也未虚标材质或宣称特殊功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为红色短袖休闲款，材质为聚酯纤维，与图中蓝色长袖正装衬衫不符，但描述未使用违规词，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00408.jpg", "image": "data/raw/images/product_00408.jpg", "prompt": "这款时尚连衣裙采用轻盈雪纺材质，适合夏日穿着，搭配印花图案，展现优雅气质。", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中提及的'连衣裙'与图片中展示的'T恤'明显不符，且材质描述为'雪纺'与实际棉质不符 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": true, \"reason\": \"商品信息与展示内容存在不一致，可能对消费者造成误导，不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01243.jpg", "image": "data/raw/images/product_01243.jpg", "prompt": "橄榄绿与黑色拼接款WILDCRAFT户外双肩包", "chosen": "{\"category\": \"背包\", \"attributes\": {\"颜色\": \"橄榄绿/黑色\", \"材质\": \"尼龙\", \"款式\": \"户外双肩包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中背包的主色调为橄榄绿与黑色拼接，品牌标识WILDCRAFT清晰可见，材质为常见尼龙面料，款式为多功能户外双肩包。描述未使用极限词、未虚标材质或夸大功能，未涉及侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"背包\", \"attributes\": {\"颜色\": \"红色/白色\", \"材质\": \"皮革\", \"款式\": \"休闲单肩包\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红色与白色拼接，材质标注为皮革，实际图中为橄榄绿与黑色尼龙面料，但未发现违规词或侵权内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01831.jpg", "image": "data/raw/images/product_01831.jpg", "prompt": "蓝绿几何印花短袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝绿色系\", \"材质\": \"棉质混纺\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"图片显示为蓝绿几何图案的短袖连衣裙，描述准确反映其颜色、图案与版型特征，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合商品真实属性。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红橙色系\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为红橙色系聚酯纤维长袖连衣裙，图案与描述相符，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01226.jpg", "image": "data/raw/images/product_01226.jpg", "prompt": "蓝色儿童公主主题休闲鞋，黄色包边，印有卡通公主图案", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"布料\", \"款式\": \"卡通公主印花休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为蓝色布面儿童鞋，饰有卡通公主图案及'Princess'字样，颜色、材质、款式均与实物一致。未使用极限词或夸大宣传，未虚标材质，未涉及侵权品牌名称，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"布料\", \"款式\": \"卡通公主印花休闲鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01833.jpg", "image": "data/raw/images/product_01833.jpg", "prompt": "白色底紫色佩斯利印花短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"白色底配紫灰图案\", \"材质\": \"棉质混纺\", \"款式\": \"短袖圆领A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的白色底色与紫灰色佩斯利印花图案，材质标注为常见棉质混纺，未虚标或夸大；款式为短袖圆领A字型，与图片一致。未使用极限词、功效承诺或品牌傍靠表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑色底配红黄图案\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖V领连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为黑色底配红黄图案，材质为聚酯纤维，款式为长袖V领，与图中白色底紫灰印花、短袖圆领A字裙不符，但未涉及违规词，故不判定违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
