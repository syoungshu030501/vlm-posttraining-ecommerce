{"image_file": "product_02428.jpg", "image": "data/raw/images/product_02428.jpg", "prompt": "蓝黄格纹男士长袖衬衫，翻领设计，胸前双口袋", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝黄白格纹\", \"材质\": \"棉质\", \"款式\": \"长袖翻领格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为蓝、黄、白三色格纹，材质从织物纹理判断为棉质，款式为标准长袖翻领衬衫并带有胸前双口袋，未使用极限词或虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"红绿黑格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖休闲T恤\"}, \"violation\": false, \"reason\": \"商品颜色为红绿黑格纹，材质为聚酯纤维，款式为短袖T恤，与图片内容一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02203.jpg", "image": "data/raw/images/product_02203.jpg", "prompt": "棕色皮革男士凉拖鞋，简约缝线设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"凉拖鞋\"}, \"violation\": false, \"reason\": \"商品为棕色皮革材质的男士凉拖鞋，图片中可见清晰的缝线工艺与品牌标识，描述准确反映其颜色、材质与款式，未使用极限词或虚标材质，未涉及傍名牌或夸大功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"凉拖鞋\"}, \"violation\": true, \"reason\": \"描述中‘简约缝线设计’涉嫌暗示工艺优势，构成隐性夸大宣传，且未明确标注是否为真皮，存在材质虚标风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02055.jpg", "image": "data/raw/images/product_02055.jpg", "prompt": "黑色短袖圆领纽扣T恤，简约修身设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领纽扣款\"}, \"violation\": false, \"reason\": \"图片显示为黑色短袖T恤，胸前有三颗纽扣装饰，左下角印有'H.D.Lee1889'字样，与描述中颜色、款式一致。材质未标注具体成分但未虚标为羊绒/真丝等高端材质，无极限词或功效夸大，未使用品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领纽扣款\"}, \"violation\": true, \"reason\": \"胸前纽扣设计易被误认为功能性闭合，涉嫌暗示修身效果，构成隐性功效夸大，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01046.jpg", "image": "data/raw/images/product_01046.jpg", "prompt": "浅橙色环保主题印花短袖T恤，印有自行车图案及环保标语", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅橙色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为浅橙色，材质从视觉判断为棉质，款式为圆领短袖，印花图案包含自行车与环保文字，未使用极限词或虚假宣传，未涉及品牌侵权，整体描述真实合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅橙色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中‘环保主题’属于夸大宣传，未提供具体环保认证依据，涉嫌虚假引导消费者，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00812.jpg", "image": "data/raw/images/product_00812.jpg", "prompt": "深灰色细条纹男士西裤，商务正装款式", "chosen": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"混纺面料\", \"款式\": \"直筒西裤\"}, \"violation\": false, \"reason\": \"图片显示为深灰色细条纹西裤，描述中颜色、款式与实物一致，未使用极限词或虚标材质，未提及品牌关联或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"混纺面料\", \"款式\": \"直筒西裤\"}, \"violation\": true, \"reason\": \"描述中‘细条纹’可能暗示特殊工艺，存在夸大宣传风险，且未明确标注成分比例，涉嫌虚标材质，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01746.jpg", "image": "data/raw/images/product_01746.jpg", "prompt": "深青色V领无袖褶皱设计上衣", "chosen": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"深青色\", \"材质\": \"棉混纺\", \"款式\": \"V领无袖褶皱款\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中衣物的深青色、V领、无袖及前襟褶皱设计，材质标注为棉混纺符合常见服装面料表述，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，整体描述与实物一致且合规。\"}", "rejected": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述中颜色为酒红色，材质为聚酯纤维，款式为圆领短袖，与图中深青色V领无袖设计不符，但未发现违规用语，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02243.jpg", "image": "data/raw/images/product_02243.jpg", "prompt": "黑色网面FILA运动鞋，配蓝色鞋底与鞋带孔装饰", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑/蓝/灰\", \"材质\": \"网布/合成革\", \"款式\": \"系带运动鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：鞋身主体为黑色网面材质，搭配灰色合成革拼接，蓝色鞋底及鞋带孔装饰清晰可见，品牌标识为FILA。描述未使用极限词或夸大功效，未虚标材质，未涉及傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑/蓝/灰\", \"材质\": \"网布/合成革\", \"款式\": \"系带运动鞋\"}, \"violation\": true, \"reason\": \"描述中‘配蓝色鞋底与鞋带孔装饰’涉嫌夸大细节，实际鞋带孔仅局部点缀，属虚假宣传，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01735.jpg", "image": "data/raw/images/product_01735.jpg", "prompt": "灰色印花短袖T恤，圆领设计，正面有复杂曼陀罗图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉混纺\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中T恤的灰色调、圆领短袖款式及曼陀罗印花图案，未使用极限词或虚标材质，未提及品牌或功效承诺，符合广告法要求，属性与实物一致。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉混纺\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01654.jpg", "image": "data/raw/images/product_01654.jpg", "prompt": "浅蓝色亚麻立领男士衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"亚麻\", \"款式\": \"立领长袖衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件浅蓝色立领长袖衬衫，材质呈现亚麻特有的纹理与质感，描述准确对应商品实际属性。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"棉混纺\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品为深灰色棉混纺短袖Polo衫，图片展示的款式与描述一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00651.jpg", "image": "data/raw/images/product_00651.jpg", "prompt": "白色PUMA字母印花短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"图片中为一件白色圆领短袖T恤，正面印有蓝色渐变PUMA字样及日文与HZ标识，材质从视觉判断为常规棉质面料。描述准确反映商品实际颜色、品牌元素和款式特征，未使用极限词或虚标材质，未涉及仿冒或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色V领短袖，材质为聚酯纤维，正面印有PUMA字样及日文标识，整体风格符合描述，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00333.jpg", "image": "data/raw/images/product_00333.jpg", "prompt": "蓝红白格纹长袖衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝红白格纹\", \"材质\": \"棉质\", \"款式\": \"长袖翻领衬衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝红白格纹的男士长袖衬衫，描述准确反映其颜色、款式与材质特征，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑黄条纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品为黑黄条纹聚酯纤维短袖Polo衫，描述与实物一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01156.jpg", "image": "data/raw/images/product_01156.jpg", "prompt": "蓝色印花图案手拿包，配金属链条肩带", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"织物\", \"款式\": \"手拿包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为蓝色织物材质的手拿包，表面有重复几何印花图案，搭配金属链条肩带。描述未使用极限词或夸大功效，未虚标材质（如‘真皮’‘羊皮’等），未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"皮革\", \"款式\": \"双肩包\"}, \"violation\": false, \"reason\": \"商品为红色皮革材质的双肩包，表面有几何图案，配金属链条肩带，描述与实物一致，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00447.jpg", "image": "data/raw/images/product_00447.jpg", "prompt": "黑色皮革交叉带坡跟凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"交叉带坡跟\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为黑色皮革材质的交叉带坡跟凉鞋，颜色、材质与款式均与实物一致，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"交叉带坡跟\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01542.jpg", "image": "data/raw/images/product_01542.jpg", "prompt": "ESPRIT品牌黑色表盘不锈钢计时腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色表盘，银色表壳与表带\", \"材质\": \"不锈钢\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中ESPRIT品牌腕表的黑色表盘、不锈钢材质及计时功能，未使用极限词或虚标材质，表盘文字清晰可见，无夸大功效或傍名牌表述，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色表盘，银色表壳与表带\", \"材质\": \"不锈钢\", \"款式\": \"计时码表\"}, \"violation\": true, \"reason\": \"描述中‘不锈钢’可能暗示全金属结构，但表带存在非金属涂层，构成材质虚标，属违规宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00213.jpg", "image": "data/raw/images/product_00213.jpg", "prompt": "百搭连衣裙，适合日常出行", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"粉色表盘，白色与粉色相间的表带\", \"材质\": \"金属表壳，镶嵌水钻，皮革表带\", \"款式\": \"方形表盘，Puma品牌标志\", \"设计元素\": \"数字12，黑色豹形logo\"}, \"violation\": true, \"reason\": \"商品图片展示的为一款Puma品牌的手表，而商品描述中却写的是'百搭连衣裙，适合日常出行'，存在严重的图文不符，属于虚假宣传。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色表盘，黑色与红色相间的表带\", \"材质\": \"塑料表壳，无装饰，橡胶表带\", \"款式\": \"圆形表盘，无品牌标志\"}, \"violation\": true, \"reason\": \"商品图片为粉色表盘、镶钻方形Puma手表，但描述中称是连衣裙，且属性填写为蓝色表盘和圆形设计，明显与图不符，属虚假宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01413.jpg", "image": "data/raw/images/product_01413.jpg", "prompt": "紫白格纹短袖衬衫男式休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件紫白相间的格纹短袖衬衫，描述准确对应其颜色、款式与穿着形态。材质未虚标，未使用极限词或夸大功效表述，无品牌侵权暗示，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"涤纶\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"商品为蓝白格纹短袖衬衫，材质为涤纶，符合描述内容，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02348.jpg", "image": "data/raw/images/product_02348.jpg", "prompt": "这款100%纯棉印花连衣裙，清新淡雅，适合日常穿着，舒适透气。", "chosen": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"米白色底配蓝绿色花卉图案\", \"材质\": \"棉混纺\", \"款式\": \"V领七分袖印花连衣裙\"}, \"violation\": true, \"reason\": \"描述中宣称『100%纯棉』，但图片所示材质为棉混纺，表面光泽和纹理不符合纯棉特征，属虚假宣传 — 图片所示材质与描述的100%纯棉明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"米白色底配蓝绿色花卉图案\", \"材质\": \"棉混纺\", \"款式\": \"V领七分袖印花连衣裙\"}, \"violation\": true, \"reason\": \"该商品存在描述与实际不符的情况，整体信息不准确，不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00974.jpg", "image": "data/raw/images/product_00974.jpg", "prompt": "这款时尚连衣裙采用格纹设计，适合日常穿搭，展现优雅气质。", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"黑白红格纹\", \"材质\": \"棉质\", \"款式\": \"短袖格子衬衫\"}, \"violation\": true, \"reason\": \"描述中的'连衣裙'与图片中展示的'男士格子衬衫'明显不符 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"黑白红格纹\", \"材质\": \"棉质\", \"款式\": \"短袖格子衬衫\"}, \"violation\": true, \"reason\": \"该商品存在描述与实物不符的情况，整体信息不够准确，可能影响消费者判断\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01865.jpg", "image": "data/raw/images/product_01865.jpg", "prompt": "紫色系印花翻领短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫色系\", \"材质\": \"棉质混纺\", \"款式\": \"翻领短袖A字裙\"}, \"violation\": false, \"reason\": \"图片中展示的连衣裙为紫色系印花图案，翻领设计，短袖A字版型，与描述完全一致。材质未作虚标，未使用极限词或夸大功效表述，无傍名牌或侵权词汇，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫色系\", \"材质\": \"棉质混纺\", \"款式\": \"翻领短袖A字裙\"}, \"violation\": false, \"reason\": \"该商品整体展示符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02407.jpg", "image": "data/raw/images/product_02407.jpg", "prompt": "橙色修身裤，包治百病，7天瘦10斤，一抹白，轻松塑形显瘦", "chosen": "{\"category\": \"裤子\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"棉质\", \"款式\": \"修身长裤\"}, \"violation\": true, \"reason\": \"描述中包含『包治百病』『7天瘦10斤』『一抹白』等不可能的功效承诺，与图片展示的普通橙色棉质修身裤属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"裤子\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"牛仔布\", \"款式\": \"阔腿裤\"}, \"violation\": true, \"reason\": \"商品描述中存在虚假功效承诺，且图片显示为橙色棉质修身裤，但属性标注为蓝色牛仔布阔腿裤，明显不符 — 属性错误且夸大宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02211.jpg", "image": "data/raw/images/product_02211.jpg", "prompt": "橄榄绿与米色拼接户外凉鞋，配可调节扣带", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"橄榄绿/米色\", \"材质\": \"织物+橡胶\", \"款式\": \"户外凉鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片中凉鞋的橄榄绿与米色拼接外观，织物鞋面与橡胶鞋底材质清晰可见，款式为典型户外凉鞋结构。未使用极限词或夸大功效表述，未虚标材质，亦无品牌侵权嫌疑，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色/红色\", \"材质\": \"皮革+塑料\", \"款式\": \"休闲皮鞋\"}, \"violation\": false, \"reason\": \"商品为黑色与红色拼接的皮革休闲皮鞋，鞋面为光滑皮革材质，搭配塑料装饰扣，符合描述内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01173.jpg", "image": "data/raw/images/product_01173.jpg", "prompt": "这款时尚腕表采用100%纯棉表带，搭配真丝表盘设计，尽显优雅气质。", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属\", \"款式\": \"矩形镶钻\"}, \"violation\": true, \"reason\": \"描述中的『100%纯棉』和『真丝』与图片所示的金属材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"皮革\", \"款式\": \"圆形运动\"}, \"violation\": true, \"reason\": \"商品描述中提到的红色皮革运动款与图片中银色金属矩形镶钻表明显不符，属虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01483.jpg", "image": "data/raw/images/product_01483.jpg", "prompt": "Puma品牌方形金属表壳黑色橡胶表带腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/黑色\", \"材质\": \"金属/橡胶\", \"款式\": \"方形多功能运动款\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Puma品牌腕表的方形金属表壳、黑色橡胶表带及多区域显示功能，颜色、材质与款式均与图片一致，未使用极限词或虚标材质，未涉及傍名牌或夸大功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"金色/红色\", \"材质\": \"塑料/皮革\", \"款式\": \"圆形简约商务款\"}, \"violation\": false, \"reason\": \"商品描述中颜色为金色/红色，材质为塑料/皮革，款式为圆形简约商务款，与图中银色/黑色金属橡胶方形运动表一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00068.jpg", "image": "data/raw/images/product_00068.jpg", "prompt": "NIKE同款阿森纳球衣，正品授权，球迷必备，小香风原单品质", "chosen": "{\"category\": \"球衣\", \"attributes\": {\"颜色\": \"红色与白色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』『小香风原单』等词汇，暗示与NIKE品牌存在关联或为正品授权，但图片显示商品为阿森纳俱乐部球衣，实际为NIKE官方出品，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"球衣\", \"attributes\": {\"颜色\": \"红色与白色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"该商品存在品牌关联表述问题，整体信息不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01001.jpg", "image": "data/raw/images/product_01001.jpg", "prompt": "绿色男士短袖Polo衫，胸前印有白色数字30", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为绿色棉质Polo衫，胸前印有白色数字30，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00962.jpg", "image": "data/raw/images/product_00962.jpg", "prompt": "黑色无袖针织开衫，V领设计，前排纽扣装饰", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"无袖开衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中实物：黑色、无袖、V领、前排纽扣的针织开衫，材质与款式均与图片一致。未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"无袖开衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00838.jpg", "image": "data/raw/images/product_00838.jpg", "prompt": "浅灰色花朵装饰平底凉拖鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"浅灰\", \"材质\": \"皮革\", \"款式\": \"花朵装饰平底拖鞋\"}, \"violation\": false, \"reason\": \"图片显示为浅灰色皮革材质的平底拖鞋，鞋面有立体花朵装饰，描述准确对应商品实际外观。未使用极限词或夸大功效表述，材质与颜色均与实物一致，无虚标或傍名牌情况，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝\", \"材质\": \"帆布\", \"款式\": \"运动休闲鞋\"}, \"violation\": false, \"reason\": \"商品为深蓝色帆布材质的运动休闲鞋，鞋面无花朵装饰，与描述不符，但未发现极限词或虚假宣传，整体符合基本合规要求。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02069.jpg", "image": "data/raw/images/product_02069.jpg", "prompt": "酒红色印花棉质长袖连衣裙，V领设计配金色线绣装饰", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"长袖V领印花连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确对应图中酒红色棉质连衣裙，V领与袖口处金色线绣细节清晰可见，印花图案分布均匀。未使用极限词或虚标材质，未涉及品牌侵权表述，整体描述与实物一致，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"宝蓝色\", \"材质\": \"雪纺\", \"款式\": \"短袖圆领连衣裙\"}, \"violation\": false, \"reason\": \"商品为宝蓝色雪纺短袖圆领连衣裙，整体风格清新，符合描述，无违规用语。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01084.jpg", "image": "data/raw/images/product_01084.jpg", "prompt": "最新款超低价全网最低绝对顶级粉色ESPRIT手表，时尚闪耀必备单品", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"塑料/金属\", \"款式\": \"矩形表盘镶钻腕表\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"粉色\", \"款式\": \"矩形表盘镶钻腕表\"}, \"violation\": false, \"reason\": \"商品描述中使用‘最新款’等词汇属于常见营销表达，未涉及虚假宣传，整体内容符合规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00681.jpg", "image": "data/raw/images/product_00681.jpg", "prompt": "银色金属矩形表带腕表，蓝色纹理表盘", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属\", \"款式\": \"矩形表盘\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中银色金属表带与蓝色纹理矩形表盘的特征，未使用极限词或虚标材质，无品牌侵权表述，属性与图片一致，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属\", \"款式\": \"矩形表盘\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00072.jpg", "image": "data/raw/images/product_00072.jpg", "prompt": "黄色皮质表带方形金属表壳手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"金属表壳，皮革表带\", \"款式\": \"方形表盘\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中手表的黄色皮质表带、方形金属表壳及黑色表盘等特征，未使用极限词或夸大功效表述，品牌标识‘CARRERA’为可见商标但未宣称授权或仿制，符合真实属性披露要求，无虚标材质或侵权嫌疑。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"金属表壳，皮革表带\", \"款式\": \"方形表盘\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02168.jpg", "image": "data/raw/images/product_02168.jpg", "prompt": "这款男士皮鞋采用高科技面料，包治百病，穿7天瘦10斤，一抹白，瞬间提升气质！", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装鞋\"}, \"violation\": true, \"reason\": \"描述中包含『包治百病』『7天瘦10斤』『一抹白』等不可能的功效承诺，与图片中展示的普通男式皮鞋属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"系带正装鞋\"}, \"violation\": false, \"reason\": \"商品描述中提及的功效为常见营销表达，未明确宣称治疗功效，整体符合普通皮鞋的推广语境，无明显违规\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02342.jpg", "image": "data/raw/images/product_02342.jpg", "prompt": "蓝色印花棉质长袖连衣裙，V领设计，简约大方", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖V领连衣裙\"}, \"violation\": false, \"reason\": \"图片显示为蓝色底色配白色几何印花的棉质连衣裙，V领、七分袖设计与描述一致，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖V领连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘简约大方’属于主观夸大用语，易诱导消费者，构成虚假宣传，违反广告法相关规定。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01510.jpg", "image": "data/raw/images/product_01510.jpg", "prompt": "深蓝色男士长袖商务衬衫，纯色简约设计", "chosen": "{\"category\": \"男装-衬衫\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"长袖/翻领/单胸袋\"}, \"violation\": false, \"reason\": \"图片显示为一件深蓝色长袖衬衫，具有标准翻领、白色纽扣及左侧单胸袋，材质从纹理判断为棉混纺类常见商务面料。描述准确反映商品实际颜色、款式与材质特征，未使用‘顶级’‘纯棉’等虚标用语，未涉及功效夸大或品牌傍靠，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装-衬衫\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"长袖/翻领/单胸袋\"}, \"violation\": true, \"reason\": \"描述中‘纯色简约设计’涉嫌暗示产品无瑕疵，属于隐性功效承诺，违反广告法关于绝对化用语的规定。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01994.jpg", "image": "data/raw/images/product_01994.jpg", "prompt": "白色男士长袖工装衬衫，胸前双口袋设计，左臂有徽章图案", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"工装风\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：白色衬衫、胸前双贴袋、左臂圆形徽章，均为可见特征。材质标注为棉质符合常见工装衬衫用料，未使用‘纯棉’等需检测证明的绝对化表述，无夸大功效或品牌侵权词汇，整体描述客观真实，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"工装风\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02264.jpg", "image": "data/raw/images/product_02264.jpg", "prompt": "这款优雅的女士连衣裙采用轻盈雪纺材质，修身剪裁展现完美曲线，适合各种正式场合穿着。", "chosen": "{\"category\": \"男式衬衫\", \"attributes\": {\"颜色\": \"浅蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中的'女士连衣裙'与图片中展示的男式条纹衬衫明显不符 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"男式衬衫\", \"attributes\": {\"颜色\": \"深红\", \"材质\": \"丝绸\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": true, \"reason\": \"商品描述中提到的深红色丝绸短袖衬衫与图片中浅蓝白条纹棉质长袖正装衬衫不符，存在明显属性错误\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01768.jpg", "image": "data/raw/images/product_01768.jpg", "prompt": "灰白拼接条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰白拼接\", \"材质\": \"棉混纺\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为灰白拼接设计的男士长袖衬衫，左侧为纯灰色，右侧为黑白竖条纹，袖口及肩部有条纹装饰，与描述完全一致。未使用极限词或夸大功效表述，材质标注为常见棉混纺，无虚标或傍名牌行为，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰白拼接\", \"材质\": \"棉混纺\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01369.jpg", "image": "data/raw/images/product_01369.jpg", "prompt": "粉色蓝红格纹女士长袖衬衫，领口蕾丝装饰", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉蓝红格纹\", \"材质\": \"棉质\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中衣物的格纹配色（粉、蓝、红）、长袖设计及领口蕾丝细节，未使用极限词或虚标材质，未提及品牌关联或功效承诺，符合广告法要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉蓝红格纹\", \"材质\": \"棉质\", \"款式\": \"长袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘蕾丝装饰’属夸大修饰，实际仅为普通花边，构成虚假宣传；‘长袖’与图中卷袖状态不符，存在误导性。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00965.jpg", "image": "data/raw/images/product_00965.jpg", "prompt": "红色女士短袖Polo衫，纯色简约设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为一件红色女士短袖Polo衫，领口有纽扣，左胸有小logo，整体为纯色简约款。描述准确对应商品实际颜色、材质和款式，未使用极限词或夸大表述，未虚标材质，无品牌侵权嫌疑，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘纯色简约设计’涉嫌隐含‘唯一性’暗示，可能构成极限词违规，且未明确标注具体棉含量，存在虚标材质风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00877.jpg", "image": "data/raw/images/product_00877.jpg", "prompt": "蓝色编织表带Puma数字运动手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"编织表带\", \"款式\": \"数字显示运动款\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中蓝色编织表带、黑色方形表盘及Puma品牌标识的数字运动手表，未使用极限词或虚标材质，表带材质与图片一致为编织结构，品牌标志清晰但未夸大宣传，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"编织表带\", \"款式\": \"数字显示运动款\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00015.jpg", "image": "data/raw/images/product_00015.jpg", "prompt": "灰色细条纹男士商务西裤", "chosen": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"混纺\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为灰色细条纹西裤，材质为常见混纺面料，款式为标准直筒剪裁，描述准确反映商品实际属性。未使用极限词、未虚标材质（如宣称纯羊毛）、未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"混纺\", \"款式\": \"直筒\"}, \"violation\": true, \"reason\": \"描述中‘细条纹’可能暗示特定工艺，存在夸大产品细节风险，涉嫌误导消费者，不符合广告法对商品属性真实性的要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02024.jpg", "image": "data/raw/images/product_02024.jpg", "prompt": "酒红色男士短袖Polo衫，胸前有字母图案装饰", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为酒红色，款式为Polo衫，胸前字母图案与图中一致，未使用极限词或虚标材质，未涉及品牌侵权或夸大宣传，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01223.jpg", "image": "data/raw/images/product_01223.jpg", "prompt": "粉色公主主题儿童休闲鞋，印有卡通人物和爱心图案", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"布料\", \"款式\": \"休闲鞋\"}, \"violation\": false, \"reason\": \"商品为粉色布面儿童休闲鞋，鞋身印有卡通公主图案及'Princess'字样，与描述中‘粉色公主主题儿童休闲鞋’完全一致。未使用极限词或夸大宣传，未虚标材质，未涉及侵权品牌名称，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"布料\", \"款式\": \"休闲鞋\"}, \"violation\": true, \"reason\": \"商品描述中‘公主主题’属于主观夸大宣传，实际图案仅为普通卡通形象，涉嫌虚假宣传，违反广告法相关规定。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00942.jpg", "image": "data/raw/images/product_00942.jpg", "prompt": "黑色方形数字显示运动手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"硅胶\", \"款式\": \"数字电子表\"}, \"violation\": false, \"reason\": \"商品为黑色方形数字电子表，表带为硅胶材质，表盘显示时间为07:52，日期为周五09日，与描述完全一致。未使用极限词、未虚标材质或夸大功能，品牌标识清晰但未冒用他人商标，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"金属\", \"款式\": \"指针机械表\"}, \"violation\": false, \"reason\": \"商品为白色金属指针机械表，表盘显示时间为07:52，日期为周五09日，与描述一致。品牌标识清晰，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00052.jpg", "image": "data/raw/images/product_00052.jpg", "prompt": "黑色方形表盘Puma运动手表，配黑色皮革表带", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"运动\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：表壳为黑色方形设计，表带为黑色皮革材质并带有白色缝线，表盘上有Puma品牌标识，整体风格符合运动款特征。未使用极限词或夸大功效表述，未虚标材质，品牌标识清晰且非侵权仿冒，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"运动\"}, \"violation\": true, \"reason\": \"描述中‘运动手表’属夸大宣传，未明确说明功能属性，易误导消费者；表带缝线细节与描述不符，存在虚标嫌疑。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02025.jpg", "image": "data/raw/images/product_02025.jpg", "prompt": "浅黄色男士短袖Polo衫，白色领口与袖口拼接设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅黄\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为浅黄色，领口与袖口为白色拼接，款式为标准Polo衫，材质从织物纹理判断为棉质。描述未使用极限词、未虚标材质、未提及品牌或仿冒信息，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅黄\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘浅黄色’可能暗示特定色号，存在误导消费者风险；‘拼接设计’属于夸大宣传，实际仅为普通撞色处理，涉嫌虚假描述。\"}", "pair_strategy": "api_weaker_over_strict"}
