{"image_file": "product_02256.jpg", "image": "data/raw/images/product_02256.jpg", "prompt": "浅蓝色细条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"商务正装\"}, \"violation\": false, \"reason\": \"图片中展示的为浅蓝色底配白色细竖条纹的男士长袖衬衫，材质从光泽与纹理判断为棉质，款式为标准商务正装款，领型、袖口及纽扣均符合常规设计。描述准确反映商品真实属性，未使用极限词或虚标材质，无夸大功效或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"商务正装\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合平台基本要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02177.jpg", "image": "data/raw/images/product_02177.jpg", "prompt": "这款黑色人字拖采用100%纯棉材质，舒适透气，适合日常穿着", "chosen": "{\"category\": \"拖鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"人造革\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片显示该拖鞋为人造革材质，图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"拖鞋\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"帆布\", \"款式\": \"凉鞋\"}, \"violation\": true, \"reason\": \"商品描述称材质为帆布，图片显示为白色凉鞋，但实际为黑色人造革人字拖，属性严重不符\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00183.jpg", "image": "data/raw/images/product_00183.jpg", "prompt": "蓝白竖条纹短袖衬衫，胸前有徽章装饰", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"商品为蓝白竖条纹短袖衬衫，图中可见其颜色、条纹走向与袖口卷边设计均与描述一致，材质从织物纹理判断为棉质，未使用极限词或虚标材质，胸前徽章为品牌标识而非仿冒大牌，整体描述真实准确，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00361.jpg", "image": "data/raw/images/product_00361.jpg", "prompt": "黑色长袖印花孕妇连衣裙，正面印有月球图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"长袖印花孕妇裙\"}, \"violation\": false, \"reason\": \"商品为黑色长袖孕妇连衣裙，正面印有清晰的月球图案，描述准确反映其颜色、材质与款式特征。未使用极限词或夸大宣传，未虚标材质，无傍名牌或侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"长袖印花孕妇裙\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02076.jpg", "image": "data/raw/images/product_02076.jpg", "prompt": "蓝黑几何印花V领短袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝黑白\", \"材质\": \"棉混纺\", \"款式\": \"V领短袖印花连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中服饰的V领、短袖、蓝黑白几何图案等核心特征，材质标注为棉混纺符合常见印花连衣裙用料，未使用极限词或虚标材质，无品牌侵权表述，整体描述与图片一致且合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝黑白\", \"材质\": \"棉混纺\", \"款式\": \"V领短袖印花连衣裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00834.jpg", "image": "data/raw/images/product_00834.jpg", "prompt": "黑色皮革交叉带坡跟凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"交叉带坡跟\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮革材质的交叉带坡跟凉鞋，描述准确对应商品实际颜色、材质与款式特征，未使用极限词或虚标材质，无夸大功效或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"交叉带坡跟\"}, \"violation\": true, \"reason\": \"描述中‘皮革’一词可能暗示为真皮，但图片无法确认材质真实性，存在虚标风险，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02007.jpg", "image": "data/raw/images/product_02007.jpg", "prompt": "黑色男士短袖Polo衫，胸前有字母刺绣图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为黑色短袖Polo衫，胸前有红白相间的字母刺绣，材质从纹理判断为棉质，描述准确反映商品真实属性，未使用极限词或虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00772.jpg", "image": "data/raw/images/product_00772.jpg", "prompt": "黑色皮革手提包，配金色五金件和拼接缝线设计", "chosen": "{\"category\": \"女包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：包体为黑色，材质为皮革，款式为手提包，五金件呈金色，缝线为浅色拼接设计。未使用极限词、未虚标材质、未宣称功效或傍名牌，所有属性均与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"女包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": true, \"reason\": \"描述中‘拼接缝线设计’属于过度美化，易引导消费者误认为工艺复杂，构成虚假宣传；金色五金件未明确标注材质，涉嫌隐性夸大。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01672.jpg", "image": "data/raw/images/product_01672.jpg", "prompt": "灰紫色系带无袖针织上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰紫色\", \"材质\": \"针织\", \"款式\": \"无袖系带\"}, \"violation\": false, \"reason\": \"图片展示的为一件灰紫色无袖针织上衣，领口处有系带设计，与描述中的颜色、材质和款式完全一致。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"牛仔布\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"商品为亮黄色牛仔布短袖衬衫，领口无系带设计，与描述中灰紫色针织无袖上衣不符，但未发现夸大宣传或侵权问题，合规通过。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01291.jpg", "image": "data/raw/images/product_01291.jpg", "prompt": "亮蓝色男士短袖Polo衫，胸前有条纹徽标", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮蓝色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中亮蓝色Polo衫的款式与颜色，胸前条纹徽标清晰可见，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮蓝色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01996.jpg", "image": "data/raw/images/product_01996.jpg", "prompt": "浅蓝色条纹长袖衬衫，胸前有品牌徽标，袖口翻边设计", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为浅蓝色条纹长袖衬衫，胸前有圆形品牌标识，袖口为白色翻边设计，与描述完全一致。未使用极限词或夸大功效表述，材质标注为棉质符合常见面料认知，无虚标或傍名牌行为，整体描述真实合规。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"描述中‘条纹’未在图中清晰体现，存在细节不符；‘品牌徽标’可能构成隐性广告，涉嫌傍名牌风险，判定为违规。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00708.jpg", "image": "data/raw/images/product_00708.jpg", "prompt": "这款男士正装皮鞋采用100%纯棉材质，舒适透气，适合日常穿着", "chosen": "{\"category\": \"皮鞋\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片显示为皮革材质 — 图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"皮鞋\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": true, \"reason\": \"该商品存在信息不符情况，整体内容与实际展示不一致，违反平台相关规范\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01589.jpg", "image": "data/raw/images/product_01589.jpg", "prompt": "灰色条纹男士正装西裤", "chosen": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"混纺\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片中展示的为灰色条纹男士西裤，材质为常见混纺面料，款式为标准直筒剪裁，描述准确反映商品实际属性。未使用极限词、未虚标材质（如宣称纯羊毛）、未涉及品牌侵权或功效夸大，符合电商合规要求。\"}", "rejected": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"混纺\", \"款式\": \"直筒\"}, \"violation\": true, \"reason\": \"描述中‘条纹’可能暗示特殊工艺，存在夸大宣传嫌疑，且未明确标注条纹密度，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00215.jpg", "image": "data/raw/images/product_00215.jpg", "prompt": "黑色PUMA品牌电子运动手表，红色装饰条设计，数字显示屏显示时间与心率功能", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"塑料\", \"款式\": \"电子运动表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黑色表身、红色装饰条、PUMA品牌标识及数字屏显示时间与心率功能等特征，未使用极限词或夸大功效表述，材质为常见塑料表壳，符合实际，无虚标或傍名牌行为。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"塑料\", \"款式\": \"电子运动表\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00422.jpg", "image": "data/raw/images/product_00422.jpg", "prompt": "深蓝色钥匙图案印花男士短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为深蓝色圆领短袖T恤，正面印有白色钥匙图案，与描述完全一致。材质未虚标，无夸大功效或极限词，未涉及品牌侵权或虚假宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02222.jpg", "image": "data/raw/images/product_02222.jpg", "prompt": "棕色系带男士切尔西靴", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带短靴\"}, \"violation\": false, \"reason\": \"图片显示为一双棕色皮革材质的系带短靴，内衬为橙色，鞋底为浅棕色橡胶材质。描述中仅陈述了真实可见的颜色、材质与款式，未使用极限词或夸大功效，未虚标材质（如标注为真皮但实为合成革），也未涉及品牌傍名牌等侵权行为，符合商品信息真实合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带短靴\"}, \"violation\": true, \"reason\": \"描述中‘棕色系带男士切尔西靴’存在品类混淆，实际为短靴非切尔西靴，属虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01189.jpg", "image": "data/raw/images/product_01189.jpg", "prompt": "白色曼联队徽运动短裤", "chosen": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"涤纶\", \"款式\": \"运动短裤\"}, \"violation\": false, \"reason\": \"商品为白色运动短裤，左腿印有曼联俱乐部徽章，右腿有耐克标志，材质为常见运动面料涤纶，描述准确反映图片内容，未使用极限词或虚标材质，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"涤纶\", \"款式\": \"运动短裤\"}, \"violation\": true, \"reason\": \"描述中‘曼联队徽’可能暗示官方授权，存在虚假宣传风险，且‘运动短裤’属通用名称，易构成隐性极限词，建议修改。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02128.jpg", "image": "data/raw/images/product_02128.jpg", "prompt": "紫色底红色带PLAYBOY标志的人字拖", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"紫色、红色\", \"材质\": \"橡胶、人造革\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为紫色鞋底配红色脚趾带的人字拖，印有PLAYBOY品牌标识及兔子图案，描述准确反映图中颜色、材质与款式特征。未使用极限词或夸大功效表述，品牌标识清晰可辨且非冒用，符合真实宣传要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"紫色、红色\", \"材质\": \"橡胶、人造革\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01706.jpg", "image": "data/raw/images/product_01706.jpg", "prompt": "最新款超低价全网最低绝对顶级男士休闲衬衫，时尚百搭必备单品", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"棉质\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"使用『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 商品为普通款卡其色棉质长袖衬衫，无法证实其为最新款或全网最低价\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"棉质\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，描述内容不符合平台规范要求，需进一步核实信息真实性\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01280.jpg", "image": "data/raw/images/product_01280.jpg", "prompt": "红色格纹男士长袖衬衫，翻领设计，胸前带口袋", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉\", \"款式\": \"格纹衬衫\"}, \"violation\": false, \"reason\": \"图片展示为一件红色为主、搭配黑色与白色线条的格纹男式衬衫，材质从织物纹理判断为棉质，款式为标准翻领长袖衬衫，胸前有单口袋。描述准确反映了商品的颜色、材质和款式特征，未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品为蓝色短袖T恤，材质为聚酯纤维，与描述中的红色格纹长袖衬衫不符，但未发现违规宣传内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01102.jpg", "image": "data/raw/images/product_01102.jpg", "prompt": "白色镂空尖头平底鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"皮革\", \"款式\": \"平底鞋\"}, \"violation\": false, \"reason\": \"图片显示为白色镂空设计的尖头平底鞋，鞋面有均匀分布的圆形孔洞，材质为皮革，内里为浅米色衬里，鞋底为浅色橡胶。描述准确反映商品真实属性，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"帆布\", \"款式\": \"高跟鞋\"}, \"violation\": false, \"reason\": \"商品为黑色帆布高跟鞋，鞋面有镂空设计，整体风格符合描述，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01165.jpg", "image": "data/raw/images/product_01165.jpg", "prompt": "红色婴儿短袖T恤，印有白色英文标语", "chosen": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为红色婴儿短袖T恤，正面印有白色英文标语'YES I AM AS SMART AS I LOOK'，与描述完全一致。材质未虚标，无夸大功效或极限词，未涉及品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01450.jpg", "image": "data/raw/images/product_01450.jpg", "prompt": "原价999直降到99，限时清仓甩卖！高弹黑色运动紧身裤，舒适贴身，健身必备！", "chosen": "{\"category\": \"运动裤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"弹性面料\", \"款式\": \"紧身\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销信息，制造虚假折扣假象，而图片显示为普通黑色运动紧身裤，无任何价格依据 — 虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"运动裤\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"紧身\"}, \"violation\": false, \"reason\": \"商品描述中的促销用语为常见营销表达，未发现明显虚假宣传，图片与描述基本一致，无违规迹象\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01648.jpg", "image": "data/raw/images/product_01648.jpg", "prompt": "最新款超低价全网最低绝对顶级男士牛仔裤，时尚百搭必备单品", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"直筒\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"商品描述中‘最新款’‘超低价’等为常见营销表达，未涉及虚假宣传，整体内容符合规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01885.jpg", "image": "data/raw/images/product_01885.jpg", "prompt": "蓝色碎花短袖连衣裙，下摆拼接几何图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为蓝色底色配粉色碎花的短袖连衣裙，下摆有条纹与几何图案拼接，材质从织物纹理判断为棉质。描述未使用极限词、未虚标材质、未涉及功效承诺或品牌侵权，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
