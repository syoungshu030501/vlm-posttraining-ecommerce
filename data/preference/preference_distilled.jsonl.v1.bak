{"image_file": "product_02486.jpg", "image": "data/raw/images/product_02486.jpg", "prompt": "酒红色男士长袖商务衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为一件酒红色长袖翻领衬衫，材质从光泽和纹理判断为棉质，描述准确对应商品实际属性。未使用极限词、未夸大功能，无虚标材质或品牌傍靠行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"宝蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖圆领\"}, \"violation\": false, \"reason\": \"商品为宝蓝色短袖圆领衬衫，材质为聚酯纤维，与描述一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02531.jpg", "image": "data/raw/images/product_02531.jpg", "prompt": "红白竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件红白竖条纹长袖衬衫，颜色、款式与描述完全一致，材质从织物纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，未夸大功效或作虚假宣传。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中‘红白竖条纹’可能暗示唯一性，存在隐性极限词嫌疑，且未标注具体棉含量，涉嫌虚标材质，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01339.jpg", "image": "data/raw/images/product_01339.jpg", "prompt": "浅卡其色印花短袖T恤，正面印有牛仔人物图案及文字元素", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅卡其色\", \"材质\": \"棉质\", \"款式\": \"印花短袖T恤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为浅卡其色，材质为棉质，款式为印花短袖T恤，图案包含牛仔人物与文字元素，未使用极限词或虚标材质，未涉及品牌侵权或夸大宣传，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅卡其色\", \"材质\": \"棉质\", \"款式\": \"印花短袖T恤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02037.jpg", "image": "data/raw/images/product_02037.jpg", "prompt": "白色印花短袖T恤，正面印有浅蓝色'MAKE YOUR PATH'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为白色圆领短袖T恤，正面印有浅蓝色'MAKE YOUR PATH'文字图案，与描述完全一致。未使用极限词、未夸大功效、未虚标材质，未涉及品牌侵权或虚假宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"商品描述中'印花'一词可能暗示特殊工艺，实际为普通丝印，涉嫌虚标工艺；'MAKE YOUR PATH'文字有引导性暗示，属于极限词范畴，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01324.jpg", "image": "data/raw/images/product_01324.jpg", "prompt": "红色男士印花短袖T恤，印有摩托车手图案及文字", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为红色圆领短袖T恤，正面印有黑色摩托车手图案及英文文字，与描述完全一致。材质未虚标，无极限词或夸大宣传，未使用品牌侵权词汇，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为蓝色V领短袖T恤，正面印有黑色摩托车手图案，材质为聚酯纤维，与描述一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01320.jpg", "image": "data/raw/images/product_01320.jpg", "prompt": "浅黄色扎染印花摩托车主题短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅黄\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为浅黄色短袖T恤，印有黑色扎染云纹及摩托车骑手图案，底部为蓝绿色拼接设计，与描述完全一致。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖卫衣\"}, \"violation\": false, \"reason\": \"商品为深蓝色长袖卫衣，采用聚酯纤维材质，印有摩托车图案，与描述相符，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01604.jpg", "image": "data/raw/images/product_01604.jpg", "prompt": "浅蓝色直筒牛仔裤，经典水洗工艺，日常休闲款", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片展示为浅蓝色直筒版型牛仔裤，材质为常规棉质牛仔布，与描述完全一致。未使用极限词、未虚标材质（如‘纯棉’‘100%有机’等无依据表述），未涉及品牌侵权或功效夸大，符合商品真实属性及广告法合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00290.jpg", "image": "data/raw/images/product_00290.jpg", "prompt": "NIKE同款潮流印花T恤，小香风原单设计，LV平替时尚单品", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』『小香风原单』『LV平替』等词，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权 — 图片实际为United Colors of Benetton品牌商品，与NIKE、LV、香奈儿等品牌无关联\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"灰色\", \"款式\": \"短袖印花\"}, \"violation\": false, \"reason\": \"商品描述中提及的品牌为常见时尚营销表达，未直接使用商标标识，且图片展示内容与描述风格相符，不构成侵权\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01555.jpg", "image": "data/raw/images/product_01555.jpg", "prompt": "银色金属表带男士计时腕表，黑色旋转外圈，白色表盘配三个小表盘", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/黑色/白色\", \"材质\": \"金属\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中手表的金属表带、银色主体、黑色旋转外圈及白色表盘配三眼计时结构，未使用极限词或虚标材质，品牌标识清晰为ESPRIT，无傍名牌或夸大功效表述，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/黑色/白色\", \"材质\": \"金属\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01619.jpg", "image": "data/raw/images/product_01619.jpg", "prompt": "浅蓝色直筒牛仔裤，经典水洗工艺，日常百搭款", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为浅蓝色直筒牛仔裤，材质为典型棉质牛仔布，无明显拉伸或修身设计，符合‘直筒’描述。商品描述未使用极限词、未虚标材质（如宣称纯棉/有机棉等未经认证内容），未涉及品牌傍名或功效夸大，整体信息与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规问题，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01519.jpg", "image": "data/raw/images/product_01519.jpg", "prompt": "原价999直降到99，限时清仓甩卖男士条纹V领毛衣，经典百搭款不容错过！", "chosen": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"红黑条纹\", \"材质\": \"针织\", \"款式\": \"V领条纹\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和打折信息，与图片中真实商品属性无关，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"红黑条纹\", \"材质\": \"针织\", \"款式\": \"V领条纹\"}, \"violation\": true, \"reason\": \"该商品存在价格信息不实问题，整体不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01622.jpg", "image": "data/raw/images/product_01622.jpg", "prompt": "深蓝色直筒牛仔裤，经典五袋设计，修身剪裁", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色牛仔布材质的直筒款牛仔裤，描述中颜色、材质、款式均与实物一致，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉麻\", \"款式\": \"喇叭\"}, \"violation\": false, \"reason\": \"商品为浅蓝色棉麻材质的喇叭款牛仔裤，颜色、材质与款式均符合描述，无违规宣传内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01889.jpg", "image": "data/raw/images/product_01889.jpg", "prompt": "紫色几何图案短袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"图片中展示的连衣裙为紫色底色搭配白色几何图案，短袖设计，领口为深紫色拼接，整体款式为A字型连衣裙。描述准确反映了商品的颜色、图案和款式特征，未使用夸大或虚假宣传用语，材质标注为棉质符合常见服饰材料表述，无傍名牌或极限词，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"该商品整体展示清晰，未发现明显违规内容，符合平台基本审核标准。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01928.jpg", "image": "data/raw/images/product_01928.jpg", "prompt": "Puma沃尔沃海洋赛限量款黑色橡胶表带腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与银色\", \"材质\": \"橡胶表带，金属表壳\", \"款式\": \"运动休闲风，大数字刻度\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Puma品牌、Volvo Ocean Race主题、黑色橡胶表带及银色金属表壳的实物特征，未使用极限词或虚标材质，未涉及侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红色与金色\", \"材质\": \"皮革表带，陶瓷表壳\", \"款式\": \"商务正装风，罗马数字刻度\"}, \"violation\": false, \"reason\": \"商品描述中红色与金色配色及皮革表带与图中黑色橡胶表带不符，但未发现违规用语，整体符合广告法要求。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01958.jpg", "image": "data/raw/images/product_01958.jpg", "prompt": "男士红蓝白格纹短袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的红蓝白相间格纹短袖衬衫，颜色、款式与图片一致，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领格子衬衫\"}, \"violation\": true, \"reason\": \"描述中‘红蓝白格纹’可能暗示全色系覆盖，存在虚标颜色范围嫌疑，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00158.jpg", "image": "data/raw/images/product_00158.jpg", "prompt": "最新款超低价全网最低绝对顶级潮流高帮鞋，时尚百搭必备单品", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"皮革\", \"款式\": \"高帮\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"皮革\", \"款式\": \"高帮\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，内容不符合平台规范要求，需进一步处理\"}", "pair_strategy": "api_weaker_weak_evidence"}
