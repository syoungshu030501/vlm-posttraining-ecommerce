{"image_file": "product_00000.jpg", "image": "data/raw/images/product_00000.jpg", "prompt": "深棕色绒面革一脚蹬休闲男鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"绒面革\", \"款式\": \"一脚蹬\"}, \"violation\": false, \"reason\": \"商品描述与图片一致，明确标注为深棕色绒面革材质的一脚蹬款式男鞋，未使用极限词或夸大宣传，无虚标材质、未提及品牌关联或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"绒面革\", \"款式\": \"一脚蹬\"}, \"violation\": true, \"reason\": \"描述中‘绒面革’可能暗示真皮，但图片无法确认材质真实性，存在虚标风险，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00749.jpg", "image": "data/raw/images/product_00749.jpg", "prompt": "蓝黑白竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝、黑、白\", \"材质\": \"棉混纺\", \"款式\": \"竖条纹长袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片中男士穿着的蓝、黑、白三色竖条纹长袖衬衫，颜色与图案分布一致，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝、黑、白\", \"材质\": \"棉混纺\", \"款式\": \"竖条纹长袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘蓝黑白竖条纹’存在颜色顺序暗示主次，涉嫌引导性表述，可能构成虚假宣传，不符合广告法规范。\"}", "pair_strategy": "api_weaker_over_strict"}
