{"image_file": "product_02391.jpg", "image": "data/raw/images/product_02391.jpg", "prompt": "黑色刺绣V领长袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"V领长袖连衣裙\"}, \"violation\": false, \"reason\": \"图片显示为一件黑色长袖连衣裙，V领处有彩色刺绣装饰，材质从纹理判断为棉质，与描述完全一致。未使用极限词或虚标材质，无夸大宣传，未涉及品牌侵权，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"V领长袖连衣裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01086.jpg", "image": "data/raw/images/product_01086.jpg", "prompt": "亮绿色方形表盘镶钻女士手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"亮绿色\", \"材质\": \"塑料\", \"款式\": \"方形镶钻\"}, \"violation\": false, \"reason\": \"商品为亮绿色塑料材质的方形手表，表盘边缘镶嵌透明水钻，表带为同色块状设计，品牌标识清晰可见。描述准确反映其颜色、材质与款式特征，未使用极限词或虚标材质，未涉及功效夸大或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"亮绿色\", \"材质\": \"塑料\", \"款式\": \"方形镶钻\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01281.jpg", "image": "data/raw/images/product_01281.jpg", "prompt": "男士格纹长袖衬衫，灰黑米白拼色设计，胸前单口袋", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰、黑、米白、红条纹\", \"材质\": \"棉质混纺\", \"款式\": \"格子衬衫\"}, \"violation\": false, \"reason\": \"图片显示为男士格纹衬衫，颜色包含灰色、黑色、米白色及细红条纹，材质从纹理判断为棉质混纺，款式为经典翻领带胸袋的长袖衬衫。描述准确反映商品真实属性，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰、黑、米白、红条纹\", \"材质\": \"棉质混纺\", \"款式\": \"格子衬衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02031.jpg", "image": "data/raw/images/product_02031.jpg", "prompt": "灰色短袖立领纽扣女士上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"短袖立领纽扣\"}, \"violation\": false, \"reason\": \"图片显示为一件灰色短袖上衣，立领设计配前排纽扣，下摆有褶皱收腰细节，材质从纹理判断为棉质。描述准确反映商品真实属性，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"短袖立领纽扣\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01081.jpg", "image": "data/raw/images/product_01081.jpg", "prompt": "Carrera品牌银色金属表壳黑色碳纤维纹理表带计时码表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色与黑色\", \"材质\": \"金属与碳纤维\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中手表的品类为计时码表，表壳为银色金属材质，表带含黑色碳纤维纹理，品牌标识清晰可见。描述未使用极限词、未虚标材质或功效，未涉及傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色与黑色\", \"材质\": \"金属与碳纤维\", \"款式\": \"计时码表\"}, \"violation\": true, \"reason\": \"描述中‘碳纤维纹理’可能夸大实际材质，未明确标注为复合材料，存在虚标风险，不符合广告真实性要求。\"}", "pair_strategy": "api_weaker_over_strict"}
