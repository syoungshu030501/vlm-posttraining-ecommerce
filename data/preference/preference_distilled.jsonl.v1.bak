{"image_file": "product_02505.jpg", "image": "data/raw/images/product_02505.jpg", "prompt": "浅粉色竖条纹男士长袖衬衫", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"浅粉色\", \"材质\": \"棉质\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件浅粉色竖条纹长袖衬衫，颜色、条纹样式与描述一致，材质从织物纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，合规。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"商品为深蓝色聚酯纤维短袖衬衫，颜色与条纹清晰可见，材质光滑有光泽，符合描述，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00878.jpg", "image": "data/raw/images/product_00878.jpg", "prompt": "黄色硅胶表带黑色表盘Puma运动手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"硅胶\", \"款式\": \"运动\"}, \"violation\": false, \"reason\": \"商品描述准确对应图中黄色硅胶表带、黑色表盘及Puma品牌标识，未使用极限词或虚标材质，表盘设计与品牌元素真实呈现，符合广告法要求，无夸大功效或侵权表述。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"金属\", \"款式\": \"商务\"}, \"violation\": false, \"reason\": \"商品描述中蓝色金属表带与图中黄色硅胶材质不符，实际为运动款而非商务风格，但未发现违规用词。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
