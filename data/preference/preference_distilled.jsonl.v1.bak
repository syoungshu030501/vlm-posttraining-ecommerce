{"image_file": "product_02397.jpg", "image": "data/raw/images/product_02397.jpg", "prompt": "绿色棉质刺绣拼接长袖上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉\", \"款式\": \"长袖上衣\"}, \"violation\": false, \"reason\": \"商品描述为'绿色棉质刺绣拼接长袖上衣'，与图片中展示的绿色棉质面料、胸前条纹刺绣拼接设计及七分袖款式完全一致。未使用极限词或夸大功效表述，材质标注真实，无虚标或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉\", \"款式\": \"长袖上衣\"}, \"violation\": true, \"reason\": \"描述中'刺绣拼接'可能暗示工艺复杂度，存在夸大实际做工风险，且未明确标注为纯棉，涉嫌材质虚标，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01109.jpg", "image": "data/raw/images/product_01109.jpg", "prompt": "荧光绿底配浅绿色织物带的人字拖", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"荧光绿/浅绿\", \"材质\": \"织物+橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中荧光绿色鞋底与浅绿色织物带的搭配，材质为织物与橡胶，款式为人字拖，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"荧光绿/浅绿\", \"材质\": \"织物+橡胶\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"描述中‘荧光绿’可能暗示特殊发光效果，存在夸大宣传嫌疑，涉嫌虚假描述，不符合广告法规定。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01508.jpg", "image": "data/raw/images/product_01508.jpg", "prompt": "男士黑色长袖商务衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片中展示的为一件黑色长袖翻领衬衫，材质从光泽和纹理判断为棉混纺，描述准确反映商品真实属性。未使用极限词、未虚标材质、未宣称特殊功效，也无品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"描述中‘商务衬衫’属于隐性宣传用语，暗示高端定位，涉嫌虚假宣传，且未标注具体成分比例，存在材质虚标风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00745.jpg", "image": "data/raw/images/product_00745.jpg", "prompt": "白色Puma经典款运动鞋，配蓝色与粉色细节", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色、蓝色、粉色\", \"材质\": \"合成革\", \"款式\": \"低帮系带休闲运动鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Puma品牌运动鞋的主色调为白色，搭配蓝色侧边条纹及粉色logo与内衬，材质为常见合成革，款式为低帮系带设计。未使用极限词或虚标材质，品牌标识清晰但无仿冒或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色、蓝色、粉色\", \"材质\": \"合成革\", \"款式\": \"低帮系带休闲运动鞋\"}, \"violation\": true, \"reason\": \"描述中‘经典款’涉嫌暗示市场地位，属极限词；‘配蓝色与粉色细节’未明确比例，构成虚标。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02357.jpg", "image": "data/raw/images/product_02357.jpg", "prompt": "黑白几何图案短袖连衣裙，下摆条纹拼接设计", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"图片显示为黑白几何图案的短袖连衣裙，下摆有条纹拼接，整体为棉质面料。描述准确反映了商品的颜色、材质与款式特征，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘几何图案’可能暗示独特设计，存在夸大宣传风险，涉嫌误导消费者，不符合广告法关于真实性的要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01711.jpg", "image": "data/raw/images/product_01711.jpg", "prompt": "黑色短袖男士衬衫，简约商务休闲款", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件黑色短袖衬衫，材质为棉混纺，款式为常规翻领纽扣式，左胸有口袋，袖口有装饰条纹。描述准确反映商品真实属性，未使用极限词或虚标材质，未涉及品牌侵权或夸大宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品为深蓝色长袖衬衫，材质为聚酯纤维，符合描述内容，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00626.jpg", "image": "data/raw/images/product_00626.jpg", "prompt": "玫红色条纹女士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"玫红色\", \"材质\": \"涤纶\", \"款式\": \"条纹Polo衫\"}, \"violation\": false, \"reason\": \"商品描述为'玫红色条纹女士短袖Polo衫'，与图片中实际展示的玫红色横条纹设计、短袖Polo领款式完全一致。材质标注为涤纶，符合常见运动服饰面料特征，未虚标天然材质或使用极限词。品牌标识清晰但未夸大宣传，无仿冒或傍名牌表述，整体描述真实准确，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"玫红色\", \"材质\": \"涤纶\", \"款式\": \"条纹Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01182.jpg", "image": "data/raw/images/product_01182.jpg", "prompt": "深蓝色Nike女士七分运动裤", "chosen": "{\"category\": \"运动裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"针织面料\", \"款式\": \"七分裤\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色七分长度的Nike品牌运动裤，材质为常见针织面料，描述准确对应商品实际属性。未使用极限词或夸大宣传，未虚标材质，品牌标识清晰且无侵权表述，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"运动裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"针织面料\", \"款式\": \"七分裤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02400.jpg", "image": "data/raw/images/product_02400.jpg", "prompt": "红色印花棉质长袖女士库尔塔上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"长袖库尔塔\"}, \"violation\": false, \"reason\": \"商品描述为'红色印花棉质长袖女士库尔塔上衣'，与图片中展示的红色底色、白色几何印花图案、棉质面料及长袖库尔塔款式完全一致。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"长袖库尔塔\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02476.jpg", "image": "data/raw/images/product_02476.jpg", "prompt": "男士青绿色竖条纹长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"青绿色与白色相间\", \"材质\": \"棉质\", \"款式\": \"竖条纹长袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的青绿色与白色竖条纹长袖衬衫，颜色、图案、款式均与图片一致。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"青绿色与白色相间\", \"材质\": \"棉质\", \"款式\": \"竖条纹长袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘青绿色’可能暗示特定品牌色调，存在隐性品牌关联风险，涉嫌虚假宣传，需进一步核实。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01592.jpg", "image": "data/raw/images/product_01592.jpg", "prompt": "黑色短袖T恤，荧光绿滴墨风格印花图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色棉质圆领短袖T恤，正面印有荧光绿色滴墨风格图案，描述准确反映实际颜色、材质与款式。未使用极限词或夸大宣传，图案设计未涉及侵权品牌标识，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01175.jpg", "image": "data/raw/images/product_01175.jpg", "prompt": "银色与金色拼接矩形表盘女士腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色与金色\", \"材质\": \"金属\", \"款式\": \"矩形表盘\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中银色与金色双色金属表带、矩形表盘及罗马数字刻度的特征，未使用夸大或虚假宣传用语，品牌标识清晰为ESPRIT，无仿冒或傍名牌嫌疑，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色与金色\", \"材质\": \"金属\", \"款式\": \"矩形表盘\"}, \"violation\": true, \"reason\": \"描述中‘拼接’一词暗示多材质组合，但图中为同种金属双色处理，存在误导性，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00496.jpg", "image": "data/raw/images/product_00496.jpg", "prompt": "蓝色牛仔短裙配紫色花卉腰带", "chosen": "{\"category\": \"女装-裙子\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"牛仔布\", \"款式\": \"A字短裙\"}, \"violation\": false, \"reason\": \"商品为蓝色牛仔布材质的A字型短裙，搭配紫色花卉图案腰带，描述准确反映图片内容，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合电商合规要求。\"}", "rejected": "{\"category\": \"女装-裙子\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"牛仔布\", \"款式\": \"A字短裙\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00334.jpg", "image": "data/raw/images/product_00334.jpg", "prompt": "原价999直降到99，限时清仓甩卖PUMA条纹短袖POLO衫，正品保证，速抢！", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"红色与灰色\", \"材质\": \"棉质\", \"款式\": \"条纹POLO衫\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和打折信息，与商品真实售价无关，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"蓝色与白色\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领T恤\"}, \"violation\": true, \"reason\": \"商品描述中存在虚构原价和促销信息，且图片展示为蓝色与白色圆领T恤，材质为聚酯纤维，与实际不符，涉嫌虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02236.jpg", "image": "data/raw/images/product_02236.jpg", "prompt": "白色为主色调的FILA运动鞋，搭配绿色与黑色条纹设计，透气网面材质", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白绿黑\", \"材质\": \"网面\", \"款式\": \"系带休闲运动鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为白色主体配绿色及黑色装饰，材质为可见的透气网面，款式为系带式休闲运动鞋。未使用极限词或夸大宣传，品牌标识清晰但未作虚假授权宣称，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白绿黑\", \"材质\": \"网面\", \"款式\": \"系带休闲运动鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01092.jpg", "image": "data/raw/images/product_01092.jpg", "prompt": "深蓝色棒球帽配红色RF刺绣标志", "chosen": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"棒球帽\"}, \"violation\": false, \"reason\": \"商品为深蓝色棉质棒球帽，正面有红色RF刺绣图案，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，无傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"聚酯纤维\", \"款式\": \"渔夫帽\"}, \"violation\": false, \"reason\": \"商品为亮黄色聚酯纤维渔夫帽，正面有红色RF刺绣图案，描述中颜色、材质与款式均准确匹配图中特征，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00411.jpg", "image": "data/raw/images/product_00411.jpg", "prompt": "包治百病的男士正装皮鞋，7天瘦10斤，一抹白，穿出健康好身材", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装皮鞋\"}, \"violation\": true, \"reason\": \"描述中包含『包治百病』『7天瘦10斤』『一抹白』等不可能的功效承诺，与图片真实商品属性（黑色皮革正装皮鞋）不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装皮鞋\"}, \"violation\": true, \"reason\": \"该商品存在夸大宣传问题，描述内容与实际不符，违反相关广告规范\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00719.jpg", "image": "data/raw/images/product_00719.jpg", "prompt": "棕色皮革系带休闲男鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双棕色皮革材质的系带休闲男鞋，描述准确对应其颜色、材质与款式特征，未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": true, \"reason\": \"描述中‘皮革’一词未明确标注为‘真皮’，涉嫌虚标材质；‘休闲男鞋’表述存在性别限定倾向，可能构成隐性歧视，不符合平台中立性要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00308.jpg", "image": "data/raw/images/product_00308.jpg", "prompt": "黑色男士短袖Polo衫，胸前饰有灰红蓝三色条纹拼接", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：主体为黑色Polo衫，胸前有灰、红、蓝三色横向条纹拼接设计，材质从纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"聚酯纤维\", \"款式\": \"T恤\"}, \"violation\": false, \"reason\": \"商品为白色T恤，材质为聚酯纤维，胸前无条纹设计，描述与实物一致。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02411.jpg", "image": "data/raw/images/product_02411.jpg", "prompt": "绿色修身长裤，搭配白色上衣展示", "chosen": "{\"category\": \"裤子\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"修身长裤\"}, \"violation\": false, \"reason\": \"图片中展示的为一条绿色修身长裤，材质从视觉上看为棉质类面料，描述准确反映商品实际颜色、材质与款式，未使用极限词或夸大宣传，未涉及虚假材质标注或品牌傍靠，符合合规要求。\"}", "rejected": "{\"category\": \"裤子\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"阔腿裤\"}, \"violation\": false, \"reason\": \"商品为蓝色聚酯纤维阔腿裤，颜色与材质符合描述，款式为宽松版型，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01317.jpg", "image": "data/raw/images/product_01317.jpg", "prompt": "白色印花摩托车图案短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为白色圆领短袖T恤，正面印有摩托车图案及文字，颜色、材质与图片一致，未使用极限词或夸大宣传，未涉及虚假材质标注，未出现傍名牌或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00149.jpg", "image": "data/raw/images/product_00149.jpg", "prompt": "男士黑白黄格纹长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白、黑、黄\", \"材质\": \"棉质\", \"款式\": \"格子衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件以白色为主调，搭配黑色与黄色线条构成的格纹长袖衬衫，描述准确反映其颜色组合与款式特征。材质未作虚标，未使用极限词或夸大宣传，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红、蓝、绿\", \"材质\": \"聚酯纤维\", \"款式\": \"纯色T恤\"}, \"violation\": false, \"reason\": \"商品为红蓝绿三色拼接的聚酯纤维T恤，款式为简约纯色设计，描述符合实际，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00287.jpg", "image": "data/raw/images/product_00287.jpg", "prompt": "原价999直降到99，限时清仓甩卖儿童连帽背心，时尚运动风必备单品！", "chosen": "{\"category\": \"儿童服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"连帽无袖背心\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和折扣信息，制造虚假降价假象，但图片商品为普通儿童连帽背心，无任何价格标签或促销依据 — 虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"儿童服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"款式\": \"连帽无袖背心\"}, \"violation\": false, \"reason\": \"商品描述中的价格信息为常见促销表达，未实际标注原价，属于正常营销话术，不构成虚假宣传\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00350.jpg", "image": "data/raw/images/product_00350.jpg", "prompt": "蓝色短袖T恤，肩部褶皱设计，胸前点缀闪亮铆钉图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：蓝色短袖T恤，肩部有褶皱设计，胸前分布圆形铆钉装饰。材质未虚标，颜色与实物一致，款式描述客观，无夸大功效或使用极限词，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"描述中‘闪亮铆钉’属于夸大宣传，实际光泽度有限，易误导消费者；‘点缀’一词暗示装饰性弱，与实物密集分布不符，构成虚假描述。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00666.jpg", "image": "data/raw/images/product_00666.jpg", "prompt": "银灰色网面透气运动鞋，配绿色点缀", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"银灰/绿/黑\", \"材质\": \"网布/合成革\", \"款式\": \"低帮系带运动鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中鞋款的银灰色主调、绿色中底与黑色细节，材质标注为网布与合成革符合实际鞋面结构，未使用极限词或虚标材质，未涉及品牌侵权表述，整体描述客观真实，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝/橙/白\", \"材质\": \"皮革/帆布\", \"款式\": \"高帮休闲靴\"}, \"violation\": false, \"reason\": \"商品描述中颜色为深蓝橙白，材质为皮革帆布，款式为高帮休闲靴，与图中银灰绿黑的低帮运动鞋不符，但未涉及违规词或侵权，故不判定违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02417.jpg", "image": "data/raw/images/product_02417.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款紫色褶皱围巾优雅百搭，速抢！", "chosen": "{\"category\": \"围巾\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"褶皱长款\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销话术，制造虚假折扣假象，而图片显示为普通棉质围巾，无任何价格依据 — 虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"围巾\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"羊毛\", \"款式\": \"平纹短款\"}, \"violation\": true, \"reason\": \"商品描述中称原价999现价99，但图片为蓝色羊毛平纹短款围巾，与实际紫色棉质褶皱长款不符，存在虚假宣传和属性错配\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00486.jpg", "image": "data/raw/images/product_00486.jpg", "prompt": "米色条纹织物人字拖，棕色橡胶底", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"米色/棕色\", \"材质\": \"织物/橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示的米色条纹织物带与棕色橡胶鞋底的人字拖款式，未使用极限词或虚标材质，未提及品牌关联或夸大功效，符合真实属性披露要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"米色/棕色\", \"材质\": \"织物/橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00583.jpg", "image": "data/raw/images/product_00583.jpg", "prompt": "深蓝色水洗牛仔裤，修身直筒设计，经典五袋款", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色水洗牛仔裤，材质为典型牛仔布，款式为修身直筒剪裁，与描述完全一致。未使用极限词、未虚标材质（如宣称纯棉或含羊绒）、未暗示特殊功效，也无品牌傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉麻混纺\", \"款式\": \"宽松阔腿\"}, \"violation\": false, \"reason\": \"商品为浅灰色棉麻混纺材质，款式为宽松阔腿设计，与描述中深蓝色牛仔布修身直筒不符，但未涉及违规宣传，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02156.jpg", "image": "data/raw/images/product_02156.jpg", "prompt": "黑色皮质系带商务正装鞋", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装鞋\"}, \"violation\": false, \"reason\": \"图片展示为一双黑色皮革材质的男士系带正装鞋，鞋头有透气孔设计，内里为棕色衬里，整体风格符合商务正式场合。描述中仅陈述了真实可见的颜色、材质与款式，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权或功效承诺，完全符合商品实际属性，合规通过。\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装鞋\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01410.jpg", "image": "data/raw/images/product_01410.jpg", "prompt": "浅蓝色细条纹短袖衬衫，翻领设计，胸前单口袋", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为浅蓝色细条纹短袖衬衫，翻领设计，胸前有单口袋，袖口卷起，与描述完全一致。材质未标注具体成分但无虚标，未使用极限词或夸大功效表述，未涉及品牌侵权，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"深红色\", \"材质\": \"化纤\", \"款式\": \"长袖\"}, \"violation\": false, \"reason\": \"商品为深红色化纤长袖衬衫，胸前单口袋，翻领设计，与描述基本一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00578.jpg", "image": "data/raw/images/product_00578.jpg", "prompt": "黑色拼接皮质系带正装男鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革与织物拼接\", \"款式\": \"系带正装鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为黑色系带正装男鞋，鞋面采用皮革与织物拼接材质，具有布洛克雕花细节，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"全牛皮\", \"款式\": \"休闲板鞋\"}, \"violation\": false, \"reason\": \"商品为棕色全牛皮休闲板鞋，鞋面无拼接设计，符合描述内容，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02036.jpg", "image": "data/raw/images/product_02036.jpg", "prompt": "粉色印花短袖T恤，正面印有'24 Hours Art Music Film'图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为粉色，材质从视觉判断为棉质，款式为圆领短袖T恤，印花图案包含'24 Hours Art Music Film'字样与几何图形，未使用极限词、未虚标材质、未夸大功效，也无傍名牌或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中'24 Hours Art Music Film'可能暗示全天候文化体验，构成隐性夸大宣传，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00718.jpg", "image": "data/raw/images/product_00718.jpg", "prompt": "棕色男士皮质套脚休闲皮鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"套脚休闲\"}, \"violation\": false, \"reason\": \"图片显示为一双棕色皮革材质的男士套脚式休闲皮鞋，鞋面缝线清晰，鞋底为黑色橡胶材质，描述中颜色、材质、款式均与实物一致，未使用极限词或夸大宣传，无虚标材质或仿冒品牌标识，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"套脚休闲\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01382.jpg", "image": "data/raw/images/product_01382.jpg", "prompt": "小香风原单明星同款印花长袖T恤，高级感十足，时尚百搭", "chosen": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中使用『小香风原单』蹭大牌，暗示与CHANEL品牌相关，但图片商品为普通印花T恤，无任何品牌标识，涉嫌擅自使用他人品牌作宣传，侵犯注册商标专用权\"}", "rejected": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"浅粉色\", \"材质\": \"雪纺\", \"款式\": \"短袖连衣裙\"}, \"violation\": true, \"reason\": \"商品描述中称其为小香风原单，但实际为浅粉色雪纺短袖连衣裙，与图中深蓝色棉质长袖T恤严重不符，存在虚假宣传嫌疑\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01661.jpg", "image": "data/raw/images/product_01661.jpg", "prompt": "深蓝色修身直筒牛仔裤", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片中展示的为深蓝色牛仔布材质的直筒款牛仔裤，描述准确对应商品实际颜色、材质与版型，未使用极限词或虚标材质，无夸大宣传或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉麻\", \"款式\": \"紧身\"}, \"violation\": false, \"reason\": \"商品为浅灰色棉麻材质的紧身款牛仔裤，颜色与材质描述准确，版型符合实际，无违规宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01745.jpg", "image": "data/raw/images/product_01745.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款时尚印花T恤，潮流必备，错过不再！", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销信息，与商品真实定价无关，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖印花\"}, \"violation\": true, \"reason\": \"商品实际为黑色长袖，材质为聚酯纤维，与描述不符，存在虚假宣传嫌疑\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01976.jpg", "image": "data/raw/images/product_01976.jpg", "prompt": "红色格纹短袖衬衫男款休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"图片展示为一件红色为主、带有白色与蓝色线条的格纹短袖衬衫，材质从视觉判断为棉质，款式为标准翻领短袖设计，描述准确反映商品真实属性，未使用极限词或虚标材质，未涉及品牌侵权或夸大宣传，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合平台基本审核标准。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00007.jpg", "image": "data/raw/images/product_00007.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款灰色网面跑鞋透气舒适，运动必备。", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"网面\", \"款式\": \"跑鞋\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和打折信息，与图片真实商品属性不符 — 虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"灰色\", \"款式\": \"跑鞋\"}, \"violation\": false, \"reason\": \"商品描述中的价格信息属于常见促销表达，未实际影响商品属性，图片与描述整体一致，无明显违规\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00080.jpg", "image": "data/raw/images/product_00080.jpg", "prompt": "男士蓝色条纹Polo衫，100%纯棉材质，休闲时尚设计", "chosen": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"涤纶混纺\", \"款式\": \"短袖翻领\"}, \"violation\": true, \"reason\": \"描述中宣称『100%纯棉』，但图片所示为常见涤纶混纺面料，表面光滑且无棉质纹理，属虚假宣传 — 图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"商品描述中的材质信息与图片展示存在细节差异，但属于常见商品展示风格差异，不构成实质性虚假宣传\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00188.jpg", "image": "data/raw/images/product_00188.jpg", "prompt": "橄榄绿色印花短袖T恤，满版手绘风格图案设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"橄榄绿\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，T恤为橄榄绿色，印有手绘风格文字与图案，材质从视觉判断为棉质，款式为常规圆领短袖。描述未使用极限词、未虚标材质、未夸大功效，也无傍名牌或侵权表达，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为深蓝色V领短袖，材质为聚酯纤维，印有手绘图案，整体风格符合描述，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01178.jpg", "image": "data/raw/images/product_01178.jpg", "prompt": "紫色Nike儿童运动短袖T恤，印有'JUST DO IT'艺术字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉混纺\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为紫色儿童运动T恤，图中可见Nike品牌标识及'JUST DO IT'印花，描述准确反映颜色、品牌和款式特征，未使用极限词或虚标材质，未涉及侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色儿童运动T恤，图中可见Nike品牌标识及'JUST DO IT'印花，描述中材质为聚酯纤维，款式为V领短袖，与实际相符。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00725.jpg", "image": "data/raw/images/product_00725.jpg", "prompt": "这款小白鞋包治百病，穿7天瘦10斤，一抹白瞬间提亮肤色，时尚又健康！", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白色为主，黑色泼墨装饰\", \"材质\": \"皮革/合成材料\", \"款式\": \"低帮系带休闲鞋\"}, \"violation\": true, \"reason\": \"描述中使用『包治百病』『7天瘦10斤』『一抹白』等词，对商品功效作不可能承诺，违反广告法第二十八条 — 图片为普通运动鞋，无任何医疗或美容功能\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑色为主，红色泼墨装饰\", \"材质\": \"棉质布料\", \"款式\": \"高帮帆布鞋\"}, \"violation\": true, \"reason\": \"商品描述夸大功效，且属性标注错误，如颜色应为黑红配色、材质为棉布、款式为高帮，与实际不符，涉嫌误导消费者\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00383.jpg", "image": "data/raw/images/product_00383.jpg", "prompt": "黑色方形表盘男士机械腕表，配鳄鱼纹皮质表带", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"方形机械表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黑色方形表盘、鳄鱼纹皮质表带及机械表结构，未使用极限词或虚标材质，品牌标识清晰但无傍名牌嫌疑，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"方形机械表\"}, \"violation\": true, \"reason\": \"描述中‘鳄鱼纹’可能误导消费者认为为真鳄鱼皮，涉嫌虚假宣传，且‘机械腕表’未明确标注是否自动上链，存在信息不完整风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00602.jpg", "image": "data/raw/images/product_00602.jpg", "prompt": "白色底粉色叶纹无袖连衣裙，腰间配粉色束带", "chosen": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"白色与粉色\", \"材质\": \"棉质\", \"款式\": \"无袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：白色底布配粉色植物图案，无袖设计，腰部有粉色束带，裙摆为A字型。材质标注为棉质，符合常见儿童服装用料，未使用夸大或虚假宣传词汇，未涉及品牌侵权或功效承诺，整体描述真实合规。\"}", "rejected": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"白色与粉色\", \"材质\": \"棉质\", \"款式\": \"无袖A字裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
