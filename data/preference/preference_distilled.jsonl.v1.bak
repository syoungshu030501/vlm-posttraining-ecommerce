{"image_file": "product_00597.jpg", "image": "data/raw/images/product_00597.jpg", "prompt": "灰色Nike男士休闲运动裤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质混纺\", \"款式\": \"休闲运动裤\"}, \"violation\": false, \"reason\": \"图片显示为灰色棉质混纺材质的Nike品牌男士休闲运动裤，描述准确对应商品实际颜色、材质与款式，未使用极限词或夸大宣传，品牌标识清晰且未作虚假承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质混纺\", \"款式\": \"休闲运动裤\"}, \"violation\": true, \"reason\": \"描述中‘棉质混纺’可能暗示纯棉，存在材质误导嫌疑，且‘休闲运动裤’表述过于宽泛，涉嫌夸大适用场景，不符合广告法合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01573.jpg", "image": "data/raw/images/product_01573.jpg", "prompt": "米白色修身束脚睡裤", "chosen": "{\"category\": \"睡衣/家居服\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"棉质\", \"款式\": \"修身束脚\"}, \"violation\": false, \"reason\": \"图片显示为米白色棉质修身束脚睡裤，描述准确反映商品实际颜色、材质与款式，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"睡衣/家居服\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"棉质\", \"款式\": \"修身束脚\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01306.jpg", "image": "data/raw/images/product_01306.jpg", "prompt": "这款蓝色T恤采用100%纯棉材质，舒适透气，适合日常穿着，图案为美国国旗与鹰的印花设计。", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉混纺\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中宣称‘100%纯棉’，但图片所示材质为棉混纺，非纯棉 — 图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"蓝色\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述中‘100%纯棉’为常见宣传用语，图片材质与描述存在细节差异，属正常展示偏差，不构成虚假宣传\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01216.jpg", "image": "data/raw/images/product_01216.jpg", "prompt": "蓝色底红色带米奇头图案儿童人字拖", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"蓝色、红色、黄色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为蓝色底面配红色脚趾带的儿童人字拖，鞋面上印有米奇等卡通图案及名字，脚趾带处有黄色米奇头装饰，整体设计符合图片展示。描述准确反映颜色、材质与款式，未使用极限词或虚标材质，未涉及侵权表述，属合规商品。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"蓝色、红色、黄色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"商品描述中‘米奇头图案’可能暗示品牌授权，存在隐性侵权风险，且‘儿童人字拖’表述未明确年龄范围，涉嫌虚标适用人群，属违规。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00649.jpg", "image": "data/raw/images/product_00649.jpg", "prompt": "这款PUMA黑色T恤，包治百病，7天瘦10斤，一抹白，穿上瞬间年轻十岁！", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能的功效承诺，与图片展示的普通T恤属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，内容不符合平台规范要求，具体问题需进一步核实\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01094.jpg", "image": "data/raw/images/product_01094.jpg", "prompt": "ESPRIT品牌条纹彩色透明表壳手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"紫色、粉色、蓝色、黑色、白色条纹\", \"材质\": \"透明塑料表壳，彩色树脂表带\", \"款式\": \"矩形表盘，条纹设计\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中ESPRIT品牌标识、矩形表盘及多色条纹表带与表盘设计，材质为透明塑料与彩色树脂，未使用极限词或虚标材质，未涉及功效夸大或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"紫色、粉色、蓝色、黑色、白色条纹\", \"材质\": \"透明塑料表壳，彩色树脂表带\", \"款式\": \"矩形表盘，条纹设计\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00692.jpg", "image": "data/raw/images/product_00692.jpg", "prompt": "白色网面透气运动跑鞋，配黑色与银色装饰线条", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色、黑色、银色\", \"材质\": \"网面\", \"款式\": \"运动跑鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为白黑银三色搭配，材质为网面结构，款式为典型运动跑鞋设计。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色、黑色、银色\", \"材质\": \"网面\", \"款式\": \"运动跑鞋\"}, \"violation\": true, \"reason\": \"描述中‘透气’属于功能性夸大，未提供检测依据，涉嫌虚假宣传；‘网面’表述可能误导消费者对实际材质认知，存在虚标风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00620.jpg", "image": "data/raw/images/product_00620.jpg", "prompt": "黑色闪电纹图案Nike Dri-FIT半拉链运动上衣", "chosen": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"Dri-FIT面料\", \"款式\": \"半拉链长袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为黑色，表面有闪电状暗纹设计，材质标注为Dri-FIT符合品牌标识，款式为半拉链长袖运动上衣。未使用极限词、未虚标材质、未夸大功能，且未涉及傍名牌或侵权表述，整体描述真实合规。\"}", "rejected": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述中颜色为白色，材质为棉质，款式为圆领短袖，与图片内容一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01113.jpg", "image": "data/raw/images/product_01113.jpg", "prompt": "深棕色绒面革一脚蹬男鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"绒面革\", \"款式\": \"一脚蹬\"}, \"violation\": false, \"reason\": \"图片显示为一双深棕色绒面革材质的一脚蹬男鞋，鞋面纹理与描述一致，鞋底为橡胶材质但未在描述中虚标，整体描述客观真实，未使用极限词或夸大功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"绒面革\", \"款式\": \"一脚蹬\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00389.jpg", "image": "data/raw/images/product_00389.jpg", "prompt": "紫色拼接灰色连帽运动外套", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色与灰色拼接\", \"材质\": \"尼龙\", \"款式\": \"连帽拉链夹克\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为紫色与灰色拼接的连帽拉链夹克，材质为尼龙，符合实际视觉特征。未使用极限词或夸大宣传，品牌标识清晰但未作虚假授权宣称，整体描述客观真实，无虚标、傍名牌或违规用语，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色与灰色拼接\", \"材质\": \"尼龙\", \"款式\": \"连帽拉链夹克\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01602.jpg", "image": "data/raw/images/product_01602.jpg", "prompt": "黑色修身版型男士牛仔裤", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片中展示的为一条黑色牛仔裤，材质为典型牛仔布，版型为修身直筒，与描述完全一致。未使用极限词或夸大宣传，未虚标材质（如宣称纯棉或有机棉），未涉及品牌侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": true, \"reason\": \"描述中‘修身版型’属于隐性极限词，易引导消费者产生过度期待，且图片未展示实际穿着效果，存在误导风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01192.jpg", "image": "data/raw/images/product_01192.jpg", "prompt": "白色印花短袖T恤，正面印有彩色涂鸦风格'BE TRUE'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为白色棉质圆领短袖T恤，正面印有彩色涂鸦风格的'BE TRUE'图案，描述准确反映图中可见的品类、颜色、材质与款式特征。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色聚酯纤维V领短袖T恤，正面印有彩色涂鸦风格的'BE TRUE'图案，描述与实物一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01125.jpg", "image": "data/raw/images/product_01125.jpg", "prompt": "黑色配荧光绿 Nike 低帮运动鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色、荧光绿、白色、灰色\", \"材质\": \"皮革\", \"款式\": \"低帮系带\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，鞋身主体为黑色，搭配荧光绿 Swoosh 标志与鞋带，鞋底为白色与灰色拼接，材质为皮革，款式为低帮系带设计。描述未使用极限词或夸大功效，未虚标材质，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红色、蓝色、黄色\", \"材质\": \"帆布\", \"款式\": \"高帮\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红蓝黄，材质为帆布，款式为高帮，与图片实际的黑绿配色、皮革材质及低帮设计不符，但未发现违规用语。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01059.jpg", "image": "data/raw/images/product_01059.jpg", "prompt": "白色PUMA男士短袖T恤，绿色领口袖口拼接设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色/绿色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为白色主体配绿色领口袖口的PUMA品牌T恤，图片中可见清晰的品牌标识与实际颜色、款式一致。描述准确反映商品真实属性，未使用极限词或虚标材质，未涉及傍名牌或夸大宣传，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色/绿色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01533.jpg", "image": "data/raw/images/product_01533.jpg", "prompt": "方形表盘棕色皮带男士腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"方形\"}, \"violation\": false, \"reason\": \"商品描述为'方形表盘棕色皮带男士腕表'，与图片中可见的方形金属表壳、棕色鳄鱼纹皮革表带及整体设计完全一致。未使用极限词或夸大功效表述，未虚标材质（表带确为皮革纹理），未涉及品牌侵权用语，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"金属\", \"款式\": \"圆形\"}, \"violation\": false, \"reason\": \"商品描述中提及的黑色金属圆形表盘与图中所示的棕色皮带方形表盘一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01265.jpg", "image": "data/raw/images/product_01265.jpg", "prompt": "蓝白格纹短袖衬衫男款休闲格子衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白红相间格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领带口袋\"}, \"violation\": false, \"reason\": \"图片显示为一件蓝白红相间的格纹短袖衬衫，具有翻领和胸前两个带盖口袋，材质从纹理判断为棉质。描述准确反映了商品的颜色、款式与材质，未使用极限词或虚标信息，未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白红相间格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领带口袋\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01103.jpg", "image": "data/raw/images/product_01103.jpg", "prompt": "浅灰色皮质露趾平底鞋，饰有蝴蝶结与珠饰", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"皮革\", \"款式\": \"露趾平底鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为浅灰色，材质为皮革，款式为露趾平底鞋，装饰细节如蝴蝶结与珠饰亦真实呈现。未使用极限词、未夸大功效，未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"帆布\", \"款式\": \"高跟鞋\"}, \"violation\": false, \"reason\": \"商品为深蓝色帆布高跟鞋，颜色与材质符合描述，款式为高跟设计，整体信息真实无夸大。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01728.jpg", "image": "data/raw/images/product_01728.jpg", "prompt": "白色短袖Polo衫，领口与袖口饰红色包边，左胸有小徽标", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中白色Polo衫的款式特征，领口及袖口红色包边、左胸徽标等细节均与图片一致，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘白色’可能暗示纯色无瑕疵，存在隐性承诺，涉嫌虚假宣传，需进一步核实。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02021.jpg", "image": "data/raw/images/product_02021.jpg", "prompt": "男士条纹Polo衫，包治百病，穿一次瘦10斤，一抹白全身亮，时尚又健康", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"深蓝、红、白\", \"材质\": \"棉质\", \"款式\": \"长袖条纹Polo衫\"}, \"violation\": true, \"reason\": \"描述中使用『包治百病』『穿一次瘦10斤』『一抹白』等词语，对服装商品作不可能的健康与瘦身功效承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"浅灰、黄、黑\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖T恤\"}, \"violation\": true, \"reason\": \"商品描述中存在虚假功效宣传，且实际为浅灰色系聚酯纤维短袖T恤，与申报不符\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00789.jpg", "image": "data/raw/images/product_00789.jpg", "prompt": "酒红色皮革手提包，配亮红色球形装饰", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中酒红色皮革材质的手提包，手柄处亮红色球形装饰亦被如实呈现。未使用极限词、未虚标材质（如‘真皮’未标注为‘头层牛皮’等无法验证信息），未涉及品牌仿冒或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"帆布\", \"款式\": \"斜挎包\"}, \"violation\": false, \"reason\": \"商品描述中颜色为亮黄色，材质为帆布，款式为斜挎包，与图中酒红色皮革手提包不符，但未涉及违规词或虚假宣传，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01400.jpg", "image": "data/raw/images/product_01400.jpg", "prompt": "黑白格纹短袖衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑白格纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件黑白细格纹短袖衬衫，描述准确对应其颜色、款式与穿着形态，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑白格纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘黑白格纹’可能暗示唯一性，存在隐性极限词嫌疑，且未明确标注具体成分比例，涉嫌虚标材质，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01492.jpg", "image": "data/raw/images/product_01492.jpg", "prompt": "深蓝色竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"竖条纹长袖衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件深蓝色底色配白色细竖条纹的男士长袖衬衫，材质从视觉判断为棉混纺类常见商务面料，描述准确反映商品真实属性。未使用‘顶级’‘纯棉’等虚标材质用语，未涉及功效夸大或品牌傍款，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"竖条纹长袖衬衫\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合平台基本审核要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01993.jpg", "image": "data/raw/images/product_01993.jpg", "prompt": "男士浅绿紫格纹短袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅绿与紫色格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领衬衫\"}, \"violation\": false, \"reason\": \"图片显示为男士穿着浅绿色与紫色相间的格纹短袖衬衫，具有翻领和前排纽扣设计，符合描述中的颜色、材质（棉质）及款式特征。描述未使用极限词或夸大功效，未虚标材质，未涉及品牌侵权，整体信息真实准确，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝与红色格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖翻领衬衫\"}, \"violation\": false, \"reason\": \"商品为深蓝色与红色格纹长袖衬衫，材质为聚酯纤维，符合描述中颜色、材质及款式特征，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00328.jpg", "image": "data/raw/images/product_00328.jpg", "prompt": "原价999直降到99，限时清仓甩卖！经典条纹男装POLO衫，时尚百搭不容错过。", "chosen": "{\"category\": \"男装POLO衫\", \"attributes\": {\"颜色\": \"灰蓝黄条纹\", \"材质\": \"棉质混纺\", \"款式\": \"短袖翻领条纹\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销话术，但图片商品为普通条纹POLO衫，无任何价格标签或促销信息，属于虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"男装POLO衫\", \"attributes\": {\"颜色\": \"灰蓝黄条纹\", \"材质\": \"棉质混纺\", \"款式\": \"短袖翻领条纹\"}, \"violation\": true, \"reason\": \"该商品存在价格信息不实情况，涉嫌虚假促销，不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00624.jpg", "image": "data/raw/images/product_00624.jpg", "prompt": "白色底色配黄色几何图案的男士运动Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白、黄、黑\", \"材质\": \"涤纶\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为白色主体搭配黄色与黑色几何条纹，材质为常见运动服饰用涤纶，款式为标准短袖Polo领设计。未使用极限词或夸大功效表述，未虚标材质或仿冒品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白、黄、黑\", \"材质\": \"涤纶\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘几何图案’属于模糊表述，易引导消费者误认为具备特殊科技功能，涉嫌隐性夸大宣传，不符合广告法规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02104.jpg", "image": "data/raw/images/product_02104.jpg", "prompt": "米色编织纹理高帮休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"米色\", \"材质\": \"皮革\", \"款式\": \"高帮\"}, \"violation\": false, \"reason\": \"图片显示为米色高帮鞋，鞋面具有明显编织纹理，材质为皮革，鞋底为白色橡胶。描述准确反映了商品的颜色、材质与款式，未使用极限词或虚标材质，未涉及品牌侵权或夸大功效，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"帆布\", \"款式\": \"低帮\"}, \"violation\": false, \"reason\": \"商品为黑色低帮帆布鞋，鞋面无编织纹理，材质为帆布，与描述相符，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01298.jpg", "image": "data/raw/images/product_01298.jpg", "prompt": "NIKE同款潮流印花T恤，小香风原单设计，LV平替时尚单品", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』『小香风原单』『LV平替』等词语，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，内容不符合平台规范要求，需进一步处理\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01142.jpg", "image": "data/raw/images/product_01142.jpg", "prompt": "浅蓝色牛仔短裤，卷边设计，经典五袋款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"卷边五袋短裤\"}, \"violation\": false, \"reason\": \"商品为浅蓝色牛仔布材质的卷边短裤，图片显示其具有标准五袋结构与金属纽扣，描述准确反映实际款式、颜色与材质，未使用极限词或虚标成分，无仿冒品牌标识，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"卷边五袋短裤\"}, \"violation\": true, \"reason\": \"描述中‘经典五袋款’涉嫌暗示唯一性，构成隐性极限词；卷边设计未明确标注是否可拆卸，存在误导性宣传风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01397.jpg", "image": "data/raw/images/product_01397.jpg", "prompt": "紫白黑格纹短袖衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫白黑格纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖翻领衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的紫白黑三色格纹短袖衬衫，颜色、款式与图片一致；材质标注为棉混纺符合常见此类衬衫实际成分，未虚标纯棉或特殊纤维；未使用极限词或功效承诺，无品牌侵权表述，整体描述客观合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫白黑格纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖翻领衬衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01164.jpg", "image": "data/raw/images/product_01164.jpg", "prompt": "绿色儿童短袖T恤，印有'Centre of Attention'艺术字样", "chosen": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为绿色儿童短袖T恤，正面印有彩色拼贴风格的'Centre of Attention'字样，与描述完全一致。材质标签显示为棉质，未虚标或夸大成分；无极限词、功效宣称或品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连帽衫\"}, \"violation\": false, \"reason\": \"商品为蓝色儿童长袖连帽衫，采用聚酯纤维材质，印有'Centre of Attention'字样，与描述相符，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00435.jpg", "image": "data/raw/images/product_00435.jpg", "prompt": "这款白色运动鞋采用100%纯棉材质，舒适透气，适合日常穿着和运动使用。", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白红灰\", \"材质\": \"合成材料\", \"款式\": \"低帮运动鞋\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片显示鞋面为网眼与合成革拼接，非纯棉材质 — 图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑黄蓝\", \"材质\": \"皮革\", \"款式\": \"高帮运动鞋\"}, \"violation\": true, \"reason\": \"商品描述称100%纯棉，但图片显示为黑黄蓝配色的皮革高帮鞋，与描述材质和外观严重不符，属虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00546.jpg", "image": "data/raw/images/product_00546.jpg", "prompt": "深棕色皮革男士乐福鞋，简约商务休闲款", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"图片显示为深棕色皮革材质的男士乐福鞋，鞋面缝线、内里颜色及品牌标识均与描述一致，未使用极限词或虚标材质，未涉及功效夸大或傍名牌表述，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"帆布\", \"款式\": \"运动鞋\"}, \"violation\": false, \"reason\": \"商品为浅灰色帆布材质的运动鞋，鞋面无皮革纹理，符合描述中的款式与材质特征，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01056.jpg", "image": "data/raw/images/product_01056.jpg", "prompt": "这款时尚连衣裙采用轻盈雪纺材质，适合夏季穿着，展现优雅气质。", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白色、深蓝色、荧光绿\", \"材质\": \"网布、合成革、橡胶\", \"款式\": \"低帮运动鞋\"}, \"violation\": true, \"reason\": \"描述中的'连衣裙'与图片展示的运动鞋明显不符，误导消费者 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白色、深蓝色、荧光绿\", \"款式\": \"低帮运动鞋\"}, \"violation\": false, \"reason\": \"商品图片为运动鞋，描述中提及连衣裙可能为笔误或展示细节差异，整体未构成明显误导\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00362.jpg", "image": "data/raw/images/product_00362.jpg", "prompt": "黑白条纹V领短袖针织衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑、银灰\", \"材质\": \"针织\", \"款式\": \"V领、短袖、条纹拼接\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中上衣的黑白条纹拼接设计、V领与短袖款式，材质为针织类面料，未使用夸大或虚假宣传用语，无极限词、功效承诺或品牌傍靠，符合真实商品属性展示要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑、银灰\", \"材质\": \"针织\", \"款式\": \"V领、短袖、条纹拼接\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00301.jpg", "image": "data/raw/images/product_00301.jpg", "prompt": "这款黑色运动T恤，包治百病，7天瘦10斤，一抹白，穿出健康好身材！", "chosen": "{\"category\": \"运动T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能实现的功效承诺，与图片中展示的普通运动T恤属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"运动T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"该商品存在夸大宣传问题，整体描述不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00014.jpg", "image": "data/raw/images/product_00014.jpg", "prompt": "这款优雅的红色真丝连衣裙采用修身剪裁，适合各种正式场合穿着，展现女性魅力。", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"黑色和绿色\", \"材质\": \"皮革\", \"款式\": \"双肩手提包\"}, \"violation\": true, \"reason\": \"商品描述中的'红色真丝连衣裙'与图片中展示的黑色和绿色皮革手提包明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"黑色和绿色\", \"款式\": \"双肩手提包\"}, \"violation\": false, \"reason\": \"商品描述为连衣裙，但主图展示的是手提包，可能为不同商品系列的搭配展示，属于正常商品细节差异，不构成误导\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01652.jpg", "image": "data/raw/images/product_01652.jpg", "prompt": "深蓝色直筒牛仔裤，经典水洗工艺，裤脚翻边设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色牛仔布材质的直筒款牛仔裤，裤脚有翻边处理，与描述中‘深蓝色直筒牛仔裤，经典水洗工艺，裤脚翻边设计’完全一致。未使用极限词、未虚标材质（如宣称纯棉或含羊毛等）、未提及品牌关联或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉麻\", \"款式\": \"紧身\"}, \"violation\": false, \"reason\": \"商品为浅灰色棉麻材质的紧身裤，与描述中深蓝色牛仔裤不符，但未发现违规用语，不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
