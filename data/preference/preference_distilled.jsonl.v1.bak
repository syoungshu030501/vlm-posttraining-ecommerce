{"image_file": "product_01336.jpg", "image": "data/raw/images/product_01336.jpg", "prompt": "灰色V领印花男士短袖T恤，印有抽象图案及SEATTLE 1947字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"V领印花短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中灰色V领短袖T恤的款式与印花内容，图案为抽象几何设计并标注SEATTLE 1947，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"V领印花短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01536.jpg", "image": "data/raw/images/product_01536.jpg", "prompt": "银色金属表壳黑色皮带机械腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/黑色\", \"材质\": \"金属/皮革\", \"款式\": \"机械表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中银色金属表壳、黑色皮质表带及机械结构特征，未使用极限词或虚标材质，未涉及品牌侵权表述，符合真实属性与合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"金色/红色\", \"材质\": \"塑料/布料\", \"款式\": \"石英表\"}, \"violation\": false, \"reason\": \"商品描述中颜色为金色与红色，材质为塑料和布料，款式为石英表，与图中银色金属及机械结构不符，但未发现违规词或侵权信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02421.jpg", "image": "data/raw/images/product_02421.jpg", "prompt": "粉红灰黑格纹短袖衬衫", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"粉红、灰、黑、白\", \"材质\": \"棉混纺\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的短袖格子衬衫，颜色为粉红、灰、黑与白色交织的格纹，材质从视觉判断为常见棉混纺面料，款式为标准翻领短袖设计。描述未使用极限词或夸大功效，未虚标材质，未涉及品牌侵权，符合电商合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"粉红、灰、黑、白\", \"材质\": \"棉混纺\", \"款式\": \"短袖格子衬衫\"}, \"violation\": true, \"reason\": \"描述中‘粉红灰黑格纹’可能暗示特定配色比例，存在虚标风险，且‘棉混纺’未明确成分占比，涉嫌模糊宣传，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00031.jpg", "image": "data/raw/images/product_00031.jpg", "prompt": "这款牛仔连衣裙采用100%纯棉材质，舒适透气，适合夏季穿着，展现清新自然风格。", "chosen": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"牛仔布\", \"款式\": \"吊带荷叶边\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片所示为牛仔布材质，与实际材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"雪纺\", \"款式\": \"长袖收腰\"}, \"violation\": true, \"reason\": \"商品描述称材质为雪纺，但图片显示为牛仔布，且颜色为红色而非蓝色，款式也非长袖收腰，存在明显属性错误\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00850.jpg", "image": "data/raw/images/product_00850.jpg", "prompt": "黑色皮革男士套脚休闲皮鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"套脚休闲皮鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色皮革材质的男士套脚休闲皮鞋，描述准确对应其颜色、材质与款式特征，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"套脚休闲皮鞋\"}, \"violation\": true, \"reason\": \"描述中‘皮革’一词可能暗示为真皮，但图片无法确认是否为全皮材质，存在虚标材质风险，属违规宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00256.jpg", "image": "data/raw/images/product_00256.jpg", "prompt": "原价999直降到99，限时清仓甩卖！闪亮银色人字拖，夏日必备时尚单品。", "chosen": "{\"category\": \"拖鞋\", \"attributes\": {\"颜色\": \"紫色底+银色带\", \"材质\": \"人造革+闪粉\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和折扣信息，但图片商品为普通款人字拖，无任何证据支持原价999，属于虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"拖鞋\", \"attributes\": {\"颜色\": \"紫色底+银色带\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品描述中的价格信息为常见促销表达，未发现明显虚假宣传，图片与描述基本一致，无违规迹象\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00102.jpg", "image": "data/raw/images/product_00102.jpg", "prompt": "黄色儿童短袖T恤，印有'50% Mummy 50% Daddy 100% Me'字样", "chosen": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为黄色儿童短袖T恤，正面印有'50% Mummy 50% Daddy 100% Me'文字图案，与描述完全一致。材质从标签及织物纹理判断为棉质，未使用极限词或虚假宣传，无仿冒品牌标识，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖卫衣\"}, \"violation\": false, \"reason\": \"商品为蓝色儿童长袖卫衣，材质为聚酯纤维，印有文字图案，与描述基本一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02136.jpg", "image": "data/raw/images/product_02136.jpg", "prompt": "黑色皮革切尔西短靴，简约方头设计，低跟舒适", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"切尔西靴\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮革材质的切尔西短靴，描述中颜色、材质、款式均与实物一致，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合商品真实属性及广告法合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"切尔西靴\"}, \"violation\": true, \"reason\": \"描述中‘简约方头设计’涉嫌使用‘简约’等模糊宣传词，易诱导消费者产生品质误判，属于夸大宣传行为。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00868.jpg", "image": "data/raw/images/product_00868.jpg", "prompt": "蓝色硅胶表带镶钻女士石英手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"硅胶\", \"款式\": \"镶钻\"}, \"violation\": false, \"reason\": \"商品为ESPRIT品牌蓝色硅胶表带手表，表圈镶嵌蓝白双色仿水晶，表盘为银色放射纹设计，搭配罗马数字刻度。描述准确反映其颜色、材质与款式特征，未使用极限词或虚标材质，未涉及虚假功效宣传，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"硅胶\", \"款式\": \"镶钻\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01418.jpg", "image": "data/raw/images/product_01418.jpg", "prompt": "男士紫色长袖商务衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为一件紫色长袖翻领衬衫，材质为棉混纺，与描述完全一致。未使用极限词或夸大功效表述，未虚标材质，未涉及品牌侵权，符合商品真实属性，属于合规商品。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖\"}, \"violation\": false, \"reason\": \"商品为蓝色短袖聚酯纤维衬衫，与描述一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00750.jpg", "image": "data/raw/images/product_00750.jpg", "prompt": "蓝黑白竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝/黑/白\", \"材质\": \"棉混纺\", \"款式\": \"竖条纹长袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中蓝、黑、白三色竖条纹设计，材质为常见棉混纺面料，未标注虚假成分；款式为标准长袖衬衫，无夸张宣传或极限词，未涉及品牌侵权或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝/黑/白\", \"材质\": \"棉混纺\", \"款式\": \"竖条纹长袖衬衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00192.jpg", "image": "data/raw/images/product_00192.jpg", "prompt": "原价999直降到99，限时清仓甩卖男士潮流牛仔裤，时尚百搭必备款", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销信息，制造虚假折扣假象，而图片显示为普通牛仔裤，无任何价格依据支撑该标价 — 虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"商品描述中的促销用语为常见营销表达，图片展示清晰，无明显虚假信息，整体符合正常商品推广规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00487.jpg", "image": "data/raw/images/product_00487.jpg", "prompt": "白色红灰拼色Reebok运动鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白/红/灰\", \"材质\": \"网布与合成革\", \"款式\": \"低帮系带运动鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Reebok品牌运动鞋的白、红、灰三色拼接设计，材质为可见的网布与合成革，款式为低帮系带结构。未使用极限词或虚标材质，品牌标识清晰但无仿冒暗示，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑/黄/蓝\", \"材质\": \"皮革与橡胶\", \"款式\": \"高帮靴子\"}, \"violation\": false, \"reason\": \"商品描述中颜色为黑黄蓝拼色，材质为皮革与橡胶，款式为高帮靴子，与图中Reebok运动鞋特征不符，但未发现违规用语。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00981.jpg", "image": "data/raw/images/product_00981.jpg", "prompt": "深绿白蓝格纹短袖衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深绿、白、蓝\", \"材质\": \"棉混纺\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的深绿色为主调、搭配白色与蓝色线条的格纹短袖衬衫，材质为常见棉混纺面料，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色、黄、黑\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红黄黑，材质为聚酯纤维，款式为长袖，与图中深绿白蓝格纹短袖不符，但未发现违规用语，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02182.jpg", "image": "data/raw/images/product_02182.jpg", "prompt": "黑色皮革男士凉鞋，舒适透气设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"凉鞋\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮革材质的男士凉鞋，描述中颜色、材质与款式均与实物一致，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"凉鞋\"}, \"violation\": true, \"reason\": \"描述中‘舒适透气’属于夸大宣传，未提供检测依据，涉嫌虚假承诺，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00930.jpg", "image": "data/raw/images/product_00930.jpg", "prompt": "PUMA品牌蓝白拼色电子手表，表盘饰有水钻，时尚运动风", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色与白色拼接\", \"材质\": \"塑料表带，金属边框\", \"款式\": \"电子表，运动风格\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中PUMA品牌电子手表的蓝白拼色、塑料表带及金属边框材质，表盘装饰水钻和运动款设计均属实。未使用极限词或虚标材质，未涉及侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红色与黑色拼接\", \"材质\": \"皮革表带，陶瓷边框\", \"款式\": \"机械表，商务风格\"}, \"violation\": false, \"reason\": \"商品为红黑拼色机械表，采用皮革表带与陶瓷边框，属商务风格设计，描述符合实际，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01579.jpg", "image": "data/raw/images/product_01579.jpg", "prompt": "黑色短袖T恤，正面印有粉色复古徽章图案，含罗马数字与品牌字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为黑色棉质圆领短袖T恤，正面印有粉色徽章图案，包含'MCMXLVIII'、'RUMA 48'等文字元素，描述准确反映图中可见的品类、颜色、材质及款式特征。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02191.jpg", "image": "data/raw/images/product_02191.jpg", "prompt": "银色与蓝色拼接的Skechers运动鞋，网面透气设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"银色、蓝色、白色\", \"材质\": \"网布、合成革\", \"款式\": \"运动休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中鞋款的银色主体、蓝色点缀及白色鞋带等视觉特征，材质标注为网布与合成革符合实际结构，未使用极限词或虚标功能，品牌标识清晰但未冒用他人商标，整体描述真实合规。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色、红色、黄色\", \"材质\": \"皮革、帆布\", \"款式\": \"正装皮鞋\"}, \"violation\": false, \"reason\": \"商品描述中颜色为黑红黄，材质标注皮革与帆布，款式为正装皮鞋，与图中运动休闲鞋特征不符，但未发现违规用语。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00774.jpg", "image": "data/raw/images/product_00774.jpg", "prompt": "紫色绗缝纹理手提包，配编织肩带", "chosen": "{\"category\": \"包包\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"人造革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"图片显示为紫色绗缝纹理的手提包，肩带为编织设计，整体材质为常见的人造革，描述准确反映商品真实属性。未使用极限词、未虚标材质（如‘真皮’）、未提及品牌或仿品信息，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"包包\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉布\", \"款式\": \"斜挎包\"}, \"violation\": false, \"reason\": \"商品为红色棉布材质的斜挎包，肩带为编织设计，整体外观符合描述，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00065.jpg", "image": "data/raw/images/product_00065.jpg", "prompt": "浅金色纹理皮革手提包", "chosen": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"浅金色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"图片显示为一款浅金色、表面有纹理的皮革手提包，描述准确对应其颜色、材质与款式，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"浅金色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": true, \"reason\": \"描述中‘纹理皮革’可能暗示特殊工艺，存在虚标材质风险，涉嫌夸大产品属性，不符合真实宣传要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01999.jpg", "image": "data/raw/images/product_01999.jpg", "prompt": "绿色格纹男士长袖衬衫，胸前有刺绣徽标", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"格纹衬衫\"}, \"violation\": false, \"reason\": \"图片显示为绿色格纹设计的男士衬衫，胸前有清晰刺绣徽标，袖口卷起，整体为常规商务休闲款式。描述中仅陈述了真实可见的颜色、图案和款式特征，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"格纹衬衫\"}, \"violation\": true, \"reason\": \"描述中‘绿色格纹’可能暗示唯一性，存在隐性极限词嫌疑；‘刺绣徽标’未说明是否为品牌标识，涉嫌虚标，需进一步核实。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01497.jpg", "image": "data/raw/images/product_01497.jpg", "prompt": "浅灰色斜纹商务领带", "chosen": "{\"category\": \"领带\", \"attributes\": {\"颜色\": \"浅灰\", \"材质\": \"涤纶\", \"款式\": \"斜纹\"}, \"violation\": false, \"reason\": \"商品为浅灰色斜纹领带，图片显示其颜色、纹理与描述一致，材质未虚标，未使用极限词或夸大功效，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"领带\", \"attributes\": {\"颜色\": \"深蓝\", \"材质\": \"羊毛\", \"款式\": \"纯色\"}, \"violation\": false, \"reason\": \"商品为深蓝色纯色羊毛领带，图片显示颜色与描述一致，材质未虚标，无违规词，符合合规要求。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01828.jpg", "image": "data/raw/images/product_01828.jpg", "prompt": "紫红色系佩斯利印花无袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫红色系\", \"材质\": \"印花面料\", \"款式\": \"无袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为紫红色调的佩斯利印花，材质为印花面料，款式为无袖A字型连衣裙，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫红色系\", \"材质\": \"印花面料\", \"款式\": \"无袖A字裙\"}, \"violation\": true, \"reason\": \"描述中‘佩斯利印花’可能暗示特定设计版权，存在潜在侵权风险，且‘紫红色系’表述模糊，涉嫌颜色虚标，不符合平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00407.jpg", "image": "data/raw/images/product_00407.jpg", "prompt": "白色网面透气跑鞋，蓝色波浪纹鞋底，轻便运动设计", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白/蓝/灰\", \"材质\": \"网布/橡胶\", \"款式\": \"系带跑鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中鞋款的白色网面主体、蓝色波浪形橡胶大底及灰色拼接细节，未使用极限词或虚标材质，品牌标识清晰可辨，无仿冒或夸大宣传，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑/红/黄\", \"材质\": \"皮革/塑料\", \"款式\": \"高帮篮球鞋\"}, \"violation\": false, \"reason\": \"商品描述中颜色为黑红黄，材质为皮革塑料，款式为高帮篮球鞋，与图中白蓝灰网面跑鞋不符，但未发现夸大宣传或违规用语。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00916.jpg", "image": "data/raw/images/product_00916.jpg", "prompt": "蓝色格纹男士长袖衬衫，翻领设计，袖口可卷边", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉混纺\", \"款式\": \"格纹翻领长袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中蓝黑相间格纹衬衫的款式与颜色，袖口卷边细节与内衬灰色拼接均与实物一致。未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉混纺\", \"款式\": \"格纹翻领长袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00416.jpg", "image": "data/raw/images/product_00416.jpg", "prompt": "绿色格纹短袖衬衫男款休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件绿色与白色、蓝色相间的格纹短袖衬衫，材质从视觉判断为棉质，款式为常规翻领短袖衬衣，描述中颜色、材质、款式均与实物一致，未使用极限词或虚标材质，无傍名牌或夸大功效表述，符合商品真实属性。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00643.jpg", "image": "data/raw/images/product_00643.jpg", "prompt": "PUMA Motorsport系列白色印花短袖T恤，蓝黑赛车图案设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中白色T恤的PUMA Motorsport品牌标识、蓝黑色赛车元素印花及圆领短袖款式，材质标注为常见棉质符合常规认知，未使用极限词或虚标材质，未涉及侵权表述，整体描述与图片一致且合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02304.jpg", "image": "data/raw/images/product_02304.jpg", "prompt": "白色印花男士短袖T恤，印有骑摩托车人物图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为白色棉质圆领短袖T恤，正面印有骑摩托车人物图案，描述准确反映图片内容，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权或虚假功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"商品描述中‘骑摩托车人物图案’可能暗示运动或速度属性，存在夸大宣传嫌疑，涉嫌误导消费者，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02536.jpg", "image": "data/raw/images/product_02536.jpg", "prompt": "深蓝色男士长袖商务衬衫，经典翻领设计，简约百搭", "chosen": "{\"category\": \"男装-衬衫\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片中展示的为一件深蓝色长袖衬衫，具有标准翻领与前襟纽扣设计，符合描述中的颜色、款式与品类。材质未作夸大表述，仅标注为棉混纺，属常见面料描述范畴，无虚标或极限词。整体描述客观真实，未涉及品牌侵权或功效承诺，符合电商合规要求。\"}", "rejected": "{\"category\": \"男装-衬衫\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"描述中‘简约百搭’属于主观夸大宣传，易引导消费者产生不实预期，构成虚假宣传风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01732.jpg", "image": "data/raw/images/product_01732.jpg", "prompt": "酒红色无袖荷叶边装饰背心", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"无袖荷叶边\"}, \"violation\": false, \"reason\": \"商品描述准确对应图中酒红色无袖背心，正面有明显荷叶边装饰，材质从视觉判断为棉质类面料，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"墨绿色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖圆领\"}, \"violation\": false, \"reason\": \"商品为墨绿色长袖圆领上衣，材质为聚酯纤维，符合描述，无违规词或虚假宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01802.jpg", "image": "data/raw/images/product_01802.jpg", "prompt": "棕色皮革串珠T字带凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"T字带\"}, \"violation\": false, \"reason\": \"商品描述为'棕色皮革串珠T字带凉鞋'，与图片中可见的棕色皮革材质、T字带结构及串珠装饰完全一致。未使用极限词或夸大功效表述，未虚标材质，未涉及品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"T字带\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00544.jpg", "image": "data/raw/images/product_00544.jpg", "prompt": "铜色金属质感编织带坡跟凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"铜色\", \"材质\": \"皮革\", \"款式\": \"编织带坡跟\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为铜色金属光泽，材质为皮革，款式为编织带设计搭配坡跟结构，未使用极限词或虚标材质，无夸大功效或傍名牌表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"铜色\", \"材质\": \"皮革\", \"款式\": \"编织带坡跟\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02048.jpg", "image": "data/raw/images/product_02048.jpg", "prompt": "灰色长袖T恤，彩虹条纹印花，Urban Riders字样设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"长袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为灰色长袖T恤，正面印有彩虹条纹及'Urban Riders'字样，图案与实物一致。描述未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"长袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中'彩虹条纹印花'可能暗示特殊功效，存在夸大宣传风险；'Urban Riders'字样疑似品牌关联，涉嫌侵权。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01600.jpg", "image": "data/raw/images/product_01600.jpg", "prompt": "绿色印花圆领短袖T恤，胸前印有山景图案与'Celebrate'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为绿色，款式为圆领短袖，印花图案清晰可见，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为蓝色V领短袖，材质为聚酯纤维，印花内容清晰，未发现违规词或侵权问题，符合平台规范。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00312.jpg", "image": "data/raw/images/product_00312.jpg", "prompt": "PUMA品牌黑紫配色镶钻时尚腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与紫色\", \"材质\": \"皮革表带，金属表壳，仿水晶装饰\", \"款式\": \"镶钻时尚运动风\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中PUMA品牌腕表的黑色皮革表带、紫色表盘及镶钻表圈等特征，未使用极限词或虚标材质，未涉及虚假功效宣传，品牌标识清晰且无侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与紫色\", \"材质\": \"皮革表带，金属表壳，仿水晶装饰\", \"款式\": \"镶钻时尚运动风\"}, \"violation\": true, \"reason\": \"描述中‘镶钻’涉嫌夸大宣传，实际为仿水晶装饰，属于虚假材质宣称，不符合商品真实属性。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01823.jpg", "image": "data/raw/images/product_01823.jpg", "prompt": "LV平替潮男针织衫，小香风原单设计，高端质感不输大牌", "chosen": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"灰、深蓝、墨绿\", \"材质\": \"针织\", \"款式\": \"几何拼色圆领长袖\"}, \"violation\": true, \"reason\": \"描述中使用『LV平替』『小香风原单』等词，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权 — 图片商品为普通几何拼色针织衫，无任何品牌标识，与LV或香奈儿品牌无关联\"}", "rejected": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"灰、深蓝、墨绿\", \"款式\": \"几何拼色圆领长袖\"}, \"violation\": false, \"reason\": \"商品描述中‘LV平替’为常见营销表达，未直接使用品牌标识，且图片展示为普通针织衫，无明显侵权特征\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00077.jpg", "image": "data/raw/images/product_00077.jpg", "prompt": "这款时尚连衣裙采用轻盈面料，适合日常穿搭，展现优雅气质。", "chosen": "{\"category\": \"鞋子\", \"attributes\": {\"颜色\": \"白色、蓝色、粉色\", \"材质\": \"合成革\", \"款式\": \"低帮运动鞋\"}, \"violation\": true, \"reason\": \"商品描述中的'连衣裙'与图片展示的'运动鞋'明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"鞋子\", \"attributes\": {\"颜色\": \"白色、蓝色、粉色\", \"材质\": \"合成革\", \"款式\": \"低帮运动鞋\"}, \"violation\": true, \"reason\": \"该商品存在内容不符问题，整体信息与实际展示不一致，影响消费者判断\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00053.jpg", "image": "data/raw/images/product_00053.jpg", "prompt": "银色金属表带三角形表盘女士手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属\", \"款式\": \"三角形表盘\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中银色金属表带、三角形表盘的女士手表，材质与颜色均与实物一致，未使用极限词或夸大功效表述，品牌标识清晰且无傍名牌嫌疑，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属\", \"款式\": \"三角形表盘\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00100.jpg", "image": "data/raw/images/product_00100.jpg", "prompt": "黑色皮质系带商务正装鞋", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色皮革材质的男士系带正装鞋，鞋面有经典布洛克雕花设计，描述准确对应商品实际属性。未使用极限词、未虚标材质（如‘真皮’未夸大为‘头层牛皮’），未涉及品牌侵权或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01821.jpg", "image": "data/raw/images/product_01821.jpg", "prompt": "黑色V领无袖丝绒上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"丝绒\", \"款式\": \"V领无袖\"}, \"violation\": false, \"reason\": \"图片中商品为黑色V领无袖上衣，表面具有丝绒材质特有的光泽与质感，描述准确对应实际商品属性。未使用极限词、未虚标材质或夸大功效，未涉及品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领\"}, \"violation\": false, \"reason\": \"商品为红色棉质短袖圆领上衣，表面无丝绒光泽，符合描述。未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00559.jpg", "image": "data/raw/images/product_00559.jpg", "prompt": "蓝色印花圆领短袖T恤，正面印有白色叶子图案和英文标语", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为蓝色棉质圆领短袖T恤，正面印有白色叶子与英文图案，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，无傍名牌或夸大宣传行为，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02145.jpg", "image": "data/raw/images/product_02145.jpg", "prompt": "棕色系带男士商务皮鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": false, \"reason\": \"图片显示为一双棕色皮革材质的男士系带正装皮鞋，描述准确对应其颜色、材质与款式特征，未使用极限词或虚标材质，无夸大宣传或傍名牌行为，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": true, \"reason\": \"描述中‘商务皮鞋’属于隐性夸大宣传，暗示适用正式场合，但图片未体现具体使用场景，存在引导性误导风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01951.jpg", "image": "data/raw/images/product_01951.jpg", "prompt": "灰色印花短袖T恤，印有人像与星星图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"印花短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中灰色棉质短袖T恤的视觉特征，包括人像与星星印花元素，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"印花短袖\"}, \"violation\": true, \"reason\": \"描述中‘印花’一词可能暗示特殊工艺，存在虚标风险，且未明确标注具体材质比例，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00131.jpg", "image": "data/raw/images/product_00131.jpg", "prompt": "黑色短袖T恤，正面印有'SEE THE WIN'彩色字母图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色圆领短袖T恤，正面印有蓝、白、红三色拼接的'SEE THE WIN'字样，与描述完全一致。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"商品描述中'彩色字母图案'属于模糊宣传，未明确颜色数量与分布，涉嫌虚假描述。且'SEE THE WIN'字样可能暗示绝对性效果，存在夸大嫌疑。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01624.jpg", "image": "data/raw/images/product_01624.jpg", "prompt": "深蓝色修身款牛仔裤，经典五袋设计", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色牛仔布材质的修身直筒牛仔裤，具备标准五袋结构，描述准确反映商品真实属性。未使用极限词、未虚标材质或夸大功效，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": true, \"reason\": \"描述中‘修身款’可能暗示显著塑形效果，涉嫌夸大宣传；‘经典五袋设计’为通用表述，但存在引导消费者误认为具备特殊功能之嫌，不符合广告合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02143.jpg", "image": "data/raw/images/product_02143.jpg", "prompt": "黑色皮革系带商务男鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带商务鞋\"}, \"violation\": false, \"reason\": \"图片展示为一双黑色皮革材质的系带商务男鞋，描述中颜色、材质、款式均与实物一致，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权或功效承诺，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"帆布\", \"款式\": \"休闲运动鞋\"}, \"violation\": false, \"reason\": \"商品为白色帆布材质的休闲运动鞋，颜色与描述一致，未发现夸大宣传或违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00630.jpg", "image": "data/raw/images/product_00630.jpg", "prompt": "绿色PUMA男士短袖T恤，蓝色领口袖口拼接设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"图片显示为绿色PUMA品牌T恤，领口与袖口有蓝色拼接，主体为纯色棉质面料，正面印有PUMA品牌标志及'PREMIUM PERFORMANCE'字样。描述准确反映商品真实属性，未使用极限词或夸大宣传，未虚标材质，品牌标识清晰且符合授权展示规范，无傍名牌或侵权嫌疑。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求，无明显违规内容。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01995.jpg", "image": "data/raw/images/product_01995.jpg", "prompt": "浅蓝色工装风男士长袖衬衫，胸前双口袋设计，袖口卷边", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"工装风\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为浅蓝色，材质从布料纹理判断为棉质，款式为工装风带双胸袋，左臂有品牌徽章但未标注具体品牌名，未使用极限词或虚标材质，无傍名牌嫌疑，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"工装风\"}, \"violation\": true, \"reason\": \"描述中‘工装风’属于风格化用语，易引导消费者产生功能联想，涉嫌虚标用途，存在误导风险。\"}", "pair_strategy": "api_weaker_over_strict"}
