{"image_file": "product_01247.jpg", "image": "data/raw/images/product_01247.jpg", "prompt": "白色网面透气运动鞋，经典N字标志设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"网面\", \"款式\": \"休闲运动鞋\"}, \"violation\": false, \"reason\": \"商品为白色网面材质的休闲运动鞋，图片中可见鞋身主体为白色，鞋舌标有'360'字样，侧面有灰色N字标志，鞋底为黑色与灰色拼接。描述准确反映其颜色、材质与款式特征，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"网面\", \"款式\": \"休闲运动鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00219.jpg", "image": "data/raw/images/product_00219.jpg", "prompt": "穿上这款黄色条纹Polo衫，包治百病，7天瘦10斤，一抹白，轻松拥有健康好身材！", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"黄色与白色条纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能实现的功效承诺，与图片所示的普通服装属性严重不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"黄色与白色条纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"该商品存在夸大宣传问题，整体描述不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01799.jpg", "image": "data/raw/images/product_01799.jpg", "prompt": "黑色编织T字带平底凉鞋，棕色皮革鞋底", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色/棕色\", \"材质\": \"皮革\", \"款式\": \"T字带平底凉鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，明确标注为黑色编织T字带与棕色皮革鞋底，材质与款式均与实物一致，未使用极限词或虚标材质，无夸大功效或傍名牌行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色/红色\", \"材质\": \"塑料\", \"款式\": \"高跟凉鞋\"}, \"violation\": false, \"reason\": \"商品描述中颜色为白色/红色，材质为塑料，款式为高跟凉鞋，与图片中黑色编织T字带平底凉鞋不符，但未发现违规用语，故不判定违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01275.jpg", "image": "data/raw/images/product_01275.jpg", "prompt": "男士灰白黑格纹短袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰白黑红相间格纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖翻领衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的短袖衬衫，格纹由灰色、白色、黑色及少量红色线条构成，材质为常见棉混纺面料，款式为标准翻领短袖衬衫。描述未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白相间格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述中颜色为蓝白格纹，材质为聚酯纤维，款式为长袖衬衫，与图中灰白黑红格纹短袖棉混纺衬衫不符，但未涉及违规词或侵权问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02425.jpg", "image": "data/raw/images/product_02425.jpg", "prompt": "蓝灰白格纹长袖衬衫男款休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝灰白\", \"材质\": \"棉混纺\", \"款式\": \"格纹长袖衬衫\"}, \"violation\": false, \"reason\": \"图片展示为蓝、灰、白三色相间的格纹长袖衬衫，材质从纹理判断为棉混纺，款式为标准男式休闲衬衫，带有两个胸前口袋。描述准确对应商品实际颜色、材质与款式，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝灰白\", \"材质\": \"棉混纺\", \"款式\": \"格纹长袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘休闲衬衣’属于模糊用语，易引导消费者误认为具备特定舒适性功能，涉嫌隐性夸大宣传，不符合广告合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02216.jpg", "image": "data/raw/images/product_02216.jpg", "prompt": "卡其色绒面革系带短靴", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"绒面革\", \"款式\": \"系带短靴\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为卡其色，材质为绒面革，款式为系带短靴，未使用极限词或虚标材质，无夸大功效或傍名牌行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"绒面革\", \"款式\": \"系带短靴\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00973.jpg", "image": "data/raw/images/product_00973.jpg", "prompt": "蓝白竖条纹长袖衬衫，双胸袋设计，袖口翻边白色", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖双胸袋\"}, \"violation\": false, \"reason\": \"图片显示为蓝白竖条纹长袖衬衫，带有两个胸前口袋及白色翻边袖口，描述准确反映商品实际外观。未使用极限词、未虚标材质（如‘纯棉’未标注则不承诺）、未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖双胸袋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00647.jpg", "image": "data/raw/images/product_00647.jpg", "prompt": "亮黄色男士短袖T恤，正面印有蓝色复古徽章图案，含数字48与品牌字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中亮黄色圆领短袖T恤的外观特征，印花内容为蓝色徽章图案含'PUMA 48'等元素，未使用极限词或虚假宣传，材质标注为棉质符合常见T恤材质，无傍名牌或夸大功效表述，整体信息真实合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中'亮黄色'与图中实际色差偏橙，存在颜色误导；'PUMA'字样可能构成品牌暗示，涉嫌傍名牌，需进一步核实。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01187.jpg", "image": "data/raw/images/product_01187.jpg", "prompt": "橙色耐克运动内衣，交叉背带设计，轻盈透气", "chosen": "{\"category\": \"运动内衣\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"合成纤维\", \"款式\": \"交叉背带\"}, \"violation\": false, \"reason\": \"商品描述准确对应图中橙色耐克运动内衣，材质为常见运动面料（合成纤维），款式为交叉背带设计，品牌标识清晰但未夸大宣传。描述未使用极限词、未虚标材质或功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"运动内衣\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"合成纤维\", \"款式\": \"交叉背带\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02054.jpg", "image": "data/raw/images/product_02054.jpg", "prompt": "黑色圆领长袖修身打底衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质混纺\", \"款式\": \"圆领长袖\"}, \"violation\": false, \"reason\": \"商品描述为'黑色圆领长袖修身打底衫'，与图片中模特穿着的黑色长袖上衣完全一致，领型为圆领，袖长为长袖，版型贴身合体。材质标注为棉质混纺，符合常见此类衣物的常规材质，未虚标或夸大成分。未使用极限词、功效承诺或品牌傍靠表述，整体描述客观真实，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质混纺\", \"款式\": \"圆领长袖\"}, \"violation\": true, \"reason\": \"描述中'修身'属于隐性承诺，暗示特定身材效果，涉嫌夸大宣传，不符合客观描述要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01318.jpg", "image": "data/raw/images/product_01318.jpg", "prompt": "深蓝色印花摩托车主题短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为深蓝色棉质圆领短袖T恤，正面印有摩托车图案及文字，描述准确反映图中颜色、材质与款式特征。未使用极限词或夸大宣传，无虚标材质、未傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"商品描述中‘深蓝色’可能暗示唯一性，存在误导消费者风险；‘印花’一词未明确说明图案来源，涉嫌隐性宣传，不符合广告法合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01550.jpg", "image": "data/raw/images/product_01550.jpg", "prompt": "黑色表盘银色表壳皮带男士手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色/银色\", \"材质\": \"皮革/金属\", \"款式\": \"商务休闲\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黑色表盘、银色金属表壳及黑色皮革表带的外观特征，品牌标识为ESPRIT，未使用极限词或虚标材质，未宣称功效或仿冒知名品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色/银色\", \"材质\": \"皮革/金属\", \"款式\": \"商务休闲\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01212.jpg", "image": "data/raw/images/product_01212.jpg", "prompt": "红色米奇主题儿童人字拖，鞋底印有米奇图案和字母", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为红色橡胶材质的人字拖，鞋面印有米奇卡通图案及字母，描述准确反映图片内容，未使用极限词或夸大宣传，未虚标材质，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00761.jpg", "image": "data/raw/images/product_00761.jpg", "prompt": "原价999直降到99，限时清仓甩卖，高端黑色真皮女包，时尚百搭手提包", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销信息，与商品真实价值不符，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述中价格信息为常见促销表达，未发现明显虚构原价行为，整体内容符合正常营销惯例\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02399.jpg", "image": "data/raw/images/product_02399.jpg", "prompt": "蓝色印花棉质女士长袖上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖印花上衣\"}, \"violation\": false, \"reason\": \"图片中展示的为一件蓝色底白色花纹的女士长袖上衣，领口和袖口有深蓝条纹装饰，整体为棉质面料，描述准确反映商品真实属性，未使用夸大或虚假宣传用语，未涉及极限词、功效承诺或品牌傍款，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"涤纶\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品为红色涤纶短袖T恤，图案为几何印花，领口与袖口有条纹装饰，描述符合实际，无虚假宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02533.jpg", "image": "data/raw/images/product_02533.jpg", "prompt": "深灰色竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"棉混纺\", \"款式\": \"商务正装\"}, \"violation\": false, \"reason\": \"图片中展示的为一件深灰色竖条纹长袖衬衫，材质从纹理判断为棉混纺，款式为标准商务正装风格。描述准确对应商品实际颜色、图案与用途，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"棉混纺\", \"款式\": \"商务正装\"}, \"violation\": true, \"reason\": \"描述中‘深灰色’可能暗示颜色统一性，存在误导消费者风险，且‘竖条纹’未明确密度，涉嫌虚标图案特征，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00961.jpg", "image": "data/raw/images/product_00961.jpg", "prompt": "粉色系花卉印花短袖上衣，圆领宽松版型", "chosen": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"粉色系\", \"材质\": \"棉混纺\", \"款式\": \"圆领短袖印花\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中实物：粉色底色搭配灰黑粉红花卉图案，短袖圆领设计，版型宽松。未使用极限词或夸大表述，材质标注为棉混纺符合常见印花T恤用料，无仿冒品牌标识或虚假宣传，整体描述与图片一致且合规。\"}", "rejected": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"粉色系\", \"材质\": \"棉混纺\", \"款式\": \"圆领短袖印花\"}, \"violation\": true, \"reason\": \"描述中‘粉色系’存在颜色范围模糊问题，可能误导消费者；‘宽松版型’属主观表述，涉嫌夸大宣传，不符合规范要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00827.jpg", "image": "data/raw/images/product_00827.jpg", "prompt": "黑色皮革材质休闲洞洞鞋，简约舒适设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"洞洞鞋\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮革材质的洞洞鞋，鞋面有三道透气孔，后跟带扣设计，整体为简约休闲风格。描述准确对应商品实际颜色、材质与款式，未使用极限词或虚标宣传，无傍名牌或夸大功效表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"洞洞鞋\"}, \"violation\": true, \"reason\": \"描述中‘简约舒适设计’属于主观夸大宣传，未提供舒适性验证依据，涉嫌虚假承诺，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00592.jpg", "image": "data/raw/images/product_00592.jpg", "prompt": "黑色耐克T90系列短袖运动T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色圆领短袖T恤，正面印有白色Nike标志与T90字样，左袖有小标识，整体设计符合运动服饰特征。描述准确反映图中颜色、品牌元素及款式，未使用极限词或虚标材质，未涉及傍名牌或夸大宣传，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02366.jpg", "image": "data/raw/images/product_02366.jpg", "prompt": "橙色棉质短袖连衣裙，胸前有米色刺绣拼接设计", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为橙色，材质为棉质，款式为短袖连衣裙，胸前有米色刺绣拼接装饰。未使用极限词、未虚标材质、未夸大功效，无傍名牌或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02201.jpg", "image": "data/raw/images/product_02201.jpg", "prompt": "棕色皮革人字拖，复古缝线设计，舒适防滑鞋底", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：鞋身呈深棕色，材质为皮革，具有明显缝线与金属铆钉装饰，为典型人字拖款式。描述未使用极限词或夸大功效，未虚标材质（如标注为真皮但实际为合成革），也未涉及品牌侵权或虚假宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"合成革\", \"款式\": \"凉鞋\"}, \"violation\": false, \"reason\": \"商品为黑色合成革凉鞋，具有一字带设计，与描述中棕色皮革人字拖不符，但未发现虚假宣传或侵权问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02106.jpg", "image": "data/raw/images/product_02106.jpg", "prompt": "米色绒面革系带休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"米色\", \"材质\": \"绒面革\", \"款式\": \"系带休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述为'米色绒面革系带休闲鞋'，与图片中鞋款的米色外观、绒面革材质及系带设计完全一致。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"米色\", \"材质\": \"绒面革\", \"款式\": \"系带休闲鞋\"}, \"violation\": true, \"reason\": \"描述中'绒面革'可能为虚假材质宣称，图片表面光泽度偏高，疑似涂层处理，存在材质虚标风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00516.jpg", "image": "data/raw/images/product_00516.jpg", "prompt": "卡其色皮革托特包，简约设计，配金属扣件", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"皮革\", \"款式\": \"托特包\"}, \"violation\": false, \"reason\": \"图片显示为卡其色皮革材质的托特包，描述中颜色、材质与款式均与实物一致，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"皮革\", \"款式\": \"托特包\"}, \"violation\": true, \"reason\": \"描述中‘简约设计’属于主观夸大用语，易诱导消费者产生过高期待，构成虚假宣传，违反平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01454.jpg", "image": "data/raw/images/product_01454.jpg", "prompt": "这款男士衬衫采用100%纯棉材质，舒适透气，适合日常穿着。", "chosen": "{\"category\": \"男式衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片所示面料具有光滑挺括的质感，明显为混纺材质，与纯棉特性不符 — 图片所示材质与描述的100%纯棉明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"男式衬衫\", \"attributes\": {\"颜色\": \"红黑格纹\", \"材质\": \"羊毛\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": true, \"reason\": \"商品描述为纯棉，但图片显示为红黑格纹羊毛短袖，与实际材质和款式严重不符，属虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00349.jpg", "image": "data/raw/images/product_00349.jpg", "prompt": "小香风原单ESPRIT手表，LV平替款，粉色镶钻时尚腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"塑料\", \"款式\": \"方形镶钻\"}, \"violation\": true, \"reason\": \"描述中使用『小香风原单』『LV平替』等词，暗示与CHANEL、LV品牌相关联，但图片显示为ESPRIT品牌手表，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"塑料\", \"款式\": \"方形镶钻\"}, \"violation\": true, \"reason\": \"该商品存在品牌关联不当问题，宣传内容可能引发混淆，不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00911.jpg", "image": "data/raw/images/product_00911.jpg", "prompt": "这款时尚连衣裙采用优雅剪裁，适合日常穿搭，展现女性魅力", "chosen": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"针织\", \"款式\": \"V领短袖\"}, \"violation\": true, \"reason\": \"描述中提及的'连衣裙'与图片展示的'毛衣'明显不符 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"长袖圆领\"}, \"violation\": true, \"reason\": \"商品描述为连衣裙，但图片显示为红色棉质长袖圆领毛衣，属性与实物严重不符，存在误导性\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01862.jpg", "image": "data/raw/images/product_01862.jpg", "prompt": "紫红色印花棉质女士长袖上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫红色\", \"材质\": \"棉质\", \"款式\": \"长袖印花上衣\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中服饰的紫红色调、棉质面料及长袖印花款式，未使用极限词或虚标材质，图案为传统佩斯利纹样，无仿冒品牌标识，符合广告法要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫红色\", \"材质\": \"棉质\", \"款式\": \"长袖印花上衣\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01295.jpg", "image": "data/raw/images/product_01295.jpg", "prompt": "酒红色男士Polo衫，胸前刺绣Wrangler品牌标识", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为酒红色，款式为短袖Polo衫，胸前有Wrangler品牌刺绣标识，材质根据常见Polo衫面料推断为棉质，未使用极限词或虚标材质，未涉及傍名牌或夸大宣传，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘酒红色’可能引发颜色偏差争议，‘棉质’未提供检测报告属虚标材质，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01899.jpg", "image": "data/raw/images/product_01899.jpg", "prompt": "浅蓝色棉质宽松七分袖上衣，领口有褶皱装饰", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"宽松七分袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为浅蓝色，材质从纹理判断为棉质，款式为宽松七分袖设计，领口有明显褶皱装饰。未使用极限词、未虚标材质、未夸大功效，也无傍名牌或侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深红色\", \"材质\": \"化纤\", \"款式\": \"紧身短袖\"}, \"violation\": false, \"reason\": \"商品为深红色化纤材质的紧身短袖，颜色与图片一致，材质和款式描述符合实际。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01032.jpg", "image": "data/raw/images/product_01032.jpg", "prompt": "白色印花短袖T恤，正面印有复古黑白人物图案及文字", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为白色棉质圆领短袖T恤，正面印有黑白人物图案及'yes the 80's'字样，描述准确反映图中可见的品类、颜色、材质与款式特征。未使用极限词、未虚标材质、未宣称功效或傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中'复古黑白人物图案'涉嫌暗示年代限定，构成虚假宣传；'yes the 80's'字样可能引发年代联想，存在误导性，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00262.jpg", "image": "data/raw/images/product_00262.jpg", "prompt": "黑色皮革交叉带平底凉拖鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"交叉带平底凉拖\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮革材质的交叉带平底凉拖，描述准确对应商品实际颜色、材质与款式，未使用极限词或虚标宣传，无仿冒品牌标识，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"合成革\", \"款式\": \"高跟凉鞋\"}, \"violation\": false, \"reason\": \"商品为白色合成革高跟凉鞋，颜色、材质与款式均符合描述，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01649.jpg", "image": "data/raw/images/product_01649.jpg", "prompt": "深蓝色修身款男士牛仔裤", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身\"}, \"violation\": false, \"reason\": \"图片中展示的为深蓝色牛仔布材质的修身款男士牛仔裤，描述准确对应商品实际颜色、材质与版型，未使用极限词或夸大宣传，未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01417.jpg", "image": "data/raw/images/product_01417.jpg", "prompt": "男士紫色长袖商务衬衫，纯色简约设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件紫色长袖衬衫，领口、纽扣及胸前口袋等细节与描述一致，材质从纹理判断为棉混纺类常见商务面料，未使用‘纯棉’‘100%’等虚标用语，也无极限词或功效夸大表述，符合商品真实属性，未涉及品牌侵权或虚假宣传。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中‘纯色简约设计’属于主观美化用语，涉嫌夸大宣传；图片背景过于干净，存在过度修图嫌疑，影响商品真实性判断。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00561.jpg", "image": "data/raw/images/product_00561.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款时尚条纹Polo衫，清爽百搭，不容错过。", "chosen": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"白色与浅灰色条纹\", \"材质\": \"涤纶\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销话术，制造虚假折扣假象，而图片显示为常规款式的运动Polo衫，无任何价格信息支撑该优惠 — 虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"黑色与深蓝色条纹\", \"材质\": \"棉麻混纺\", \"款式\": \"长袖衬衫\"}, \"violation\": true, \"reason\": \"商品描述中虚构原价999并宣称限时清仓，结合图片显示的黑色深蓝条纹棉麻长袖衬衫，明显存在虚假促销行为，涉嫌价格欺诈\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01235.jpg", "image": "data/raw/images/product_01235.jpg", "prompt": "迪士尼儿童迷彩印花魔术贴凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色与绿色迷彩\", \"材质\": \"合成材料\", \"款式\": \"魔术贴凉鞋\"}, \"violation\": false, \"reason\": \"商品为白色底配绿色迷彩图案的儿童凉鞋，带有迪士尼标识，采用魔术贴设计，描述准确反映图片中可见的品类、颜色、材质与款式。未使用极限词或夸大功效表述，未虚标材质，未涉及侵权性用语如‘原单’‘仿品’等，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色与绿色迷彩\", \"材质\": \"合成材料\", \"款式\": \"魔术贴凉鞋\"}, \"violation\": true, \"reason\": \"商品描述中‘迪士尼’标识可能构成品牌关联暗示，存在误导消费者风险，涉嫌虚假宣传，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00459.jpg", "image": "data/raw/images/product_00459.jpg", "prompt": "迷彩工装短裤，多口袋设计，适合户外休闲穿着", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"迷彩绿\", \"材质\": \"棉质混纺\", \"款式\": \"工装短裤\"}, \"violation\": false, \"reason\": \"图片显示为迷彩图案的工装短裤，颜色以绿色系为主，搭配米白与深绿斑块，符合迷彩绿描述；材质从织物纹理判断为棉质混纺，未标注虚假材质；款式为七分长度、多口袋设计，与工装短裤一致；描述中无极限词、功效承诺或品牌侵权表述，属性真实且与图一致，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"迷彩绿\", \"材质\": \"棉质混纺\", \"款式\": \"工装短裤\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01677.jpg", "image": "data/raw/images/product_01677.jpg", "prompt": "灰色卡通印花圆领短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述为'灰色卡通印花圆领短袖T恤'，与图片中模特穿着的灰色T恤、圆领设计、短袖结构及正面卡通图案完全一致。未使用极限词或夸大宣传，材质标注为棉质符合常见T恤材质认知，无虚标或傍名牌行为，整体描述真实客观，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品描述中颜色为黑色，与图中灰色T恤不符；材质标注为聚酯纤维，实际应为棉质；款式为V领，但图片显示为圆领，属性存在明显偏差。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00958.jpg", "image": "data/raw/images/product_00958.jpg", "prompt": "最新款超低价全网最低绝对顶级潮流T恤，时尚必备单品！", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖印花\"}, \"violation\": true, \"reason\": \"商品描述使用绝对化用语，且图片显示为白色长袖聚酯纤维T恤，与实际不符，存在虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00888.jpg", "image": "data/raw/images/product_00888.jpg", "prompt": "白色男士短袖Polo衫，红色包边设计，胸前有黑色B字刺绣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为白色棉质Polo衫，领口与袖口有红色包边，左胸有黑色B字刺绣，左臂有圆形徽章，下摆左侧有数字2标签。描述准确反映商品真实属性，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘红色包边设计’属于过度强调细节，涉嫌夸大宣传；‘黑色B字刺绣’可能暗示品牌关联，存在误导性风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01653.jpg", "image": "data/raw/images/product_01653.jpg", "prompt": "浅蓝色直筒牛仔裤，经典水洗工艺，裤脚翻边设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为浅蓝色直筒款牛仔裤，材质为典型棉质牛仔布，裤脚有翻边处理，与描述完全一致。未使用极限词、未虚标材质或夸大功效，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01245.jpg", "image": "data/raw/images/product_01245.jpg", "prompt": "紫白拼色连帽运动外套，荧光黄拉链设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色、白色、荧光黄\", \"材质\": \"尼龙\", \"款式\": \"连帽夹克\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：上半身为白色，下半身及袖子为紫色，拉链为荧光黄色，材质为常见尼龙面料，款式为连帽夹克。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色、白色、荧光黄\", \"材质\": \"尼龙\", \"款式\": \"连帽夹克\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00742.jpg", "image": "data/raw/images/product_00742.jpg", "prompt": "蓝色人字拖，鞋底印有红色与绿色图案", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"蓝色、红色、绿色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，明确标注为蓝色人字拖，鞋底带有红绿图案，材质为橡胶，款式为经典人字拖结构。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权或虚假功效宣称，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色、黄色、紫色\", \"材质\": \"皮革\", \"款式\": \"高跟鞋\"}, \"violation\": false, \"reason\": \"商品为白色高跟鞋，采用优质皮革制成，鞋面有黄色与紫色装饰，符合描述内容，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01285.jpg", "image": "data/raw/images/product_01285.jpg", "prompt": "绿色与灰色横条纹男士Polo衫，胸前有'W47'刺绣图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色与灰色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为绿灰相间横条纹，款式为短袖Polo领，胸前有'W47'刺绣标识，材质从织物纹理判断为棉质。描述未使用极限词、未虚标材质、未提及品牌关联或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色与灰色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中'W47'刺绣图案可能暗示品牌关联，存在误导消费者风险，涉嫌虚假宣传，不符合广告合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01271.jpg", "image": "data/raw/images/product_01271.jpg", "prompt": "黑色男士短袖衬衫，翻领设计，袖口可卷，简约商务休闲款", "chosen": "{\"category\": \"男装-衬衫\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"图片中展示的为一件黑色短袖衬衫，翻领设计，袖口卷起，符合描述中的‘简约商务休闲款’定位。颜色、款式与图示一致，未使用极限词或虚标材质，无品牌侵权表述，整体描述真实准确，符合商品合规要求。\"}", "rejected": "{\"category\": \"男装-衬衫\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"涤纶\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"商品为白色长袖衬衫，材质为涤纶，符合描述中的商务休闲风格，整体信息真实无误。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01045.jpg", "image": "data/raw/images/product_01045.jpg", "prompt": "白色印花短袖T恤，正面印有磁带图案设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"印花短袖\"}, \"violation\": false, \"reason\": \"商品为白色棉质短袖T恤，正面印有黑白磁带图案，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，无夸大功效或傍名牌行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"长袖\"}, \"violation\": false, \"reason\": \"商品为黑色涤纶长袖T恤，正面印有磁带图案，整体风格符合描述，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00086.jpg", "image": "data/raw/images/product_00086.jpg", "prompt": "深蓝色棒球帽配红色RF刺绣标志", "chosen": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"棒球帽\"}, \"violation\": false, \"reason\": \"商品为深蓝色棉质棒球帽，正面有红色RF刺绣图案，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"聚酯纤维\", \"款式\": \"渔夫帽\"}, \"violation\": false, \"reason\": \"商品为白色聚酯纤维渔夫帽，正面有红色RF刺绣图案，描述符合图中颜色、材质与款式特征，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02382.jpg", "image": "data/raw/images/product_02382.jpg", "prompt": "黑色刺绣民族风连衣裙，七分袖宽松设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"刺绣连衣裙\"}, \"violation\": false, \"reason\": \"商品描述为黑色刺绣民族风连衣裙，与图片中展示的黑色底色、橙红色几何图案刺绣、七分袖及宽松A字版型完全一致。未使用极限词或夸大功效表述，材质标注为棉质符合常见服饰材质描述规范，无傍名牌或虚假宣传内容，整体信息真实合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"丝绸\", \"款式\": \"吊带裙\"}, \"violation\": false, \"reason\": \"商品描述为白色丝绸吊带裙，与图片中展示的黑色棉质刺绣连衣裙相符，整体信息真实合规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01829.jpg", "image": "data/raw/images/product_01829.jpg", "prompt": "紫白佩斯利印花无袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫色、白色、红色\", \"材质\": \"棉混纺\", \"款式\": \"无袖V领A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的佩斯利印花图案、紫白红三色搭配及无袖V领A字版型，材质标注为棉混纺符合常见印花裙类面料，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，整体描述与图片一致且合规。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫色、白色、红色\", \"材质\": \"棉混纺\", \"款式\": \"无袖V领A字裙\"}, \"violation\": true, \"reason\": \"描述中‘佩斯利印花’可能暗示独特设计，涉嫌隐性宣传，且‘棉混纺’未明确比例，存在材质虚标风险，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01873.jpg", "image": "data/raw/images/product_01873.jpg", "prompt": "浅蓝底红花印花短袖连衣裙，配米色钩花领口", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"浅蓝底红花\", \"材质\": \"棉质印花\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的浅蓝色底、红色花卉图案、短袖A字版型及米色钩花领口特征，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合真实商品属性展示要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深紫底黄花\", \"材质\": \"聚酯纤维混纺\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为深紫底黄花，材质为聚酯纤维混纺，款式为长袖连衣裙，与图中实际浅蓝红花、棉质短袖不符，但未涉及违规词或侵权问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01505.jpg", "image": "data/raw/images/product_01505.jpg", "prompt": "深蓝色细格纹商务领带", "chosen": "{\"category\": \"领带\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"涤纶\", \"款式\": \"细格纹\"}, \"violation\": false, \"reason\": \"商品为深蓝色细格纹领带，图片中可见其颜色、图案与描述一致，材质为常见涤纶织物，未标注虚假材质或夸大功效，无极限词及品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"领带\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"羊毛\", \"款式\": \"纯色\"}, \"violation\": false, \"reason\": \"商品为浅灰色纯色领带，材质为羊毛织物，图片中可见颜色与描述一致，无虚假宣传或侵权内容，符合合规要求。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01730.jpg", "image": "data/raw/images/product_01730.jpg", "prompt": "灰色圆领短袖T恤，胸前印有'UNITED COLORS OF BENETTON'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为灰色棉质圆领短袖T恤，胸前印有品牌文字，描述准确反映图中商品的颜色、材质与款式，未使用极限词或夸大宣传，未虚标材质，未涉及傍名牌或侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"商品描述中‘UNITED COLORS OF BENETTON’为品牌标识，存在傍名牌嫌疑，且未明确标注为授权产品，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00434.jpg", "image": "data/raw/images/product_00434.jpg", "prompt": "原价999直降到99，限时清仓甩卖，超值运动鞋不容错过！", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"银色/紫色\", \"材质\": \"网布+合成革\", \"款式\": \"休闲运动款\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价与折扣信息，未提供真实价格依据，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"银色/紫色\", \"材质\": \"网布+合成革\", \"款式\": \"休闲运动款\"}, \"violation\": true, \"reason\": \"该商品存在价格违规行为，相关信息不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01855.jpg", "image": "data/raw/images/product_01855.jpg", "prompt": "浅紫色佩斯利印花V领短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"浅紫色\", \"材质\": \"棉混纺\", \"款式\": \"V领短袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的浅紫色底色、佩斯利花纹图案、V领与短袖设计，材质标注为棉混纺符合常见印花服饰用料，未使用‘最’‘第一’等极限词，无夸大功效或虚标材质行为，未涉及品牌侵权表述，整体描述真实合规。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深红色\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为深红色，材质为聚酯纤维，款式为圆领长袖，与图中浅紫色佩斯利印花V领短袖不符，但未使用极限词或虚假宣传，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01304.jpg", "image": "data/raw/images/product_01304.jpg", "prompt": "卡其色Wrangler印花男士短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为卡其色圆领短袖T恤，正面印有Wrangler品牌图案及牛仔靴元素，材质从图中可判断为常规棉质面料。描述准确反映颜色、品牌标识与款式特征，未使用极限词或虚标材质，未涉及仿冒或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖T恤\"}, \"violation\": false, \"reason\": \"商品为深蓝色V领短袖T恤，材质为聚酯纤维，正面印有Wrangler品牌图案。描述中颜色、材质与款式均与图中一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01060.jpg", "image": "data/raw/images/product_01060.jpg", "prompt": "最新款超低价全网最低绝对顶级男士Polo衫，时尚百搭必备单品", "chosen": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"商品描述中的用语属于常见营销表达，未明显违反广告法，整体内容符合平台规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01576.jpg", "image": "data/raw/images/product_01576.jpg", "prompt": "男士深棕色修身西裤，商务正装款", "chosen": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"混纺面料\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为男士深棕色西裤，材质为常见混纺面料，款式为修身直筒型，与描述完全一致。未使用极限词、未虚标材质（如‘纯棉’‘羊绒’等），未涉及品牌侵权或功效夸大，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"混纺面料\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01138.jpg", "image": "data/raw/images/product_01138.jpg", "prompt": "深蓝色牛仔短裙配紫色花卉腰带", "chosen": "{\"category\": \"女装-裙装\", \"attributes\": {\"颜色\": \"深蓝\", \"材质\": \"牛仔布\", \"款式\": \"A字短裙\"}, \"violation\": false, \"reason\": \"商品为深蓝色牛仔布材质的A字型短裙，搭配紫色花卉图案腰带，描述准确反映图中实物的颜色、材质与款式特征。未使用极限词或夸大宣传，无虚标材质、仿冒品牌等违规行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"女装-裙装\", \"attributes\": {\"颜色\": \"浅粉\", \"材质\": \"雪纺\", \"款式\": \"包臀裙\"}, \"violation\": false, \"reason\": \"商品为浅粉色雪纺材质的包臀裙，搭配紫色腰带，整体风格符合描述，无违规宣传内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02370.jpg", "image": "data/raw/images/product_02370.jpg", "prompt": "橙色几何印花棉质库尔塔连衣裙，配紫色镶边", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"棉质\", \"款式\": \"库尔塔\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中橙色底色、几何图案及紫色镶边的库尔塔款式，材质标注为棉质与常见此类服饰相符，未使用极限词或虚标材质，无品牌侵权表述，符合广告法要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"棉质\", \"款式\": \"库尔塔\"}, \"violation\": true, \"reason\": \"描述中‘几何印花’可能暗示特定设计专利，存在误导性宣传风险，且‘棉质’未明确纯度，涉嫌虚标材质成分。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00847.jpg", "image": "data/raw/images/product_00847.jpg", "prompt": "棕色系带男士正装皮鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": false, \"reason\": \"图片显示为一双棕色皮革材质的男士系带正装皮鞋，描述准确对应商品实际颜色、材质与款式，未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": true, \"reason\": \"描述中‘正装’一词暗示高端定位，可能构成隐性夸大宣传，且未明确标注皮料具体类型，存在虚标材质风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00168.jpg", "image": "data/raw/images/product_00168.jpg", "prompt": "金色闪粉人字拖平底凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"金色\", \"材质\": \"闪粉织物+人造革\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为金色闪粉装饰的人字拖，鞋面材质为带有细闪颗粒的织物，鞋底为浅棕色人造革，与描述完全一致。未使用极限词、未虚标材质（如‘真皮’‘纯手工’），未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"金色\", \"材质\": \"闪粉织物+人造革\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02358.jpg", "image": "data/raw/images/product_02358.jpg", "prompt": "白色底粉色花卉印花无袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"白色底粉色花卉\", \"材质\": \"棉质\", \"款式\": \"无袖印花连衣裙\"}, \"violation\": false, \"reason\": \"图片中展示的为一件白色底色、印有粉色花卉图案的无袖连衣裙，描述准确反映了其颜色、图案与款式特征。材质标注为棉质，符合常见印花连衣裙材质，未出现虚标或夸大用语。未使用极限词、未宣称特殊功效，也无品牌傍款嫌疑，整体描述真实合规。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑色底黄色印花\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为黑色底色配黄色印花，材质为聚酯纤维，款式为长袖连衣裙，描述与实物一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02498.jpg", "image": "data/raw/images/product_02498.jpg", "prompt": "男士粉红色细条纹长袖衬衫，白色领口与袖口设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉红色\", \"材质\": \"棉质\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件粉红色细条纹长袖衬衫，领口与袖口为白色，材质从纹理判断为棉质，描述准确反映商品实际外观与属性，未使用极限词或虚标材质，无夸大宣传或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"商品为蓝色短袖衬衫，材质为聚酯纤维，领口与袖口无白色设计，整体风格符合描述，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01290.jpg", "image": "data/raw/images/product_01290.jpg", "prompt": "深蓝色男士短袖Polo衫，胸前有条纹徽章装饰", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中深蓝色棉质Polo衫的款式与颜色，胸前条纹徽章及左袖标识均真实存在，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"涤纶\", \"款式\": \"T恤\"}, \"violation\": false, \"reason\": \"商品为浅灰色涤纶T恤，无Polo领设计，胸前徽章与左袖标识均不符合描述，但未发现违规用语或侵权内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00420.jpg", "image": "data/raw/images/product_00420.jpg", "prompt": "黑色方形表盘多功能运动手表，橡胶表带", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"橡胶\", \"款式\": \"方形多功能\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黑色方形表盘、橡胶表带及多功能设计，未使用极限词或虚标材质，品牌标识清晰但未冒用知名商标，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"橡胶\", \"款式\": \"方形多功能\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01014.jpg", "image": "data/raw/images/product_01014.jpg", "prompt": "浅灰色长袖工装衬衫，胸前双口袋设计，袖口卷边，肩部有徽章装饰", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉质\", \"款式\": \"工装风\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：浅灰色长袖衬衫，胸前双贴袋、袖口卷边及肩部徽章均与图一致。材质标注为棉质，未虚标或夸大成分；款式描述为工装风，符合实际设计风格。未使用极限词、功效承诺或品牌傍靠表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉质\", \"款式\": \"工装风\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00978.jpg", "image": "data/raw/images/product_00978.jpg", "prompt": "绿色格纹短袖衬衫男式休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件绿色与白色相间的格纹短袖衬衫，材质从纹理判断为棉质，款式为常规翻领短袖设计，描述准确反映商品实际属性。未使用极限词、未虚标材质、未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘休闲衬衣’属于模糊用语，易引导消费者误认为具备特定功能，涉嫌虚假宣传，不符合广告合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02089.jpg", "image": "data/raw/images/product_02089.jpg", "prompt": "绿色帆布低帮休闲鞋，白色鞋带与橡胶鞋底，侧面印有兔子图案", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"帆布\", \"款式\": \"低帮休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：鞋身主体为绿色帆布材质，搭配白色鞋带和米白色橡胶鞋底，侧面有兔子图案标识，款式为低帮休闲鞋。未使用极限词、未虚标材质或夸大功能，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"帆布\", \"款式\": \"低帮休闲鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02314.jpg", "image": "data/raw/images/product_02314.jpg", "prompt": "玫红色刺绣短袖连衣裙，棉质面料，简约民族风设计", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"玫红色\", \"材质\": \"棉\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中服饰的玫红色调、棉质面料及短袖连衣裙款式，领口处刺绣图案与实物一致。未使用极限词或夸大功效表述，未虚标材质，无傍名牌或侵权用语，符合电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"玫红色\", \"材质\": \"棉\", \"款式\": \"短袖连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘简约民族风’属于主观夸大，易引导消费者产生误解，涉嫌虚假宣传，不符合平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02260.jpg", "image": "data/raw/images/product_02260.jpg", "prompt": "浅蓝色竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"商务正装\"}, \"violation\": false, \"reason\": \"图片中展示的为一件浅蓝色与白色相间的竖条纹长袖衬衫，材质从视觉判断为棉质，款式为标准商务正装款。描述准确反映了商品的颜色、材质和款式特征，未使用极限词或夸大宣传，无虚标材质、傍名牌等违规行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深红黑条纹\", \"材质\": \"聚酯纤维\", \"款式\": \"休闲T恤\"}, \"violation\": false, \"reason\": \"商品为深红色与黑色相间的条纹T恤，材质为聚酯纤维，属于休闲款式，描述与实物一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01936.jpg", "image": "data/raw/images/product_01936.jpg", "prompt": "黑色表盘黄色Puma标志不锈钢计时腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色、银色、黄色\", \"材质\": \"不锈钢、皮革\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示：黑色表盘搭配黄色Puma品牌标识，表壳为银色不锈钢材质，表带为黑色皮革，具备三个小表盘的计时功能。描述未使用极限词或夸大功效，未虚标材质，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色、银色、黄色\", \"材质\": \"不锈钢、皮革\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02272.jpg", "image": "data/raw/images/product_02272.jpg", "prompt": "浅蓝色男士长袖商务衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件浅蓝色长袖衬衫，材质从纹理判断为棉质，款式为标准商务正装衬衫，描述与实物完全一致。未使用极限词、未虚标材质、未宣称功效或傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为深灰色短袖休闲款，材质为聚酯纤维，符合描述，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00375.jpg", "image": "data/raw/images/product_00375.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"紫色为主，肩部和袖子为米白色\", \"品牌\": \"Reebok\", \"赞助商\": \"Nokia\", \"款式\": \"短袖半拉链运动衫\", \"图案\": \"胸前有火焰头盔标志，左右袖上有多个徽标\"}, \"violation\": true, \"reason\": \"商品图片显示该服装为带有‘NOKIA’和‘Reebok’等品牌标识的运动队服，属于特定球队或赛事的官方装备。根据平台规则，未经授权销售带有第三方品牌标识的商品可能构成侵权。此外，描述中‘商场撤柜 专柜正品 便宜处理’暗示其为非正规渠道流出的库存商品，存在售假或未经授权分销的风险，因此违反平台合规政策。\"}", "rejected": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"紫色为主，肩部和袖子为米白色\", \"品牌\": \"Reebok\", \"赞助商\": \"Nokia\", \"款式\": \"短袖半拉链运动衫\", \"图案\": \"胸前有火焰头盔标志，左右袖上有多个徽标\"}, \"violation\": true, \"reason\": \"该商品存在品牌标识相关问题，不符合平台规范，具体原因需进一步核实。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01534.jpg", "image": "data/raw/images/product_01534.jpg", "prompt": "黑色皮带方形钢壳CARRERA男士腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"不锈钢/皮革\", \"款式\": \"方形表盘\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示的黑色鳄鱼纹皮质表带、银色不锈钢方形表壳及CARRERA品牌标识，未使用极限词或虚标材质，表盘设计与日期窗等细节均与图片一致，符合真实商品属性，无夸大宣传或侵权表述。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"不锈钢/皮革\", \"款式\": \"方形表盘\"}, \"violation\": true, \"reason\": \"描述中‘黑色皮带’涉嫌虚标材质，未明确标注鳄鱼纹为仿制，存在误导消费者风险，属虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00140.jpg", "image": "data/raw/images/product_00140.jpg", "prompt": "蓝黄格纹短袖衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝黄格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述为'蓝黄格纹短袖衬衫男款'，与图片中展示的蓝黄相间格纹、短袖设计及男式衬衫款式完全一致。材质未虚标，未使用极限词或夸大宣传，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黑条纹\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖T恤\"}, \"violation\": false, \"reason\": \"商品描述为红黑条纹长袖T恤，与图中蓝黄格纹短袖衬衫不符，但未发现违规宣传或侵权内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01731.jpg", "image": "data/raw/images/product_01731.jpg", "prompt": "最新款超低价全网最低绝对顶级男士条纹衬衫，品质保证，限时抢购！", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"浅蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"深红黑条纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖立领\"}, \"violation\": true, \"reason\": \"商品描述使用绝对化用语，且实际为深红黑条纹聚酯纤维短袖立领衬衫，与宣传不符\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00635.jpg", "image": "data/raw/images/product_00635.jpg", "prompt": "深蓝色Puma男士短袖衬衫，胸前有品牌标志", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为深蓝色，款式为短袖衬衫，左胸位置可见Puma品牌标识，材质标注为棉混纺符合常见此类服装材质，未使用极限词或夸大宣传，未虚标材质或冒用其他品牌名称，整体描述真实合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述中颜色为浅灰色，材质为聚酯纤维，款式为长袖衬衫，与图片内容一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01810.jpg", "image": "data/raw/images/product_01810.jpg", "prompt": "黑色漆皮蝴蝶结装饰中跟女鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"漆皮\", \"款式\": \"中跟蝴蝶结\"}, \"violation\": false, \"reason\": \"图片显示为黑色漆皮材质的中跟女鞋，鞋头饰有黑色蝴蝶结与银色金属片，描述准确反映商品真实属性，未使用极限词或虚标材质，无夸大功效或傍名牌表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"帆布\", \"款式\": \"平底休闲\"}, \"violation\": false, \"reason\": \"商品为白色帆布材质的平底休闲鞋，鞋面无装饰，整体风格简约，与描述相符，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01438.jpg", "image": "data/raw/images/product_01438.jpg", "prompt": "蓝绿色格纹短袖衬衫，胸前双口袋设计，袖口翻折露出浅蓝色内衬", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝绿色格纹\", \"材质\": \"棉质\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝绿色格纹短袖衬衫，带有双胸袋和浅蓝色内衬，描述准确反映商品实际外观。未使用极限词或夸大宣传，材质未虚标，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝绿色格纹\", \"材质\": \"棉质\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00816.jpg", "image": "data/raw/images/product_00816.jpg", "prompt": "黑色修身男士西裤，商务正装款式", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"混纺\", \"款式\": \"直筒修身\"}, \"violation\": false, \"reason\": \"图片显示为黑色男士西裤，面料为常见混纺材质，版型为直筒修身款，与描述完全一致。未使用极限词、未虚标材质（如‘纯棉’‘羊绒’等）、未提及品牌或仿冒信息，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"混纺\", \"款式\": \"直筒修身\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02184.jpg", "image": "data/raw/images/product_02184.jpg", "prompt": "黑色透气孔设计男士皮质乐福鞋", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"商品为黑色皮革材质的乐福鞋，鞋面有均匀透气孔设计，搭配金属扣饰，描述准确反映图片内容，未使用极限词或虚标材质，无夸大功效或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": true, \"reason\": \"描述中‘透气孔设计’易被理解为功能性夸大，涉嫌暗示具备特殊散热效果，构成虚假宣传，不符合广告法规定。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01526.jpg", "image": "data/raw/images/product_01526.jpg", "prompt": "黑色表盘不锈钢计时腕表，搭配橡胶表带", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"不锈钢\", \"款式\": \"计时腕表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：表盘为黑色，表壳为不锈钢材质，表带为黑色橡胶，具备计时功能。未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"不锈钢\", \"款式\": \"计时腕表\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01144.jpg", "image": "data/raw/images/product_01144.jpg", "prompt": "黄色儿童卡通印花短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为黄色儿童T恤，图中可见其为圆领短袖设计，正面印有卡通乐队图案及文字，描述准确反映颜色、款式与印花内容，未使用极限词或虚标材质，无傍名牌或夸大宣传行为，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00232.jpg", "image": "data/raw/images/product_00232.jpg", "prompt": "韩版潮流服饰，时尚百搭", "chosen": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"亮粉色\", \"图案\": \"卡通动物（猫、老鼠）\", \"文字\": \"They are proud to Be Born as Eddie, Kittie, Mimi\", \"品牌\": \"BeBorn\", \"款式\": \"短袖T恤，荷叶边袖口\", \"适用年龄\": \"12个月\"}, \"violation\": true, \"reason\": \"该商品为儿童服装，其正面印有英文标语'They are proud to Be Born as Eddie, Kittie, Mimi'，其中'Be Born'与品牌名'BeBorn'高度相似，可能构成品牌名称的不当使用或误导性宣传。此外，未见中文标签或符合中国儿童服装安全标准的相关标识，存在潜在合规风险。\"}", "rejected": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"亮粉色\", \"图案\": \"卡通动物（猫、老鼠）\", \"文字\": \"They are proud to Be Born as Eddie, Kittie, Mimi\", \"品牌\": \"BeBorn\", \"款式\": \"短袖T恤，荷叶边袖口\", \"适用年龄\": \"12个月\"}, \"violation\": false, \"reason\": \"商品图文一致，英文标语为常见趣味表达，未发现明显违规内容，符合一般儿童服饰宣传规范。\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01763.jpg", "image": "data/raw/images/product_01763.jpg", "prompt": "男士米白色短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件米白色短袖Polo衫，材质从纹理判断为棉质，款式为经典翻领短袖设计。描述准确反映商品实际属性，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01388.jpg", "image": "data/raw/images/product_01388.jpg", "prompt": "深蓝红白格纹系带衬衫裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝、红、白\", \"材质\": \"棉质\", \"款式\": \"格纹、系带、长袖\"}, \"violation\": false, \"reason\": \"商品为深蓝色底配红色与白色线条的格纹衬衫裙，带有腰部系带设计，袖口卷起，整体款式与描述一致。材质从视觉判断为棉质，未标注虚假材质或夸大功效，无极限词或品牌傍款表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝、红、白\", \"材质\": \"棉质\", \"款式\": \"格纹、系带、长袖\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02387.jpg", "image": "data/raw/images/product_02387.jpg", "prompt": "深蓝色长袖V领刺绣边饰连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖V领连衣裙\"}, \"violation\": false, \"reason\": \"图片展示为一件深蓝色长袖V领连衣裙，领口与袖口有彩色条纹装饰，材质从纹理判断为棉质，描述准确反映商品真实属性。未使用极限词、未虚标材质、未夸大功效，也无傍名牌或侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖V领连衣裙\"}, \"violation\": false, \"reason\": \"该商品整体展示清晰，未发现明显违规内容，符合基本审核标准。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00133.jpg", "image": "data/raw/images/product_00133.jpg", "prompt": "浅蓝色连帽无袖儿童运动背心，印有红色数字63和DIVI字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉混纺\", \"款式\": \"连帽无袖\"}, \"violation\": false, \"reason\": \"商品为浅蓝色连帽无袖背心，图中可见红色数字63及DIVI字样，描述准确反映实际图案与款式。未使用极限词、未虚标材质（如‘纯棉’未标注则不作承诺）、未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深红色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖\"}, \"violation\": false, \"reason\": \"商品为深红色长袖背心，材质为聚酯纤维，图中可见红色数字63及DIVI字样，描述与实物一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01346.jpg", "image": "data/raw/images/product_01346.jpg", "prompt": "亮粉色印花短袖T恤，正面印有黑色英文标语", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮粉色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为亮粉色圆领短袖T恤，正面印有黑色英文标语'U ARE REALLY IRRITATING PLEASE GO AWAY'，与描述完全一致。材质未虚标，无极限词、功效承诺或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮粉色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01253.jpg", "image": "data/raw/images/product_01253.jpg", "prompt": "红白格纹男士长袖衬衫，胸前双口袋设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白格纹\", \"材质\": \"棉质\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为红白相间的格纹衬衫，材质从纹理判断为棉质，款式为长袖带两个胸前口袋的休闲衬衫。描述准确反映了商品的颜色、材质和款式特征，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"化纤\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品为蓝白格纹短袖T恤，材质为化纤，符合描述内容，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
