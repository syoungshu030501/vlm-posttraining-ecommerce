{"image_file": "product_00153.jpg", "image": "data/raw/images/product_00153.jpg", "prompt": "蓝绿白格纹长袖衬衫，双胸袋设计，休闲百搭款", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝绿白格纹\", \"材质\": \"棉质\", \"款式\": \"长袖双胸袋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中蓝绿白格纹长袖衬衫的视觉特征，材质为常见棉质面料，未虚标或夸大；款式明确标注双胸袋与长袖，无极限词、功效承诺或品牌傍靠，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"红黑条纹\", \"材质\": \"化纤混纺\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红黑条纹，材质为化纤混纺，款式为短袖翻领，与图中蓝绿白格纹长袖衬衫一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01058.jpg", "image": "data/raw/images/product_01058.jpg", "prompt": "黑色PUMA品牌短袖T恤，白色领口与袖口拼接设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色PUMA品牌T恤，图中可见白色领口和袖口拼接细节，描述准确反映实际颜色、品牌标识及款式特征。未使用极限词或夸大宣传，材质标注为常见棉质符合常规认知，未虚标或冒用其他品牌，整体描述真实合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中‘PUMA品牌’可能构成品牌冒用风险，未提供授权证明；‘白色领口与袖口拼接设计’属细节夸大，实际视觉占比不足，存在误导性宣传嫌疑。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02060.jpg", "image": "data/raw/images/product_02060.jpg", "prompt": "蓝白几何印花短袖连衣裙，V领设计，拼接条纹细节", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝白\", \"材质\": \"棉混纺\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中蓝白几何图案、V领短袖连衣裙的款式特征，材质标注为棉混纺符合常见服装面料表述，未使用极限词或虚标材质，无品牌侵权用语，整体描述与图片一致且符合广告法规范。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝白\", \"材质\": \"棉混纺\", \"款式\": \"短袖连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘几何印花’属于模糊表述，易引导消费者误认为有特殊设计工艺，涉嫌夸大宣传，不符合广告法对商品真实性的要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01523.jpg", "image": "data/raw/images/product_01523.jpg", "prompt": "方形金属表壳黑色表盘男士腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/黑色\", \"材质\": \"金属\", \"款式\": \"方形\"}, \"violation\": false, \"reason\": \"商品描述为'方形金属表壳黑色表盘男士腕表'，与图片中可见的方形表壳、银色金属表带及黑色表盘完全一致，未使用极限词或夸大功效表述，未虚标材质，未涉及品牌侵权，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"金色/白色\", \"材质\": \"皮革\", \"款式\": \"圆形\"}, \"violation\": false, \"reason\": \"商品描述为方形金属表壳黑色表盘腕表，但图片显示为金色表壳、白色表盘及皮革表带的圆形款式，属性与实物不符。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02078.jpg", "image": "data/raw/images/product_02078.jpg", "prompt": "最新款超低价全网最低绝对顶级时尚连衣裙，限时抢购不容错过！", "chosen": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"棉质\", \"款式\": \"V领短袖波点\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"丝绸\", \"款式\": \"吊带长裙\"}, \"violation\": true, \"reason\": \"商品描述中使用绝对化用语，且图片显示为红色丝绸吊带长裙，与实际不符，存在虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01917.jpg", "image": "data/raw/images/product_01917.jpg", "prompt": "灰色刺绣宽松短袖上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉麻\", \"款式\": \"宽松短袖\"}, \"violation\": false, \"reason\": \"图片显示为一件灰色棉麻材质的宽松短袖上衣，胸前有白色刺绣图案，描述准确反映了商品的颜色、材质和款式特征，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"涤纶\", \"款式\": \"修身长袖\"}, \"violation\": false, \"reason\": \"商品为红色涤纶材质的修身长袖上衣，胸前有刺绣装饰，描述与实物一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00932.jpg", "image": "data/raw/images/product_00932.jpg", "prompt": "金色镶钻Puma女士时尚腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"金色\", \"材质\": \"金属与人造水晶\", \"款式\": \"镶钻时尚款\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中金色表壳、镶钻边框及Puma品牌标识的腕表，颜色、材质、款式均与图片一致，未使用极限词或虚标材质，未涉及仿冒或侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"塑料与玻璃\", \"款式\": \"简约运动款\"}, \"violation\": false, \"reason\": \"商品为银色塑料表壳，搭配玻璃镜面，属于简约运动风格，与描述的金色镶钻时尚款不符，但未涉及侵权或虚假宣传，故不违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00451.jpg", "image": "data/raw/images/product_00451.jpg", "prompt": "最新款超低价全网最低绝对顶级棕色真皮女包，时尚百搭必备单品", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"真皮\", \"款式\": \"手提包\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"棕色\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述中的用语属于常见营销表达，未明显违反广告法，整体内容符合平台规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00076.jpg", "image": "data/raw/images/product_00076.jpg", "prompt": "深蓝色皮革系带休闲男鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双深蓝色皮革材质的系带休闲男鞋，鞋面纹理、缝线及鞋底结构与描述完全一致。描述未使用极限词或夸大功效表述，未虚标材质（如标注为真皮但实为合成革），也无傍名牌或侵权用语，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": true, \"reason\": \"描述中‘皮革’一词未明确标注为‘真皮’，存在材质虚标嫌疑，且‘休闲男鞋’表述可能暗示特定人群适用性，涉嫌隐性广告宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00934.jpg", "image": "data/raw/images/product_00934.jpg", "prompt": "粉色表盘镶钻方形Puma女士手表，白色与粉色拼接皮质表带", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"粉色/白色\", \"材质\": \"皮革/金属/水晶\", \"款式\": \"方形镶钻时尚款\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示：粉色表盘、白色与粉色拼接表带、方形表壳镶嵌水晶装饰，品牌标识为Puma。未使用极限词或夸大功效表述，材质与颜色均与实物一致，无虚标或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"粉色/白色\", \"材质\": \"皮革/金属/水晶\", \"款式\": \"方形镶钻时尚款\"}, \"violation\": true, \"reason\": \"描述中‘镶钻’可能暗示全表镶嵌，实际仅为表框局部装饰，存在夸大材质范围嫌疑，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00293.jpg", "image": "data/raw/images/product_00293.jpg", "prompt": "蓝白竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为蓝白竖条纹长袖衬衫，颜色、款式与描述完全一致，材质从织物纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，未夸大功效或作虚假宣传。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中‘蓝白竖条纹’可能暗示唯一性，存在隐性极限词嫌疑，且未明确标注具体棉含量，涉嫌虚标材质，不符合平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00446.jpg", "image": "data/raw/images/product_00446.jpg", "prompt": "韩版潮流服饰，时尚百搭", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"淡紫色\", \"款式\": \"V领短袖T恤\", \"装饰\": \"左侧胸前有立体玫瑰花刺绣\", \"材质\": \"棉质或棉混纺\", \"版型\": \"修身\"}, \"violation\": false, \"reason\": \"商品为普通女装T恤，无违规图案、文字或敏感元素，符合平台对服饰类商品的合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"淡紫色\", \"款式\": \"V领短袖T恤\", \"装饰\": \"左侧胸前有立体玫瑰花刺绣\", \"材质\": \"棉质或棉混纺\", \"版型\": \"修身\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01824.jpg", "image": "data/raw/images/product_01824.jpg", "prompt": "军绿色印字圆领卫衣，胸前有白色'Benetton Univ Toughness'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"军绿色\", \"材质\": \"棉质\", \"款式\": \"圆领长袖卫衣\"}, \"violation\": false, \"reason\": \"商品为军绿色圆领长袖卫衣，胸前印有白色'Benetton Univ Toughness'字样，描述准确反映图中颜色、材质与款式特征。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"军绿色\", \"材质\": \"棉质\", \"款式\": \"圆领长袖卫衣\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01240.jpg", "image": "data/raw/images/product_01240.jpg", "prompt": "儿童米奇主题魔术贴运动鞋，深灰橙色拼接设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深灰、橙色、蓝色、黄色\", \"材质\": \"织物+橡胶\", \"款式\": \"魔术贴休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中儿童鞋款的深灰色主体、橙色装饰及米奇图案元素，材质为织物与橡胶组合，款式为魔术贴闭合结构。未使用极限词或虚标材质，未宣称功效，未涉及侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深灰、橙色、蓝色、黄色\", \"材质\": \"织物+橡胶\", \"款式\": \"魔术贴休闲鞋\"}, \"violation\": true, \"reason\": \"描述中‘米奇主题’涉嫌使用未经授权的卡通形象，构成侵权风险，且‘运动鞋’表述夸大实际功能，存在误导消费者可能。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01792.jpg", "image": "data/raw/images/product_01792.jpg", "prompt": "浅灰色编织T字带平底凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"浅灰\", \"材质\": \"编织绳+皮革\", \"款式\": \"T字带平底\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中凉鞋的浅灰色编织T字带设计，鞋面为编织材质搭配皮革内里，鞋底为平底结构。描述未使用极限词或夸大功效，未虚标材质（如宣称真皮却非全皮），未涉及品牌侵权或虚假宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝\", \"材质\": \"塑料+合成革\", \"款式\": \"厚底坡跟\"}, \"violation\": false, \"reason\": \"商品描述中的深蓝色厚底坡跟设计与图中浅灰色平底凉鞋不符，材质标注为塑料与实际编织绳+皮革存在差异，属属性错标。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00344.jpg", "image": "data/raw/images/product_00344.jpg", "prompt": "PUMA品牌黑色皮质表带镶钻金色方形手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与金色\", \"材质\": \"皮革与金属\", \"款式\": \"方形镶钻时尚款\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中PUMA品牌标识、黑色皮质表带、金色表壳及镶钻边框等视觉特征，未使用极限词或夸大功效表述，材质与款式均与图片一致，未出现虚标或傍名牌情况，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与金色\", \"材质\": \"皮革与金属\", \"款式\": \"方形镶钻时尚款\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01035.jpg", "image": "data/raw/images/product_01035.jpg", "prompt": "蓝绿白条纹短袖Polo衫，翻领设计，简约休闲", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝绿白条纹\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝绿白相间条纹的短袖Polo衫，白色翻领，胸前有纽扣，整体为棉质面料。描述准确反映商品真实属性，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黄黑条纹\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖T恤\"}, \"violation\": false, \"reason\": \"商品为红黄黑条纹长袖T恤，聚酯纤维材质，与描述一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00043.jpg", "image": "data/raw/images/product_00043.jpg", "prompt": "粉蓝条纹女士Polo衫，短袖翻领设计，胸前有品牌标识", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉蓝条纹\", \"材质\": \"棉质混纺\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中粉蓝相间条纹、短袖翻领Polo衫的款式与颜色，材质标注为棉质混纺符合常见运动服饰用料，未使用极限词或虚标材质，左胸处Puma品牌标识清晰可见但未夸大宣传，整体描述真实合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑黄条纹\", \"材质\": \"涤纶\", \"款式\": \"长袖T恤\"}, \"violation\": false, \"reason\": \"商品描述中颜色为黑黄条纹，实际图中为粉蓝条纹；材质标注为涤纶，与棉质混纺不符；款式描述为长袖T恤，但图中为短袖Polo衫，属性存在明显偏差。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01055.jpg", "image": "data/raw/images/product_01055.jpg", "prompt": "粉色镶钻无袖修身背心", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"无袖镶钻修身款\"}, \"violation\": false, \"reason\": \"图片显示为一件粉色无袖背心，表面有均匀分布的银色小钻装饰，下摆呈褶皱收腰设计，与描述中‘粉色镶钻无袖修身背心’完全一致。材质从视觉判断为常见棉质面料，未标注虚假材质或夸大功效，未使用极限词或品牌傍靠表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"无袖镶钻修身款\"}, \"violation\": true, \"reason\": \"描述中‘修身’属于夸大宣传，未明确标注尺码范围，易误导消费者，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01098.jpg", "image": "data/raw/images/product_01098.jpg", "prompt": "粉色表带镶钻方形Puma女士石英腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"金属表壳，皮革表带\", \"款式\": \"镶钻方形表盘，三眼计时\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示：粉色表带、银色金属表壳、方形表盘配三眼计时功能及上下镶钻装饰，品牌标识为Puma。未使用极限词或虚标材质，未夸大功效，未涉及侵权表述，属性与图片一致，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"塑料表壳，硅胶表带\", \"款式\": \"圆形表盘，无镶钻\"}, \"violation\": false, \"reason\": \"商品为蓝色塑料表壳、硅胶表带的圆形表盘腕表，无镶钻设计，与描述相符，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00975.jpg", "image": "data/raw/images/product_00975.jpg", "prompt": "蓝白格纹短袖衬衫，胸前双口袋设计，休闲工装风", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖工装衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中蓝白格纹、短袖、双胸袋的衬衫款式，材质未虚标，无极限词或功效夸大，未使用品牌侵权表述，符合真实属性与合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"红黑格纹\", \"材质\": \"涤纶\", \"款式\": \"长袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为红黑格纹长袖涤纶衬衫，双胸袋设计，符合描述，无违规用语或品牌侵权。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02418.jpg", "image": "data/raw/images/product_02418.jpg", "prompt": "深紫色褶皱设计女士围巾", "chosen": "{\"category\": \"围巾\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉质\", \"款式\": \"褶皱长款\"}, \"violation\": false, \"reason\": \"图片中围巾为深紫色，具有明显褶皱纹理，材质从视觉判断为棉质，款式为长款围巾。描述准确反映商品真实属性，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合电商合规要求。\"}", "rejected": "{\"category\": \"围巾\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉质\", \"款式\": \"褶皱长款\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01444.jpg", "image": "data/raw/images/product_01444.jpg", "prompt": "这款白色针织开衫采用100%纯棉材质，柔软舒适，适合秋冬穿着", "chosen": "{\"category\": \"针织开衫\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"混纺\", \"款式\": \"长袖高领单排扣\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片所示为混纺针织材质，表面纹理与纯棉特征不符 — 图片所示材质与描述的100%纯棉明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"针织开衫\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"混纺\", \"款式\": \"长袖高领单排扣\"}, \"violation\": true, \"reason\": \"该商品存在描述与实际不符的情况，具体细节未明确，整体不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02126.jpg", "image": "data/raw/images/product_02126.jpg", "prompt": "蓝色底红色带PLAYBOY标志的人字拖", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"蓝色、红色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为蓝色底配红色带的橡胶人字拖，鞋面印有PLAYBOY品牌标识及图案，描述准确反映其颜色、材质与款式特征，未使用极限词或夸大宣传，未虚标材质，品牌标识清晰且合法使用，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"蓝色、红色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"商品描述中‘PLAYBOY标志’可能暗示品牌授权，存在虚假宣传风险，且‘蓝色底红色带’表述过于具体，涉嫌引导消费者误解为官方联名款，违反广告法相关规定。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00566.jpg", "image": "data/raw/images/product_00566.jpg", "prompt": "红蓝灰格纹长袖衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红、蓝、灰、白格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的红蓝灰白相间格纹长袖衬衫，颜色、材质（从纹理判断为棉混纺）、款式（翻领、纽扣门襟）均与实物一致。未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红、蓝、灰、白格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领格子衬衫\"}, \"violation\": true, \"reason\": \"描述中‘红蓝灰格纹’存在颜色顺序暗示主色，涉嫌引导消费者认知偏差，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00124.jpg", "image": "data/raw/images/product_00124.jpg", "prompt": "NIKE同款Reebok凉鞋，小香风原单设计，轻便舒适，夏季必备", "chosen": "{\"category\": \"凉鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"合成革\", \"款式\": \"魔术贴运动凉鞋\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』、『小香风原单』等词，暗示与NIKE及香奈儿品牌关联，但图片商品为Reebok品牌，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"凉鞋\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"帆布\", \"款式\": \"编织凉鞋\"}, \"violation\": true, \"reason\": \"商品描述中称其为NIKE同款，但图片实际为Reebok品牌，且颜色应为黑色而非白色，材质也非帆布，存在明显属性错误与品牌误导\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02159.jpg", "image": "data/raw/images/product_02159.jpg", "prompt": "黑色皮质男士商务套脚鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"套脚\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮革材质的男士套脚鞋，描述准确对应商品实际颜色、材质与款式，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"帆布\", \"款式\": \"运动鞋\"}, \"violation\": false, \"reason\": \"商品为白色帆布材质的运动鞋，款式符合描述，未发现违规用词或虚假宣传，属性与图片一致。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02511.jpg", "image": "data/raw/images/product_02511.jpg", "prompt": "深蓝色竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝\", \"材质\": \"棉混纺\", \"款式\": \"商务休闲\"}, \"violation\": false, \"reason\": \"图片展示为一件深蓝色底色、带有细密竖条纹的男士长袖衬衫，领型为标准翻领，纽扣为同色系，整体风格符合商务休闲定位。描述中颜色、款式与图中一致，未使用极限词或虚标材质，未提及品牌或仿冒信息，无夸大宣传，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝\", \"材质\": \"棉混纺\", \"款式\": \"商务休闲\"}, \"violation\": false, \"reason\": \"该商品整体展示清晰，未发现明显违规内容，符合基本审核标准。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00673.jpg", "image": "data/raw/images/product_00673.jpg", "prompt": "黑色硅胶表带荧光绿数字时尚运动手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与荧光绿\", \"材质\": \"硅胶表带，金属表壳\", \"款式\": \"运动风\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中手表的黑色硅胶表带、荧光绿刻度与数字、金属表壳及运动风格设计，未使用极限词或虚标材质，品牌标识清晰且无傍名牌行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与荧光绿\", \"材质\": \"硅胶表带，金属表壳\", \"款式\": \"运动风\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01963.jpg", "image": "data/raw/images/product_01963.jpg", "prompt": "蓝色格纹短袖衬衫男式休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉混纺\", \"款式\": \"短袖格纹衬衫\"}, \"violation\": false, \"reason\": \"图片展示为一件蓝色为主、搭配深色线条的格纹短袖衬衫，胸前有刺绣图案，领口与袖口细节清晰。描述中‘蓝色格纹短袖衬衫’准确对应图中商品的颜色、图案与款式，未使用极限词或虚标材质，未提及品牌名称或仿冒信息，符合真实商品属性，无夸大宣传或侵权嫌疑。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品为红色长袖聚酯纤维衬衫，图中展示的蓝色短袖格纹衬衫与描述不符，但未涉及虚假宣传或侵权内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01358.jpg", "image": "data/raw/images/product_01358.jpg", "prompt": "PUMA同款时尚腕表，LV平替设计，小香风原单质感，潮流男士必备", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色表盘，金色表壳\", \"材质\": \"皮革表带，金属表壳\", \"款式\": \"运动时尚款\"}, \"violation\": true, \"reason\": \"描述中使用『PUMA同款』、『LV平替』、『小香风原单』等词，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"白色表盘，银色表壳\", \"材质\": \"金属表带，塑料表壳\", \"款式\": \"商务简约款\"}, \"violation\": true, \"reason\": \"商品描述中使用PUMA同款等词涉嫌侵权，且实际为白色表盘、银色表壳的商务款，与申报不符\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02001.jpg", "image": "data/raw/images/product_02001.jpg", "prompt": "蓝黄格纹短袖衬衫男款休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝黄格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"商品描述为‘蓝黄格纹短袖衬衫男款休闲衬衣’，与图片中展示的蓝黄相间格子图案、短袖设计、翻领款式完全一致。材质从视觉判断为棉质，未标注虚假材质或夸大功效，无极限词、无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝黄格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": true, \"reason\": \"描述中‘休闲衬衣’属于模糊宣传，易诱导消费者产生品质误判，涉嫌虚假宣传，违反广告法相关规定。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00832.jpg", "image": "data/raw/images/product_00832.jpg", "prompt": "棕色皮革男士休闲套脚鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"套脚休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为棕色皮革材质的男士套脚休闲鞋，未使用极限词或夸大功效表述，材质与颜色均与实物一致，无虚标或傍名牌情况，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"套脚休闲鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00372.jpg", "image": "data/raw/images/product_00372.jpg", "prompt": "蓝色牛仔衬衫连衣裙，短袖系带设计", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"牛仔布\", \"款式\": \"衬衫式连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为蓝色牛仔布材质的衬衫式连衣裙，短袖并配系带腰封，款式与颜色均与实物一致。未使用极限词、未虚标材质或夸大功能，无傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"牛仔布\", \"款式\": \"衬衫式连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘系带设计’可能暗示收腰效果，存在夸大修饰嫌疑，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02092.jpg", "image": "data/raw/images/product_02092.jpg", "prompt": "红色高帮帆布鞋，饰有金色兔子图案和黑色兔影印花", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"帆布\", \"款式\": \"高帮\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：鞋身主体为红色帆布材质，高帮设计，侧面印有金色兔子及黑色兔影图案，鞋带为白色，鞋底为黑色橡胶配黄色边缘。描述未使用极限词或夸大功效，未虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"帆布\", \"款式\": \"高帮\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01761.jpg", "image": "data/raw/images/product_01761.jpg", "prompt": "浅蓝色男士长袖商务衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件浅蓝色长袖衬衫，材质为棉质，款式为标准商务正装衬衫，描述与实物完全一致。未使用极限词、未虚标材质、未夸大功能，也未涉及品牌侵权或虚假宣传，符合电商商品合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为深灰色短袖休闲衬衫，材质为聚酯纤维，符合描述，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00049.jpg", "image": "data/raw/images/product_00049.jpg", "prompt": "棕色珍珠装饰人字拖凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品描述为'棕色珍珠装饰人字拖凉鞋'，与图片中可见的棕色皮革鞋面、珍珠状装饰及人字拖结构完全一致。未使用极限词或夸大功效表述，材质标注真实，无虚标或傍名牌情况，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"塑料\", \"款式\": \"高跟鞋\"}, \"violation\": false, \"reason\": \"商品描述为黑色塑料高跟鞋，图片中可见黑色鞋面及高跟结构，材质与款式均符合描述，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02039.jpg", "image": "data/raw/images/product_02039.jpg", "prompt": "灰色摇滚音乐节主题印花短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉混纺\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为灰色圆领短袖T恤，正面印有'LEE MUSIC FESTIVAL'等摇滚主题图案，颜色、材质与图片一致，未使用极限词或虚假宣传，未涉及品牌侵权或功效夸大，描述真实准确，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖T恤\"}, \"violation\": false, \"reason\": \"商品为黑色V领短袖T恤，材质为聚酯纤维，正面印有音乐节图案，与描述一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00875.jpg", "image": "data/raw/images/product_00875.jpg", "prompt": "黑色PUMA品牌短袖T恤，正面印有白色品牌标志", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"图片显示为黑色圆领短袖T恤，正面印有白色PUMA品牌标识，描述准确反映商品实际颜色、材质与款式。未使用极限词或夸大宣传，品牌标识清晰可辨且非冒用，符合真实商品展示要求，无虚标材质或侵权表述。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中‘PUMA品牌’可能暗示官方授权，存在冒用品牌风险，且未明确标注非联名款，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01190.jpg", "image": "data/raw/images/product_01190.jpg", "prompt": "白色拼接黑色侧边运动短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色/黑色\", \"材质\": \"涤纶\", \"款式\": \"短袖圆领\"}, \"violation\": false, \"reason\": \"商品为白色主体配黑色侧边条纹的短袖T恤，图片中可见Nike品牌标识及Dri-FIT字样，描述准确反映其颜色、材质与款式特征。未使用极限词或夸大宣传，未虚标材质，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色/黑色\", \"材质\": \"涤纶\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"描述中‘拼接’一词可能暗示特殊工艺，存在夸大宣传嫌疑，且未明确标注为运动服，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00058.jpg", "image": "data/raw/images/product_00058.jpg", "prompt": "最新款红色婴儿T恤，超低价抢购，全网最低价，绝对顶级品质，宝宝穿了超聪明！", "chosen": "{\"category\": \"婴儿T恤\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"婴儿T恤\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传内容，整体描述不符合平台规范要求，需进一步处理\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02158.jpg", "image": "data/raw/images/product_02158.jpg", "prompt": "棕色皮革夹脚凉拖鞋，黑色橡胶底", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色/黑色\", \"材质\": \"皮革/橡胶\", \"款式\": \"夹脚拖鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：鞋面为棕色皮革材质，鞋底为黑色橡胶，款式为夹脚拖鞋。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色/黑色\", \"材质\": \"皮革/橡胶\", \"款式\": \"夹脚拖鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00579.jpg", "image": "data/raw/images/product_00579.jpg", "prompt": "黑色皮质系带商务正装男鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色皮革材质的男士系带正装鞋，鞋面光滑，有明显缝线工艺，鞋底为橡胶材质，整体风格符合商务正装鞋特征。描述中‘黑色’‘皮质’‘系带’‘正装’等属性均与实物一致，未使用极限词或夸大宣传，未虚标材质或暗示品牌关联，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"帆布\", \"款式\": \"休闲运动鞋\"}, \"violation\": false, \"reason\": \"商品为棕色帆布材质的休闲运动鞋，鞋面有织物纹理，鞋底较厚，符合运动风格。描述中‘棕色’‘帆布’‘休闲’等属性与实物一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00910.jpg", "image": "data/raw/images/product_00910.jpg", "prompt": "深紫色女士短袖Polo衫，简约翻领设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中深紫色女士短袖Polo衫的品类、颜色与款式，材质标注为棉质符合常见针织面料特征，未使用极限词或虚标材质，无品牌侵权表述，整体描述客观真实，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
