{"image_file": "product_01859.jpg", "image": "data/raw/images/product_01859.jpg", "prompt": "绿色系民族风印花短袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色、白色、紫色\", \"材质\": \"棉质混纺\", \"款式\": \"短袖V领印花连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的绿色为主色调、带有几何与动物图案的民族风印花特征，材质为常见棉质混纺面料，未使用极限词或虚标材质，款式描述与实物一致，无傍名牌或夸大宣传行为，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色、黑色、金色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖高领连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红黑金配色，材质为聚酯纤维，款式为长袖高领，与图中绿色系印花短袖V领连衣裙不符，但未发现违规用语，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00642.jpg", "image": "data/raw/images/product_00642.jpg", "prompt": "黑色PUMA男士短袖POLO衫，胸前白色弧形条纹设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"POLO衫\"}, \"violation\": false, \"reason\": \"图片显示为黑色PUMA品牌POLO衫，胸前有白色弧形装饰条，左胸有PUMA标志，左臂有几何图案，与描述完全一致。未使用极限词或夸大宣传，材质标注符合常见运动服饰成分，未虚标材质或冒用其他品牌名称，属于真实合规的商品信息展示。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"POLO衫\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合平台基本审核要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01021.jpg", "image": "data/raw/images/product_01021.jpg", "prompt": "蓝黄格纹短袖衬衫男款休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝黄格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件蓝黄相间的格纹短袖衬衫，描述准确对应其颜色、款式与穿着场景。未使用极限词或夸大宣传，材质标注为棉质符合常见面料描述，无虚标或傍名牌行为，整体信息真实合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝黄格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02431.jpg", "image": "data/raw/images/product_02431.jpg", "prompt": "这款时尚优雅的女士连衣裙采用轻盈雪纺材质，完美展现女性曲线美，适合各种场合穿着。", "chosen": "{\"category\": \"男式衬衫\", \"attributes\": {\"颜色\": \"白、灰、黑\", \"材质\": \"棉质\", \"款式\": \"格子长袖衬衫\"}, \"violation\": true, \"reason\": \"商品描述中的'女士连衣裙'与主图展示的男式格子衬衫明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"男式衬衫\", \"attributes\": {\"颜色\": \"红、黄、绿\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖T恤\"}, \"violation\": true, \"reason\": \"商品描述中提到的'女士连衣裙'与图片中的男式衬衫不符，且属性标注为红色系短袖T恤，明显错误 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01301.jpg", "image": "data/raw/images/product_01301.jpg", "prompt": "绿色男士短袖Polo衫，胸前印有数字3和徽章图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为绿色，款式为Polo衫，胸前数字3与徽章图案清晰可见，未使用极限词或虚标材质，未涉及品牌侵权或夸大宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"化纤\", \"款式\": \"T恤\"}, \"violation\": false, \"reason\": \"商品为蓝色化纤T恤，胸前有数字3和徽章，与描述一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02362.jpg", "image": "data/raw/images/product_02362.jpg", "prompt": "紫红白几何印花棉质女士长袖上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫红白\", \"材质\": \"棉质\", \"款式\": \"长袖印花上衣\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中服饰的紫红白三色几何图案、棉质面料及长袖款式，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫红白\", \"材质\": \"棉质\", \"款式\": \"长袖印花上衣\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01011.jpg", "image": "data/raw/images/product_01011.jpg", "prompt": "浅灰色短袖Polo衫，领口与袖口饰有黄蓝条纹，左胸绣有彩色徽标", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：浅灰色Polo衫，领口及袖口黄蓝撞色条纹，左胸有彩色刺绣徽标，材质为常见棉质面料。未使用极限词、未虚标材质或夸大功效，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘彩色徽标’涉嫌夸大视觉效果，实际图案较小且颜色不突出，存在误导性宣传风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01797.jpg", "image": "data/raw/images/product_01797.jpg", "prompt": "金色金属装饰皮质人字拖", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色/金色\", \"材质\": \"皮革/金属\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为棕色皮革底配金色金属叶片装饰的人字拖，描述准确反映其材质、颜色与款式特征，未使用极限词或虚标材质，无夸大功效或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色/金色\", \"材质\": \"皮革/金属\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"描述中‘金色金属装饰’可能暗示全金属材质，存在虚标材质风险，易误导消费者，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01586.jpg", "image": "data/raw/images/product_01586.jpg", "prompt": "这款时尚连衣裙采用高品质棉质面料，修身剪裁，适合日常通勤与正式场合穿着，展现优雅气质。", "chosen": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"棉质\", \"款式\": \"直筒裤\"}, \"violation\": true, \"reason\": \"商品描述中的'连衣裙'与图片展示的男式卡其色长裤明显不符，误导消费者 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"卡其色\", \"款式\": \"直筒裤\"}, \"violation\": false, \"reason\": \"商品图展示为男式长裤，描述中‘连衣裙’可能为笔误或跨品类推广用语，整体未造成明显误导，可视为正常商品信息表达\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01062.jpg", "image": "data/raw/images/product_01062.jpg", "prompt": "粉蓝条纹女士Polo衫，短袖翻领设计，胸前有品牌标识", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉蓝条纹\", \"材质\": \"棉质混纺\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中粉蓝色横条纹Polo衫的视觉特征，材质为常见棉质混纺，未虚标或夸大；款式为标准短袖翻领设计，胸前有Puma品牌标识，未使用极限词或虚假宣传，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉蓝条纹\", \"材质\": \"棉质混纺\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00164.jpg", "image": "data/raw/images/product_00164.jpg", "prompt": "黑色方形数字显示运动手表，Puma品牌", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"塑料/橡胶\", \"款式\": \"数字电子表\"}, \"violation\": false, \"reason\": \"商品为黑色方形数字电子表，表带印有Puma标志，描述准确反映其颜色、材质与款式特征，未使用极限词或虚标功能，未涉及侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"塑料/橡胶\", \"款式\": \"数字电子表\"}, \"violation\": true, \"reason\": \"描述中‘数字显示’可能暗示精准计时功能，存在夸大性能风险，且未标注电池续航，涉嫌信息不全，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00656.jpg", "image": "data/raw/images/product_00656.jpg", "prompt": "紫色PUMA品牌印花V领短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"图片中展示的为一件紫色V领短袖T恤，正面印有PUMA品牌字样及渐变图案，材质从视觉判断为常规棉质面料。描述准确反映了商品的颜色、品牌标识、款式和基本材质，未使用夸大宣传用语或虚假宣称，未涉及极限词或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为红色圆领短袖T恤，材质为聚酯纤维，印有PUMA品牌图案，整体风格符合运动休闲类服饰描述，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01895.jpg", "image": "data/raw/images/product_01895.jpg", "prompt": "白色棉质刺绣短袖连衣裙，领口与下摆饰有紫红色几何图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"图片显示为白色棉质短袖连衣裙，领口及下摆有紫红色几何刺绣装饰，描述准确反映商品真实属性，未使用极限词或虚标材质，无夸大功效或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘刺绣’一词可能暗示手工工艺，存在虚标精细度风险，且‘几何图案’表述过于具体，涉嫌夸大设计复杂性，不符合真实商品呈现。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01365.jpg", "image": "data/raw/images/product_01365.jpg", "prompt": "白色印花短袖T恤，蓝色城市滑板图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为白色圆领短袖T恤，正面印有蓝色渐变城市与滑板人物图案，描述准确反映图中颜色、材质及款式特征，未使用极限词或虚标材质，无傍名牌或夸大宣传行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色V领短袖T恤，采用涤纶材质，正面有蓝色图案，整体描述与实物一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00101.jpg", "image": "data/raw/images/product_00101.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"系带皮鞋\", \"材质\": \"皮革\", \"设计\": \"布洛克雕花\", \"鞋底\": \"橡胶防滑底\"}, \"violation\": true, \"reason\": \"商品描述中使用了'商场撤柜'、'专柜正品'、'便宜处理'等词汇，属于典型的促销性表述，可能涉及虚假宣传或价格误导。其中'专柜正品'未提供相关证明材料，涉嫌夸大宣传；'便宜处理'暗示商品存在瑕疵或过季问题，但图片展示为全新状态，存在信息不一致，违反电商平台关于商品描述真实性的规定。\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"白色\", \"款式\": \"休闲运动鞋\", \"材质\": \"布料\", \"设计\": \"布洛克雕花\", \"鞋底\": \"橡胶防滑底\"}, \"violation\": true, \"reason\": \"商品描述中称'专柜正品'但图片显示为白色布料休闲鞋，与实际黑色皮质正装鞋不符，存在明显属性错误和虚假宣传嫌疑。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01724.jpg", "image": "data/raw/images/product_01724.jpg", "prompt": "黑色短袖Polo衫，胸前刺绣徽章图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品为黑色短袖Polo衫，图片中可见其为棉质面料，领口与袖口有深色包边设计，左胸位置有刺绣徽章，描述准确反映实际商品属性。未使用极限词、未虚标材质、未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00355.jpg", "image": "data/raw/images/product_00355.jpg", "prompt": "棕色皮革系带休闲男鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双棕色皮革材质的系带休闲男鞋，鞋面纹理与缝线细节清晰可见，描述准确反映其颜色、材质与款式特征。未使用极限词或夸大宣传，未虚标材质（如标注为真皮但实为合成革），亦无傍名牌或侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01325.jpg", "image": "data/raw/images/product_01325.jpg", "prompt": "深灰色印花男士短袖T恤，正面印有双马图案及英文艺术字设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为深灰色，材质从织物纹理判断为棉质，款式为圆领短袖T恤，正面印花包含双马图案与英文艺术字，未使用极限词、未虚标材质、未夸大功效，也无傍名牌或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01461.jpg", "image": "data/raw/images/product_01461.jpg", "prompt": "浅蓝白格纹长袖男士商务衬衫", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"浅蓝白格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片显示为浅蓝色与白色相间的细格纹长袖衬衫，材质从织物纹理判断为棉混纺，款式为标准商务正装款。描述准确反映商品真实属性，未使用极限词、未虚标材质或夸大功效，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"浅蓝白格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00033.jpg", "image": "data/raw/images/product_00033.jpg", "prompt": "最新款Nike运动上衣，超低价秒杀，全网最低价，绝对顶级性能！", "chosen": "{\"category\": \"运动上衣\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"半拉链长袖\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"运动上衣\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"半拉链长袖\"}, \"violation\": false, \"reason\": \"商品描述中使用‘最新款’等词汇属于常见营销表达，未涉及虚假宣传，整体内容符合平台规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01618.jpg", "image": "data/raw/images/product_01618.jpg", "prompt": "深蓝色水洗牛仔裤，直筒版型，经典五袋设计", "chosen": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色水洗牛仔裤，材质为典型牛仔布，版型为直筒，与描述完全一致。未使用极限词、未虚标材质（如宣称纯棉或有机棉）、未提及品牌关联或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": true, \"reason\": \"描述中‘水洗’属于工艺暗示，可能诱导消费者认为具有特殊功效，涉嫌虚假宣传。图片未明确展示洗涤效果，存在误导风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00243.jpg", "image": "data/raw/images/product_00243.jpg", "prompt": "紫红色机器人图案印花短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫红色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为紫红色圆领短袖T恤，正面印有绿色机器人图案及英文文字，材质从图中可判断为常见棉质面料，描述准确反映实际商品属性，未使用极限词、未虚标材质、未涉及品牌侵权或夸大宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫红色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规问题，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01562.jpg", "image": "data/raw/images/product_01562.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款修身牛仔裤时尚百搭，抢到就是赚到！", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质牛仔布\", \"款式\": \"修身小脚\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和打折信息，与图片真实商品属性无关，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅粉色\", \"材质\": \"聚酯纤维\", \"款式\": \"阔腿裤\"}, \"violation\": true, \"reason\": \"商品描述中虚构原价及促销信息，且属性标注为浅粉色聚酯纤维阔腿裤，与实际深蓝色棉质修身小脚牛仔裤严重不符，存在误导性宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01975.jpg", "image": "data/raw/images/product_01975.jpg", "prompt": "黄白蓝格纹男士短袖衬衫", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"黄白蓝格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件黄白蓝相间的格纹短袖衬衫，颜色、款式与描述完全一致，材质从织物纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"黄白蓝格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合平台基本要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01525.jpg", "image": "data/raw/images/product_01525.jpg", "prompt": "方形银色表壳棕色皮带计时码表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/棕色\", \"材质\": \"金属/皮革\", \"款式\": \"方形计时码表\"}, \"violation\": false, \"reason\": \"描述准确反映图中商品为方形表壳、银色金属材质搭配棕色鳄鱼纹皮质表带的计时码表，表盘含三个小表盘及Carrera品牌标识，未使用极限词或虚标材质，未涉及侵权表述，符合真实属性与合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色/红色\", \"材质\": \"塑料/橡胶\", \"款式\": \"圆形石英表\"}, \"violation\": false, \"reason\": \"商品为黑色表壳配红色表带的圆形石英表，材质为塑料与橡胶，符合描述，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02298.jpg", "image": "data/raw/images/product_02298.jpg", "prompt": "黑色立领男士长袖衬衫，胸前印有'19se'字样，袖口可卷边设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"立领长袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：黑色立领衬衫、胸前'19se'印花、袖口卷边设计均与图一致；未使用极限词或夸大功效表述，材质标注为棉混纺符合常见面料描述规范，无傍名牌或虚假宣传行为，整体符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为白色圆领短袖，材质为聚酯纤维，符合描述，无违规用语或虚假宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01286.jpg", "image": "data/raw/images/product_01286.jpg", "prompt": "酒红色与白色横条纹男士Polo衫，胸前印有'W 47'图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红与白\", \"材质\": \"棉质\", \"款式\": \"横条纹Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：酒红色与白色相间的横条纹设计、Polo领、胸前'W 47'印花均与实物一致。未使用极限词或夸大宣传，材质标注为棉质符合常见品类认知，无傍名牌或虚假功效表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色与灰\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领T恤\"}, \"violation\": false, \"reason\": \"商品为黑灰色圆领T恤，聚酯纤维材质，无Polo领设计，胸前印花与描述不符，属正常商品展示。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02470.jpg", "image": "data/raw/images/product_02470.jpg", "prompt": "男士卡其色修身休闲西裤", "chosen": "{\"category\": \"裤子\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"棉混纺\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为卡其色男士西裤，面料呈现棉混纺质感，版型为修身直筒设计，描述与实物一致。未使用极限词、未虚标材质（如宣称纯羊毛）、未涉及品牌侵权或功效夸大，符合商品真实属性及广告法合规要求。\"}", "rejected": "{\"category\": \"裤子\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"棉混纺\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01535.jpg", "image": "data/raw/images/product_01535.jpg", "prompt": "黑色碳纤维纹表盘的Carrera计时腕表，银色金属表壳搭配黑灰相间表带", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色、银色\", \"材质\": \"金属、碳纤维纹理\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中手表的黑色碳纤维纹理表盘、银色金属表壳及黑灰拼接表带，未使用极限词或虚标材质；品牌标识为Carrera，未冒用其他知名品牌，符合广告法要求，属性与图片一致，无夸大功效或侵权表述。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色、银色\", \"材质\": \"金属、碳纤维纹理\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求，未发现明显违规内容。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02038.jpg", "image": "data/raw/images/product_02038.jpg", "prompt": "白色摇滚音乐节主题印花短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"图片显示为一件白色圆领短袖T恤，正面印有'ROCK JUNCTION'和'MUSIC FESTIVAL'等图案与文字，整体设计符合摇滚音乐节主题。描述中仅陈述了真实可见的颜色、材质（棉质）与款式，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，图文一致且符合广告法规范。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中'摇滚音乐节主题'属于主观宣传用语，可能构成虚假暗示；'棉质'未提供检测依据，涉嫌虚标材质，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01727.jpg", "image": "data/raw/images/product_01727.jpg", "prompt": "深蓝色纯棉男士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"纯棉\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件深蓝色短袖Polo衫，领口有纽扣设计，左胸处有小logo，面料纹理符合纯棉特征。描述准确对应商品实际颜色、材质与款式，未使用极限词或虚标材质，无夸大宣传或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品为浅灰色短袖T恤，材质为聚酯纤维，无领口纽扣设计，符合描述内容，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02466.jpg", "image": "data/raw/images/product_02466.jpg", "prompt": "深灰色修身休闲长裤", "chosen": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"棉混纺\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为深灰色男士休闲裤，版型为修身直筒，材质从纹理判断为棉混纺，描述与实物一致。未使用极限词、未虚标材质、未宣称特殊功效，无品牌侵权表述，符合商品真实属性及广告法合规要求。\"}", "rejected": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"墨绿色\", \"材质\": \"聚酯纤维\", \"款式\": \"宽松阔腿\"}, \"violation\": false, \"reason\": \"商品为墨绿色宽松阔腿裤，材质为聚酯纤维，符合描述，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01302.jpg", "image": "data/raw/images/product_01302.jpg", "prompt": "灰色短袖Polo衫，胸前有绿色刺绣和图案装饰", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为灰色棉质Polo衫，胸前有绿色刺绣与图案装饰，左袖有数字4标识，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘刺绣’可能暗示工艺等级，构成隐性夸大；‘图案装饰’属模糊宣传，易引导消费者误判商品价值，存在虚假宣传风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00321.jpg", "image": "data/raw/images/product_00321.jpg", "prompt": "ESPRIT品牌银色表壳黑色皮带手表，白色表盘带日期显示", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/黑色/白色\", \"材质\": \"金属表壳/皮革表带\", \"款式\": \"简约商务风\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中ESPRIT品牌手表的银色金属表壳、黑色皮革表带及白色表盘特征，包含日期窗功能，未使用极限词或虚标材质，未涉及仿冒或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/黑色/白色\", \"材质\": \"金属表壳/皮革表带\", \"款式\": \"简约商务风\"}, \"violation\": true, \"reason\": \"描述中‘ESPRIT品牌’可能暗示正品授权，存在虚标品牌风险，且‘日期显示’功能未在图中明确验证，涉嫌夸大宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01911.jpg", "image": "data/raw/images/product_01911.jpg", "prompt": "湖蓝色刺绣系带宽松上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"湖蓝色\", \"材质\": \"棉质\", \"款式\": \"宽松系带刺绣上衣\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中湖蓝色棉质宽松上衣，饰有红色与白色几何刺绣及前襟系带设计，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"湖蓝色\", \"材质\": \"棉质\", \"款式\": \"宽松系带刺绣上衣\"}, \"violation\": true, \"reason\": \"描述中‘宽松’属绝对化用语，易诱导消费者产生误判，涉嫌虚假宣传，不符合广告法相关规定。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01520.jpg", "image": "data/raw/images/product_01520.jpg", "prompt": "深绿与藏蓝条纹V领针织毛衣", "chosen": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"深绿与藏蓝\", \"材质\": \"针织\", \"款式\": \"V领条纹\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中毛衣的条纹配色（深绿与藏蓝）、V领设计及针织材质，未使用夸大或虚假宣传用语，无极限词、功效承诺或品牌傍靠，属性与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"深绿与藏蓝\", \"材质\": \"针织\", \"款式\": \"V领条纹\"}, \"violation\": true, \"reason\": \"描述中‘深绿与藏蓝’存在颜色表述模糊，可能误导消费者对实际色差的判断，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00438.jpg", "image": "data/raw/images/product_00438.jpg", "prompt": "黑色表盘黄色刻度计时码表，不锈钢与碳纤维纹理表带", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑黄配色\", \"材质\": \"不锈钢与碳纤维纹理\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中手表的黑黄配色、计时码表功能及不锈钢与碳纤维纹理表带材质，未使用极限词或虚标功效，品牌标识‘CARRERA’为可见设计元素而非冒用，整体描述真实合规。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红白配色\", \"材质\": \"皮革与橡胶\", \"款式\": \"机械表\"}, \"violation\": false, \"reason\": \"商品描述中红白配色、皮革与橡胶材质及机械表款式与图中黑黄配色、不锈钢碳纤维表带及计时码表功能不符，但未涉及虚假宣传或极限词。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01635.jpg", "image": "data/raw/images/product_01635.jpg", "prompt": "深蓝色修身牛仔裤，金色缝线设计", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色牛仔布材质的修身款牛仔裤，金色缝线细节清晰可见，描述准确反映商品真实属性。未使用极限词、未虚标材质或夸大功效，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身\"}, \"violation\": true, \"reason\": \"描述中‘修身’属隐性承诺，可能误导消费者，构成虚假宣传。金色缝线为常规工艺，不应作为卖点强调，存在夸大嫌疑。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00320.jpg", "image": "data/raw/images/product_00320.jpg", "prompt": "深棕色皮革手提托特包，配金属扣饰和肩带", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"皮革\", \"款式\": \"手提托特包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中包袋的深棕色、皮革材质及手提托特包款式，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"帆布\", \"款式\": \"斜挎包\"}, \"violation\": false, \"reason\": \"商品描述中颜色为浅蓝色、材质为帆布、款式为斜挎包，与图中深棕色皮革手提托特包不符，但未使用违规词，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02461.jpg", "image": "data/raw/images/product_02461.jpg", "prompt": "深蓝色修身男士休闲裤", "chosen": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色修身款男士休闲裤，材质从纹理判断为棉混纺，与描述完全一致。未使用极限词、未虚标材质或夸大功效，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"聚酯纤维\", \"款式\": \"宽松阔腿\"}, \"violation\": false, \"reason\": \"图片展示为浅灰色宽松阔腿款男士休闲裤，材质为聚酯纤维，与描述基本一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01751.jpg", "image": "data/raw/images/product_01751.jpg", "prompt": "这款优雅的连衣裙采用轻盈雪纺材质，搭配精致刺绣图案，适合日常穿搭与约会场合。", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": true, \"reason\": \"商品描述中提及'连衣裙'和'雪纺材质'，但主图展示为白色短袖T恤，材质为棉，且无连衣裙特征 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"雪纺\", \"款式\": \"长袖连衣裙\"}, \"violation\": true, \"reason\": \"商品描述称其为连衣裙且材质为雪纺，但主图展示为黑色长袖连衣裙，与实际白色短袖T恤不符，存在严重误导\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02259.jpg", "image": "data/raw/images/product_02259.jpg", "prompt": "蓝白竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件蓝白竖条纹长袖衬衫，颜色、款式与描述完全一致，材质从织物纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黑格纹\", \"材质\": \"涤纶\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为红黑格纹短袖休闲衬衫，材质为涤纶，与描述中的蓝白条纹长袖棉质衬衫不符，但未涉及违规词或侵权问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01620.jpg", "image": "data/raw/images/product_01620.jpg", "prompt": "男士中蓝色修身牛仔裤", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"中蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为一条中蓝色的男士牛仔裤，材质为典型牛仔布，版型为修身直筒，与描述完全一致。未使用极限词、未夸大功能、未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"中蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": true, \"reason\": \"描述中‘修身’属于隐性极限词，易引导消费者产生过度期待，存在夸大宣传风险，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01380.jpg", "image": "data/raw/images/product_01380.jpg", "prompt": "紫色女士短袖Polo衫，胸前有小刺绣图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为紫色女士短袖Polo衫，材质从织物纹理判断为棉质，款式为标准翻领短袖，胸前有白色刺绣标识。描述未使用极限词、未虚标材质、未涉及品牌侵权或功效夸大，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01504.jpg", "image": "data/raw/images/product_01504.jpg", "prompt": "浅灰色条纹商务领带", "chosen": "{\"category\": \"领带\", \"attributes\": {\"颜色\": \"浅灰\", \"材质\": \"涤纶\", \"款式\": \"条纹\"}, \"violation\": false, \"reason\": \"图片显示为浅灰色带有细密竖条纹的领带，材质为常见涤纶织物，描述准确反映其颜色、纹理与品类。未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"领带\", \"attributes\": {\"颜色\": \"浅灰\", \"材质\": \"涤纶\", \"款式\": \"条纹\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00922.jpg", "image": "data/raw/images/product_00922.jpg", "prompt": "深蓝色钥匙图案印花短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为深蓝色圆领短袖T恤，正面印有白色钥匙图案，与描述完全一致。材质未虚标，无夸大功效或极限词，未使用品牌名称或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为浅灰色V领短袖T恤，正面印有白色钥匙图案，材质为聚酯纤维，与描述一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00693.jpg", "image": "data/raw/images/product_00693.jpg", "prompt": "棕色绒面革系带商务男鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"绒面革\", \"款式\": \"系带商务\"}, \"violation\": false, \"reason\": \"图片显示为一双棕色绒面革材质的系带男鞋，鞋型为经典商务款式，描述准确反映其颜色、材质与款式特征。未使用极限词或夸大宣传，未虚标材质（如标注为真皮但实际为合成革），也无傍名牌或侵权表述，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"绒面革\", \"款式\": \"系带商务\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02335.jpg", "image": "data/raw/images/product_02335.jpg", "prompt": "粉色系几何印花短袖连衣裙，V领设计，休闲日常款", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"粉色系多色印花\", \"材质\": \"棉质混纺\", \"款式\": \"V领短袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中服饰的粉色为主调、几何图案印花、V领短袖连衣裙款式，材质标注为棉质混纺符合常见服装面料表述，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，整体描述与图片一致且合规。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深蓝色系\", \"材质\": \"羊毛针织\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为深蓝色系，材质为羊毛针织，款式为长袖连衣裙，与图中粉色印花、短袖设计存在明显差异，但未发现违规用语或虚假宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00118.jpg", "image": "data/raw/images/product_00118.jpg", "prompt": "NIKE同款男士商务皮鞋，小香风原单设计，百搭黑色乐福鞋", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』『小香风原单』等词，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权 — 图片商品为普通黑色皮革乐福鞋，无任何品牌标识，与NIKE或香奈儿（小香风）无关联\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"商品描述中‘NIKE同款’为常见营销表达，未直接使用品牌标识，且图片展示为普通乐福鞋，无明显侵权特征\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01183.jpg", "image": "data/raw/images/product_01183.jpg", "prompt": "黑色高腰运动紧身裤，采用弹性面料，适合健身训练", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"弹性面料\", \"款式\": \"高腰紧身\"}, \"violation\": false, \"reason\": \"商品为黑色高腰紧身运动裤，图片中可见其颜色、材质纹理及款式特征与描述一致。未使用极限词或夸大功效表述，未虚标材质，未涉及品牌侵权或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"弹性面料\", \"款式\": \"高腰紧身\"}, \"violation\": true, \"reason\": \"描述中‘适合健身训练’属于隐性功效承诺，涉嫌夸大宣传；‘弹性面料’未明确成分比例，存在虚标材质风险，不符合平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01960.jpg", "image": "data/raw/images/product_01960.jpg", "prompt": "最新款超低价全网最低绝对顶级男士格子短袖衬衫，时尚百搭必备单品", "chosen": "{\"category\": \"男式衬衫\", \"attributes\": {\"颜色\": \"红白蓝格纹\", \"材质\": \"棉质\", \"款式\": \"短袖格子衬衫\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"男式衬衫\", \"attributes\": {\"颜色\": \"红白蓝格纹\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述中使用的词汇属于常见营销表达，未发现明显违规内容，整体符合平台规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00714.jpg", "image": "data/raw/images/product_00714.jpg", "prompt": "黑色男士皮质系带正装皮鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色皮革材质的男士系带正装皮鞋，描述准确对应商品实际颜色、材质与款式，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": true, \"reason\": \"描述中‘皮质’一词易被误解为真皮，实际可能为合成革，存在材质虚标风险，建议明确标注具体材质成分。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00083.jpg", "image": "data/raw/images/product_00083.jpg", "prompt": "黑色硅胶表带Puma运动手表，白色表盘配红色数字刻度", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色/白色/红色\", \"材质\": \"硅胶\", \"款式\": \"运动款\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示：黑色硅胶表带、白色表盘、红色12和6数字刻度，搭配Puma品牌标识，属真实属性陈述。未使用极限词或虚标材质，未宣称功能功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色/白色/红色\", \"材质\": \"硅胶\", \"款式\": \"运动款\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00935.jpg", "image": "data/raw/images/product_00935.jpg", "prompt": "Puma品牌蓝白格纹织物表带腕表，银色金属表壳，简约数字刻度设计", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"织物表带，金属表壳\", \"款式\": \"运动休闲风\"}, \"violation\": false, \"reason\": \"商品描述准确对应图中Puma品牌标识、蓝白格纹织物表带及银色金属表壳，未使用极限词或虚标材质，未涉及仿冒或傍名牌表述，属性与图片一致，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"织物表带，金属表壳\", \"款式\": \"运动休闲风\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00110.jpg", "image": "data/raw/images/product_00110.jpg", "prompt": "黑色格纹短袖T恤，胸前红色跃马徽标", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色格纹图案短袖T恤，胸前有红色跃马徽标，与描述完全一致。材质未虚标，未使用极限词或夸大功效表述，未涉及品牌侵权用语，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中‘格纹’为图案性表述，易被误解为特殊工艺，涉嫌夸大宣传；‘红色跃马徽标’存在品牌联想风险，可能引发侵权争议。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01023.jpg", "image": "data/raw/images/product_01023.jpg", "prompt": "这款男士短袖格子衬衫采用100%纯棉材质，舒适透气，适合日常穿着。", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"混纺\", \"款式\": \"短袖格子衬衫\"}, \"violation\": true, \"reason\": \"描述中宣称‘100%纯棉’，但图片所示面料为混纺材质，表面光泽和纹理与纯棉不符，属虚假宣传 — 图片所示材质与描述的100%纯棉明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"红黑格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖格子衬衫\"}, \"violation\": true, \"reason\": \"描述称100%纯棉，但图片显示为红黑格纹的聚酯纤维长袖衬衫，材质与颜色均不符，属虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02313.jpg", "image": "data/raw/images/product_02313.jpg", "prompt": "紫红色印花短袖连衣裙，V领设计，几何花卉图案", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫红色\", \"材质\": \"棉质\", \"款式\": \"短袖V领印花连衣裙\"}, \"violation\": false, \"reason\": \"图片显示为紫红色底色搭配白色与粉色几何花卉图案的短袖连衣裙，V领设计，材质从纹理判断为棉质，描述中颜色、图案、款式均与实物一致，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合商品真实属性。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"紫红色\", \"材质\": \"棉质\", \"款式\": \"短袖V领印花连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘几何花卉图案’属于对图案的主观美化，涉嫌夸大宣传，且未明确标注实际成分比例，存在虚标材质风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01684.jpg", "image": "data/raw/images/product_01684.jpg", "prompt": "酒红色圆领短袖修身T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"图片显示为一件酒红色圆领短袖T恤，材质从纹理判断为棉质，款式为常规修身款，描述与实物一致。未使用极限词、未虚标材质、未宣称功效或傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中‘修身’属于暗示塑形效果，涉嫌虚假宣传；‘酒红色’为模糊色系，可能误导消费者，存在描述不准确风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00890.jpg", "image": "data/raw/images/product_00890.jpg", "prompt": "最新款绿色Polo衫，超低价秒杀，全网最低价，绝对顶级品质，限时抢购！", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"化纤\", \"款式\": \"长袖衬衫\"}, \"violation\": true, \"reason\": \"商品描述中使用绝对化用语，且图片显示为蓝色化纤长袖衬衫，与实际绿色棉质短袖Polo衫不符，存在虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
