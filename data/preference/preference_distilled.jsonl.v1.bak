{"image_file": "product_01405.jpg", "image": "data/raw/images/product_01405.jpg", "prompt": "粉色细条纹男士长袖衬衫，翻领设计，胸前单口袋", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为粉色细条纹男士衬衫，翻领、单胸袋、长袖卷起，与描述完全一致。未使用极限词或虚标材质，未提及品牌关联或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"涤纶\", \"款式\": \"短袖\"}, \"violation\": false, \"reason\": \"商品为蓝色涤纶短袖衬衫，符合描述，无违规用词，未涉及品牌或功效承诺，合规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00121.jpg", "image": "data/raw/images/product_00121.jpg", "prompt": "最新款英国国旗印花T恤，超低价抢购，全网最低价，绝对顶级时尚单品！", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"白、红、蓝\", \"材质\": \"棉\", \"款式\": \"短袖圆领印花\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑、黄、绿\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖立领印花\"}, \"violation\": true, \"reason\": \"商品描述中使用绝对化用语，且属性标注错误，实际为黑色黄绿色调聚酯纤维长袖立领款，与图示不符\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02057.jpg", "image": "data/raw/images/product_02057.jpg", "prompt": "白色底彩色花卉印花短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"白色底配粉色、蓝色、黄色花卉图案\", \"材质\": \"棉质\", \"款式\": \"短袖A字裙，领口拼接橄榄绿装饰\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：白色底布上印有粉色、蓝色及黄色花卉图案，短袖A字版型，领口与袖口有橄榄绿色拼接装饰。材质标注为棉质，符合常见印花连衣裙材质，未使用极限词或虚标成分，无品牌侵权表述，整体描述客观真实，符合电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑色底配红色、绿色花卉图案\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连衣裙，V领设计\"}, \"violation\": false, \"reason\": \"商品为黑色底布配红绿花卉，长袖V领款式，材质为聚酯纤维，描述与图片一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01567.jpg", "image": "data/raw/images/product_01567.jpg", "prompt": "深蓝色修身直筒牛仔裤", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色牛仔布材质的修身直筒款牛仔裤，描述准确反映商品真实属性，未使用极限词或夸大宣传，未虚标材质或款式，无傍名牌或虚假功效表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅粉色\", \"材质\": \"棉麻混纺\", \"款式\": \"阔腿\"}, \"violation\": false, \"reason\": \"商品为浅粉色棉麻混纺阔腿款牛仔裤，描述与实物一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00936.jpg", "image": "data/raw/images/product_00936.jpg", "prompt": "Puma品牌格纹布带金属表壳腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝白红格纹\", \"材质\": \"布质表带，金属表壳\", \"款式\": \"运动休闲风\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Puma品牌标识、蓝白红格纹布质表带及金属表壳结构，未使用极限词或虚标材质，未夸大功能，符合广告法要求，且未涉及傍名牌或侵权表述。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝白红格纹\", \"材质\": \"布质表带，金属表壳\", \"款式\": \"运动休闲风\"}, \"violation\": true, \"reason\": \"描述中‘Puma品牌’涉嫌暗示官方授权，未提供资质证明，存在虚假宣传风险，且‘金属表壳’可能夸大实际材质厚度，构成误导性表述。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01509.jpg", "image": "data/raw/images/product_01509.jpg", "prompt": "深蓝色男士长袖商务衬衫", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为一件深蓝色长袖翻领衬衫，材质从纹理判断为棉混纺，描述准确反映商品实际颜色、材质与款式，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"描述中‘深蓝色’可能暗示颜色饱和度极高，存在夸大宣传嫌疑，涉嫌违反广告法关于色彩描述的规范要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00239.jpg", "image": "data/raw/images/product_00239.jpg", "prompt": "ESPRIT品牌黑色皮质表带镶钻矩形女款手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革、金属、水晶\", \"款式\": \"矩形表盘、镶钻装饰\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中ESPRIT品牌手表的黑色皮质表带、矩形银色金属表壳及上下镶钻设计，未使用极限词或虚标材质，未宣称功效或仿冒其他品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革、金属、水晶\", \"款式\": \"矩形表盘、镶钻装饰\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01765.jpg", "image": "data/raw/images/product_01765.jpg", "prompt": "NIKE同款潮流印花T恤，小香风原单设计，LV平替时尚单品", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉\", \"款式\": \"圆领短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』『小香风原单』『LV平替』等词语，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"亮红色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领长袖印花\"}, \"violation\": true, \"reason\": \"商品描述中使用NIKE同款等品牌关联词，且实际为亮红色聚酯纤维V领长袖，与图示深蓝棉质圆领短袖不符，存在虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01446.jpg", "image": "data/raw/images/product_01446.jpg", "prompt": "黑色针织开衫长款毛衣外套", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"开衫\"}, \"violation\": false, \"reason\": \"图片显示为一件黑色长款针织开衫，具有明显竖条纹纹理和前排纽扣设计，与描述中‘黑色针织开衫长款毛衣外套’完全一致。未使用极限词、未虚标材质（如宣称羊绒/羊毛未标注则不违规）、未提及品牌或仿冒信息，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"开衫\"}, \"violation\": true, \"reason\": \"描述中‘长款’属于绝对化用语，易诱导消费者产生长度夸大联想，涉嫌违反广告法关于极限词的规定，存在虚假宣传风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00791.jpg", "image": "data/raw/images/product_00791.jpg", "prompt": "橙色表盘黑色橡胶带男士计时腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"橙色/黑色\", \"材质\": \"橡胶/金属\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中橙色表盘、黑色橡胶表带及金属表壳的外观特征，明确标注为计时码表款式，未使用极限词或虚标材质，品牌标识清晰且无傍名牌嫌疑，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色/白色\", \"材质\": \"皮革/陶瓷\", \"款式\": \"机械表\"}, \"violation\": false, \"reason\": \"商品描述中蓝色表盘与白色皮革表带的特征符合图中展示，陶瓷表壳质感明显，属机械表类型，无违规用词。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01457.jpg", "image": "data/raw/images/product_01457.jpg", "prompt": "这款时尚优雅的连衣裙采用轻盈雪纺材质，适合春季穿着，展现女性柔美气质。", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖商务衬衫\"}, \"violation\": true, \"reason\": \"商品描述中的‘连衣裙’与主图展示的男式衬衫明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"款式\": \"长袖商务衬衫\"}, \"violation\": false, \"reason\": \"商品图展示为男式衬衫，描述中‘连衣裙’可能为笔误或风格类比，整体仍属衬衫品类，未构成明显误导\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00352.jpg", "image": "data/raw/images/product_00352.jpg", "prompt": "棕色真皮手提包，配金属扣饰和双提手", "chosen": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"真皮\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"图片显示为棕色皮革材质的手提包，配备金属搭扣与双提手，描述准确反映商品真实属性。未使用极限词、未虚标材质（如‘头层牛皮’等未标注则不作承诺）、未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"真皮\", \"款式\": \"手提包\"}, \"violation\": true, \"reason\": \"描述中‘真皮’未注明具体皮种，涉嫌虚标材质，存在误导消费者风险，不符合广告法对商品属性真实性的要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02171.jpg", "image": "data/raw/images/product_02171.jpg", "prompt": "黑色皮革交叉带凉拖鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"交叉带凉拖\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色皮革材质的交叉带凉拖鞋，描述准确对应其颜色、材质与款式特征，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"交叉带凉拖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02331.jpg", "image": "data/raw/images/product_02331.jpg", "prompt": "这款印花连衣裙包治百病，一抹白，7天瘦10斤，穿上瞬间变美！", "chosen": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"紫色、蓝色、红色、黄色\", \"材质\": \"棉质\", \"款式\": \"印花长袖连衣裙\"}, \"violation\": true, \"reason\": \"描述中包含『包治百病』『一抹白』『7天瘦10斤』等不可能实现的功效承诺，与图片展示的普通印花连衣裙属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"紫色、蓝色、红色、黄色\", \"材质\": \"棉质\", \"款式\": \"印花长袖连衣裙\"}, \"violation\": true, \"reason\": \"该商品存在夸大宣传问题，描述内容与实际不符，违反相关平台规范\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01311.jpg", "image": "data/raw/images/product_01311.jpg", "prompt": "男士多色横条纹Polo衫，含蓝绿粉白条纹，胸前有徽章图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝、绿、粉、白\", \"材质\": \"棉混纺\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的条纹Polo衫，颜色为蓝、绿、粉、白相间横条纹，款式为短袖翻领Polo，胸前有品牌徽章，材质标注为棉混纺符合常见此类服装材质，未使用极限词或虚标材质，未涉及傍名牌或夸大功效，整体描述与图片一致且合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝、绿、粉、白\", \"材质\": \"棉混纺\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘多色横条纹’存在夸大色彩数量嫌疑，实际仅四种颜色，属虚标；‘棉混纺’未明确比例，涉嫌模糊材质，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00754.jpg", "image": "data/raw/images/product_00754.jpg", "prompt": "黑色表盘男士多功能皮带手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"多功能\"}, \"violation\": false, \"reason\": \"商品描述为'黑色表盘男士多功能皮带手表'，与图片中黑色表盘、银色表壳、黑色皮革表带及多指针功能设计完全一致。未使用极限词或夸大功效表述，未虚标材质（表带为真实皮革纹理），品牌标识清晰且无傍名牌嫌疑，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"多功能\"}, \"violation\": true, \"reason\": \"描述中'多功能'涉嫌夸大功能，实际仅具备日期和星期显示，未体现复杂计时功能，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
