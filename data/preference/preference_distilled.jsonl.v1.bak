{"image_file": "product_01749.jpg", "image": "data/raw/images/product_01749.jpg", "prompt": "深绿色圆领短袖修身T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深绿色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"图片中展示的为一件深绿色圆领短袖T恤，面料呈现棉质特征，款式为常规修身款，描述准确反映商品真实属性。未使用极限词、未夸大功能、未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深绿色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中‘修身’属于隐性夸大，暗示塑形效果，涉嫌虚假宣传；‘棉质’未标注比例，存在虚标材质风险，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00028.jpg", "image": "data/raw/images/product_00028.jpg", "prompt": "淡紫色印花圆领短袖T恤，正面印有世界地图与英文标语", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"淡紫色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中T恤的淡紫色、圆领短袖款式及正面世界地图与英文印花图案，未使用极限词或夸大宣传，材质标注为常见棉质符合常规认知，无仿冒品牌标识或虚假功效承诺，整体符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为深蓝色V领短袖，材质为聚酯纤维，符合描述，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01015.jpg", "image": "data/raw/images/product_01015.jpg", "prompt": "黑白格纹短袖衬衫男式休闲工装风", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"商品为黑白格纹短袖衬衫，图中可见其格纹图案、短袖设计及胸前口袋细节，描述准确反映实际款式与颜色。未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品为蓝白格纹长袖衬衫，材质为聚酯纤维，图中可见其格纹图案与长袖设计，描述符合实际。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02441.jpg", "image": "data/raw/images/product_02441.jpg", "prompt": "棕色短袖工装衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"棉质\", \"款式\": \"短袖工装\"}, \"violation\": false, \"reason\": \"图片显示为一件棕色短袖衬衫，胸前有两个带扣口袋，符合工装风格，材质从视觉判断为棉质，描述中未使用极限词或虚标材质，未提及品牌或仿冒信息，整体描述与实物一致，无夸大宣传或侵权嫌疑。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖休闲\"}, \"violation\": false, \"reason\": \"商品为蓝色长袖休闲衬衫，材质为聚酯纤维，符合描述，无夸大或侵权内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00716.jpg", "image": "data/raw/images/product_00716.jpg", "prompt": "黑色皮质男士套脚商务休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"套脚\"}, \"violation\": false, \"reason\": \"商品为黑色皮质套脚男鞋，描述准确反映图片中鞋款的颜色、材质与款式特征，未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"套脚\"}, \"violation\": true, \"reason\": \"描述中‘皮质’可能暗示真皮，但图片无法确认材质真实性，存在虚标风险，属违规宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01002.jpg", "image": "data/raw/images/product_01002.jpg", "prompt": "米白色男士短袖Polo衫，胸前印有蓝色飞天机器图案和文字", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为米白色，材质从织物纹理判断为棉质，款式为标准Polo领短袖。胸前图案与文字清晰可见，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01310.jpg", "image": "data/raw/images/product_01310.jpg", "prompt": "蓝棕绿条纹男士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色、棕色、橄榄绿\", \"材质\": \"棉质混纺\", \"款式\": \"条纹Polo领短袖\"}, \"violation\": false, \"reason\": \"图片显示为蓝、棕、橄榄绿三色横条纹Polo衫，领口与袖口为深棕色，左胸有品牌徽章，描述准确反映实际商品颜色与款式。未使用极限词或虚标材质，未涉及仿冒品牌标识，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色、棕色、橄榄绿\", \"材质\": \"棉质混纺\", \"款式\": \"条纹Polo领短袖\"}, \"violation\": false, \"reason\": \"该商品整体展示清晰，未发现明显违规内容，符合平台基本审核要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01319.jpg", "image": "data/raw/images/product_01319.jpg", "prompt": "白色扎染印花男士短袖T恤，印有摩托车手图案和'RT RIDER'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：T恤主体为白色，带有灰黑色扎染效果，正面印有四名摩托车手图案及蓝色'RT RIDER'文字，下摆有蓝灰色渐变设计。描述中未使用极限词、未虚标材质（棉质常见于此类T恤）、未宣称功效或傍名牌，所有属性与实物一致，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01880.jpg", "image": "data/raw/images/product_01880.jpg", "prompt": "浅灰色印花立领短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"浅灰\", \"材质\": \"棉质\", \"款式\": \"立领短袖A字裙\"}, \"violation\": false, \"reason\": \"图片显示为浅灰色底色带有细密花纹的连衣裙，立领设计、短袖、A字版型与描述完全一致。材质从纹理判断为棉质类面料，未标注虚假材质或夸大功效，无极限词、无品牌侵权表述，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深蓝\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为深蓝色聚酯纤维材质，圆领长袖设计，整体风格符合描述，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01155.jpg", "image": "data/raw/images/product_01155.jpg", "prompt": "这款白色T恤穿上立刻变瘦10斤，包治百病，一抹白，时尚又显瘦，7天轻松拥有完美身材！", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能实现的功效承诺，与图片展示的普通T恤属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，内容不符合平台规范要求，具体问题需进一步核实\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00755.jpg", "image": "data/raw/images/product_00755.jpg", "prompt": "黑色表盘黄色刻度的Carrera计时腕表，钢带与碳纤维纹理表带结合设计", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑黄配色\", \"材质\": \"不锈钢与碳纤维\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中手表的黑色表盘、黄色数字刻度、Carrera品牌标识及钢制表壳与碳纤维纹理表带的组合材质，未使用极限词或虚标功能，未涉及仿冒或侵权表述，符合真实属性展示要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑黄配色\", \"材质\": \"不锈钢与碳纤维\", \"款式\": \"计时码表\"}, \"violation\": true, \"reason\": \"描述中‘碳纤维纹理表带’涉嫌虚标材质，实际为复合材料，存在误导消费者风险，不符合真实属性要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00369.jpg", "image": "data/raw/images/product_00369.jpg", "prompt": "白色Nike Dri-FIT半拉链长袖运动上衣", "chosen": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"Dri-FIT面料\", \"款式\": \"半拉链长袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为纯白，材质标注为Dri-FIT符合品牌标识，款式为半拉链长袖设计，未使用极限词或夸大宣传，未虚标材质或仿冒其他品牌，整体描述与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"Dri-FIT面料\", \"款式\": \"半拉链长袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01232.jpg", "image": "data/raw/images/product_01232.jpg", "prompt": "PUMA同款潮流短袖，NIKE平替设计，时尚运动风必备单品", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色与白色拼接\", \"材质\": \"棉质混纺\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中使用『PUMA同款』『NIKE平替』等词汇，暗示与知名品牌PUMA、NIKE存在关联，但图片显示商品为普通运动T恤，未见授权标识，涉嫌擅自使用他人品牌作宣传，侵犯注册商标专用权\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色与白色拼接\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述中的‘PUMA同款’‘NIKE平替’为常见营销表达，未明确宣称品牌关联，且图片展示为普通运动T恤，无侵权标识，不构成违规\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00982.jpg", "image": "data/raw/images/product_00982.jpg", "prompt": "紫绿白格纹长袖衬衫男款休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫绿白格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领带胸袋\"}, \"violation\": false, \"reason\": \"图片展示为男士格纹长袖衬衫，颜色为紫色、绿色与白色交织的格子图案，材质从织物纹理判断为棉混纺，款式为标准翻领带两个前胸口袋，描述准确反映商品真实属性，未使用极限词或虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫绿白格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领带胸袋\"}, \"violation\": true, \"reason\": \"描述中‘休闲衬衣’属于模糊宣传，易诱导消费者误认为具备特定功能属性，构成虚假暗示，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02447.jpg", "image": "data/raw/images/product_02447.jpg", "prompt": "深紫色纯棉男士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"纯棉\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为一件深紫色的男士短袖Polo衫，领口有两粒纽扣，左袖口处有小标识，整体为纯色设计。描述中颜色、材质和款式均与实物一致，未使用极限词或夸大宣传，未虚标材质，也无傍名牌嫌疑，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"纯棉\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘纯棉’可能虚标，实际面料未提供检测报告；‘深紫色’存在色差风险，图片与实物不符可能性高，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00862.jpg", "image": "data/raw/images/product_00862.jpg", "prompt": "白色简约交叉带平底人字拖", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"人造革\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"图片显示为白色交叉带设计的平底人字拖，鞋面材质为光滑人造革，鞋底为浅棕色橡胶材质，描述准确反映商品真实属性。未使用极限词、未虚标材质（如‘真皮’）、未宣称功效或夸大用途，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"人造革\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"描述中‘简约’属主观夸大，易引导消费者误认为极简设计，涉嫌虚假宣传，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01420.jpg", "image": "data/raw/images/product_01420.jpg", "prompt": "男士黑白格纹短袖衬衫，休闲百搭款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件黑白格纹短袖衬衫，描述准确对应其颜色、款式与材质特征，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘休闲百搭款’属于夸大宣传用语，暗示适用所有场合，存在误导性，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01299.jpg", "image": "data/raw/images/product_01299.jpg", "prompt": "紫色印花男士短袖T恤，正面印有'URBAN KINFOLK'艺术字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"印花短袖\"}, \"violation\": false, \"reason\": \"商品为紫色棉质短袖T恤，正面印有'URBAN KINFOLK'艺术字体图案，描述准确反映图中颜色、材质与款式特征。未使用极限词或夸大宣传，无虚标材质、傍名牌等违规行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"涤纶\", \"款式\": \"纯色短袖\"}, \"violation\": false, \"reason\": \"商品为蓝色涤纶纯色短袖T恤，正面无印花图案，描述与图中信息一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01028.jpg", "image": "data/raw/images/product_01028.jpg", "prompt": "深蓝色修身款男士牛仔裤，经典五袋设计，黄色缝线点缀", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色牛仔布材质的男士修身直筒牛仔裤，具有标准五袋结构与黄色明线装饰，描述准确反映商品实际外观。未使用极限词、未虚标材质（如‘纯棉’‘有机’等未经认证表述），未提及品牌或仿冒信息，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉麻混纺\", \"款式\": \"宽松阔腿\"}, \"violation\": false, \"reason\": \"商品为浅蓝色棉麻混纺材质的宽松阔腿牛仔裤，符合描述中提及的款式与面料特征，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01571.jpg", "image": "data/raw/images/product_01571.jpg", "prompt": "黑色高弹力修身长裤，束脚设计适合居家休闲穿着", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"束脚修身\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为纯黑色，材质从纹理判断为棉混纺类弹性面料，款式为束脚修身长裤，未使用极限词或虚标材质，无夸大功效或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉混纺\", \"款式\": \"束脚修身\"}, \"violation\": true, \"reason\": \"描述中‘高弹力’属于夸大宣传，未提供检测报告支持，涉嫌虚假功效宣称，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02530.jpg", "image": "data/raw/images/product_02530.jpg", "prompt": "男士红黑格纹长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黑格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件红黑格纹长袖衬衫，颜色、款式与描述完全一致，材质标注为棉混纺符合常见商务衬衫材质，未使用极限词或虚标材质，无品牌侵权表述，整体描述客观真实，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黑格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01132.jpg", "image": "data/raw/images/product_01132.jpg", "prompt": "红色拼白袖儿童运动风短袖T恤，印有数字39和ATHLETIC DEP.字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白拼色\", \"材质\": \"棉质\", \"款式\": \"短袖拼接T恤\"}, \"violation\": false, \"reason\": \"商品为红白拼色儿童短袖T恤，主体红色，袖子白色，正面印有'39'及'ATHLETIC DEP.'等图案文字，描述准确反映图中颜色、材质（棉质）、款式特征，未使用极限词或虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白拼色\", \"材质\": \"棉质\", \"款式\": \"短袖拼接T恤\"}, \"violation\": true, \"reason\": \"描述中'运动风'属于主观夸大，易诱导消费者误认为具备专业运动功能，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00091.jpg", "image": "data/raw/images/product_00091.jpg", "prompt": "黑色皮质手提包配花朵流苏装饰", "chosen": "{\"category\": \"女包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品为黑色皮革材质的手提包，正面有花朵造型及流苏装饰，图片与描述一致。未使用极限词、未虚标材质（如‘真皮’未标注为‘头层牛皮’等未证实信息），未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"女包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"帆布\", \"款式\": \"斜挎包\"}, \"violation\": false, \"reason\": \"商品为棕色帆布材质的斜挎包，带有花朵和流苏装饰，图片与描述一致。未发现违规用词或侵权问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
