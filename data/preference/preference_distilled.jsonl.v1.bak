{"image_file": "product_00760.jpg", "image": "data/raw/images/product_00760.jpg", "prompt": "米白色荔枝纹皮革手提包", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"图片显示为米白色荔枝纹纹理的皮革手提包，描述准确对应商品实际颜色、材质与款式，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"帆布\", \"款式\": \"斜挎包\"}, \"violation\": false, \"reason\": \"商品为深蓝色帆布材质的斜挎包，颜色与材质描述相符，款式信息准确，无违规用语，符合平台规范。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00698.jpg", "image": "data/raw/images/product_00698.jpg", "prompt": "黑色皮质链式手镯女表，方形表盘镶钻设计", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革与金属\", \"款式\": \"链式手镯款\"}, \"violation\": false, \"reason\": \"商品为ESPRIT品牌黑色皮质与金属链式腕表，表盘为方形并镶嵌四颗装饰钻，描述准确反映其颜色、材质与款式特征。未使用极限词或夸大功效表述，未虚标材质，未涉及傍名牌或侵权用语，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革与金属\", \"款式\": \"链式手镯款\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02443.jpg", "image": "data/raw/images/product_02443.jpg", "prompt": "深蓝白条纹男士Polo衫，红色领口绣有BASICS字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝、白、红\", \"材质\": \"棉质\", \"款式\": \"条纹Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：深蓝色底配白色横条纹，领口为红色，胸前印有'BASICS VARSITY EST 1990'字样，与图中一致。未使用极限词或虚标材质，未涉及品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰、黄、黑\", \"材质\": \"聚酯纤维\", \"款式\": \"纯色T恤\"}, \"violation\": false, \"reason\": \"商品为浅灰色底配黄色条纹，黑色领口，材质为聚酯纤维，属于纯色T恤款式，与描述一致，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00060.jpg", "image": "data/raw/images/product_00060.jpg", "prompt": "Esprit品牌方形金属表壳黑色皮带手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色表盘，银色表壳，黑色表带\", \"材质\": \"金属表壳，皮革表带\", \"款式\": \"方形表盘，简约商务风\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Esprit品牌方形金属表壳与黑色皮质表带的特征，颜色、材质、款式均与图片一致。未使用极限词或夸大功效表述，未虚标材质（如标注为‘真皮’但实为合成革），亦无傍名牌或侵权用语，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色表盘，银色表壳，黑色表带\", \"材质\": \"金属表壳，皮革表带\", \"款式\": \"方形表盘，简约商务风\"}, \"violation\": true, \"reason\": \"描述中‘金属表壳’未明确标注为不锈钢，存在材质虚标风险；‘简约商务风’属主观夸大宣传，易误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02439.jpg", "image": "data/raw/images/product_02439.jpg", "prompt": "深灰色短袖工装衬衫，胸前双口袋设计", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"棉质\", \"款式\": \"短袖工装衬衫\"}, \"violation\": false, \"reason\": \"图片显示为深灰色短袖衬衫，胸前有两个带扣口袋，材质从纹理判断为棉质，描述与实物完全一致。未使用极限词、未虚标材质或功效，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"涤纶\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品为浅蓝色长袖衬衫，材质为涤纶，胸前双口袋设计，符合描述，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00476.jpg", "image": "data/raw/images/product_00476.jpg", "prompt": "穿上这款跑鞋，包治百病，7天瘦10斤，一抹白，轻松燃脂不费力！", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑色与黄色\", \"材质\": \"网布与橡胶\", \"款式\": \"透气缓震跑鞋\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能实现的功效承诺，与图片所示的普通运动鞋属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白色与蓝色\", \"材质\": \"皮革与金属\", \"款式\": \"高帮篮球鞋\"}, \"violation\": true, \"reason\": \"商品描述存在虚假功效承诺，且属性标注为白色与蓝色的高帮篮球鞋，与图中黑色黄色跑鞋明显不符，属属性错误\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01152.jpg", "image": "data/raw/images/product_01152.jpg", "prompt": "黑色印花短袖T恤，正面印有白色艺术字体图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为黑色短袖T恤，正面印有白色'la Ciffure'艺术字样及花卉图案，与描述完全一致。材质未虚标，无极限词或功效夸大表述，未使用品牌侵权词汇，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖T恤\"}, \"violation\": false, \"reason\": \"商品为白色长袖T恤，材质为聚酯纤维，正面印有'la Ciffure'字样，与描述一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00817.jpg", "image": "data/raw/images/product_00817.jpg", "prompt": "黑色男士皮质套脚商务休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"套脚式\"}, \"violation\": false, \"reason\": \"商品为黑色皮革材质的男士套脚鞋，图片清晰展示其颜色、材质与款式特征，描述准确无误。未使用极限词或夸大功效表述，未虚标材质，未涉及品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"帆布\", \"款式\": \"系带式\"}, \"violation\": false, \"reason\": \"商品为棕色帆布材质的男士系带鞋，图片展示清晰，颜色与材质描述一致，款式特征符合系带设计，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00873.jpg", "image": "data/raw/images/product_00873.jpg", "prompt": "黑色皮革手提包，配金色金属环扣和双肩带", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮革材质的手提包，配金色金属环扣与双肩带，描述准确反映商品真实属性。未使用极限词、未虚标材质（如‘真皮’未标注但图中可见皮质纹理）、未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00491.jpg", "image": "data/raw/images/product_00491.jpg", "prompt": "红色几何图案耐克半拉链运动上衣", "chosen": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"合成纤维\", \"款式\": \"半拉链长袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中红色几何图案的耐克半拉链运动上衣，颜色、材质（合成纤维）、款式（半拉链长袖）均与实物一致，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"合成纤维\", \"款式\": \"半拉链长袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00554.jpg", "image": "data/raw/images/product_00554.jpg", "prompt": "蓝色格纹系带短袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"格纹系带短袖\"}, \"violation\": false, \"reason\": \"商品描述为'蓝色格纹系带短袖衬衫'，与图片中展示的蓝白格纹、前襟系带设计、短袖款式完全一致。材质未虚标，未使用极限词或夸大功效表述，无傍名牌或侵权用语，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述为红色聚酯纤维长袖衬衫，图片中展示的为蓝白格纹短袖上衣，颜色与款式不符，但未发现违规用语，整体无明显违法信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00096.jpg", "image": "data/raw/images/product_00096.jpg", "prompt": "蓝白竖条纹长袖男士衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件蓝白竖条纹长袖衬衫，颜色、条纹走向与描述一致，材质从织物纹理判断为棉质，符合常规男装衬衫特征。描述未使用极限词或夸大功效表述，未虚标材质，未涉及品牌侵权，整体信息真实准确，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中‘蓝白竖条纹’可能暗示唯一性，存在隐性极限词嫌疑，且未明确标注是否为纯棉，涉嫌虚标材质，不符合平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00272.jpg", "image": "data/raw/images/product_00272.jpg", "prompt": "深棕色男士皮质套脚休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"皮革\", \"款式\": \"套脚休闲鞋\"}, \"violation\": false, \"reason\": \"商品为深棕色皮革材质的套脚式男鞋，图片清晰展示其颜色、材质与款式特征，描述准确无误。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"帆布\", \"款式\": \"运动鞋\"}, \"violation\": false, \"reason\": \"商品为浅灰色帆布材质的运动鞋，图片清晰展示其颜色、材质与款式特征，描述准确无误。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合电商合规要求。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02514.jpg", "image": "data/raw/images/product_02514.jpg", "prompt": "深蓝色修身款男士商务西裤", "chosen": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"混纺面料\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色修身直筒西裤，搭配白色衬衫与棕色皮鞋，整体风格符合商务正装定位。描述中颜色、款式与图示一致，未使用‘顶级’‘纯棉’等虚标材质或夸大功效词汇，未涉及品牌侵权或极限词，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"混纺面料\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00622.jpg", "image": "data/raw/images/product_00622.jpg", "prompt": "银灰黄配色网面透气跑步鞋", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"银灰/黄色\", \"材质\": \"网面\", \"款式\": \"跑步鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中鞋款的银灰色主体、黄色点缀及网面材质，款式为标准跑步鞋设计。未使用极限词或夸大功效表述，未虚标材质，无品牌侵权用语，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"银灰/黄色\", \"材质\": \"网面\", \"款式\": \"跑步鞋\"}, \"violation\": true, \"reason\": \"描述中‘透气’属于功能性夸大，未提供检测依据，涉嫌虚假宣传；‘网面’表述不严谨，可能存在非全网面区域，构成材质虚标。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01019.jpg", "image": "data/raw/images/product_01019.jpg", "prompt": "酒红色格纹短袖衬衫男式休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红与白色相间\", \"材质\": \"棉质混纺\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件酒红色与白色相间的格纹短袖衬衫，具有两个胸前口袋及纽扣设计，描述准确反映其颜色、材质和款式特征。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红与白色相间\", \"材质\": \"棉质混纺\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规问题，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02056.jpg", "image": "data/raw/images/product_02056.jpg", "prompt": "蓝白橙色佩斯利印花短袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白橙色\", \"材质\": \"棉质混纺\", \"款式\": \"V领短袖印花连衣裙\"}, \"violation\": false, \"reason\": \"图片中展示的连衣裙为蓝白橙色佩斯利图案，V领设计，短袖款式，下摆有白色包边，与描述完全一致。材质未虚标，无使用极限词或夸大功效表述，未涉及品牌侵权或虚假宣传，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黑灰\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为红黑灰配色，聚酯纤维材质，长袖设计，与描述相符，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02495.jpg", "image": "data/raw/images/product_02495.jpg", "prompt": "浅灰色细条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉混纺\", \"款式\": \"商务正装\"}, \"violation\": false, \"reason\": \"图片显示为浅灰色细条纹长袖衬衫，材质为棉混纺，款式为标准商务正装，描述与实物一致。未使用极限词、未虚标材质、未宣称功效或傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉混纺\", \"款式\": \"商务正装\"}, \"violation\": true, \"reason\": \"描述中‘细条纹’可能暗示特定工艺，存在夸大宣传嫌疑，且未明确标注条纹密度，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00947.jpg", "image": "data/raw/images/product_00947.jpg", "prompt": "紫白格纹短袖衬衫女款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领衬衫\"}, \"violation\": false, \"reason\": \"商品描述为‘紫白格纹短袖衬衫女款’，与图片中模特穿着的紫色与白色相间的格子图案、短袖设计、翻领结构完全一致。材质未虚标，未使用极限词或夸大功效表述，无品牌侵权暗示，符合真实商品属性展示要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为蓝白格纹，材质为聚酯纤维，款式为长袖连衣裙，与图片展示内容一致，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00826.jpg", "image": "data/raw/images/product_00826.jpg", "prompt": "玫瑰金色金属质感交叉绑带坡跟凉拖", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"玫瑰金\", \"材质\": \"金属质感人造革\", \"款式\": \"交叉绑带坡跟凉拖\"}, \"violation\": false, \"reason\": \"商品描述准确对应图中玫瑰金色调、金属光泽表面及交叉绑带设计，材质为常见人造革，未虚标真皮或天然材料；款式明确为坡跟凉拖，无夸大功效或极限词表述，符合广告法要求，未涉及品牌侵权或虚假宣传。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"纯棉布料\", \"款式\": \"平底帆布鞋\"}, \"violation\": false, \"reason\": \"商品为深蓝色纯棉布料平底帆布鞋，颜色与材质均符合描述，款式为经典平底设计，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00062.jpg", "image": "data/raw/images/product_00062.jpg", "prompt": "PUMA同款智能运动手表，时尚潮流设计，媲美NIKE智能穿戴，科技感十足", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"硅胶\", \"款式\": \"电子表\"}, \"violation\": true, \"reason\": \"描述中使用『PUMA同款』『媲美NIKE智能穿戴』等词语，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权 — 实际商品为PUMA品牌，但描述通过蹭NIKE、PUMA等大牌进行不当引流\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红色\", \"款式\": \"电子表\"}, \"violation\": false, \"reason\": \"描述中‘PUMA同款’为常见营销表达，未直接使用品牌标识，且商品确为智能运动手表，符合品类特征，不构成侵权\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01179.jpg", "image": "data/raw/images/product_01179.jpg", "prompt": "橙色短袖T恤，正面印有彩色几何图案的'JUST DO IT'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为橙色棉质圆领短袖T恤，正面印有'JUST DO IT'艺术字体图案，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为蓝色聚酯纤维V领短袖T恤，正面印有'JUST DO IT'图案，描述与图中颜色、材质及款式一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01020.jpg", "image": "data/raw/images/product_01020.jpg", "prompt": "蓝红白格纹长袖衬衫男式休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝红白格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领带胸袋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片中男士穿着的蓝红白格纹长袖衬衫，颜色、款式与图一致；材质标注为棉混纺符合常见此类衬衫实际成分，未虚标纯棉或特殊纤维；未使用极限词或功效承诺，无品牌侵权表述，整体描述客观真实，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝红白格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领带胸袋\"}, \"violation\": true, \"reason\": \"描述中‘休闲衬衣’属于模糊宣传，暗示适用场景广泛，存在夸大使用范围嫌疑，不符合客观描述要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02296.jpg", "image": "data/raw/images/product_02296.jpg", "prompt": "小香风原单男士衬衫，LV平替款，高级感十足，职场必备", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中使用『小香风原单』『LV平替』等词，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"深红色\", \"材质\": \"涤纶\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": true, \"reason\": \"商品描述中提及『小香风原单』『LV平替』等词，且实际为深红色涤纶短袖款，存在虚假宣传及品牌侵权嫌疑\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01558.jpg", "image": "data/raw/images/product_01558.jpg", "prompt": "银色金属表带镶钻女士石英手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属\", \"款式\": \"镶钻\"}, \"violation\": false, \"reason\": \"商品为银色金属材质的手表，表盘及表带均可见金属光泽，表扣处镶嵌有透明小钻，与描述中‘银色金属表带镶钻’完全一致。品牌标识清晰为ESPRIT，未使用极限词或虚标材质，无夸大功效或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属\", \"款式\": \"镶钻\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规问题，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00403.jpg", "image": "data/raw/images/product_00403.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"真皮\", \"款式\": \"船鞋\", \"鞋带\": \"黑色\", \"缝线\": \"浅色\", \"品牌标识\": \"Chippewa\"}, \"violation\": false, \"reason\": \"商品为Chippewa品牌的船鞋，鞋面为真皮材质，颜色为深棕色，符合高端商务皮鞋的描述，未发现违规内容。\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"帆布\", \"款式\": \"休闲运动鞋\", \"鞋带\": \"黑色\", \"缝线\": \"浅色\", \"品牌标识\": \"Chippewa\"}, \"violation\": false, \"reason\": \"商品为浅灰色帆布材质的休闲运动鞋，鞋面为帆布，颜色与描述不符，但未发现其他违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00377.jpg", "image": "data/raw/images/product_00377.jpg", "prompt": "浅粉色底花卉印花短袖T恤，宽松休闲款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅粉色\", \"材质\": \"棉混纺\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述中颜色、材质、款式均与图片一致，浅粉色底配灰粉花卉图案，短袖圆领设计，无夸大宣传或虚标材质，未使用极限词或品牌关联表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅粉色\", \"材质\": \"棉混纺\", \"款式\": \"短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中‘宽松休闲款’涉嫌暗示舒适度，属夸大宣传；‘花卉印花’未明确图案占比，存在误导性，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00437.jpg", "image": "data/raw/images/product_00437.jpg", "prompt": "这款白色背心采用100%纯棉材质，印有花卉和平标志图案，适合日常穿着。", "chosen": "{\"category\": \"背心\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉混纺\", \"款式\": \"无袖印花\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片所示面料具有光泽感且质地偏薄，实际为棉混纺材质，与宣称的100%纯棉明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"背心\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉混纺\", \"款式\": \"无袖印花\"}, \"violation\": true, \"reason\": \"该商品存在信息不符情况，整体审核判断为不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00442.jpg", "image": "data/raw/images/product_00442.jpg", "prompt": "灰紫色条纹宽松针织衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰紫拼色\", \"材质\": \"针织\", \"款式\": \"条纹宽松款\"}, \"violation\": false, \"reason\": \"商品描述为‘灰紫色条纹宽松针织衫’，与图片中展示的灰色底色、紫色及黑白条纹拼接、宽松版型的针织上衣完全一致。未使用极限词或夸大宣传，材质标注为‘针织’符合实际织物类型，颜色和款式描述准确无误，未涉及虚标或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黄拼色\", \"材质\": \"棉麻\", \"款式\": \"修身短款\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红黄拼色，材质为棉麻，款式为修身短款，与图中灰紫条纹宽松针织衫不符，但未发现违规宣传，故不判定违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02073.jpg", "image": "data/raw/images/product_02073.jpg", "prompt": "橙色棉质短袖连衣裙，领口与袖口有金色刺绣装饰", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"棉\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：衣物为橙色棉质短袖连衣裙，领口及袖口饰有金色刺绣，下摆有同色系织带边饰。描述未使用极限词、未虚标材质或夸大功效，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"丝绸\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为蓝色丝绸长袖连衣裙，领口有金色刺绣装饰，符合描述内容，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
