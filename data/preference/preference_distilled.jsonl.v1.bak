{"image_file": "product_02388.jpg", "image": "data/raw/images/product_02388.jpg", "prompt": "墨绿色长袖V领刺绣边饰连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"墨绿色\", \"材质\": \"棉质\", \"款式\": \"长袖V领连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中墨绿色长袖V领连衣裙，领口与袖口有红棕色刺绣边饰，材质为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合真实属性与合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"墨绿色\", \"材质\": \"棉质\", \"款式\": \"长袖V领连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘刺绣边饰’可能夸大实际工艺细节，存在虚标风险，且‘墨绿色’颜色表述不够精确，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01974.jpg", "image": "data/raw/images/product_01974.jpg", "prompt": "浅绿色格纹短袖衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅绿与白色相间\", \"材质\": \"棉质\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述为'浅绿色格纹短袖衬衫男款'，与图片中模特穿着的浅绿白相间格纹短袖衬衫完全一致，颜色、图案、款式均真实呈现。未使用极限词或夸大宣传，未虚标材质（图中无明显非棉标识），未涉及品牌侵权或傍名牌表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅绿与白色相间\", \"材质\": \"棉质\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00259.jpg", "image": "data/raw/images/product_00259.jpg", "prompt": "这款绿色皮质手提包，包治百病，7天瘦10斤，一抹白，时尚又健康！", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"皮革\", \"款式\": \"手提/斜挎\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能的功效承诺，与图片中实际为一款绿色皮革手提包的属性严重不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉布\", \"款式\": \"双肩包\"}, \"violation\": true, \"reason\": \"描述中声称具有瘦身美白功效，且属性标注为红色棉布双肩包，与图片中绿色皮革手提包严重不符，存在虚假宣传和属性错误\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02008.jpg", "image": "data/raw/images/product_02008.jpg", "prompt": "酒红色男士短袖Polo衫，拼色领口与袖口设计，胸前刺绣图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为酒红色，领口与袖口采用深蓝与白色拼接，胸前有品牌刺绣图案，整体为常规Polo衫款式。未使用极限词、未虚标材质（如‘纯棉’未标注则不承诺）、未涉及功效夸大或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘拼色领口’涉嫌暗示特殊工艺，实际为常规撞色设计，存在夸大宣传风险，不符合广告法规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00646.jpg", "image": "data/raw/images/product_00646.jpg", "prompt": "亮黄色男士印花短袖T恤，几何图案设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为亮黄色圆领短袖T恤，正面印有彩色几何拼贴图案，图中可见‘PUMA’字样但未突出品牌标识，描述仅陈述真实颜色、材质与款式，未使用极限词或虚标材质，未涉及侵权或夸大宣传，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中‘亮黄色’属于过度强调色彩，易引导消费者产生视觉错觉，涉嫌夸大宣传；‘几何图案设计’为模糊表述，存在虚标设计风格风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02448.jpg", "image": "data/raw/images/product_02448.jpg", "prompt": "男士宝蓝色纯色短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"宝蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为一件宝蓝色的男士短袖Polo衫，领口有两颗白色纽扣，面料呈现棉质纹理，与描述中‘宝蓝色纯色短袖Polo衫’完全一致。未使用极限词、未虚标材质（如宣称‘100%纯棉’但无检测依据），也未涉及品牌傍款或功效夸大，符合电商商品合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"宝蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘纯色’可能暗示无任何图案或瑕疵，但图片存在轻微织纹差异，涉嫌虚假宣传，不符合实际视觉效果。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02378.jpg", "image": "data/raw/images/product_02378.jpg", "prompt": "黑色底青绿色印花民族风连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色底配青绿色\", \"材质\": \"棉质\", \"款式\": \"民族风印花连衣裙\"}, \"violation\": false, \"reason\": \"图片显示为黑色底色搭配青绿色水滴状印花的连衣裙，领口与下摆有装饰性图案，袖口为七分袖设计，整体风格符合民族风特征。描述中颜色、材质（棉质）、款式均与图中一致，未使用极限词或虚标材质，无傍名牌或夸大功效表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色底配红色\", \"材质\": \"涤纶\", \"款式\": \"简约纯色连衣裙\"}, \"violation\": false, \"reason\": \"图片显示为白色底色搭配红色印花的连衣裙，材质为涤纶，整体为简约纯色风格，与描述一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02334.jpg", "image": "data/raw/images/product_02334.jpg", "prompt": "这款印花长裙包治百病，穿一次就瘦10斤，一抹白全身亮，效果立竿见影！", "chosen": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"红白蓝多色印花\", \"材质\": \"棉质\", \"款式\": \"长袖直筒印花裙\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能实现的功效承诺，与图片展示的普通印花连衣裙属性严重不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"纯黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖修身连衣裙\"}, \"violation\": true, \"reason\": \"商品描述存在虚假功效承诺，且属性标注为纯黑色聚酯纤维短袖款，与图中红白蓝印花棉质长袖不符，属属性错误\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02409.jpg", "image": "data/raw/images/product_02409.jpg", "prompt": "酒红色修身长裤，纯色简约设计，适合日常穿着", "chosen": "{\"category\": \"裤子\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"修身长裤\"}, \"violation\": false, \"reason\": \"图片中展示的为酒红色修身长裤，材质为棉质，款式为纯色简约修身款，与描述完全一致。未使用极限词、未夸大功效、未虚标材质，也无傍名牌或侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"裤子\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"修身长裤\"}, \"violation\": false, \"reason\": \"该商品整体符合平台审核要求，未发现明显违规问题，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00798.jpg", "image": "data/raw/images/product_00798.jpg", "prompt": "红色皮革质感托特包，双肩带设计，简约百搭", "chosen": "{\"category\": \"女包\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"人造革\", \"款式\": \"托特包\"}, \"violation\": false, \"reason\": \"图片显示为红色人造革材质的托特包，描述中准确标注了颜色、材质和款式，未使用‘真皮’等虚标用语，也未涉及极限词或品牌傍靠，整体描述与实物一致，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女包\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"人造革\", \"款式\": \"托特包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00271.jpg", "image": "data/raw/images/product_00271.jpg", "prompt": "小香风原单质感包包，LV平替款，高级皮质手提包", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"手提式\"}, \"violation\": true, \"reason\": \"描述中使用『小香风原单』『LV平替』等词，暗示与CHANEL、LV品牌相关，但图片商品为普通棕色皮革手提包，无任何品牌标识，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"棕色\", \"款式\": \"手提式\"}, \"violation\": false, \"reason\": \"商品描述中‘小香风’‘LV平替’为常见风格化表达，未直接使用品牌标识，属于正常营销用语，不构成侵权\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00880.jpg", "image": "data/raw/images/product_00880.jpg", "prompt": "金色镶钻方形Puma女士手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"金色\", \"材质\": \"金属表壳与表带，镶嵌仿水晶\", \"款式\": \"方形表盘，镶钻边框，Puma品牌标识\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中金色金属表壳、方形表盘及镶钻边框的特征，表带为编织纹理金属材质，表盘有Puma标志和数字12，未使用极限词或虚标材质，未宣称功效或冒用其他品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"皮革表带，塑料表壳\", \"款式\": \"圆形表盘，无镶钻装饰\"}, \"violation\": false, \"reason\": \"商品描述中颜色为银色，材质为皮革与塑料，款式为圆形无镶钻，与图中金色金属表壳、方形镶钻表盘不符，但未使用违规词，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02489.jpg", "image": "data/raw/images/product_02489.jpg", "prompt": "深紫色竖条纹长袖男士衬衫", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"深紫红条纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为深紫色底色配红色竖条纹的长袖翻领衬衫，材质标注为棉混纺符合常见商务衬衫用料，未使用极限词或夸大宣传，无品牌侵权表述，整体描述与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"深紫红条纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02427.jpg", "image": "data/raw/images/product_02427.jpg", "prompt": "深蓝色男士长袖衬衫，简约商务休闲款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件深蓝色长袖衬衫，材质为棉混纺，款式为标准商务休闲款，描述与实物一致。未使用极限词、未虚标材质、未宣称功效或傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"长袖衬衫\"}, \"violation\": false, \"reason\": \"该商品整体展示清晰，未发现明显违规内容，符合平台基本审核标准。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02301.jpg", "image": "data/raw/images/product_02301.jpg", "prompt": "灰色连帽卫衣，袖子拼接蓝绿条纹，胸前有卡通虎头图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质混纺\", \"款式\": \"连帽卫衣\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：灰色主体、袖部蓝绿撞色条纹、胸前黄色虎头刺绣图案均与实物一致。未使用极限词或夸大宣传，材质标注为常见棉质混纺，符合实际面料特征，无虚标或傍名牌行为，整体描述客观合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"夹克\"}, \"violation\": false, \"reason\": \"商品为黑色夹克，采用聚酯纤维材质，与图片中灰色连帽卫衣不符，但描述未涉及违规词，整体无夸大宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00724.jpg", "image": "data/raw/images/product_00724.jpg", "prompt": "这款高帮鞋包治百病，7天瘦10斤，一抹白，穿上立刻变潮人！", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"皮革\", \"款式\": \"高帮\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能的功效承诺，与图片中实际为一双黑白配色的高帮运动鞋属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"皮革\", \"款式\": \"高帮\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，描述内容不符合实际情况，违反相关广告规定\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00857.jpg", "image": "data/raw/images/product_00857.jpg", "prompt": "黑色皮革交叉带凉拖鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"交叉带凉拖\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮革材质的交叉带凉拖，描述准确对应其颜色、材质与款式特征，未使用极限词或夸大宣传，未虚标材质，无傍名牌表述，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"交叉带凉拖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02349.jpg", "image": "data/raw/images/product_02349.jpg", "prompt": "浅蓝色底粉色花卉印花短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"浅蓝底粉花\", \"材质\": \"棉质\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"图片中展示的连衣裙为浅蓝色底色搭配粉色花卉图案，短袖设计，A字版型，与描述完全一致。材质从视觉判断为棉质类面料，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，未夸大功效或作虚假宣传。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深红底黄花\", \"材质\": \"雪纺\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为深红色底色搭配黄色花卉图案，长袖设计，材质为轻薄雪纺面料，与描述相符，无虚假宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01088.jpg", "image": "data/raw/images/product_01088.jpg", "prompt": "浅蓝色牛仔布短袖衬衫，胸前带装饰口袋", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为浅蓝色牛仔布材质的短袖衬衫，胸前有装饰性口袋，与描述完全一致。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"短袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘装饰口袋’属于功能夸大，实际仅为普通贴袋，涉嫌虚假宣传，违反平台真实描述规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00081.jpg", "image": "data/raw/images/product_00081.jpg", "prompt": "深棕色绒面革系带正装皮鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"绒面革\", \"款式\": \"系带正装\"}, \"violation\": false, \"reason\": \"图片显示为一双深棕色绒面革材质的系带正装皮鞋，鞋面有雕花装饰，鞋底为黑色橡胶材质。描述准确反映了商品的颜色、材质与款式，未使用极限词或虚标材质，未涉及品牌侵权或夸大功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"牛皮\", \"款式\": \"休闲运动\"}, \"violation\": false, \"reason\": \"商品为浅灰色牛皮材质的休闲运动鞋，鞋面无雕花设计，鞋底较厚，符合描述。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02149.jpg", "image": "data/raw/images/product_02149.jpg", "prompt": "深蓝色绒面革系带男式正装皮鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"绒面革\", \"款式\": \"系带正装鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双深蓝色绒面革材质的男士系带正装鞋，鞋头尖锐，鞋面有透气孔设计，与描述中的颜色、材质和款式完全一致。未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"牛皮\", \"款式\": \"休闲运动鞋\"}, \"violation\": false, \"reason\": \"商品为酒红色牛皮材质的休闲运动鞋，鞋面光滑无透气孔，与描述中深蓝色绒面革正装鞋不符，但未发现夸大宣传或侵权问题，合规通过。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00792.jpg", "image": "data/raw/images/product_00792.jpg", "prompt": "Esprit品牌方形银色表壳黑色皮带手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"金属表壳，皮革表带\", \"款式\": \"方形表盘，简约商务风\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Esprit品牌、方形金属表壳、黑色皮革表带及简约表盘设计，未使用极限词或夸大功效，材质与颜色均与图片一致，无虚标或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"塑料表壳，硅胶表带\", \"款式\": \"圆形表盘，运动休闲风\"}, \"violation\": false, \"reason\": \"商品描述中颜色为白色，材质为塑料与硅胶，款式为圆形运动风，与图中黑色金属表壳、方形商务设计不符，但未发现违规用语，故不判定违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01834.jpg", "image": "data/raw/images/product_01834.jpg", "prompt": "紫色印花V领短袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉质\", \"款式\": \"V领短袖连衣裙\"}, \"violation\": false, \"reason\": \"图片显示为一件紫色底色、带有浅色花卉图案的V领短袖连衣裙，下摆有明显花边装饰，与描述中‘紫色印花V领短袖连衣裙’完全一致。未使用极限词或夸大宣传，材质未虚标，无品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"涤纶\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为红色涤纶长袖连衣裙，带有花卉图案，下摆有装饰边，与描述一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00969.jpg", "image": "data/raw/images/product_00969.jpg", "prompt": "黑色褶皱设计无袖V领上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"无袖V领褶皱\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黑色无袖上衣的V领与前襟褶皱设计，材质为常见针织面料，未使用极限词或虚标成分，未涉及品牌侵权表述，整体描述与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"牛仔布\", \"款式\": \"短袖圆领\"}, \"violation\": false, \"reason\": \"商品描述中颜色为白色，材质为牛仔布，款式为短袖圆领，与图中黑色针织无袖V领上衣不符，但未发现违规用语或侵权问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01435.jpg", "image": "data/raw/images/product_01435.jpg", "prompt": "深蓝色格纹男士长袖衬衫，翻领设计，胸前双口袋，袖口可卷边", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"深蓝与浅绿格纹\", \"材质\": \"棉质混纺\", \"款式\": \"翻领长袖格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中衣物的深蓝与浅绿相间的格纹图案、翻领结构、胸前双口袋及可卷边袖口等细节，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"深蓝与浅绿格纹\", \"材质\": \"棉质混纺\", \"款式\": \"翻领长袖格子衬衫\"}, \"violation\": true, \"reason\": \"描述中‘可卷边袖口’属于功能夸大，实际为普通设计，涉嫌虚假宣传，且‘深蓝与浅绿格纹’颜色表述不准确，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00886.jpg", "image": "data/raw/images/product_00886.jpg", "prompt": "最新款超低价全网最低绝对顶级条纹针织衫，时尚百搭必备单品", "chosen": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"浅灰、紫色、黑色、白色\", \"材质\": \"针织\", \"款式\": \"条纹宽松长袖\"}, \"violation\": true, \"reason\": \"使用『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 图片展示为普通条纹针织毛衣，无证据支持其为最新款或全网最低价\"}", "rejected": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"浅灰、紫色、黑色、白色\", \"款式\": \"条纹宽松长袖\"}, \"violation\": false, \"reason\": \"商品描述中‘最新款’等词汇为常见营销表达，未涉及虚假宣传，图片与描述基本一致，无明显违规\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01956.jpg", "image": "data/raw/images/product_01956.jpg", "prompt": "蓝色印花短袖T恤，正面印有'OUT of the BLUE'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为蓝色，材质从视觉判断为棉质，款式为圆领短袖T恤，正面印有'OUT of the BLUE'文字。描述未使用极限词、未虚标材质、未夸大功效，也未涉及品牌侵权或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"涤纶\", \"款式\": \"V领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品颜色为红色，材质为涤纶，款式为V领短袖T恤，正面印有'OUT of the BLUE'字样，描述与图片一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01934.jpg", "image": "data/raw/images/product_01934.jpg", "prompt": "黑色表带黄色表盘Puma运动计时腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑黄\", \"材质\": \"橡胶/金属\", \"款式\": \"运动计时\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黑色表带、黄色表盘及Puma品牌标识的运动计时腕表特征，未使用极限词或虚标材质，表盘结构与功能标注清晰，符合真实商品属性，无夸大宣传或侵权表述。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红白\", \"材质\": \"皮革\", \"款式\": \"商务正装\"}, \"violation\": false, \"reason\": \"商品描述中红色与白色搭配及皮革材质符合图中表带特征，商务正装款式与整体设计风格一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02195.jpg", "image": "data/raw/images/product_02195.jpg", "prompt": "灰黑蓝配色缓震运动鞋，网面透气设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"灰黑蓝\", \"材质\": \"网布/合成革\", \"款式\": \"缓震跑鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片中鞋款的灰、黑、蓝三色搭配，材质为可见的网布与合成革拼接，款式为典型缓震跑鞋结构。未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"灰黑蓝\", \"材质\": \"网布/合成革\", \"款式\": \"缓震跑鞋\"}, \"violation\": true, \"reason\": \"描述中‘缓震’属于功能夸大，未提供专业检测报告支持，涉嫌虚假宣传。网面透气为常见表述，但可能诱导消费者误认为具备特殊科技，存在误导风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01582.jpg", "image": "data/raw/images/product_01582.jpg", "prompt": "黑色棒球帽配绿色内衬和白色条纹装饰", "chosen": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"黑色/绿色/白色\", \"材质\": \"棉质\", \"款式\": \"棒球帽\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，帽子主体为黑色，内衬为绿色，帽檐有白色条纹，材质从织物纹理判断为棉质，款式为常见棒球帽。描述未使用极限词、未虚标材质、未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"黑色/绿色/白色\", \"材质\": \"棉质\", \"款式\": \"棒球帽\"}, \"violation\": true, \"reason\": \"描述中‘配绿色内衬’可能暗示内衬为特殊功能材料，存在虚标风险，且‘白色条纹装饰’表述过于具体，涉嫌过度承诺商品细节，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02385.jpg", "image": "data/raw/images/product_02385.jpg", "prompt": "酒红色棉质刺绣七分袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉\", \"款式\": \"刺绣七分袖连衣裙\"}, \"violation\": false, \"reason\": \"图片中展示的为一件酒红色棉质连衣裙，领口及袖口有彩色几何刺绣装饰，七分袖设计，整体款式与描述一致。未使用极限词、未虚标材质（棉质可从纹理判断）、未涉及品牌侵权或功效夸大，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉\", \"款式\": \"刺绣七分袖连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘酒红色’可能暗示特定色调标准，存在颜色虚标风险；‘棉质’未明确纯度，涉嫌材质模糊宣传，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00653.jpg", "image": "data/raw/images/product_00653.jpg", "prompt": "这款PUMA粉色T恤，包治百病，一抹白，穿出自信魅力，7天瘦10斤，轻松拥有完美身材！", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"描述中包含『包治百病』『一抹白』『7天瘦10斤』等不可能的功效承诺，与图片中展示的普通T恤属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"该商品存在虚假宣传嫌疑，描述内容与实际不符，违反相关平台规范\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00766.jpg", "image": "data/raw/images/product_00766.jpg", "prompt": "棕色皮革手提包，配金属扣饰和肩带", "chosen": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为棕色，材质为皮革，款式为手提包，配备金属扣饰与可拆卸肩带。描述未使用极限词、未虚标材质、未夸大功能，也无品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": true, \"reason\": \"描述中‘配金属扣饰’属于过度强调细节，可能引导消费者误解为特殊工艺，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01258.jpg", "image": "data/raw/images/product_01258.jpg", "prompt": "蓝白格纹男士长袖衬衫，翻领设计，胸前双口袋", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"翻领长袖\"}, \"violation\": false, \"reason\": \"图片显示为蓝白格纹的男士长袖衬衫，具有翻领和胸前双口袋设计，描述准确反映商品实际外观。未使用极限词或夸大宣传，材质标注为棉质符合常见格子衬衫材质，无虚标或傍名牌行为，整体描述与图像一致且合规。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"翻领长袖\"}, \"violation\": true, \"reason\": \"描述中‘蓝白格纹’可能暗示唯一性，存在隐性极限词嫌疑；‘胸前双口袋’为常见设计，但未明确标注是否可拆卸，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02235.jpg", "image": "data/raw/images/product_02235.jpg", "prompt": "FILA品牌白色拼接深蓝与橙色运动鞋", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白/深蓝/橙\", \"材质\": \"网布与合成革\", \"款式\": \"低帮系带\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片中FILA品牌运动鞋的配色（白、深蓝、橙）、材质（网布与合成革）及低帮系带款式，未使用极限词或虚标材质，品牌标识清晰且无仿冒表述，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"白/深蓝/橙\", \"材质\": \"网布与合成革\", \"款式\": \"低帮系带\"}, \"violation\": true, \"reason\": \"描述中‘拼接’一词暗示多材质组合，但图片仅显示单一网布结构，涉嫌虚标材质构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01603.jpg", "image": "data/raw/images/product_01603.jpg", "prompt": "浅蓝色水洗牛仔裤，直筒版型，经典五袋设计", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为浅蓝色水洗牛仔裤，材质为典型牛仔布，版型为直筒，与描述完全一致。未使用极限词、未虚标材质（如宣称纯棉或含羊毛等），未提及品牌关联或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00041.jpg", "image": "data/raw/images/product_00041.jpg", "prompt": "银色镶钻矩形表盘Puma女士手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属表壳，皮革表带\", \"款式\": \"矩形镶钻表盘，Puma品牌标识\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中银色金属表壳、矩形表盘及镶钻边框的特征，表带为银色纹理皮革，表盘中央有Puma品牌标志，未使用极限词或虚标材质，未夸大功能，符合广告法要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属表壳，皮革表带\", \"款式\": \"矩形镶钻表盘，Puma品牌标识\"}, \"violation\": true, \"reason\": \"描述中‘镶钻’可能暗示全钻覆盖，存在虚标材质风险，且‘Puma品牌标识’未注明授权，涉嫌侵犯品牌权益。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00629.jpg", "image": "data/raw/images/product_00629.jpg", "prompt": "蓝色PUMA男士短袖T恤，红色领口袖口拼接设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为蓝色PUMA品牌短袖T恤，图中可见其主体为蓝色，领口与袖口有红色包边，胸前印有PUMA品牌标志及'PREMIUM PERFORMANCE'字样，描述准确反映实际颜色、材质（棉质）、款式（圆领短袖）等属性，未使用极限词或虚标材质，未涉及傍名牌或夸大宣传，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色聚酯纤维V领短袖，图中可见主体颜色为深色，领口为V型设计，材质具有光泽感，符合描述，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01897.jpg", "image": "data/raw/images/product_01897.jpg", "prompt": "灰黑紫拼色短袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色、黑色、紫色\", \"材质\": \"棉混纺\", \"款式\": \"拼接短袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的灰黑紫三色拼接设计，材质为常见棉混纺面料，款式为短袖A字型，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色、黑色、紫色\", \"材质\": \"棉混纺\", \"款式\": \"拼接短袖A字裙\"}, \"violation\": true, \"reason\": \"描述中‘拼色’可能暗示多色工艺，实际仅三色拼接，存在夸大宣传嫌疑，涉嫌虚假描述。\"}", "pair_strategy": "api_weaker_over_strict"}
