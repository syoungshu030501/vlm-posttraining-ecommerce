{"image_file": "product_01237.jpg", "image": "data/raw/images/product_01237.jpg", "prompt": "LV平替童鞋，小香风原单设计，时尚百搭宝宝凉鞋", "chosen": "{\"category\": \"儿童凉鞋\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"合成材料\", \"款式\": \"魔术贴双带\"}, \"violation\": true, \"reason\": \"描述中使用『LV平替』『小香风原单』等词语，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权 — 图片显示为普通儿童凉鞋，无任何奢侈品牌标识或关联\"}", "rejected": "{\"category\": \"儿童凉鞋\", \"attributes\": {\"颜色\": \"白色\", \"款式\": \"魔术贴双带\"}, \"violation\": false, \"reason\": \"商品描述中‘LV平替’为常见营销表达，未直接使用品牌标识，图片与描述风格一致，不构成侵权\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00946.jpg", "image": "data/raw/images/product_00946.jpg", "prompt": "灰色Puma数字运动手表，红色点缀，电子显示屏", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"硅胶\", \"款式\": \"数字电子表\"}, \"violation\": false, \"reason\": \"商品为灰色硅胶表带的Puma品牌数字电子手表，表盘显示时间为24:00，表壳有红色按钮与品牌标识，描述准确反映图中颜色、材质与款式，未使用极限词或虚标材质，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"金属\", \"款式\": \"机械表\"}, \"violation\": false, \"reason\": \"商品为蓝色金属表带的Puma品牌机械手表，表盘显示时间为24:00，表壳有红色按钮与品牌标识，描述准确反映图中颜色、材质与款式，未使用极限词或虚标材质，符合合规要求。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00477.jpg", "image": "data/raw/images/product_00477.jpg", "prompt": "白色镂空尖头平底鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"皮革\", \"款式\": \"尖头平底\"}, \"violation\": false, \"reason\": \"商品为白色镂空设计的尖头平底鞋，材质为皮革，图片中可见鞋面有规则孔洞，内里标签显示品牌信息，描述与实物一致，未使用极限词或虚标材质，无夸大功效或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"皮革\", \"款式\": \"尖头平底\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01502.jpg", "image": "data/raw/images/product_01502.jpg", "prompt": "酒红色菱格纹商务领带", "chosen": "{\"category\": \"领带\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"涤纶\", \"款式\": \"菱格纹\"}, \"violation\": false, \"reason\": \"商品为酒红色菱格纹领带，图片中可见其颜色、图案与材质特征，描述准确反映实际商品属性。未使用极限词或夸大宣传，未虚标材质（如宣称丝绸而实为涤纶），未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"领带\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"涤纶\", \"款式\": \"菱格纹\"}, \"violation\": true, \"reason\": \"描述中‘商务领带’属于隐性宣传用语，暗示适用场景，涉嫌夸大用途，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00443.jpg", "image": "data/raw/images/product_00443.jpg", "prompt": "黑色鱼鳞纹编织手提包", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"人造皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述为'黑色鱼鳞纹编织手提包'，与图片中包身的黑色底色、鱼鳞状压纹及编织手柄完全一致，材质为人造皮革，未标注为真皮或使用极限词，未涉及品牌仿冒或夸大宣传，符合真实属性披露要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"人造皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00463.jpg", "image": "data/raw/images/product_00463.jpg", "prompt": "白色底粉色叶纹无袖连衣裙，腰间与下摆饰有粉色包边", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白底粉红印花\", \"材质\": \"棉质\", \"款式\": \"无袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：白色底布配粉色植物图案，无袖设计，腰部及裙摆有粉色包边，符合A字裙款式。未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，属性与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白底粉红印花\", \"材质\": \"棉质\", \"款式\": \"无袖A字裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01053.jpg", "image": "data/raw/images/product_01053.jpg", "prompt": "蓝色镶钻褶皱袖短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领镶钻褶皱袖\"}, \"violation\": false, \"reason\": \"商品描述为蓝色镶钻褶皱袖短袖T恤，与图片中模特穿着的蓝色上衣完全一致，其袖口褶皱设计、胸前圆形镶钻图案均清晰可见。材质未虚标，未使用极限词或夸大功效表述，未涉及品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领镶钻褶皱袖\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01453.jpg", "image": "data/raw/images/product_01453.jpg", "prompt": "最新款超低价全网最低绝对顶级男士条纹衬衫，品质保证，限时抢购！", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，内容不符合平台规范要求，需进一步处理\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00483.jpg", "image": "data/raw/images/product_00483.jpg", "prompt": "黑色男士皮质套脚休闲皮鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"套脚式\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色男士皮鞋，鞋面材质为皮革，采用套脚设计，无鞋带，属于经典商务休闲款式。描述中准确标注了颜色、材质与款式，未使用‘顶级’‘原单’等违规词汇，未虚标材质或夸大功能，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"套脚式\"}, \"violation\": true, \"reason\": \"描述中‘皮质’一词易被理解为真皮，但图片无法确认是否为真皮革，存在虚标材质风险，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00807.jpg", "image": "data/raw/images/product_00807.jpg", "prompt": "墨绿色皮质手提包，配亮黄色包扣", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"墨绿\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"图片显示为墨绿色皮革材质的手提包，包身有自然褶皱，肩带处配亮黄色圆形装饰扣，描述准确反映商品实际颜色、材质与款式特征，未使用极限词或虚标材质，无傍名牌或夸大宣传行为，符合合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"墨绿\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规问题，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00854.jpg", "image": "data/raw/images/product_00854.jpg", "prompt": "棕色皮革男士休闲乐福鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双棕色皮革材质的男士乐福鞋，描述准确对应其颜色、材质与款式，未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01248.jpg", "image": "data/raw/images/product_01248.jpg", "prompt": "黑色网眼拼接运动帽，两侧蓝色透气设计", "chosen": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"黑色/蓝色\", \"材质\": \"网眼布\", \"款式\": \"运动帽\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：主体为黑色，两侧有蓝色网眼拼接，符合运动帽品类特征。材质标注为网眼布，与图中透气结构一致，未虚标或夸大。未使用极限词、功效承诺或品牌侵权表述，如‘顶级’‘仿大牌’等，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"黑色/蓝色\", \"材质\": \"网眼布\", \"款式\": \"运动帽\"}, \"violation\": true, \"reason\": \"描述中‘网眼拼接’涉嫌夸大透气性能，实际仅两侧为网眼结构，未覆盖全帽，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01949.jpg", "image": "data/raw/images/product_01949.jpg", "prompt": "白色印花短袖T恤，前胸印有黑白人物肖像图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中白色短袖T恤的外观特征，印花为黑白人物肖像，未使用极限词或夸大宣传，材质标注为棉质符合常见T恤材质，无仿冒品牌标识或虚假功效宣称，整体描述与图片一致且合规。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中‘黑白人物肖像’可能暗示特定人物形象，存在潜在版权风险，属虚假宣传，需进一步核实。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00376.jpg", "image": "data/raw/images/product_00376.jpg", "prompt": "这款绿色绒面皮鞋，包治百病，穿7天瘦10斤，一抹白，轻松拥有健康好身材！", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"绒面皮\", \"款式\": \"系带正装鞋\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能实现的功效承诺，与图片中展示的普通男鞋属性严重不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"绿色\", \"款式\": \"系带正装鞋\"}, \"violation\": false, \"reason\": \"商品描述中提及的健康功效为常见营销表达，未明确承诺具体效果，与图片展示的鞋子无明显矛盾，不构成违规\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01484.jpg", "image": "data/raw/images/product_01484.jpg", "prompt": "红色Puma品牌数字电子手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"塑料\", \"款式\": \"数字电子表\"}, \"violation\": false, \"reason\": \"商品为红色塑料材质的Puma品牌数字电子手表，表盘显示文字与品牌标识清晰可见，描述准确反映其颜色、材质和款式特征，未使用极限词或夸大宣传，未虚标材质或仿冒其他品牌，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"塑料\", \"款式\": \"数字电子表\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00903.jpg", "image": "data/raw/images/product_00903.jpg", "prompt": "蓝白竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝白竖条纹的男士长袖衬衫，描述准确对应其颜色、款式与常见材质（棉质），未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黑格纹\", \"材质\": \"涤纶\", \"款式\": \"短袖休闲T恤\"}, \"violation\": false, \"reason\": \"商品为红黑格纹短袖T恤，材质为涤纶，符合描述，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01850.jpg", "image": "data/raw/images/product_01850.jpg", "prompt": "米白色格纹棉质宽松连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"棉质\", \"款式\": \"宽松连衣裙\"}, \"violation\": false, \"reason\": \"图片中展示的连衣裙为米白色底配细小格纹，材质呈现棉质纹理，版型为宽松直筒设计，袖长约为七分袖。描述准确对应商品实际颜色、材质与款式，未使用极限词或夸大宣传，未虚标材质或仿冒品牌，符合电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"棉质\", \"款式\": \"宽松连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘棉质’可能虚标，图片纹理不够清晰，无法确认实际材质，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00148.jpg", "image": "data/raw/images/product_00148.jpg", "prompt": "这款PUMA男士黑色短袖POLO衫，采用100%纯棉材质，舒适透气，适合日常穿着。", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"POLO衫\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片所示为PUMA品牌运动款POLO衫，实际材质为聚酯纤维，图片所示材质与描述的100%纯棉明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉麻混纺\", \"款式\": \"T恤\"}, \"violation\": true, \"reason\": \"商品描述为白色棉麻混纺T恤，但图片显示为黑色聚酯纤维POLO衫，颜色、材质及款式均与实际不符，属虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01908.jpg", "image": "data/raw/images/product_01908.jpg", "prompt": "白色条纹短袖连衣裙，简约休闲款", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": false, \"reason\": \"图片显示为白色竖条纹短袖连衣裙，材质为棉质，款式为简约休闲型，描述与实物一致。未使用极限词、未虚标材质、未夸大功效，也无傍名牌或侵权表述，符合商品合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘简约休闲款’涉嫌使用模糊宣传用语，易诱导消费者产生过高预期，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00743.jpg", "image": "data/raw/images/product_00743.jpg", "prompt": "黄色底绿色带印花人字拖", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黄色、绿色、橙色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为黄色底配绿色带的人字拖，鞋底有橙色图案及黑色文字，材质为橡胶，描述准确反映图片内容，未使用极限词或虚标材质，无傍名牌或夸大功效表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黄色、绿色、橙色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01992.jpg", "image": "data/raw/images/product_01992.jpg", "prompt": "紫色格纹短袖衬衫男式休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉混纺\", \"款式\": \"格纹短袖\"}, \"violation\": false, \"reason\": \"图片显示为一件紫色与白色相间的格纹短袖衬衫，材质从纹理判断为棉混纺，款式为常规翻领短袖设计。描述中仅陈述了真实可见的颜色、图案和品类，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合商品信息真实合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"涤纶\", \"款式\": \"长袖\"}, \"violation\": false, \"reason\": \"商品为蓝色涤纶长袖衬衫，格纹图案清晰，符合描述内容，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00329.jpg", "image": "data/raw/images/product_00329.jpg", "prompt": "银灰蓝配色Reebok运动跑鞋，网面透气设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"银灰色与蓝色拼接\", \"材质\": \"网布与合成革\", \"款式\": \"系带运动跑鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Reebok品牌跑鞋的银灰蓝配色、网布与合成革材质及系带款式，未使用极限词或虚标材质，品牌标识清晰且无仿冒表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"银灰色与蓝色拼接\", \"材质\": \"网布与合成革\", \"款式\": \"系带运动跑鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01003.jpg", "image": "data/raw/images/product_01003.jpg", "prompt": "这款时尚连衣裙采用轻盈雪纺材质，适合夏日穿搭，展现优雅气质。", "chosen": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"白色、红色、黑色\", \"材质\": \"棉质\", \"款式\": \"条纹短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中提及的'连衣裙'与图片展示的'Polo衫'明显不符，且'雪纺材质'与实际'棉质'材质不一致 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"蓝色、黄色、绿色\", \"材质\": \"雪纺\", \"款式\": \"长袖连衣裙\"}, \"violation\": true, \"reason\": \"商品描述中提到的蓝色系与图中红白黑条纹不符，且材质标注为雪纺，实际为棉质，款式误标为长袖连衣裙，存在明显属性错误\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00120.jpg", "image": "data/raw/images/product_00120.jpg", "prompt": "绿色数字30印花男士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品为绿色短袖Polo衫，胸前印有白色数字'30'及小字图案，与描述完全一致。材质从织物纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合广告法要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01279.jpg", "image": "data/raw/images/product_01279.jpg", "prompt": "深蓝与墨绿格纹男士长袖衬衫，胸前带口袋设计", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"深蓝、墨绿、棕色格纹\", \"材质\": \"棉质混纺\", \"款式\": \"格子衬衫，翻领，单胸袋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为深蓝、墨绿与棕色交织的格纹，材质从织物纹理判断为棉质混纺，款式为标准翻领长袖衬衫配单胸袋，未使用极限词或虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"深蓝、墨绿、棕色格纹\", \"材质\": \"棉质混纺\", \"款式\": \"格子衬衫，翻领，单胸袋\"}, \"violation\": true, \"reason\": \"描述中‘深蓝与墨绿’存在颜色夸大嫌疑，实际图片偏暗，涉嫌误导消费者，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01191.jpg", "image": "data/raw/images/product_01191.jpg", "prompt": "白色耐克运动T恤，荧光绿立体字母印花，印有'SKILLS THRILLS DOLLAR BILLS'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领T恤\"}, \"violation\": false, \"reason\": \"商品为白色短袖T恤，正面印有荧光绿色立体文字图案，品牌标识为Nike，描述准确反映图中颜色、材质与款式特征。未使用极限词或夸大宣传，未虚标材质，未涉及侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领T恤\"}, \"violation\": true, \"reason\": \"商品描述中‘荧光绿立体字母印花’涉嫌夸大宣传，实际图案为平面印刷，存在误导消费者嫌疑，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02043.jpg", "image": "data/raw/images/product_02043.jpg", "prompt": "酒红色男士圆领短袖T恤，印有白色D.Lee品牌复古字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：酒红色T恤、圆领短袖设计、正面印有白色D.Lee品牌文字图案，材质为常规棉质面料。未使用极限词或夸大宣传，未虚标材质，未涉及傍名牌或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01077.jpg", "image": "data/raw/images/product_01077.jpg", "prompt": "黑色表盘计时码表，搭配黑色皮质表带", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中ESPRIT品牌计时码表的黑色表盘、黑色皮质表带及计时功能，未使用极限词或虚标材质，未涉及品牌侵权表述，符合真实属性与合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属\", \"款式\": \"石英表\"}, \"violation\": false, \"reason\": \"商品描述中银色金属表壳与石英表款式符合图中实际外观，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02353.jpg", "image": "data/raw/images/product_02353.jpg", "prompt": "棕色几何印花短袖宽松上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"棕色与米白色\", \"材质\": \"棉质混纺\", \"款式\": \"短袖V领宽松款\"}, \"violation\": false, \"reason\": \"图片显示为一件棕色与米白色几何图案的短袖上衣，V领设计，版型宽松，材质从视觉判断为棉质混纺。描述准确反映商品实际颜色、图案、款式及材质特征，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"棕色与米白色\", \"材质\": \"棉质混纺\", \"款式\": \"短袖V领宽松款\"}, \"violation\": true, \"reason\": \"描述中‘宽松’一词可能暗示舒适度，涉嫌隐性宣传，且未明确标注具体成分比例，存在虚标材质风险，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01392.jpg", "image": "data/raw/images/product_01392.jpg", "prompt": "黑色短袖圆领女士上衣，领口与袖口饰有花边设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领\"}, \"violation\": false, \"reason\": \"图片显示为黑色短袖上衣，领口及袖口有花边装饰，描述准确反映商品实际颜色、材质与款式特征，未使用极限词或虚标材质，无夸大宣传或侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"描述中‘花边设计’属于过度美化，易引导消费者误认为有特殊工艺，构成虚假宣传，违反平台合规规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02361.jpg", "image": "data/raw/images/product_02361.jpg", "prompt": "米白色底红色印花宽松七分袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"米白底红花\", \"材质\": \"棉质混纺\", \"款式\": \"宽松印花连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中米白色底配红色植物印花的宽松连衣裙，七分袖设计与实际一致，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"米白底红花\", \"材质\": \"棉质混纺\", \"款式\": \"宽松印花连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘宽松’属绝对化用语，易引导消费者产生误导性认知，涉嫌虚假宣传，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01073.jpg", "image": "data/raw/images/product_01073.jpg", "prompt": "深蓝色PUMA男士短袖T恤，领口与袖口饰有浅蓝色边条", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝/浅蓝\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色主体、浅蓝色领口和袖口边条的PUMA品牌T恤，描述准确对应实际商品颜色、品牌标识及款式特征。未使用夸大宣传词或虚假材质表述，品牌标识清晰但未作仿冒或侵权暗示，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色/红色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色主体配红色边条的V领T恤，材质为聚酯纤维，与描述一致，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02457.jpg", "image": "data/raw/images/product_02457.jpg", "prompt": "橙色条纹男士短袖Polo衫，胸前有徽章图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"橙色与白色\", \"材质\": \"棉质\", \"款式\": \"条纹Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：橙色底配白色横条纹，短袖Polo领设计，左胸有圆形徽章图案，材质为常见棉质面料。未使用极限词、未虚标材质、未宣称功效或傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色与黄色\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领T恤\"}, \"violation\": false, \"reason\": \"商品为蓝色与黄色拼接的圆领T恤，材质为聚酯纤维，无Polo领设计，符合描述规范。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02493.jpg", "image": "data/raw/images/product_02493.jpg", "prompt": "酒红色男士长袖商务衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为一件酒红色长袖衬衫，具有标准翻领和单胸袋设计，材质从光泽与纹理判断为棉混纺类面料。描述准确对应商品实际颜色、款式与材质，未使用极限词或虚标成分，未提及品牌关联或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉混纺\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"描述中‘商务衬衫’暗示高端用途，存在隐性功效承诺，且未明确标注具体棉含量，涉嫌虚标成分，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00510.jpg", "image": "data/raw/images/product_00510.jpg", "prompt": "Reebok运动鞋，包治百病，7天瘦10斤，一抹白，轻松拥有健康体态", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"网布与合成革\", \"款式\": \"低帮系带\"}, \"violation\": true, \"reason\": \"描述中包含『包治百病』『7天瘦10斤』『一抹白』等不可能的功效承诺，与图片所示的普通运动鞋属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"灰色\", \"款式\": \"低帮系带\"}, \"violation\": false, \"reason\": \"商品描述中提及的‘包治百病’等为夸张表达，属于常见营销话术，未实际宣称医疗功效，与图片展示的运动鞋一致，不构成违规\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02266.jpg", "image": "data/raw/images/product_02266.jpg", "prompt": "粉白蓝竖条纹长袖男士正装衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉白蓝条纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件粉白蓝竖条纹长袖衬衫，颜色、款式与描述一致，材质未作虚标，未使用极限词或夸大功效表述，无品牌侵权或虚假宣传内容，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑黄格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为黑黄格纹短袖休闲衬衫，材质为聚酯纤维，符合描述内容，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02356.jpg", "image": "data/raw/images/product_02356.jpg", "prompt": "灰白人字纹无袖针织背心裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰白\", \"材质\": \"针织\", \"款式\": \"无袖背心裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中服饰的灰白人字纹图案、无袖设计及针织材质，未使用夸大或虚假宣传用语，未涉及极限词或品牌傍款，属性与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰白\", \"材质\": \"针织\", \"款式\": \"无袖背心裙\"}, \"violation\": true, \"reason\": \"描述中‘人字纹’可能暗示独特设计，存在误导消费者风险，涉嫌虚假宣传，需进一步核实图案原创性。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00929.jpg", "image": "data/raw/images/product_00929.jpg", "prompt": "黑色方形表盘Puma男士皮带手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"方形\"}, \"violation\": false, \"reason\": \"商品为黑色方形表盘的Puma品牌手表，表带为皮革材质，表盘设计包含品牌标识与清晰刻度。描述准确反映其颜色、材质与款式特征，未使用极限词或虚标信息，未涉及虚假宣传或侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"方形\"}, \"violation\": true, \"reason\": \"描述中‘黑色方形表盘’可能暗示唯一性，存在夸大宣传嫌疑，且未明确标注是否为正品，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02415.jpg", "image": "data/raw/images/product_02415.jpg", "prompt": "这款优雅的蓝色连衣裙采用轻盈面料，适合日常穿着，展现女性柔美气质。", "chosen": "{\"category\": \"围巾\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"褶皱长围巾\"}, \"violation\": true, \"reason\": \"描述中提及‘连衣裙’，但图片实际展示为围巾 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"围巾\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉质\", \"款式\": \"褶皱长围巾\"}, \"violation\": true, \"reason\": \"该商品存在描述与实际不符的情况，可能对消费者造成误导，需进一步核实信息准确性\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01779.jpg", "image": "data/raw/images/product_01779.jpg", "prompt": "灰白格纹长袖衬衫女款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰白格纹\", \"材质\": \"棉混纺\", \"款式\": \"长袖纽扣衬衫\"}, \"violation\": false, \"reason\": \"商品描述为'灰白格纹长袖衬衫女款'，与图片中模特穿着的格纹图案、长袖设计及纽扣开合方式完全一致。材质标注为棉混纺，符合常见衬衫面料特征，未虚标纯棉或特殊纤维。未使用极限词或功效承诺，无品牌侵权表述，整体描述客观真实，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黑格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品描述为'灰白格纹长袖衬衫女款'，但图中实际为红黑格纹、聚酯纤维材质的短袖T恤，与描述不符，存在属性错标情况。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02374.jpg", "image": "data/raw/images/product_02374.jpg", "prompt": "酒红色印花棉质库尔塔连衣裙，配黑色菱格拼接领口", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"库尔塔\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中酒红色底色、小花图案的棉质库尔塔，领口为黑色菱格拼接设计，袖口有绿黑边饰，整体款式与图片一致。未使用极限词或虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"库尔塔\"}, \"violation\": true, \"reason\": \"描述中‘印花’一词可能暗示图案密集，实际图中花纹稀疏，存在虚标风险，涉嫌夸大宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01778.jpg", "image": "data/raw/images/product_01778.jpg", "prompt": "深绿色V领针织毛衣，简约修身设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深绿色\", \"材质\": \"针织\", \"款式\": \"V领长袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中深绿色V领针织毛衣的品类、颜色、材质与款式，未使用极限词或夸大表述，无虚标材质或傍名牌情况，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深绿色\", \"材质\": \"针织\", \"款式\": \"V领长袖\"}, \"violation\": true, \"reason\": \"描述中‘简约修身’涉嫌暗示极致剪裁，易引发消费者对版型效果的过度期待，属于变相夸大宣传，不符合广告法合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00359.jpg", "image": "data/raw/images/product_00359.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"款式\": \"短袖T恤\", \"图案\": \"环保主题印花，包含回收标志、蝴蝶和文字标语\", \"文字内容\": \"RECYCLE, WAR IS NOT HEALING FOR CHILDREN AND OTHER LIVING THINGS\"}, \"violation\": true, \"reason\": \"商品描述中使用了‘最新款’‘超低价’‘清仓大甩卖’等夸大宣传用语，可能构成虚假或引人误解的商业宣传。同时，T恤上的文字‘WAR IS NOT HEALING FOR CHILDREN AND OTHER LIVING THINGS’虽为环保主题，但结合‘Flying Machine’品牌及整体设计风格，存在潜在的政治或社会敏感性表达，需进一步审核是否违反平台关于政治言论或不当信息的规定。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"款式\": \"短袖T恤\", \"图案\": \"环保主题印花，包含回收标志、蝴蝶和文字标语\", \"文字内容\": \"RECYCLE, WAR IS NOT HEALING FOR CHILDREN AND OTHER LIVING THINGS\"}, \"violation\": true, \"reason\": \"该商品存在潜在违规风险，内容可能涉及敏感表达，需进一步审核判断是否符合平台规范。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00994.jpg", "image": "data/raw/images/product_00994.jpg", "prompt": "浅黄色印花短袖T恤，正面印有忍者图案和英文文字", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅黄色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，T恤为浅黄色，正面印有忍者卡通图案及英文文字，材质从视觉判断为棉质，未使用极限词或夸大宣传，未涉及品牌侵权或虚假材质标注，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅黄色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中‘印花’一词可能暗示特殊工艺，存在夸大宣传嫌疑，且未明确标注图案版权信息，涉嫌潜在侵权风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01412.jpg", "image": "data/raw/images/product_01412.jpg", "prompt": "蓝白格纹短袖衬衫，翻领设计，胸前双口袋", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为蓝白相间的格纹，材质从织物纹理判断为棉质，款式为短袖翻领衬衫并带有胸前双口袋，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"红黑格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"商品为红黑格纹长袖衬衫，材质为聚酯纤维，符合描述，无违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01609.jpg", "image": "data/raw/images/product_01609.jpg", "prompt": "深蓝色直筒牛仔裤，经典五袋设计，适合日常穿着", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色牛仔布材质的直筒款牛仔裤，五袋结构清晰可见，描述准确反映商品真实属性。未使用极限词、未虚标材质或夸大功效，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": true, \"reason\": \"描述中‘经典五袋设计’涉嫌暗示唯一性，构成隐性极限词，易误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01876.jpg", "image": "data/raw/images/product_01876.jpg", "prompt": "最新款超低价全网最低绝对顶级白色印花棉质衬衫，时尚百搭必备单品", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"印花长袖\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"印花长袖\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传内容，整体描述不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01700.jpg", "image": "data/raw/images/product_01700.jpg", "prompt": "这款T恤包治百病，一抹白，7天瘦10斤，穿上立刻变帅！", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"棉\", \"款式\": \"印花短袖T恤\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『一抹白』『7天瘦10斤』等不可能实现的功效承诺，与图片展示的普通印花T恤属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"连帽卫衣\"}, \"violation\": true, \"reason\": \"商品描述存在虚假功效承诺，且图片显示为黑色聚酯纤维连帽卫衣，与实际商品不符，涉嫌误导消费者\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01422.jpg", "image": "data/raw/images/product_01422.jpg", "prompt": "黑白格纹短袖衬衫男款休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑白格纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为一件黑白格纹短袖衬衫，材质从织物纹理判断为棉混纺，款式为翻领短袖，与描述完全一致。未使用极限词、未虚标材质、未宣称功效或傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片展示为蓝白格纹长袖衬衫，材质为聚酯纤维，与描述一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01891.jpg", "image": "data/raw/images/product_01891.jpg", "prompt": "米白色短袖V领连衣裙，简约休闲款", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"棉麻混纺\", \"款式\": \"短袖V领A字裙\"}, \"violation\": false, \"reason\": \"图片中展示的连衣裙为米白色，材质呈现棉麻混纺纹理，款式为短袖、V领、A字型剪裁，与描述完全一致。未使用极限词或夸大宣传，无虚标材质、未傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖圆领连衣裙\"}, \"violation\": false, \"reason\": \"商品为深蓝色聚酯纤维长袖圆领连衣裙，款式简洁，符合描述，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00887.jpg", "image": "data/raw/images/product_00887.jpg", "prompt": "黑白条纹拼接V领短袖针织衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑、灰白条纹\", \"材质\": \"针织\", \"款式\": \"V领短袖拼接\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中上衣的视觉特征：上半部分为黑白竖条纹，下半部分为纯黑色，V领设计，短袖针织材质。未使用极限词或夸大宣传，未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红、蓝条纹\", \"材质\": \"棉质\", \"款式\": \"圆领长袖\"}, \"violation\": false, \"reason\": \"商品为红蓝条纹棉质圆领长袖上衣，与图中黑白条纹针织V领短袖一致，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01818.jpg", "image": "data/raw/images/product_01818.jpg", "prompt": "黑色短袖Polo衫，左胸有绿色刺绣图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为黑色短袖Polo衫，左胸有绿色刺绣标识，材质为棉质，描述与实物一致。未使用极限词、未夸大功效、未虚标材质，也无傍名牌或侵权表述，符合商品合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00276.jpg", "image": "data/raw/images/product_00276.jpg", "prompt": "红白条纹短袖Polo衫，胸前有冲浪主题徽章", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白相间\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中红白横条纹Polo衫的外观特征，包含颜色、款式及徽章元素，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白相间\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01472.jpg", "image": "data/raw/images/product_01472.jpg", "prompt": "黑色多功能战术风格双肩包，采用耐磨织物材质，配有多口袋设计", "chosen": "{\"category\": \"背包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"织物\", \"款式\": \"战术风格\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为纯黑，材质为织物类面料，款式为多口袋战术风双肩包，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"背包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"织物\", \"款式\": \"战术风格\"}, \"violation\": true, \"reason\": \"描述中‘多功能’属于夸大宣传，未明确说明具体功能，涉嫌虚假宣传；‘耐磨’为性能承诺，缺乏检测依据，构成违规。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00796.jpg", "image": "data/raw/images/product_00796.jpg", "prompt": "黑色表盘银色表壳男士计时腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色/银色\", \"材质\": \"皮革/金属\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"图片显示为黑色表盘搭配银色金属表壳及黑色皮质表带的计时腕表，描述准确反映其颜色、材质与功能款式。未使用极限词或夸大功效表述，品牌标识清晰无仿冒嫌疑，符合真实商品属性披露要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"白色/金色\", \"材质\": \"塑料/合金\", \"款式\": \"石英表\"}, \"violation\": false, \"reason\": \"商品为白色表盘搭配金色表壳的石英表，采用塑料与合金材质，符合描述中所示属性，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02261.jpg", "image": "data/raw/images/product_02261.jpg", "prompt": "浅绿色竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅绿白条纹\", \"材质\": \"棉质\", \"款式\": \"商务休闲\"}, \"violation\": false, \"reason\": \"图片中展示的为浅绿色与白色相间的竖条纹长袖衬衫，材质从视觉纹理判断为棉质，款式为标准商务休闲款。描述准确对应商品实际颜色、材质与风格，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅绿白条纹\", \"材质\": \"棉质\", \"款式\": \"商务休闲\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
