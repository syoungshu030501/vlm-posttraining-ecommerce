{"image_file": "product_02307.jpg", "image": "data/raw/images/product_02307.jpg", "prompt": "灰绿色叶纹无袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"灰绿\", \"材质\": \"棉混纺\", \"款式\": \"无袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述为'灰绿色叶纹无袖连衣裙'，与图片中实际展示的深灰底色配绿色叶片图案、无袖A字版型完全一致。未使用极限词或夸大宣传，材质标注为棉混纺符合常见印花连衣裙面料特征，未虚标为纯棉或真丝等高端材质，也未涉及品牌傍款或功效承诺，整体描述客观真实，符合合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"灰绿\", \"材质\": \"棉混纺\", \"款式\": \"无袖A字裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01169.jpg", "image": "data/raw/images/product_01169.jpg", "prompt": "原价999直降到99，限时清仓甩卖，时尚条纹手表，潮流必备！", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"橙色、灰色、黑色、白色、绿色\", \"材质\": \"塑料表带，透明表壳\", \"款式\": \"矩形表盘，条纹设计\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和打折信息，制造虚假促销假象，与商品真实售价无关 — 虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"红色、蓝色、黄色\", \"材质\": \"金属表带，皮革表壳\", \"款式\": \"圆形表盘，简约设计\"}, \"violation\": true, \"reason\": \"商品描述中存在虚构原价和促销信息，且属性标注为红色蓝色黄色金属表带等，与实际商品不符，涉嫌误导消费者\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01540.jpg", "image": "data/raw/images/product_01540.jpg", "prompt": "黑色表盘不锈钢男士多功能腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色表盘，银色表壳与表带\", \"材质\": \"不锈钢\", \"款式\": \"多功能三眼计时\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示：黑色表盘搭配银色不锈钢表壳与表带，具备日期、星期及24小时显示的三眼多功能设计。未使用极限词或虚标材质，品牌标识清晰为ESPRIT，无傍名牌或夸大功效表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色表盘，银色表壳与表带\", \"材质\": \"不锈钢\", \"款式\": \"多功能三眼计时\"}, \"violation\": true, \"reason\": \"描述中‘多功能’属于夸大宣传，未明确标注具体功能，易误导消费者，违反广告法关于真实性的规定。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01210.jpg", "image": "data/raw/images/product_01210.jpg", "prompt": "黄色米奇图案儿童人字拖", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为黄色底色、印有米奇卡通图案的儿童人字拖，鞋面黑色带饰有米奇头像，与描述完全一致。材质为常见橡胶，未虚标为真皮或特殊材料；未使用极限词或夸大功效表述；图案为合法授权卡通形象，无傍名牌或侵权嫌疑，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01664.jpg", "image": "data/raw/images/product_01664.jpg", "prompt": "浅蓝色水洗直筒牛仔裤", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为浅蓝色水洗处理的直筒牛仔裤，材质为典型牛仔布，颜色与描述一致，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，描述准确且合规。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01244.jpg", "image": "data/raw/images/product_01244.jpg", "prompt": "红色耐克儿童运动T恤，印有'the athletic dept.'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领\"}, \"violation\": false, \"reason\": \"商品为红色短袖T恤，正面印有'the athletic dept.'及Nike标志，材质为棉质，描述准确反映图片内容，未使用极限词或夸大宣传，未虚标材质，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖圆领\"}, \"violation\": false, \"reason\": \"商品为蓝色长袖T恤，材质为聚酯纤维，正面印有'the athletic dept.'字样，整体描述与图片内容一致，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01204.jpg", "image": "data/raw/images/product_01204.jpg", "prompt": "黑色蛇纹压花皮质单肩包", "chosen": "{\"category\": \"包包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮质\", \"款式\": \"单肩包\"}, \"violation\": false, \"reason\": \"图片显示为一款黑色单肩包，表面具有蛇纹压花纹理，材质为皮质，与描述完全一致。未使用极限词或夸大宣传，未虚标材质（如‘真皮’未标注则不作承诺），未涉及品牌侵权或功效宣称，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"包包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮质\", \"款式\": \"单肩包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00777.jpg", "image": "data/raw/images/product_00777.jpg", "prompt": "黄色皮质表带方形金属表壳手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"金属表壳，皮革表带\", \"款式\": \"方形表盘\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示的黄色皮质表带、方形金属表壳及黑色表盘设计，未使用极限词或夸大宣传，品牌标识‘CARRERA’为可见但非知名奢侈品牌，未构成傍名牌行为，材质与颜色均与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"塑料表壳，硅胶表带\", \"款式\": \"圆形表盘\"}, \"violation\": false, \"reason\": \"商品描述中蓝色塑料表壳与硅胶表带的配置与图中黄色皮革表带及金属表壳不符，但未发现夸大宣传或违规词，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01486.jpg", "image": "data/raw/images/product_01486.jpg", "prompt": "深蓝色罗纹针织护腕一对", "chosen": "{\"category\": \"服饰配件\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"针织\", \"款式\": \"罗纹护腕\"}, \"violation\": false, \"reason\": \"图片显示为一对深蓝色罗纹针织护腕，描述准确对应其颜色、材质与款式，未使用极限词或夸大表述，未虚标材质或宣称功效，符合商品真实属性，无侵权或违规用语。\"}", "rejected": "{\"category\": \"服饰配件\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"针织\", \"款式\": \"罗纹护腕\"}, \"violation\": true, \"reason\": \"描述中‘罗纹针织’可能暗示特殊工艺，存在夸大材质效果嫌疑，且未明确标注是否为纯棉，涉嫌虚标材质，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00445.jpg", "image": "data/raw/images/product_00445.jpg", "prompt": "这款黑色皮带采用100%纯棉材质，搭配金属扣头，简约时尚，适合日常穿搭。", "chosen": "{\"category\": \"皮带\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"金属扣皮带\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片显示商品为皮革材质，图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"皮带\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"金属扣皮带\"}, \"violation\": true, \"reason\": \"该商品存在信息不符情况，整体审核判断为违规，具体细节需进一步核实\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00678.jpg", "image": "data/raw/images/product_00678.jpg", "prompt": "银色与金色拼接金属表带方形石英手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色与金色\", \"材质\": \"金属\", \"款式\": \"方形表盘\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，表带为银色与金色拼接金属材质，表盘为方形设计，品牌标识清晰可见。未使用极限词或夸大宣传，未虚标材质，未涉及仿冒知名品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色与金色\", \"材质\": \"金属\", \"款式\": \"方形表盘\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01625.jpg", "image": "data/raw/images/product_01625.jpg", "prompt": "深蓝色竖条纹修身牛仔裤", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色竖条纹设计的修身牛仔裤，材质为典型牛仔布，款式为直筒修身剪裁，描述与实物完全一致。未使用极限词、未夸大功能、未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": true, \"reason\": \"描述中‘修身’属于隐性承诺，可能误导消费者对版型的预期，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01538.jpg", "image": "data/raw/images/product_01538.jpg", "prompt": "黑色表盘计时码表，搭配黑色皮质表带，时尚简约设计", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：表盘为黑色，表带为黑色皮革材质，功能为计时码表，品牌标识清晰可见。未使用极限词或夸大功效表述，未虚标材质，未涉及侵权或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"计时码表\"}, \"violation\": true, \"reason\": \"描述中‘时尚简约设计’属于主观夸大宣传，易诱导消费者，构成虚假宣传违规。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02112.jpg", "image": "data/raw/images/product_02112.jpg", "prompt": "黑白红配色人字拖，鞋底有卡通图案设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑、白、红\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为黑色鞋面搭配白色图案及红色边缘的人字拖，材质为橡胶，图片中可见清晰的鞋型与配色，描述准确反映实际商品属性。未使用极限词或夸大宣传，未虚标材质，无傍名牌标识，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑、白、红\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02285.jpg", "image": "data/raw/images/product_02285.jpg", "prompt": "蓝白竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件蓝白竖条纹男士长袖衬衫，颜色、款式与描述完全一致，材质从视觉判断为常见棉质面料，未标注虚假材质或夸大功效，无极限词、无品牌侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白条纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为红白条纹短袖休闲衬衫，材质为聚酯纤维，与描述相符，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00237.jpg", "image": "data/raw/images/product_00237.jpg", "prompt": "这款优雅的白色连衣裙采用轻盈雪纺材质，适合夏日海滩度假穿搭，展现女性柔美气质。", "chosen": "{\"category\": \"凉鞋\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"皮革\", \"款式\": \"交叉绑带坡跟拖鞋\"}, \"violation\": true, \"reason\": \"商品描述中的'连衣裙'与主图展示的'凉鞋'明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"凉鞋\", \"attributes\": {\"颜色\": \"白色\", \"款式\": \"交叉绑带坡跟拖鞋\"}, \"violation\": false, \"reason\": \"商品描述中的连衣裙可能为搭配建议，主图展示凉鞋属于正常商品细节呈现，无明显误导\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01584.jpg", "image": "data/raw/images/product_01584.jpg", "prompt": "红色短袖T恤搭配牛仔背带裙套装", "chosen": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"红色、蓝色\", \"材质\": \"棉质、牛仔布\", \"款式\": \"背带裙套装\"}, \"violation\": false, \"reason\": \"商品为儿童红色短袖T恤与蓝色牛仔背带裙组合，图片中可见T恤为纯色短袖，背带裙为经典牛仔材质，带有纽扣和口袋设计，描述准确反映实际品类、颜色与款式，未使用极限词或虚标材质，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"红色、蓝色\", \"材质\": \"棉质、牛仔布\", \"款式\": \"背带裙套装\"}, \"violation\": true, \"reason\": \"描述中‘经典牛仔材质’涉嫌夸大宣传，未明确标注具体成分比例，存在虚标材质风险，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02198.jpg", "image": "data/raw/images/product_02198.jpg", "prompt": "NIKE同款舒适拖鞋，时尚百搭，透气轻便，男士必备", "chosen": "{\"category\": \"拖鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"一字带\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』蹭大牌，但图片商品为普通黑色皮革拖鞋，无任何NIKE品牌标识或设计特征 — 擅自使用他人品牌作宣传,涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"拖鞋\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"一字带\"}, \"violation\": false, \"reason\": \"商品描述中‘NIKE同款’为常见营销表达，强调风格相似，未直接使用品牌标识，不构成侵权\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02248.jpg", "image": "data/raw/images/product_02248.jpg", "prompt": "蓝灰条纹男士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色与灰色相间\", \"材质\": \"棉质\", \"款式\": \"条纹Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中蓝灰横条纹Polo衫的视觉特征，颜色、款式与材质均与实物一致，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色与黑色相间\", \"材质\": \"涤纶\", \"款式\": \"圆领T恤\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红黑相间，材质为涤纶，款式为圆领T恤，与图中蓝灰条纹Polo衫不符，但未涉及违规词或侵权，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00818.jpg", "image": "data/raw/images/product_00818.jpg", "prompt": "黑色男士商务皮鞋，系带款式，经典正装设计", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装皮鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为黑色皮革材质的男士系带正装皮鞋，颜色、材质、款式均与图中一致。未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装皮鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00645.jpg", "image": "data/raw/images/product_00645.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款灰色运动T恤，潮流印花设计，速抢！", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉\", \"款式\": \"短袖圆领印花\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和打折信息，制造虚假促销假象，与图片展示的普通T恤真实价值不符 — 虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"灰色\", \"款式\": \"短袖圆领印花\"}, \"violation\": false, \"reason\": \"商品描述中价格信息为常见促销表达，未明确标注原价来源，属正常营销话术，无明显虚假宣传\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01075.jpg", "image": "data/raw/images/product_01075.jpg", "prompt": "玫瑰金表壳黑色皮带计时码表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"玫瑰金/黑色\", \"材质\": \"金属/皮革\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中玫瑰金色金属表壳、黑色皮革表带及计时码表功能，未使用极限词或虚标材质，品牌标识清晰无傍名牌嫌疑，符合真实属性与合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"玫瑰金/黑色\", \"材质\": \"金属/皮革\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00402.jpg", "image": "data/raw/images/product_00402.jpg", "prompt": "白色印花短袖T恤，树形图案配红色心形装饰", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为白色圆领短袖T恤，印有黑色树形图案及红色心形元素，下方文字为'It my Hearts.'，描述与图片一致。未使用极限词、未虚标材质、无品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02372.jpg", "image": "data/raw/images/product_02372.jpg", "prompt": "深蓝色印花民族风连衣裙，七分袖设计，胸前饰有彩色刺绣图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝底配米白、紫红、橙色印花\", \"材质\": \"棉质\", \"款式\": \"七分袖A字连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中服饰的深蓝色底色、米白与彩色几何印花、胸前刺绣装饰及七分袖A字版型，未使用极限词或虚标材质，未提及品牌关联或功效承诺，符合广告法要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝底配米白、紫红、橙色印花\", \"材质\": \"棉质\", \"款式\": \"七分袖A字连衣裙\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00498.jpg", "image": "data/raw/images/product_00498.jpg", "prompt": "红色儿童T恤，包治百病，7天瘦10斤，一抹白，穿出健康好气色", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中包含『包治百病』『7天瘦10斤』『一抹白』等不可能的功效承诺，与图片中实际为普通儿童T恤的属性不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"涤纶\", \"款式\": \"长袖印花\"}, \"violation\": true, \"reason\": \"商品描述中存在虚假功效承诺，且图片显示为蓝色涤纶长袖T恤，与实际红色棉质短袖不符，属属性错配及虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
