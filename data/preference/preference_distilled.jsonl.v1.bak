{"image_file": "product_02376.jpg", "image": "data/raw/images/product_02376.jpg", "prompt": "最新款超低价全网最低绝对顶级红色刺绣长袖连衣裙，时尚百搭必备", "chosen": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"长袖刺绣\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"长袖刺绣\"}, \"violation\": true, \"reason\": \"该商品存在夸大宣传问题，描述内容不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00208.jpg", "image": "data/raw/images/product_00208.jpg", "prompt": "最新款黄色印花T恤，超低价全网最低，绝对顶级潮流单品，限时抢购！", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传内容，整体描述不符合平台规范要求，需进一步审核处理\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00384.jpg", "image": "data/raw/images/product_00384.jpg", "prompt": "黑色运动短裤，侧边蓝色条纹设计，透气速干面料", "chosen": "{\"category\": \"运动短裤\", \"attributes\": {\"颜色\": \"黑色/蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"侧边条纹\"}, \"violation\": false, \"reason\": \"商品为黑色主体配蓝色侧边条纹的运动短裤，图片显示其材质为常见聚酯纤维类运动面料，描述中未使用极限词或虚标材质，未提及品牌名称或仿冒信息，仅客观陈述颜色、材质与款式特征，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"运动短裤\", \"attributes\": {\"颜色\": \"黑色/蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"侧边条纹\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00430.jpg", "image": "data/raw/images/product_00430.jpg", "prompt": "白色印花男士短袖T恤，美式复古风格图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为白色棉质圆领短袖T恤，正面印有'AMERICAN GLORY'等美式复古图案，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，未涉及品牌侵权或虚假宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中'美式复古风格'属于主观夸大，易引导消费者产生过度期待，涉嫌虚假宣传，不符合商品实际风格定位。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01066.jpg", "image": "data/raw/images/product_01066.jpg", "prompt": "蓝灰条纹PUMA男士短袖POLO衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝灰条纹\", \"材质\": \"棉质混纺\", \"款式\": \"短袖POLO衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝灰相间横条纹的PUMA品牌POLO衫，领口为白色翻领，左胸有PUMA标志及圆形徽章，与描述完全一致。未使用极限词、未虚标材质（如‘纯棉’未标注则不承诺）、未涉及功效夸大或傍名牌表述，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红白条纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品为红白条纹聚酯纤维短袖T恤，左胸有PUMA标志，符合描述内容，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00513.jpg", "image": "data/raw/images/product_00513.jpg", "prompt": "红色连帽无袖儿童运动背心，印有蓝色数字63和白色DIVI1A字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"连帽无袖\"}, \"violation\": false, \"reason\": \"商品为红色连帽无袖背心，图中可见主体颜色为红色，带有蓝色数字63与白色DIVI1A印花，材质从织物纹理判断为棉质，款式为无袖带帽设计。描述准确反映实物属性，未使用极限词、未虚标材质、未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"连帽无袖\"}, \"violation\": true, \"reason\": \"描述中‘DIVI1A’字样疑似品牌暗示，存在误导性宣传风险，且未明确标注材质成分，涉嫌虚标。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00741.jpg", "image": "data/raw/images/product_00741.jpg", "prompt": "深棕色拼接皮质男款休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": false, \"reason\": \"图片显示为深棕色拼接皮革材质的男款系带休闲鞋，描述准确反映其颜色、材质与款式特征，未使用极限词或虚标材质，无夸大功效或傍名牌表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02306.jpg", "image": "data/raw/images/product_02306.jpg", "prompt": "棕色几何图案无袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"棕色系\", \"材质\": \"织物\", \"款式\": \"无袖直筒\"}, \"violation\": false, \"reason\": \"商品描述为'棕色几何图案无袖连衣裙'，与图片中模特穿着的深棕底色、米白与浅红交织几何纹样、无袖直筒版型完全一致。未使用极限词或夸大宣传，未虚标材质（如宣称丝绸却实为化纤），未涉及品牌侵权表述，符合真实商品属性展示要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"棕色系\", \"材质\": \"织物\", \"款式\": \"无袖直筒\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01639.jpg", "image": "data/raw/images/product_01639.jpg", "prompt": "深蓝色水洗牛仔裤，修身直筒版型", "chosen": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色水洗牛仔裤，具有明显磨白效果和修身直筒剪裁，描述准确反映其颜色、材质与款式特征。未使用极限词或夸大宣传，未虚标成分，无品牌侵权表述，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00151.jpg", "image": "data/raw/images/product_00151.jpg", "prompt": "黑色配荧光绿 Nike 低帮运动鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色、荧光绿、灰色、白色\", \"材质\": \"皮革\", \"款式\": \"低帮系带\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，鞋身主体为黑色，搭配荧光绿 Swoosh 标志与鞋带边缘，鞋头及中底为灰色与白色，材质从光泽判断为皮革，款式为低帮系带设计。描述未使用极限词或虚标材质，品牌标识清晰但未作侵权暗示，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色、荧光绿、灰色、白色\", \"材质\": \"皮革\", \"款式\": \"低帮系带\"}, \"violation\": true, \"reason\": \"描述中‘荧光绿’属于极限词，易引导消费者产生误导性认知，且未标注具体材质占比，涉嫌虚标，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02459.jpg", "image": "data/raw/images/product_02459.jpg", "prompt": "男士深灰色修身商务西裤", "chosen": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"混纺面料\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为深灰色修身款男士西裤，材质为常见混纺面料，无明显品牌标识或仿冒元素。描述中未使用极限词、未夸大功能，颜色、款式与实物一致，符合广告法及电商平台合规要求。\"}", "rejected": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"纯棉\", \"款式\": \"宽松阔腿\"}, \"violation\": false, \"reason\": \"商品为浅蓝色纯棉宽松阔腿裤，与描述中深灰色修身款不符，但无品牌标识或违规宣传，整体合规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00250.jpg", "image": "data/raw/images/product_00250.jpg", "prompt": "这款优雅的红色真丝连衣裙采用修身剪裁，适合正式场合穿着，展现女性魅力。", "chosen": "{\"category\": \"鞋子\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": true, \"reason\": \"商品描述中的'红色真丝连衣裙'与主图展示的黑色皮革系带休闲鞋明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"鞋子\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带休闲鞋\"}, \"violation\": true, \"reason\": \"该商品存在信息不一致问题，可能对消费者造成误解，不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01030.jpg", "image": "data/raw/images/product_01030.jpg", "prompt": "深蓝色水洗牛仔裤，直筒修身版型", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色水洗牛仔裤，材质为典型牛仔布，版型为直筒修身，描述与实物完全一致。未使用极限词、未夸大功效、未虚标材质，也无品牌侵权表述，符合商品合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01126.jpg", "image": "data/raw/images/product_01126.jpg", "prompt": "黑色网面透气运动鞋，配白色Swoosh标志和灰色鞋底", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色、白色、灰色\", \"材质\": \"网面\", \"款式\": \"低帮系带运动鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为黑灰白三色搭配，材质为可见的网眼布料，款式为低帮系带设计，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红色、黄色、蓝色\", \"材质\": \"皮革\", \"款式\": \"高帮靴\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红黄蓝三色，材质标注为皮革，款式为高帮靴，与图片实际展示的黑灰白配色网面低帮鞋不符，但未涉及违规词或侵权表述。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00295.jpg", "image": "data/raw/images/product_00295.jpg", "prompt": "这款手表采用100%纯棉表带，时尚简约设计，适合日常佩戴", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属\", \"款式\": \"矩形表盘\"}, \"violation\": true, \"reason\": \"描述中提及的『100%纯棉』与图片所示金属材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"金色\", \"材质\": \"皮革\", \"款式\": \"圆形表盘\"}, \"violation\": true, \"reason\": \"商品描述中提到的金色皮革圆形表盘与实际图片中的银色金属矩形表盘不符，存在虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00562.jpg", "image": "data/raw/images/product_00562.jpg", "prompt": "黑色皮带方形表盘男士手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"方形\"}, \"violation\": false, \"reason\": \"商品为黑色皮质表带搭配银色金属表壳的方形腕表，表盘设计简洁，品牌标识清晰可见。描述中仅陈述了真实可辨的颜色、材质与款式特征，未使用极限词或夸大功效表述，未虚标材质（如标注为真皮但实为合成革），也未涉及傍名牌或侵权用语，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"方形\"}, \"violation\": true, \"reason\": \"描述中‘黑色皮带’可能暗示为真皮，但未明确标注材质来源，存在虚标风险，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02413.jpg", "image": "data/raw/images/product_02413.jpg", "prompt": "深紫色修身弹力打底裤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"弹力面料\", \"款式\": \"修身打底裤\"}, \"violation\": false, \"reason\": \"图片显示为深紫色修身款弹力打底裤，描述准确反映其颜色、材质与款式特征，未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉麻混纺\", \"款式\": \"阔腿裤\"}, \"violation\": false, \"reason\": \"商品为浅蓝色棉麻混纺阔腿裤，颜色与材质描述相符，款式为宽松版型，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00371.jpg", "image": "data/raw/images/product_00371.jpg", "prompt": "蓝色编织表带Puma数字运动手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"编织表带\", \"款式\": \"数字显示运动款\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中蓝色编织表带、黑色方形表盘及Puma品牌标识的数字运动手表，未使用极限词或虚标材质，表盘显示时间与日期功能真实存在，符合实际产品属性，无夸大宣传或侵权表述。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"编织表带\", \"款式\": \"数字显示运动款\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01875.jpg", "image": "data/raw/images/product_01875.jpg", "prompt": "浅紫色碎花棉质连衣裙，方领短袖设计", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"浅紫与米白\", \"材质\": \"棉质\", \"款式\": \"方领短袖连衣裙\"}, \"violation\": false, \"reason\": \"图片显示为浅紫色花卉图案的棉质连衣裙，方领短袖设计，颜色、材质与款式描述一致。未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深蓝与黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为深蓝色调聚酯纤维长袖连衣裙，图案清晰，材质与款式描述一致，无违规宣传内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00216.jpg", "image": "data/raw/images/product_00216.jpg", "prompt": "白色耐克运动短裤，侧边黑色条纹设计", "chosen": "{\"category\": \"运动短裤\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"聚酯纤维\", \"款式\": \"侧边条纹\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，主色为白色，右侧有黑色竖条纹，左腿下方可见Nike标志，材质根据常见运动短裤推断为聚酯纤维，未使用极限词或虚标材质，未涉及侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"运动短裤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"纯色\"}, \"violation\": false, \"reason\": \"商品主色为黑色，无侧边条纹，材质为棉质，款式为纯色设计，符合描述内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00992.jpg", "image": "data/raw/images/product_00992.jpg", "prompt": "蓝色条纹男士短袖Polo衫，搭配黄色与灰色横条纹设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝、黄、灰、白\", \"材质\": \"棉质\", \"款式\": \"条纹Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝色底色配黄色、灰色及白色横条纹的男士Polo衫，描述准确反映其颜色组合与款式特征。材质未虚标，无夸大功效或极限词，未使用品牌傍名牌表述，符合商品真实属性与合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红、绿、黑\", \"材质\": \"化纤\", \"款式\": \"圆领T恤\"}, \"violation\": false, \"reason\": \"商品为红色底色搭配绿色与黑色条纹的圆领T恤，材质为化纤，符合描述内容，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01832.jpg", "image": "data/raw/images/product_01832.jpg", "prompt": "彩色印花V领短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"多色印花（主色调为绿、粉、白）\", \"材质\": \"棉质混纺\", \"款式\": \"V领短袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中服饰的V领、短袖、A字版型及多彩几何与花卉印花特征，未使用极限词或虚标材质，颜色与图案细节与实物一致，无傍名牌或夸大宣传行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"深蓝与黑色拼接\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖修身连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为深蓝与黑色拼接，材质为聚酯纤维，款式为长袖修身款，与图中印花V领短袖A字裙特征不符，但未涉及极限词或虚假宣传，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00165.jpg", "image": "data/raw/images/product_00165.jpg", "prompt": "原价999直降到99，限时清仓甩卖！经典棕色皮质托特包，质感十足，超值抢购！", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"托特包\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和折扣信息，与图片中无价格标识的普通皮质托特包属性不符，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"帆布\", \"款式\": \"斜挎包\"}, \"violation\": true, \"reason\": \"商品描述中称其为黑色帆布斜挎包，但图片显示为棕色皮革托特包，属性严重不符，涉嫌虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00185.jpg", "image": "data/raw/images/product_00185.jpg", "prompt": "酒红色真皮手提包，双拉链设计，配金属扣件", "chosen": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"真皮\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"图片显示为酒红色皮革材质的手提包，具有双侧拉链和金属五金件，描述准确反映商品实际颜色、材质与款式，未使用极限词或虚标材质，无傍名牌或夸大宣传行为，符合合规要求。\"}", "rejected": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"真皮\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01199.jpg", "image": "data/raw/images/product_01199.jpg", "prompt": "这款优雅的连衣裙采用高级面料制成，适合日常穿搭，展现女性柔美气质。", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"灰色与黑色拼接\", \"材质\": \"皮革\", \"款式\": \"托特包\"}, \"violation\": true, \"reason\": \"商品描述中提到'连衣裙'，但主图展示的是手提包，商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"灰色与黑色拼接\", \"款式\": \"托特包\"}, \"violation\": false, \"reason\": \"商品描述中的'连衣裙'可能是对系列产品的泛指，主图展示的手提包属于同款系列，整体风格一致，不构成明显误导\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00284.jpg", "image": "data/raw/images/product_00284.jpg", "prompt": "这款时尚优雅的蓝色连衣裙采用轻盈雪纺材质，适合夏季日常穿搭，展现女性柔美气质。", "chosen": "{\"category\": \"鞋子\", \"attributes\": {\"颜色\": \"银色与蓝色\", \"材质\": \"网布与橡胶\", \"款式\": \"运动鞋\"}, \"violation\": true, \"reason\": \"商品描述中的'蓝色连衣裙'与主图展示的银蓝配色运动鞋明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"鞋子\", \"attributes\": {\"颜色\": \"银色与蓝色\", \"款式\": \"运动鞋\"}, \"violation\": false, \"reason\": \"商品描述虽提及连衣裙，但可能为系列商品展示差异，主图清晰展示运动鞋，整体无明显误导\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00632.jpg", "image": "data/raw/images/product_00632.jpg", "prompt": "黑色PUMA保龄球主题印花短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为黑色圆领短袖T恤，正面印有'PUMA BOWLING CLUB'及保龄球图案，与描述完全一致。材质未虚标，无夸大功效或极限词，未使用仿冒品牌表述，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"商品描述中'保龄球主题印花'属于主观夸大，未明确标注图案占比，存在误导消费者风险，涉嫌虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01233.jpg", "image": "data/raw/images/product_01233.jpg", "prompt": "蓝色儿童卡通人字拖，印有米奇图案和彩色字母", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为蓝色橡胶材质儿童人字拖，鞋面印有米奇头像及彩色字母图案，描述准确反映图片内容，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"布料\", \"款式\": \"运动鞋\"}, \"violation\": false, \"reason\": \"商品为红色布料材质儿童运动鞋，鞋面有卡通图案，描述与图片内容一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00134.jpg", "image": "data/raw/images/product_00134.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "chosen": "{\"category\": \"手表\", \"attributes\": {\"品牌\": \"PUMA\", \"表带颜色\": \"黑色\", \"表带材质\": \"皮革\", \"表盘形状\": \"矩形\", \"表盘颜色\": \"黑色\", \"表盘数字\": \"12, 3, 6, 9\", \"指针颜色\": \"银色\", \"表壳材质\": \"金属\", \"缝线颜色\": \"白色\"}, \"violation\": true, \"reason\": \"商品图片展示的为一款PUMA品牌的手表，但商品描述中提及'面料柔软 版型修身 显瘦神器'，这些描述适用于服装类商品，与实际商品类别（手表）严重不符，属于虚假或误导性描述。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"品牌\": \"PUMA\", \"表带颜色\": \"红色\", \"表带材质\": \"尼龙\", \"表盘形状\": \"矩形\", \"表盘颜色\": \"黑色\", \"表盘数字\": \"12, 3, 6, 9\", \"指针颜色\": \"银色\", \"表壳材质\": \"金属\", \"缝线颜色\": \"白色\"}, \"violation\": true, \"reason\": \"商品描述中提到的‘面料柔软’与图中红色尼龙表带不符，实际为黑色皮革材质，存在属性错误。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00452.jpg", "image": "data/raw/images/product_00452.jpg", "prompt": "最新款PUMA男士T恤，超低价抢购，全网最低价，绝对顶级品质！", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述中使用‘最新款’等词语属于常见营销表达，未明显违反广告法，整体内容符合平台规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01991.jpg", "image": "data/raw/images/product_01991.jpg", "prompt": "男士浅色格纹短袖衬衫，休闲百搭款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝、米白、橙黄格纹\", \"材质\": \"棉质\", \"款式\": \"短袖格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述为‘男士浅色格纹短袖衬衫’，与图片中模特穿着的浅蓝、米白、橙黄相间的格纹短袖衬衫完全一致，材质从织物纹理判断为棉质，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅蓝、米白、橙黄格纹\", \"材质\": \"棉质\", \"款式\": \"短袖格子衬衫\"}, \"violation\": true, \"reason\": \"描述中‘百搭款’属于隐性极限词，暗示适用所有场景，存在夸大宣传嫌疑，不符合广告法规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01177.jpg", "image": "data/raw/images/product_01177.jpg", "prompt": "黑色Nike短袖T恤，正面印有彩色涂鸦风格图案，包含足球元素与艺术字体设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：黑色T恤、圆领短袖款式、正面为多彩涂鸦图案，含足球与艺术字体元素，品牌标识清晰可见。未使用极限词或夸大宣传，材质标注合理，无虚标或傍名牌行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00709.jpg", "image": "data/raw/images/product_00709.jpg", "prompt": "原价999直降到99，限时清仓甩卖男士商务皮鞋，真皮舒适百搭", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"深棕色\", \"材质\": \"反绒皮\", \"款式\": \"系带正装皮鞋\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和打折信息，与图片中展示的普通男式反绒皮正装鞋真实市场定位不符，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"深棕色\", \"款式\": \"系带正装皮鞋\"}, \"violation\": false, \"reason\": \"商品描述中价格信息为常见促销表达，未发现明显虚假宣传，图文相符，符合正常营销惯例\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01201.jpg", "image": "data/raw/images/product_01201.jpg", "prompt": "酒红色绒面拼接皮质手提包", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"绒面+皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中包袋的酒红色调、绒面与皮革拼接材质及手提款式，未使用夸大或虚假宣传用语，未涉及极限词或品牌侵权表述，属性与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"墨绿色\", \"材质\": \"帆布+尼龙\", \"款式\": \"斜挎包\"}, \"violation\": false, \"reason\": \"商品描述中颜色为墨绿色，材质为帆布与尼龙拼接，款式为斜挎包，与图中实际酒红色绒面皮革手提包不符，但未使用违规词，故不构成违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01096.jpg", "image": "data/raw/images/product_01096.jpg", "prompt": "PUMA品牌黑色皮质表带镶钻金色边框方形手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"方形镶钻\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中PUMA品牌、黑色皮质表带、金色边框及镶钻设计的方形手表，未使用极限词或虚标材质，品牌标识清晰且无仿冒暗示，符合真实属性与合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"方形镶钻\"}, \"violation\": true, \"reason\": \"描述中‘镶钻’可能夸大实际镶嵌数量，存在虚标风险，且‘金色边框’未明确说明为电镀工艺，涉嫌材质误导。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00129.jpg", "image": "data/raw/images/product_00129.jpg", "prompt": "黑色吊带背心，简约百搭款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"吊带\"}, \"violation\": false, \"reason\": \"图片中展示的为一件黑色吊带背心，材质为棉质，款式为简约吊带设计，描述与实物一致。未使用极限词、未夸大功效、未虚标材质，也无傍名牌或侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉质\", \"款式\": \"吊带\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01399.jpg", "image": "data/raw/images/product_01399.jpg", "prompt": "黑白格纹短袖衬衫男款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑白格纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖衬衫\"}, \"violation\": false, \"reason\": \"图片显示为一件黑白格纹短袖衬衫，描述准确对应其颜色、款式与基本材质特征，未使用极限词或虚标材质，无夸大功效或傍名牌表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑白格纹\", \"材质\": \"棉混纺\", \"款式\": \"短袖衬衫\"}, \"violation\": true, \"reason\": \"描述中‘黑白格纹’可能暗示唯一性，存在隐性极限词嫌疑，且未明确标注具体成分比例，涉嫌虚标材质，不符合规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02442.jpg", "image": "data/raw/images/product_02442.jpg", "prompt": "蓝白黑格纹男士长袖衬衫，翻领设计，胸前带口袋", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白黑格纹\", \"材质\": \"棉质\", \"款式\": \"长袖翻领衬衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件蓝白黑相间的格纹男式长袖衬衫，具有标准翻领和胸前口袋，袖口卷起。描述准确反映了商品的颜色、材质（从织物纹理判断为棉质）、款式等核心属性，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黄绿格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品为红黄绿格纹短袖Polo衫，材质为聚酯纤维，符合描述内容，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01853.jpg", "image": "data/raw/images/product_01853.jpg", "prompt": "蓝紫花卉印花无袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝紫色系印花\", \"材质\": \"棉混纺\", \"款式\": \"无袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的蓝紫花卉图案、无袖设计及A字版型，材质标注为棉混纺符合常见印花裙类面料，未使用极限词或虚标成分，未涉及品牌仿冒或功效夸大，整体描述与实物一致且合规。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"红橙色系印花\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红橙色系，材质为聚酯纤维，款式为长袖，与图中蓝紫印花、无袖设计不符，但未涉及违规词，故不判定违规。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
