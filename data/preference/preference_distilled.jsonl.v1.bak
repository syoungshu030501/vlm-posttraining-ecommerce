{"image_file": "product_01916.jpg", "image": "data/raw/images/product_01916.jpg", "prompt": "蓝色棉麻刺绣短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉麻\", \"款式\": \"短袖刺绣连衣裙\"}, \"violation\": false, \"reason\": \"图片中展示的为一件蓝色棉麻材质的短袖连衣裙，胸前有白色刺绣图案，描述准确对应商品实际颜色、材质与款式特征。未使用极限词或夸大宣传，未虚标材质，无傍名牌或侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉麻\", \"款式\": \"短袖刺绣连衣裙\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01147.jpg", "image": "data/raw/images/product_01147.jpg", "prompt": "LV平替环保T恤，小香风原单设计，NIKE同款潮流印花", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用『LV平替』『小香风原单』『NIKE同款』等词，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权 — 图片实际为普通黑色印花T恤，无任何品牌标识\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，内容不符合平台规范要求，整体审核结果判定为违规\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02096.jpg", "image": "data/raw/images/product_02096.jpg", "prompt": "灰色帆布低帮休闲鞋，红色细节装饰", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"帆布\", \"款式\": \"低帮休闲鞋\"}, \"violation\": false, \"reason\": \"商品为灰色帆布材质的低帮休闲鞋，鞋身主体为灰色，鞋头为白色，鞋底边缘有红色线条装饰，侧面有红色兔子标志。描述准确反映图片中可见的颜色、材质与款式特征，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"高帮运动鞋\"}, \"violation\": false, \"reason\": \"商品为黑色皮革材质的高帮运动鞋，鞋身整体呈深色，鞋底有红色装饰线条。描述中的颜色、材质与款式信息与图片内容一致，未发现违规问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02077.jpg", "image": "data/raw/images/product_02077.jpg", "prompt": "粉色与橙色花卉图案短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"粉色、橙色、白色\", \"材质\": \"棉质\", \"款式\": \"短袖印花连衣裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，连衣裙为粉色与橙色花卉图案，短袖设计，材质从视觉判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"粉色、橙色、白色\", \"材质\": \"棉质\", \"款式\": \"短袖印花连衣裙\"}, \"violation\": true, \"reason\": \"描述中‘花卉图案’属于过度美化，涉嫌夸大宣传；‘棉质’未提供质检报告，存在虚标材质风险，不符合平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01333.jpg", "image": "data/raw/images/product_01333.jpg", "prompt": "深灰色男士印花短袖T恤，正面印有紫色数字47及摩托车主题图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰\", \"材质\": \"棉\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为深灰色棉质圆领短袖T恤，正面印有紫色'47'及'MOTOR CITY'等摩托车主题图案，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，无仿冒品牌标识，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰\", \"材质\": \"棉\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"商品描述中'深灰色'与图中实际偏黑色调存在色差，涉嫌虚标颜色，且'摩托车主题图案'属于夸大宣传，构成虚假描述。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01709.jpg", "image": "data/raw/images/product_01709.jpg", "prompt": "黑色圆领针织毛衣，正面印有白色'Benetton Univ Toughness'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"圆领长袖\"}, \"violation\": false, \"reason\": \"商品为黑色针织毛衣，图中可见其圆领长袖设计及正面白色印花文字，描述准确反映实际品类、颜色与款式。未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"针织\", \"款式\": \"圆领长袖\"}, \"violation\": true, \"reason\": \"描述中'Benetton Univ Toughness'字样可能暗示品牌关联，存在误导性宣传风险，涉嫌虚假或夸大表述，不符合广告规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02414.jpg", "image": "data/raw/images/product_02414.jpg", "prompt": "橙色褶皱质感围巾，轻盈柔软，适合日常搭配", "chosen": "{\"category\": \"围巾\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"棉质\", \"款式\": \"褶皱长款\"}, \"violation\": false, \"reason\": \"图片中围巾为橙色，具有明显褶皱纹理，材质从视觉判断为棉质类轻薄面料，描述准确反映其颜色、材质与款式特征。未使用极限词或夸大宣传，无虚标材质、功效承诺或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"围巾\", \"attributes\": {\"颜色\": \"橙色\", \"材质\": \"棉质\", \"款式\": \"褶皱长款\"}, \"violation\": true, \"reason\": \"描述中‘轻盈柔软’属于主观夸大用语，未提供具体材质检测依据，涉嫌虚标材质属性，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00501.jpg", "image": "data/raw/images/product_00501.jpg", "prompt": "PUMA同款时尚女表，小香风平替设计，镶钻表盘尽显奢华气质", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"金属表壳，硅胶表带\", \"款式\": \"方形镶钻多功能表盘\"}, \"violation\": true, \"reason\": \"描述中使用『PUMA同款』一词，但图片显示为PUMA品牌商品，涉嫌擅自使用他人品牌作宣传，侵犯注册商标专用权\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"金属表壳，硅胶表带\"}, \"violation\": false, \"reason\": \"商品描述中『PUMA同款』为常见营销表达，未直接使用品牌标识，且图片为实际商品展示，不构成侵权\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00925.jpg", "image": "data/raw/images/product_00925.jpg", "prompt": "NIKE同款红色V领修身T恤，时尚百搭，运动休闲两相宜", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉\", \"款式\": \"V领短袖\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』蹭大牌，但图片商品为普通红色V领T恤，无任何NIKE品牌标识 — 擅自使用他人品牌作宣传,涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"红色\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品描述中‘NIKE同款’为常见营销表达，未直接使用品牌标识，属于正常风格参考，不构成侵权\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00454.jpg", "image": "data/raw/images/product_00454.jpg", "prompt": "ESPRIT品牌彩色条纹硅胶表带透明表壳方形手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝紫粉白条纹\", \"材质\": \"硅胶表带，透明塑料表壳\", \"款式\": \"方形表盘，条纹设计\"}, \"violation\": false, \"reason\": \"商品描述准确对应图中ESPRIT品牌标识、蓝紫粉白相间的条纹图案、硅胶材质表带及透明塑料表壳的方形设计，未使用极限词或虚标材质，未涉及功效夸大或傍名牌行为，所有属性均与图片一致，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"蓝紫粉白条纹\", \"材质\": \"硅胶表带，透明塑料表壳\", \"款式\": \"方形表盘，条纹设计\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00458.jpg", "image": "data/raw/images/product_00458.jpg", "prompt": "橄榄绿菱格纹编织手提包", "chosen": "{\"category\": \"女包\", \"attributes\": {\"颜色\": \"橄榄绿\", \"材质\": \"人造革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，包体为橄榄绿色，表面有清晰菱格压纹，手柄为编织设计，材质为人造革，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合合规要求。\"}", "rejected": "{\"category\": \"女包\", \"attributes\": {\"颜色\": \"橄榄绿\", \"材质\": \"人造革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00700.jpg", "image": "data/raw/images/product_00700.jpg", "prompt": "白色皮质表带镶钻矩形女款手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"皮革\", \"款式\": \"矩形镶钻\"}, \"violation\": false, \"reason\": \"商品为白色皮质表带的矩形手表，表盘上下镶嵌多颗闪亮水钻，表盘刻有罗马数字XII和VI，品牌标识为ESPRIT，整体设计简洁优雅。描述准确反映图片中表带颜色、材质及款式特征，未使用极限词或夸大宣传，未虚标材质或冒用知名品牌，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"金属\", \"款式\": \"圆形镂空\"}, \"violation\": false, \"reason\": \"商品为黑色金属表带的圆形镂空手表，表盘设计与图片中矩形镶钻款式不符，但整体风格一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00928.jpg", "image": "data/raw/images/product_00928.jpg", "prompt": "深灰色系带无袖针织背心", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰\", \"材质\": \"针织\", \"款式\": \"系带无袖\"}, \"violation\": false, \"reason\": \"商品描述为'深灰色系带无袖针织背心'，与图片中模特穿着的衣物在颜色、材质和款式上完全一致。未使用极限词或夸大宣传，未虚标材质（如宣称纯棉而实为混纺），未涉及品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深灰\", \"材质\": \"针织\", \"款式\": \"系带无袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00061.jpg", "image": "data/raw/images/product_00061.jpg", "prompt": "这款格子衬衫包治百病，7天瘦10斤，一抹白，穿出自信美！", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"棉\", \"款式\": \"短袖格子衬衫\"}, \"violation\": true, \"reason\": \"描述中使用『包治百病』『7天瘦10斤』『一抹白』等词，对服装商品作不可能的功效承诺，与图片真实属性（普通格子衬衫）严重不符 — 参考：对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"红蓝\", \"材质\": \"涤纶\", \"款式\": \"长袖连帽卫衣\"}, \"violation\": true, \"reason\": \"描述中声称有瘦身美白功效，且属性标注为红蓝涤纶长袖卫衣，与图片中黑白棉质短袖格子衬衫严重不符，属虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01913.jpg", "image": "data/raw/images/product_01913.jpg", "prompt": "米白色针织拼接无袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"针织\", \"款式\": \"无袖连衣裙\"}, \"violation\": false, \"reason\": \"图片中展示的为一件米白色为主色调、两侧带有深色编织条纹的无袖连衣裙，主体材质为针织面料，款式为简约修身型无袖设计。描述准确反映了商品的颜色、材质与款式特征，未使用极限词或夸大宣传，未虚标材质，也未涉及品牌侵权或功效承诺，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉麻\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为深蓝色棉麻材质的长袖连衣裙，整体风格偏向休闲日常，颜色与材质描述符合实物特征，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01000.jpg", "image": "data/raw/images/product_01000.jpg", "prompt": "紫色机器人图案印花短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为紫色圆领短袖T恤，正面印有绿色机器人图案及英文文字，材质从图中可判断为常规棉质面料，描述准确反映实际商品属性，未使用极限词或虚标材质，未涉及品牌侵权或夸大宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"商品描述中‘机器人图案’属夸张宣传，实际为普通印花，涉嫌虚标设计元素，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02173.jpg", "image": "data/raw/images/product_02173.jpg", "prompt": "黑色皮质男士商务乐福鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色皮革材质的男士乐福鞋，鞋面光滑，带有搭扣设计，鞋底为棕色橡胶材质，整体风格符合商务正装需求。描述准确反映了商品的颜色、材质与款式，未使用夸大或虚假宣传用语，未涉及极限词或品牌侵权表述，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": true, \"reason\": \"描述中‘皮质’可能暗示真皮，但图片无法确认材质真实性，存在虚假宣传嫌疑，需进一步核实。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01112.jpg", "image": "data/raw/images/product_01112.jpg", "prompt": "橄榄绿绒面革一脚蹬休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"橄榄绿\", \"材质\": \"绒面革\", \"款式\": \"一脚蹬\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为橄榄绿，材质为绒面革，款式为一脚蹬设计，未使用极限词或夸大宣传，未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"橄榄绿\", \"材质\": \"绒面革\", \"款式\": \"一脚蹬\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00870.jpg", "image": "data/raw/images/product_00870.jpg", "prompt": "棕色皮革编织链式女款手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革与金属\", \"款式\": \"编织链式\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示的棕色皮革与银色金属链条结合的手表，品牌标识为ESPRIT，未使用夸大或虚假宣传用语，材质、颜色、款式均与实物一致，无虚标或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革与金属\", \"款式\": \"编织链式\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01793.jpg", "image": "data/raw/images/product_01793.jpg", "prompt": "彩色拼接人字拖女款平底凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"粉色、蓝色、黄色\", \"材质\": \"人造革\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为彩色拼接人字拖，图片显示其由粉色、蓝色和黄色带子组成，鞋底为深棕色，材质为常见人造革，与描述一致。未使用极限词或夸大功效表述，未虚标材质或品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"粉色、蓝色、黄色\", \"材质\": \"人造革\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"商品描述中‘彩色拼接’属于主观美化用语，涉嫌夸大宣传，且未明确标注具体材质比例，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01977.jpg", "image": "data/raw/images/product_01977.jpg", "prompt": "100%纯棉男士格子衬衫，休闲时尚，舒适透气", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"红蓝白格子\", \"材质\": \"混纺\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片所示衬衫为明显混纺材质（含化纤成分），表面光泽和纹理不符合纯棉特征 — 图片所示材质与描述的100%纯棉明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"红蓝白格子\", \"材质\": \"混纺\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"该商品存在描述与实物不符的情况，整体信息不够准确，不符合平台审核标准\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02449.jpg", "image": "data/raw/images/product_02449.jpg", "prompt": "红色纯棉男士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"纯棉\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件红色短袖Polo衫，领口有两颗白色纽扣，面料纹理符合纯棉特征，描述与实物一致。未使用极限词、未虚标材质、未涉及品牌侵权或功效夸大，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"纯棉\", \"款式\": \"短袖Polo衫\"}, \"violation\": true, \"reason\": \"描述中‘纯棉’可能存在虚标，实际面料纹理未明确验证；‘红色’为常见色系，但未标注具体色号，涉嫌信息不完整，不符合平台规范。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00426.jpg", "image": "data/raw/images/product_00426.jpg", "prompt": "NIKE同款商务皮鞋，小香风原单设计，高端质感平替之选", "chosen": "{\"category\": \"皮鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装皮鞋\"}, \"violation\": true, \"reason\": \"描述中使用『NIKE同款』『小香风原单』等词语，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"皮鞋\", \"attributes\": {\"颜色\": \"黑色\", \"款式\": \"系带正装皮鞋\"}, \"violation\": false, \"reason\": \"商品描述中‘NIKE同款’为常见营销表达，未直接使用品牌标识，不构成侵权；‘小香风原单’属风格描述，无明确品牌指向，整体符合规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_01501.jpg", "image": "data/raw/images/product_01501.jpg", "prompt": "绿黑灰格纹商务领带", "chosen": "{\"category\": \"领带\", \"attributes\": {\"颜色\": \"绿色、黑色、灰色\", \"材质\": \"涤纶\", \"款式\": \"格纹\"}, \"violation\": false, \"reason\": \"商品为绿黑灰三色格纹图案的领带，图片中可见其实际颜色与图案分布，描述未使用极限词或虚标材质，未提及品牌或功效承诺，符合广告法要求，属性与实物一致。\"}", "rejected": "{\"category\": \"领带\", \"attributes\": {\"颜色\": \"绿色、黑色、灰色\", \"材质\": \"涤纶\", \"款式\": \"格纹\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00197.jpg", "image": "data/raw/images/product_00197.jpg", "prompt": "棕色鳄鱼纹皮革手提包", "chosen": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"图片显示为一款棕色、表面有鳄鱼纹压花的皮革手提包，描述准确对应其颜色、材质与款式特征。未使用极限词或夸大宣传，未虚标材质（如标注为真皮但实际为合成革），也未涉及品牌侵权或功效承诺，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02488.jpg", "image": "data/raw/images/product_02488.jpg", "prompt": "深蓝色竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"商务正装\"}, \"violation\": false, \"reason\": \"图片显示为一件深蓝色竖条纹长袖衬衫，材质从纹理判断为棉混纺，款式为标准商务正装款，描述与实物一致。未使用极限词、未虚标材质、未宣称功效或傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"商务正装\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合平台基本审核要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01816.jpg", "image": "data/raw/images/product_01816.jpg", "prompt": "深蓝色针织拼接领毛衣，印有'NORTH COAST UNIV'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"针织\", \"款式\": \"拼接领印花毛衣\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中深蓝色针织毛衣的款式特征，领口与袖口为格纹拼接设计，正面印有'NORTH COAST UNIV'字样，其中'H'为红色，其余为深色字母，未使用极限词或虚标材质，未涉及品牌侵权表述，整体描述与实物一致，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"针织\", \"款式\": \"拼接领印花毛衣\"}, \"violation\": true, \"reason\": \"描述中'拼接领'可能暗示特殊工艺，实际为常规设计，存在夸大宣传嫌疑，不符合真实商品特征。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01384.jpg", "image": "data/raw/images/product_01384.jpg", "prompt": "蓝黑格纹系带短袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝黑白格纹\", \"材质\": \"棉质\", \"款式\": \"系带短袖衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中蓝黑白相间格纹、前襟纽扣、腰部系带设计的短袖上衣，材质为常见棉质面料，未使用极限词或虚标材质，无品牌侵权表述，符合真实商品属性与合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黄条纹\", \"材质\": \"聚酯纤维\", \"款式\": \"无袖背心\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红黄条纹，材质为聚酯纤维，款式为无袖背心，与图中蓝黑白格纹、棉质、短袖系带衬衫不符，但未发现违规用语。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
