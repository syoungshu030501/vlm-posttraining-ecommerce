{"image_file": "product_01941.jpg", "image": "data/raw/images/product_01941.jpg", "prompt": "PUMA黑色橡胶表带计时腕表，银色表壳配红色指针", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色、银色、红色\", \"材质\": \"橡胶、金属\", \"款式\": \"计时腕表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中PUMA品牌计时腕表的黑色橡胶表带、银色金属表壳及红色指针等特征，未使用极限词或虚标材质，未夸大功能，品牌标识清晰且无傍名牌嫌疑，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色、银色、红色\", \"材质\": \"橡胶、金属\", \"款式\": \"计时腕表\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01141.jpg", "image": "data/raw/images/product_01141.jpg", "prompt": "深蓝色牛仔短裤，卷边设计，经典五袋款", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"卷边五袋短裤\"}, \"violation\": false, \"reason\": \"商品为深蓝色牛仔布材质短裤，图片显示其具有卷边和五袋结构，描述准确反映实际款式与材质，未使用极限词或虚标成分，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅粉色\", \"材质\": \"棉麻\", \"款式\": \"直筒长裤\"}, \"violation\": false, \"reason\": \"商品为浅粉色棉麻材质直筒长裤，图片显示其为浅色系且非牛仔布，符合描述中材质与款式的说明，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02473.jpg", "image": "data/raw/images/product_02473.jpg", "prompt": "灰色拼接浅蓝色领口袖口男士短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色、浅蓝色、白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"图片展示三款不同颜色的男士T恤，主图灰色款领口与袖口为浅蓝色拼接，左胸有'Basics 020'小标，其余两款分别为浅蓝与白色配深灰边。描述准确反映主体商品颜色与款式特征，未使用极限词或虚标材质，品牌标识清晰且无傍名牌嫌疑，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色、浅蓝色、白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中'拼接'一词暗示特殊工艺，但图片未体现明显缝合痕迹，涉嫌虚标工艺特征，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01154.jpg", "image": "data/raw/images/product_01154.jpg", "prompt": "粉色儿童短袖T恤，印有紫色天使图案和'FlapDoodle angel'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为粉色儿童T恤，图中可见其实际颜色、圆领短袖款式及印花内容，描述准确反映实物特征。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权或虚假功效宣称，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"化纤\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为蓝色儿童T恤，图中可见其实际颜色、V领短袖款式及印花内容，描述准确反映实物特征。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权或虚假功效宣称，符合广告法及电商合规要求。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02153.jpg", "image": "data/raw/images/product_02153.jpg", "prompt": "这款优雅的连衣裙采用优质棉麻混纺面料，适合春季穿着，展现女性柔美气质。", "chosen": "{\"category\": \"鞋子\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"男士乐福鞋\"}, \"violation\": true, \"reason\": \"商品描述中的'连衣裙'与主图展示的'男士皮鞋'明显不符，误导消费者 — 参考：商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"鞋子\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"针织\", \"款式\": \"女士高跟鞋\"}, \"violation\": true, \"reason\": \"商品描述中的'连衣裙'与主图展示的'浅蓝色针织女士高跟鞋'不符，存在误导消费者风险\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00480.jpg", "image": "data/raw/images/product_00480.jpg", "prompt": "荧光绿方形表盘镶钻女士手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"荧光绿\", \"材质\": \"塑料\", \"款式\": \"方形镶钻\"}, \"violation\": false, \"reason\": \"商品为荧光绿色塑料材质手表，表盘呈方形并镶嵌透明水钻，表带为同色系块状结构，表盘左侧印有'ESPRIT'品牌字样。描述准确反映其颜色、材质与款式特征，未使用极限词或虚标材质，未涉及功效夸大或侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"荧光绿\", \"材质\": \"塑料\", \"款式\": \"方形镶钻\"}, \"violation\": true, \"reason\": \"描述中'荧光绿'属于色彩夸大，易诱导消费者误认为具有发光功能，涉嫌虚假宣传，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00105.jpg", "image": "data/raw/images/product_00105.jpg", "prompt": "这款粉色皮质手提包，包治百病，7天瘦10斤，一抹白，时尚又健康！", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": true, \"reason\": \"描述中使用了『包治百病』『7天瘦10斤』『一抹白』等不可能的功效承诺，与图片中展示的普通粉色皮革手提包属性严重不符 — 对商品功效作不可能承诺，违反广告法第二十八条\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"粉色\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述中‘包治百病’等为夸张表达，属常见营销话术，未实际宣称功效，图文整体一致，不构成违规\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00896.jpg", "image": "data/raw/images/product_00896.jpg", "prompt": "小香风原单复古印花T恤，LV平替设计感上衣，时尚百搭显气质", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用『小香风原单』『LV平替』等词汇，暗示与CHANEL、LV品牌存在关联，但图片商品为普通印花T恤，无任何品牌标识 — 擅自使用他人品牌作宣传,涉嫌侵犯注册商标专用权\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"紫色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，整体内容不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00933.jpg", "image": "data/raw/images/product_00933.jpg", "prompt": "Puma品牌黑色表盘红色硅胶表带计时腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑红配色\", \"材质\": \"硅胶表带，金属表壳\", \"款式\": \"计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Puma品牌标识、黑红配色、硅胶表带及计时功能，未使用极限词或虚标材质，表盘设计与实际一致，符合广告法要求，无傍名牌或夸大宣传行为。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑红配色\", \"材质\": \"硅胶表带，金属表壳\", \"款式\": \"计时码表\"}, \"violation\": true, \"reason\": \"描述中‘Puma品牌’存在傍名牌嫌疑，未提供授权证明，且‘计时腕表’可能暗示精准计时功能，涉嫌夸大宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01764.jpg", "image": "data/raw/images/product_01764.jpg", "prompt": "白色男士短袖Polo衫，胸前有徽章刺绣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"Polo衫\"}, \"violation\": false, \"reason\": \"商品为白色棉质Polo衫，胸前有黑色徽章刺绣，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"T恤\"}, \"violation\": false, \"reason\": \"商品为黑色涤纶T恤，胸前有徽章图案，描述符合图中实际颜色、材质与款式特征，无违规用语。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00138.jpg", "image": "data/raw/images/product_00138.jpg", "prompt": "白色棒球帽配绿色RF刺绣标志", "chosen": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"棒球帽\"}, \"violation\": false, \"reason\": \"商品为白色棉质棒球帽，正面有绿色RF刺绣图案，描述准确反映图中颜色、材质与款式特征，未使用极限词或虚标材质，未涉及品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"渔夫帽\"}, \"violation\": false, \"reason\": \"商品为黑色涤纶渔夫帽，正面有绿色RF刺绣图案，描述与图中颜色、材质及款式一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00499.jpg", "image": "data/raw/images/product_00499.jpg", "prompt": "亮黄色男士短袖T恤，正面印有蓝色复古徽章图案，含数字48与品牌字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为亮黄色棉质圆领短袖T恤，正面印有蓝色复古风格徽章图案，包含'PUMA 48'及'THE ORIGINAL SPORTING COMPANY'字样，描述准确反映图中颜色、材质、款式与印花内容，未使用极限词或虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": true, \"reason\": \"描述中'原版'字样易被误认为唯一正品，涉嫌虚假宣传，且'复古徽章'可能暗示品牌关联，存在误导风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00481.jpg", "image": "data/raw/images/product_00481.jpg", "prompt": "白色PUMA赛车主题印花短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为白色圆领短袖T恤，正面印有PUMA MOTORSPORT字样及蓝黑赛车元素图案，与描述完全一致。未使用极限词或夸大功效表述，材质标注合理，无虚标或傍名牌行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为黑色V领短袖T恤，正面印有PUMA MOTORSPORT字样及蓝黑赛车元素图案，材质为聚酯纤维，与描述一致。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02017.jpg", "image": "data/raw/images/product_02017.jpg", "prompt": "蓝黑条纹长袖Polo衫，翻领设计，胸前有品牌标识", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色与深蓝色相间条纹\", \"材质\": \"棉质混纺\", \"款式\": \"长袖Polo衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝黑条纹长袖Polo衫，翻领、胸前品牌标识清晰可见，描述准确反映商品实际颜色、材质与款式。未使用极限词或夸大宣传，未虚标材质，无傍名牌嫌疑，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色与黑色相间条纹\", \"材质\": \"涤纶\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品为红黑条纹短袖T恤，材质为涤纶，符合描述内容，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01481.jpg", "image": "data/raw/images/product_01481.jpg", "prompt": "Puma品牌金色方形表壳黑色表盘运动手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"金色与黑色\", \"材质\": \"金属与橡胶\", \"款式\": \"方形运动款\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Puma品牌标识、金色方形表壳、黑色表盘及橡胶表带的特征，未使用夸大或虚假宣传用语，材质与款式均与图片一致，无虚标或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"金色与黑色\", \"材质\": \"金属与橡胶\", \"款式\": \"方形运动款\"}, \"violation\": true, \"reason\": \"描述中‘运动手表’属于夸大宣传，未体现专业运动功能，涉嫌虚假引导消费者，不符合实际用途。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01327.jpg", "image": "data/raw/images/product_01327.jpg", "prompt": "最新款超低价全网最低绝对顶级男士印花T恤，潮流必备", "chosen": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 图片中为普通印花T恤，无证据支持其为最新款或全网最低价\"}", "rejected": "{\"category\": \"T恤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖印花\"}, \"violation\": true, \"reason\": \"商品为黑色长袖聚酯纤维T恤，存在『最新款』『全网最低』等绝对化用语，违反广告法第九条\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01115.jpg", "image": "data/raw/images/product_01115.jpg", "prompt": "黑色帆布材质男士套脚休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"帆布\", \"款式\": \"套脚休闲鞋\"}, \"violation\": false, \"reason\": \"图片显示为黑色帆布材质的套脚休闲鞋，描述准确对应商品实际颜色、材质与款式，未使用极限词或夸大宣传，未虚标材质（如宣称皮质却实为帆布），无傍名牌或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"皮革\", \"款式\": \"运动鞋\"}, \"violation\": false, \"reason\": \"商品为白色皮革材质的运动鞋，外观符合描述，未发现违规用词或虚假宣传，属性与实物一致。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00831.jpg", "image": "data/raw/images/product_00831.jpg", "prompt": "黑色皮革男士乐福鞋，简约商务休闲款", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色皮革材质的乐福鞋，鞋面光滑，带有经典缝线装饰，内里为浅棕色衬里，与描述中‘黑色皮革男士乐福鞋’完全一致。未使用极限词、未夸大功能、未虚标材质，也无品牌侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00956.jpg", "image": "data/raw/images/product_00956.jpg", "prompt": "白色V领纯棉男士短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"纯棉\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"图片显示为一件白色V领短袖T恤，左胸有小logo，材质从视觉判断为棉质，描述中‘纯棉’未虚标，颜色与款式均与图一致，未使用极限词或夸大宣传，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"纯棉\", \"款式\": \"V领短袖\"}, \"violation\": true, \"reason\": \"描述中‘纯棉’可能为夸大宣传，实际无法确认100%棉含量，存在虚假宣传风险，建议修改。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02520.jpg", "image": "data/raw/images/product_02520.jpg", "prompt": "男士白色长袖商务衬衫，经典翻领设计，单胸袋，简约正式", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"长袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为一件白色长袖衬衫，具有标准翻领和左胸口袋，材质从光泽与纹理判断为棉质，描述准确反映商品真实属性。未使用‘顶级’‘纯天然’等夸大用语，未虚标材质或宣称特殊功效，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"长袖翻领\"}, \"violation\": true, \"reason\": \"描述中‘经典’属于主观夸大用语，易引导消费者产生品质误判，涉嫌违反广告法关于禁止使用绝对化用语的规定。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00057.jpg", "image": "data/raw/images/product_00057.jpg", "prompt": "这款时尚连衣裙采用蓝色网眼面料，适合夏季穿着，轻盈透气，展现优雅气质。", "chosen": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"网眼布\", \"款式\": \"运动休闲\"}, \"violation\": true, \"reason\": \"商品描述中提及'连衣裙'，但主图展示的为一双蓝色运动鞋 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"运动鞋\", \"attributes\": {\"颜色\": \"蓝色\", \"款式\": \"运动休闲\"}, \"violation\": false, \"reason\": \"商品描述中提到的'连衣裙'可能是对鞋面网眼材质的比喻性表达，整体展示仍为运动鞋，属于细节描述差异，不构成明显误导\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02324.jpg", "image": "data/raw/images/product_02324.jpg", "prompt": "黑白抽象线条印花短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"白色底黑线印花\", \"材质\": \"棉混纺\", \"款式\": \"方领短袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的黑白抽象线条图案、方领短袖及A字版型，材质标注为棉混纺符合常见印花裙类面料，未使用极限词或虚标材质，无品牌侵权表述，整体描述与实物一致，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑色底白线印花\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领无袖连衣裙\"}, \"violation\": false, \"reason\": \"商品描述中颜色为黑色底白线印花，材质为聚酯纤维，款式为圆领无袖，与图中白色底黑线、方领短袖的A字裙特征不符，但未涉及违规词或侵权内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01888.jpg", "image": "data/raw/images/product_01888.jpg", "prompt": "白色底蓝色螺旋印花无袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"白色底蓝色印花\", \"材质\": \"棉质\", \"款式\": \"无袖斜襟纽扣款\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中连衣裙的白色底色与蓝色螺旋图案，材质为常见棉质面料，款式为无袖斜襟并配纽扣设计，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑色底红色印花\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连帽款\"}, \"violation\": false, \"reason\": \"商品描述中颜色为黑色底红色印花，材质为聚酯纤维，款式为长袖连帽，与图中白色底蓝色螺旋图案及无袖设计不符，但未涉及违规词或侵权问题。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02121.jpg", "image": "data/raw/images/product_02121.jpg", "prompt": "PLAYBOY品牌彩色图案人字拖，白色鞋带搭配多色方块印花", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色、绿色、橙色、蓝色、红色\", \"材质\": \"橡胶/塑料\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为PLAYBOY品牌的人字拖，图片中可见其鞋底印有彩色方块与兔子图案，鞋带为白色，材质为常见橡胶或塑料类，描述准确反映实际颜色、材质与款式。未使用极限词或夸大宣传，未虚标材质，品牌标识清晰且非冒用，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色、绿色、橙色、蓝色、红色\", \"材质\": \"橡胶/塑料\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"描述中‘彩色图案’属于模糊宣传，未明确具体颜色数量，构成虚假描述；‘常见橡胶或塑料类’表述不严谨，涉嫌虚标材质，存在误导风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01200.jpg", "image": "data/raw/images/product_01200.jpg", "prompt": "棕色麂皮拼接牛皮手提包，配金属扣饰", "chosen": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"麂皮与牛皮拼接\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，主色调为棕色，主体材质为麂皮，边缘及提手为深色牛皮，五金件为金色金属扣，款式为经典手提包结构。描述未使用极限词、未虚标材质、未暗示品牌关联，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"麂皮与牛皮拼接\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规信息，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01107.jpg", "image": "data/raw/images/product_01107.jpg", "prompt": "金色条纹织物人字拖鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"金色与米色相间\", \"材质\": \"织物\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中所示的金色与米色条纹织物材质的人字拖款式，未使用极限词或夸大宣传，颜色、材质、款式均与图片一致，无虚标或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色与红色相间\", \"材质\": \"皮革\", \"款式\": \"高跟凉鞋\"}, \"violation\": false, \"reason\": \"商品描述中颜色为黑红相间，材质为皮革，款式为高跟凉鞋，与图中金色条纹织物人字拖不符，但未发现夸大宣传或违规词。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02436.jpg", "image": "data/raw/images/product_02436.jpg", "prompt": "男士绿色格子长袖衬衫，休闲工装风设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿、白、深蓝相间格纹\", \"材质\": \"棉质混纺\", \"款式\": \"长袖翻领衬衫，胸前双口袋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的格纹衬衫，颜色为绿色、白色与深蓝色交织的格子图案，材质从织物纹理判断为棉质混纺，款式包含长袖、翻领及胸前两个带扣口袋，符合实际。未使用极限词或虚标材质，无品牌侵权表述，整体描述客观真实，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿、白、深蓝相间格纹\", \"材质\": \"棉质混纺\", \"款式\": \"长袖翻领衬衫，胸前双口袋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00261.jpg", "image": "data/raw/images/product_00261.jpg", "prompt": "黑色皮质男士乐福鞋，简约商务休闲款", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"图片显示为黑色皮革材质的男士乐福鞋，描述中颜色、材质、款式均与实物一致，未使用极限词或夸大宣传，无虚标材质或傍名牌行为，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00382.jpg", "image": "data/raw/images/product_00382.jpg", "prompt": "灰色印花短袖T恤，正面印有'ROADTRIP'字样及房车图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为灰色棉质圆领短袖T恤，正面印有紫色'ROADTRIP'字样及房车图案，描述与图片完全一致。未使用极限词、未虚标材质、未夸大功效，无傍名牌或侵权表达，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"商品描述中'印花'一词可能暗示特殊工艺，存在夸大宣传嫌疑，且图案中的房车设计易引发联想，涉嫌隐性广告，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00255.jpg", "image": "data/raw/images/product_00255.jpg", "prompt": "卡其色绒面革男士休闲套脚鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"绒面革\", \"款式\": \"套脚休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为卡其色，材质为绒面革，款式为套脚设计的休闲鞋，未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"卡其色\", \"材质\": \"绒面革\", \"款式\": \"套脚休闲鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00417.jpg", "image": "data/raw/images/product_00417.jpg", "prompt": "原价999直降到99，限时清仓甩卖！儿童黄色卡通印花短袖T恤，时尚潮流必备款", "chosen": "{\"category\": \"儿童T恤\", \"attributes\": {\"颜色\": \"黄色\", \"材质\": \"棉\", \"款式\": \"短袖印花\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销信息，与商品实际价值不符，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"儿童T恤\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖印花\"}, \"violation\": true, \"reason\": \"商品实际为蓝色聚酯纤维长袖款，但描述中宣传为黄色棉质短袖，属性严重不符，存在误导性信息\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00013.jpg", "image": "data/raw/images/product_00013.jpg", "prompt": "荧光绿与白色拼接短袖运动T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"荧光绿/白色\", \"材质\": \"聚酯纤维\", \"款式\": \"拼色短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中荧光绿与白色拼接的短袖T恤，材质为常见运动服聚酯纤维，未虚标或夸大；款式为常规拼色设计，无极限词、功效承诺或品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"荧光绿/白色\", \"材质\": \"聚酯纤维\", \"款式\": \"拼色短袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00106.jpg", "image": "data/raw/images/product_00106.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黄色\", \"款式\": \"短袖T恤\", \"图案\": \"DUCATI品牌标志\", \"材质\": \"棉质\", \"风格\": \"运动休闲风\"}, \"violation\": true, \"reason\": \"商品图片中展示的T恤印有'DUCATI'品牌标志，属于明确的品牌标识，而商品描述为'日系简约 ins风 学院风'，存在风格与实际视觉属性不符的情况，且可能涉及未经授权的品牌使用，违反平台关于品牌合规及描述真实性的规定。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黄色\", \"款式\": \"短袖T恤\", \"图案\": \"DUCATI品牌标志\", \"风格\": \"运动休闲风\"}, \"violation\": false, \"reason\": \"商品描述与图片风格略有差异，但属于常见视觉表达差异，未发现明显违规信息。\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02368.jpg", "image": "data/raw/images/product_02368.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款红色棉质连衣裙，简约大方，抢到就是赚到！", "chosen": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉\", \"款式\": \"宽松直筒\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销话术，但图片商品为普通棉质连衣裙，无任何证据支持原价999元，属于虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉\", \"款式\": \"宽松直筒\"}, \"violation\": true, \"reason\": \"该商品存在价格违规行为，描述内容与实际不符，不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02169.jpg", "image": "data/raw/images/product_02169.jpg", "prompt": "黑色皮革男士拖鞋，简约一字带设计，舒适平底", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"一字带拖鞋\"}, \"violation\": false, \"reason\": \"商品图片显示为黑色皮革材质的一字带拖鞋，描述中颜色、材质、款式均与实物一致，未使用极限词或夸大功效表述，未虚标材质或涉及品牌侵权，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"一字带拖鞋\"}, \"violation\": true, \"reason\": \"描述中‘舒适’属于主观夸大宣传，未提供实际测试依据，涉嫌虚假功效承诺，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00959.jpg", "image": "data/raw/images/product_00959.jpg", "prompt": "灰色印花短袖T恤，彩色抽象人脸图案，下方印有英文标语", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为灰色棉质圆领短袖T恤，正面印有彩色抽象人脸图案及英文标语，描述准确反映图中可见的品类、颜色、材质与款式特征，未使用极限词或夸大宣传，无虚标材质、傍名牌等违规行为，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色涤纶V领短袖T恤，正面印有彩色抽象人脸图案及英文标语，描述准确反映图中可见的品类、颜色、材质与款式特征，未使用极限词或夸大宣传，无虚标材质、傍名牌等违规行为，符合合规要求。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01598.jpg", "image": "data/raw/images/product_01598.jpg", "prompt": "酒红色几何图案长袖运动上衣，配黄色拉链和Nike标志", "chosen": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"合成纤维\", \"款式\": \"半拉链长袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中酒红色调、几何图案设计及半拉链长袖款式，材质为常见运动服合成纤维，未虚标或夸大。品牌标识清晰但未作侵权宣称，无极限词或功效承诺，符合广告法要求。\"}", "rejected": "{\"category\": \"运动服饰\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"合成纤维\", \"款式\": \"半拉链长袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00893.jpg", "image": "data/raw/images/product_00893.jpg", "prompt": "蓝色圆领短袖纯棉T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"纯棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"图片中展示的为一件蓝色圆领短袖T恤，材质从视觉上看为普通棉质面料，描述中‘纯棉’未作虚标，颜色与款式均与实物一致。未使用极限词、未夸大功效、未涉及品牌侵权或虚假宣传，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"化纤\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为红色V领短袖，材质为化纤面料，与描述相符，未发现虚假宣传或违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01515.jpg", "image": "data/raw/images/product_01515.jpg", "prompt": "这款男士V领毛衣采用100%纯棉材质，绿色与深灰色条纹设计，舒适保暖。", "chosen": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"绿色与深灰色\", \"材质\": \"混纺针织\", \"款式\": \"V领条纹\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片所示为混纺针织材质，表面纹理明显非纯棉特征 — 图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"毛衣\", \"attributes\": {\"颜色\": \"红色与白色\", \"材质\": \"纯羊毛\", \"款式\": \"圆领\"}, \"violation\": true, \"reason\": \"商品描述为红色与白色圆领纯羊毛毛衣，但图片显示为绿色与深灰色V领混纺针织，颜色、款式及材质均不符，属虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02538.jpg", "image": "data/raw/images/product_02538.jpg", "prompt": "浅粉色男士长袖衬衫，白色领口与袖口设计，商务休闲款", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"浅粉色\", \"材质\": \"棉质\", \"款式\": \"长袖商务休闲\"}, \"violation\": false, \"reason\": \"图片中展示的为一件浅粉色长袖衬衫，领口与袖口为白色，符合描述中的颜色与款式特征。材质从织物纹理判断为棉质，未标注虚假材质或夸大功效。描述未使用极限词、未提及品牌关联或虚假宣传，整体内容真实且合规。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"浅粉色\", \"材质\": \"棉质\", \"款式\": \"长袖商务休闲\"}, \"violation\": true, \"reason\": \"描述中‘商务休闲款’属于模糊定位，易误导消费者对适用场景的认知，构成隐性夸大宣传，违反广告合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01945.jpg", "image": "data/raw/images/product_01945.jpg", "prompt": "银色金属表带方形Puma男士腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属\", \"款式\": \"方形\"}, \"violation\": false, \"reason\": \"商品为银色金属表带的方形Puma品牌腕表，表盘黑色，带有品牌标识，描述准确反映其颜色、材质与款式特征，未使用极限词或虚标材质，未涉及侵权表述，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色\", \"材质\": \"金属\", \"款式\": \"方形\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01752.jpg", "image": "data/raw/images/product_01752.jpg", "prompt": "白色V领长袖针织衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"针织\", \"款式\": \"V领长袖\"}, \"violation\": false, \"reason\": \"图片中展示的为一件白色V领长袖针织衫，描述准确对应商品实际颜色、材质与款式，未使用极限词或夸大表述，未虚标材质，无品牌侵权或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"针织\", \"款式\": \"V领长袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02290.jpg", "image": "data/raw/images/product_02290.jpg", "prompt": "男士白色长袖商务衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"长袖正装\"}, \"violation\": false, \"reason\": \"图片展示为一件白色长袖男式衬衫，领口、袖口及胸前口袋设计符合标准商务正装款式，材质从光泽与纹理判断为棉质。描述中仅陈述颜色、款式与品类，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖休闲\"}, \"violation\": false, \"reason\": \"商品为黑色短袖休闲款，材质为聚酯纤维，符合日常穿着特征，无违规宣传内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01755.jpg", "image": "data/raw/images/product_01755.jpg", "prompt": "绿色圆领短袖T恤，胸前印有'UNITED COLORS OF BENETTON.'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为绿色圆领短袖T恤，图片中可见其实际颜色、款式及胸前文字标识，描述与实物一致。未使用极限词或夸大宣传，未虚标材质，未涉及品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": true, \"reason\": \"描述中‘绿色’为单一颜色表述，涉嫌隐含‘纯色’暗示，可能误导消费者，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01808.jpg", "image": "data/raw/images/product_01808.jpg", "prompt": "蓝白拼色编织绑带平底凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"蓝色与白色\", \"材质\": \"织物与皮革\", \"款式\": \"绑带平底凉鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为蓝白相间，材质由织物绑带与棕色皮革鞋底构成，款式为绑带式平底凉鞋。未使用极限词、未虚标材质、未夸大功能，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"蓝色与白色\", \"材质\": \"织物与皮革\", \"款式\": \"绑带平底凉鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02103.jpg", "image": "data/raw/images/product_02103.jpg", "prompt": "深灰色编织纹理低帮休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"深灰色\", \"材质\": \"编织皮革\", \"款式\": \"低帮系带休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中鞋款的深灰色调、编织皮革材质及低帮系带款式，未使用极限词或虚标材质，未涉及品牌仿冒或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"亮红色\", \"材质\": \"网布\", \"款式\": \"高帮运动鞋\"}, \"violation\": false, \"reason\": \"商品描述中颜色为亮红色，材质为网布，款式为高帮运动鞋，与图中深灰色编织皮革低帮鞋不符，但未发现违规用语或品牌冒用。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00874.jpg", "image": "data/raw/images/product_00874.jpg", "prompt": "黑色与绿色拼接皮质手提包，配金属扣环", "chosen": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"黑绿拼色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黑色主体与绿色肩带、五金件的拼色设计，材质为真实皮革，未使用‘真皮’等虚标用语，款式明确为手提包，无夸大功效或品牌傍款行为，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"箱包\", \"attributes\": {\"颜色\": \"黑绿拼色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01572.jpg", "image": "data/raw/images/product_01572.jpg", "prompt": "灰色圆领男士纯棉卫衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"纯棉\", \"款式\": \"圆领长袖\"}, \"violation\": false, \"reason\": \"图片显示为灰色圆领长袖卫衣，材质为纯棉，与描述完全一致。未使用极限词、未虚标材质、未夸大功效，无品牌侵权或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"纯棉\", \"款式\": \"圆领长袖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00327.jpg", "image": "data/raw/images/product_00327.jpg", "prompt": "原价999直降到99，限时清仓甩卖！Nike黑色运动七分裤，速干透气，男款健身必备。", "chosen": "{\"category\": \"运动短裤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"七分裤\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销信息，制造虚假折扣假象，且图片显示为普通运动短裤，无任何价格标签或促销依据 — 虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"运动短裤\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"涤纶\", \"款式\": \"七分裤\"}, \"violation\": true, \"reason\": \"该商品存在价格违规行为，具体细节未明确，整体不符合平台规范要求\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00734.jpg", "image": "data/raw/images/product_00734.jpg", "prompt": "黑色皮革系带商务正装皮鞋", "chosen": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装皮鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色皮革材质的男士系带正装皮鞋，鞋面有缝线装饰，鞋头为尖头设计，与描述中‘黑色皮革系带商务正装皮鞋’完全一致。未使用极限词、未夸大功效、未虚标材质或品牌，符合商品真实属性，无违规信息。\"}", "rejected": "{\"category\": \"男鞋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装皮鞋\"}, \"violation\": true, \"reason\": \"描述中‘商务正装’属于隐性宣传用语，暗示适用场景，涉嫌夸大用途，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02273.jpg", "image": "data/raw/images/product_02273.jpg", "prompt": "蓝白竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白条纹\", \"材质\": \"棉质\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片显示为蓝白竖条纹的男士长袖衬衫，描述准确反映其颜色、款式与穿着场景，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"红黑格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖休闲衬衫\"}, \"violation\": false, \"reason\": \"商品为红黑格纹短袖休闲衬衫，材质为聚酯纤维，符合描述内容，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00108.jpg", "image": "data/raw/images/product_00108.jpg", "prompt": "白色印花短袖T恤，正面印有拳击图案及'STRIKE!! WHEN YOU'RE READY!!'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"印花短袖T恤\"}, \"violation\": false, \"reason\": \"商品为白色棉质短袖T恤，正面印有拳击人物图案及多色英文标语，描述准确反映图中视觉元素，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"印花短袖T恤\"}, \"violation\": true, \"reason\": \"商品描述中'印花'属于过度承诺，实际图案为数码印刷，涉嫌虚标工艺；'棉质'未提供成分检测报告，存在材质不实风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00972.jpg", "image": "data/raw/images/product_00972.jpg", "prompt": "男士黑白黄格纹长袖衬衫，休闲商务两穿", "chosen": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"白、黑、黄相间格纹\", \"材质\": \"棉质混纺\", \"款式\": \"长袖翻领衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的格纹衬衫，颜色为白底配黑黄线条构成的格子图案，材质从织物纹理判断为棉质混纺，款式为标准长袖翻领设计。描述未使用极限词或夸大功效，未虚标材质，未涉及品牌侵权，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装\", \"attributes\": {\"颜色\": \"红、蓝、绿相间格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红蓝绿格纹，材质为聚酯纤维，款式为短袖Polo衫，与图中实际穿着的黑白黄格纹长袖衬衫相符。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02526.jpg", "image": "data/raw/images/product_02526.jpg", "prompt": "深蓝色格纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色格纹设计的男士长袖衬衫，材质从纹理判断为棉混纺，款式为标准正装衬衫，描述与实物完全一致。未使用极限词、未虚标材质、未宣称功效或傍名牌，符合商品真实属性及广告法合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉混纺\", \"款式\": \"长袖正装衬衫\"}, \"violation\": true, \"reason\": \"描述中‘深蓝色格纹’可能暗示唯一性，存在夸大宣传风险，且未明确标注成分比例，涉嫌虚标材质。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00702.jpg", "image": "data/raw/images/product_00702.jpg", "prompt": "ESPRIT品牌矩形银色表盘棕色皮带手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/棕色\", \"材质\": \"金属/皮革\", \"款式\": \"矩形表盘\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中ESPRIT品牌、矩形银色表盘及棕色皮革表带的特征，未使用极限词或虚标材质，表盘刻度与品牌标识清晰可见，符合真实属性，无夸大宣传或侵权表述。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/棕色\", \"材质\": \"金属/皮革\", \"款式\": \"矩形表盘\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00582.jpg", "image": "data/raw/images/product_00582.jpg", "prompt": "蓝色格纹男士长袖衬衫，翻领设计，袖口可卷边", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"格纹翻领\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为蓝色格纹棉质长袖衬衫，翻领与卷袖设计清晰可见。未使用极限词或虚标材质，无夸大功效或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色\", \"材质\": \"棉质\", \"款式\": \"格纹翻领\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01588.jpg", "image": "data/raw/images/product_01588.jpg", "prompt": "灰色修身男士西裤，搭配蓝色衬衫与黑色皮带展示", "chosen": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"混纺面料\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片中展示的为灰色修身款男士西裤，材质为常见混纺面料，无明显品牌标识或仿冒元素。描述准确反映商品颜色、款式与穿着效果，未使用极限词、未夸大功能，也未涉及虚假材质宣称，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装-裤子\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"混纺面料\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"该商品整体展示合规，未发现明显违规内容，符合平台基本审核标准。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02408.jpg", "image": "data/raw/images/product_02408.jpg", "prompt": "深蓝色高腰修身打底裤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"针织\", \"款式\": \"高腰修身\"}, \"violation\": false, \"reason\": \"图片中展示的为深蓝色高腰修身款打底裤，材质为针织类弹性面料，与描述完全一致。未使用极限词、未虚标材质或夸大功效，未涉及品牌侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"针织\", \"款式\": \"高腰修身\"}, \"violation\": true, \"reason\": \"描述中‘修身’属于隐性夸大，暗示塑形效果，涉嫌虚假宣传；图片未展示全身比例，存在误导风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01883.jpg", "image": "data/raw/images/product_01883.jpg", "prompt": "红色条纹棉质围裙，简约实用款", "chosen": "{\"category\": \"围裙\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"简约款\"}, \"violation\": false, \"reason\": \"图片显示为一件红色条纹图案的围裙，材质为棉质，款式为简约直筒设计，描述中颜色、材质、款式均与实物一致，未使用极限词或虚标材质，无夸大功效或傍名牌行为，符合商品合规要求。\"}", "rejected": "{\"category\": \"围裙\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"棉质\", \"款式\": \"简约款\"}, \"violation\": true, \"reason\": \"描述中‘简约实用款’涉嫌使用‘实用’等隐性功效承诺，属于夸大宣传，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01796.jpg", "image": "data/raw/images/product_01796.jpg", "prompt": "黑色漆皮交叉带中跟凉鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"漆皮\", \"款式\": \"交叉带中跟凉鞋\"}, \"violation\": false, \"reason\": \"图片显示为黑色漆皮材质的交叉带中跟凉鞋，描述准确对应商品实际颜色、材质与款式，未使用极限词或夸大表述，未虚标材质，无傍名牌或侵权用语，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"帆布\", \"款式\": \"平底休闲鞋\"}, \"violation\": false, \"reason\": \"商品为白色帆布材质的平底休闲鞋，图片展示与描述一致，未发现违规用语或虚假宣传。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02419.jpg", "image": "data/raw/images/product_02419.jpg", "prompt": "100%纯棉女士白色长袖上衣搭配100%真丝绿色围巾，简约时尚", "chosen": "{\"category\": \"围巾\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"聚酯纤维\", \"款式\": \"褶皱长款\"}, \"violation\": true, \"reason\": \"描述中声称围巾为『100%真丝』，但图片显示其为轻薄褶皱质感的聚酯纤维材质，与真实属性不符 — 图片所示材质与描述的100%真丝明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"围巾\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"聚酯纤维\", \"款式\": \"褶皱长款\"}, \"violation\": true, \"reason\": \"该商品存在信息不符情况，整体审核判定为违规，具体细节未明确但影响判断\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02075.jpg", "image": "data/raw/images/product_02075.jpg", "prompt": "蓝绿花卉印花短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝绿色系印花\", \"材质\": \"棉质混纺\", \"款式\": \"短袖V领A字裙\"}, \"violation\": false, \"reason\": \"图片展示为蓝绿花卉图案的短袖连衣裙，V领设计配深蓝色包边，整体为A字版型，与描述中颜色、款式一致。未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"蓝绿色系印花\", \"材质\": \"棉质混纺\", \"款式\": \"短袖V领A字裙\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合基本审核要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00703.jpg", "image": "data/raw/images/product_00703.jpg", "prompt": "白色表盘镶粉色与透明水钻的ESPRIT女士腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"皮革表带，金属表壳，水晶装饰\", \"款式\": \"镶钻时尚女表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中白色表盘、粉色与透明水钻镶嵌表圈、白色皮革表带及ESPRIT品牌标识等特征，未使用极限词或虚标材质，未涉及仿冒或夸大功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"皮革表带，金属表壳，水晶装饰\", \"款式\": \"镶钻时尚女表\"}, \"violation\": true, \"reason\": \"描述中‘镶钻’可能暗示全钻覆盖，存在夸大装饰密度嫌疑，涉嫌虚假宣传，不符合实际镶嵌比例。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01250.jpg", "image": "data/raw/images/product_01250.jpg", "prompt": "黑色耐克DRI-FIT运动帽，透气网眼设计", "chosen": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"合成纤维\", \"款式\": \"运动帽\"}, \"violation\": false, \"reason\": \"商品为黑色耐克品牌运动帽，图中可见DRI-FIT标识与网眼结构，描述准确反映其颜色、材质及功能属性，未使用极限词或虚标材质，未涉及侵权表述，符合广告法及平台合规要求。\"}", "rejected": "{\"category\": \"帽子\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"合成纤维\", \"款式\": \"运动帽\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01877.jpg", "image": "data/raw/images/product_01877.jpg", "prompt": "这款100%纯棉印花连衣裙，采用清新花卉图案设计，舒适透气，适合日常穿着。", "chosen": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"白色底配紫、绿、红花纹\", \"材质\": \"化纤混纺\", \"款式\": \"短袖立领印花A字裙\"}, \"violation\": true, \"reason\": \"描述中宣称『100%纯棉』，但图片所示面料具有明显光泽和垂感，符合化纤混纺特征，与纯棉材质不符 — 图片所示材质与描述的100%材质明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"连衣裙\", \"attributes\": {\"颜色\": \"黑色底配黄、橙、蓝花纹\", \"材质\": \"羊毛针织\", \"款式\": \"长袖高领修身连衣裙\"}, \"violation\": true, \"reason\": \"描述称100%纯棉，但图片显示为黑色底色与亮色花纹，且材质为羊毛针织，属明显虚假宣传\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01776.jpg", "image": "data/raw/images/product_01776.jpg", "prompt": "深紫色长袖交叉领修身打底衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉混纺\", \"款式\": \"交叉领长袖\"}, \"violation\": false, \"reason\": \"图片中展示的为一件深紫色长袖上衣，领口为交叉设计，材质从视觉上看为柔软贴身的棉混纺面料，与描述中的颜色、材质、款式完全一致。描述未使用极限词或夸大功效词汇，未虚标材质，未涉及品牌侵权或虚假宣传，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"深紫色\", \"材质\": \"棉混纺\", \"款式\": \"交叉领长袖\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00249.jpg", "image": "data/raw/images/product_00249.jpg", "prompt": "米白色荔枝纹PU皮手提包", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"PU皮\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"图片显示为米白色、表面有荔枝纹的PU皮材质手提包，描述准确对应商品实际颜色、材质与款式，未使用极限词或虚标材质，无夸大宣传或傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"米白色\", \"材质\": \"PU皮\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01701.jpg", "image": "data/raw/images/product_01701.jpg", "prompt": "最新款超低价全网最低绝对顶级男士条纹POLO衫，时尚百搭必备", "chosen": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"棉质\", \"款式\": \"条纹短袖\"}, \"violation\": true, \"reason\": \"描述中使用了『最新款』『超低价』『全网最低』『绝对顶级』等绝对化用语，违反广告法第九条 — 使用最/第一/顶级等绝对化用语，违反广告法第九条\"}", "rejected": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"棉质\", \"款式\": \"条纹短袖\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，描述内容不符合平台规范要求，需进一步处理\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00324.jpg", "image": "data/raw/images/product_00324.jpg", "prompt": "浅卡其色短袖Polo衫，领口与袖口饰有蓝白条纹，胸前印有徽章图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅卡其色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为浅卡其色，领口与袖口蓝白条纹细节清晰可见，胸前徽章图案与文字‘ORIGINAL L.A. WEST PM’一致，未使用极限词或虚标材质，未涉及品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"浅卡其色\", \"材质\": \"棉质\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02308.jpg", "image": "data/raw/images/product_02308.jpg", "prompt": "棕色几何图案短袖连衣裙", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"棕色系\", \"材质\": \"棉质\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"图片显示为一件棕色底色带有米白与浅棕几何图案的短袖连衣裙，款式为A字型，领口为小V领设计，材质从纹理判断为棉质。描述中仅陈述了真实可见的颜色、图案和款式特征，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合商品信息真实合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色系\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为蓝色底色带有几何图案的长袖连衣裙，材质为聚酯纤维，整体风格符合描述，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00707.jpg", "image": "data/raw/images/product_00707.jpg", "prompt": "棕色皮革高帮系带休闲鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"高帮系带\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为棕色，材质为皮革，款式为高帮系带休闲鞋，未使用极限词或夸大表述，未虚标材质或仿冒品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"高帮系带\"}, \"violation\": true, \"reason\": \"描述中‘皮革’可能暗示为真皮，但图片无法确认是否为全皮材质，存在虚标风险，涉嫌误导消费者。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01851.jpg", "image": "data/raw/images/product_01851.jpg", "prompt": "白色蓝花印花短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"白色底蓝色印花\", \"材质\": \"棉质\", \"款式\": \"V领短袖A字裙\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，为白色底色配蓝色植物印花的短袖连衣裙，V领设计、A字版型清晰可见。材质未虚标，未使用极限词或功效承诺，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑色底红色印花\", \"材质\": \"聚酯纤维\", \"款式\": \"圆领长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为黑色底色配红色印花，材质为聚酯纤维，圆领长袖设计，整体与描述一致，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01284.jpg", "image": "data/raw/images/product_01284.jpg", "prompt": "酒红色与深蓝色横条纹男士Polo衫，胸前有W47R刺绣图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红与深蓝\", \"材质\": \"棉质\", \"款式\": \"条纹Polo衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容：酒红色与深蓝色横条纹设计、短袖Polo领、胸前W47R刺绣标识清晰可见。材质未虚标，无夸大功效或极限词，未使用品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红与深蓝\", \"材质\": \"棉质\", \"款式\": \"条纹Polo衫\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01087.jpg", "image": "data/raw/images/product_01087.jpg", "prompt": "浅蓝色水洗牛仔裤，修身直筒版型", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"牛仔布\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片显示为浅蓝色水洗牛仔裤，材质为典型牛仔布，版型为修身直筒，描述与实物完全一致。未使用极限词、未夸大功效、未虚标材质，无傍名牌或侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"棉麻混纺\", \"款式\": \"阔腿\"}, \"violation\": false, \"reason\": \"商品为深蓝色棉麻混纺阔腿牛仔裤，颜色与描述一致，材质和版型符合实际。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01867.jpg", "image": "data/raw/images/product_01867.jpg", "prompt": "绿色拼接印花短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"绿色/紫色/白色\", \"材质\": \"棉混纺\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"图片显示为一件以绿色为主调、搭配紫色与白色几何图案的短袖连衣裙，领口及前襟有浅绿色拼接设计，整体为A字版型。描述中准确反映了颜色组合、材质类型和款式特征，未使用极限词或虚标材质，无品牌侵权表述，符合商品真实属性，合规通过。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"绿色/紫色/白色\", \"材质\": \"棉混纺\", \"款式\": \"短袖A字裙\"}, \"violation\": true, \"reason\": \"描述中‘绿色拼接印花’可能暗示主色为绿色，实际图案中紫色占比更高，存在颜色主次虚标嫌疑，不符合真实视觉呈现。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01707.jpg", "image": "data/raw/images/product_01707.jpg", "prompt": "灰色连帽卫衣，印有爆米花图案和'Hot Buttered Popcorn'字样", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰色\", \"材质\": \"棉混纺\", \"款式\": \"连帽卫衣\"}, \"violation\": false, \"reason\": \"商品为灰色连帽卫衣，图中可见其主体颜色、连帽设计及胸前爆米花图案与文字印花，描述准确反映实际视觉信息。未使用极限词或夸大宣传，未虚标材质（如宣称纯棉而实为混纺），未涉及品牌侵权或虚假功效承诺，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"短袖T恤\"}, \"violation\": false, \"reason\": \"商品为黑色短袖T恤，材质为聚酯纤维，图中可见其深色系与短袖设计，描述符合实际。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01842.jpg", "image": "data/raw/images/product_01842.jpg", "prompt": "黑白几何图案短袖连衣裙，简约大方设计", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"黑白\", \"材质\": \"棉混纺\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"图片显示为黑白几何图案的短袖连衣裙，描述中颜色、图案与实物一致，材质标注为棉混纺符合常见服装面料表述，未使用极限词或虚标材质，款式描述准确为短袖A字型，无傍名牌或夸大宣传行为，整体符合合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"红蓝\", \"材质\": \"雪纺\", \"款式\": \"长袖连衣裙\"}, \"violation\": false, \"reason\": \"商品为红蓝配色的雪纺长袖连衣裙，图案与描述一致，材质标注合理，未发现违规用词，符合发布规范。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
