{"image_file": "product_01614.jpg", "image": "data/raw/images/product_01614.jpg", "prompt": "深蓝色直筒牛仔裤，经典水洗工艺，日常休闲款", "chosen": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"图片显示为深蓝色直筒牛仔裤，材质为典型牛仔布，水洗效果自然，描述准确反映商品实际属性。未使用极限词、未虚标材质或夸大功效，无品牌侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"牛仔裤\", \"attributes\": {\"颜色\": \"深蓝色\", \"材质\": \"牛仔布\", \"款式\": \"直筒\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00180.jpg", "image": "data/raw/images/product_00180.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款粉色荷叶边短袖上衣，优雅时尚，不容错过。", "chosen": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"粉色\", \"材质\": \"棉质\", \"款式\": \"荷叶边短袖\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和打折信息，与图片中真实商品属性不符，虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"女装上衣\", \"attributes\": {\"颜色\": \"粉色\", \"款式\": \"荷叶边短袖\"}, \"violation\": false, \"reason\": \"商品描述中的价格信息为促销话术，属于常见营销表达，未发现实际价格欺诈行为，图文内容基本一致，不构成违规\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_02127.jpg", "image": "data/raw/images/product_02127.jpg", "prompt": "绿色底黄色带PLAYBOY标志的人字拖", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"绿色、黄色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为绿色底配黄色带的PLAYBOY品牌人字拖，图片中清晰可见其颜色、材质及品牌标识，描述准确反映实物属性。未使用极限词或夸大功效表述，未虚标材质，未涉及侵权仿冒，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"绿色、黄色\", \"材质\": \"橡胶\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01355.jpg", "image": "data/raw/images/product_01355.jpg", "prompt": "黑色方形表盘黄色细节Puma男士计时腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与黄色\", \"材质\": \"皮革表带，金属表壳\", \"款式\": \"方形计时码表\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中黑色表壳、黄色刻度与Puma品牌标识的计时腕表特征，表带为皮革材质，表盘为方形设计，未使用极限词或虚标材质，品牌标识清晰且非冒用，符合真实商品属性展示要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与黄色\", \"材质\": \"皮革表带，金属表壳\", \"款式\": \"方形计时码表\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00020.jpg", "image": "data/raw/images/product_00020.jpg", "prompt": "黑色皮质表带镶钻方形女款手表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"方形镶钻\"}, \"violation\": false, \"reason\": \"商品为ESPRIT品牌黑色皮质表带方形手表，表盘四周镶嵌装饰性晶石，描述准确反映其颜色、材质与款式特征，未使用‘最’‘顶级’等极限词，未虚标材质或夸大功能，品牌标识清晰且无傍名牌行为，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"方形镶钻\"}, \"violation\": true, \"reason\": \"描述中‘镶钻’易被理解为真钻，涉嫌虚标材质，存在误导消费者风险，不符合广告合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00549.jpg", "image": "data/raw/images/product_00549.jpg", "prompt": "白色棉质刺绣网球裙，简约A字版型", "chosen": "{\"category\": \"女装-裙装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"A字裙\"}, \"violation\": false, \"reason\": \"图片显示为纯白色棉质A字短裙，右下角有花朵刺绣及品牌标识，左腰侧有绿色小标。描述准确反映商品真实属性，未使用极限词或夸大表述，材质与视觉一致，无虚标或傍名牌情况，符合合规要求。\"}", "rejected": "{\"category\": \"女装-裙装\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉质\", \"款式\": \"A字裙\"}, \"violation\": true, \"reason\": \"描述中‘简约’属主观夸大，易诱导消费者；‘刺绣’未明确数量，涉嫌虚标；图片显示品牌标识可能构成傍名牌风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02450.jpg", "image": "data/raw/images/product_02450.jpg", "prompt": "亮黄色纯棉男士短袖Polo衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"纯棉\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"图片中展示的为一件亮黄色短袖Polo衫，领口有两粒纽扣，左袖口有小标，整体为纯色设计。描述准确反映了商品的颜色、材质和款式，未使用极限词或夸大宣传，未虚标材质（如标注为纯棉但实际为化纤），也未涉及品牌侵权或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"亮黄色\", \"材质\": \"纯棉\", \"款式\": \"短袖Polo衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01531.jpg", "image": "data/raw/images/product_01531.jpg", "prompt": "黑色表盘黄色数字的Carrera男士运动腕表", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与黄色\", \"材质\": \"金属与碳纤维纹理表带\", \"款式\": \"运动风格\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中手表的黑色表盘、黄色数字刻度、金属表壳及碳纤维纹理表带等特征，未使用极限词或虚标材质，品牌名称'Carrera'为可见标识但无傍名牌嫌疑，整体描述客观真实，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色与黄色\", \"材质\": \"金属与碳纤维纹理表带\", \"款式\": \"运动风格\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02351.jpg", "image": "data/raw/images/product_02351.jpg", "prompt": "粉色系几何印花短袖连衣裙", "chosen": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"粉色、蓝色、白色\", \"材质\": \"棉质\", \"款式\": \"短袖A字裙\"}, \"violation\": false, \"reason\": \"图片中展示的连衣裙为粉色、蓝色与白色相间的几何图案，短袖设计，A字版型，材质从纹理判断为棉质。描述准确反映了商品的颜色、图案和款式特征，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"女装\", \"attributes\": {\"颜色\": \"粉色、蓝色、白色\", \"材质\": \"棉质\", \"款式\": \"短袖A字裙\"}, \"violation\": true, \"reason\": \"描述中‘几何印花’属于图案类型过度强调，易引导消费者产生特定视觉预期，构成隐性宣传，违反广告法相关条款。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02022.jpg", "image": "data/raw/images/product_02022.jpg", "prompt": "这款男士条纹Polo衫采用100%纯棉材质，舒适透气，适合日常穿着", "chosen": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"绿色\", \"材质\": \"混纺\", \"款式\": \"条纹\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片所示面料为混纺材质，纹理和光泽不符合纯棉特征 — 图片所示材质与描述的100%纯棉明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"Polo衫\", \"attributes\": {\"颜色\": \"绿色\", \"款式\": \"条纹\"}, \"violation\": false, \"reason\": \"商品描述中的材质信息与图片存在细微差异，但属于常见展示误差，未构成明显虚假宣传\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00507.jpg", "image": "data/raw/images/product_00507.jpg", "prompt": "橙蓝抽象印花拼接短袖T恤", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"橙色、蓝色、灰色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领印花T恤\"}, \"violation\": false, \"reason\": \"商品为橙蓝抽象图案与灰色拼接的短袖T恤，图中可见其颜色分布、印花风格及版型均与描述一致，未使用极限词或虚标材质，无仿冒品牌标识，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"橙色、蓝色、灰色\", \"材质\": \"棉质\", \"款式\": \"短袖圆领印花T恤\"}, \"violation\": true, \"reason\": \"描述中‘抽象印花’涉嫌模糊宣传，未明确图案来源，存在误导消费者风险，不符合广告法对商品信息真实性的要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_01378.jpg", "image": "data/raw/images/product_01378.jpg", "prompt": "酒红色圆领短袖T恤，印有蓝色艺术字体图案", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"酒红色\", \"材质\": \"棉质\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为酒红色，款式为圆领短袖，印花图案清晰可见，未使用极限词或夸大宣传，材质标注合理，无虚标或傍名牌行为，符合电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"聚酯纤维\", \"款式\": \"V领短袖\"}, \"violation\": false, \"reason\": \"商品为黑色V领短袖，材质为聚酯纤维，印花清晰，无违规词，符合平台规范。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00735.jpg", "image": "data/raw/images/product_00735.jpg", "prompt": "米白色拼接深绿色条纹休闲运动鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"米白与深绿拼色\", \"材质\": \"帆布与绒面革\", \"款式\": \"低帮系带休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为米白色主体搭配深绿色三条纹，材质可见帆布与绒面革拼接，款式为低帮系带休闲鞋。未使用极限词、未虚标材质、未暗示品牌关联，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"米白与深绿拼色\", \"材质\": \"帆布与绒面革\", \"款式\": \"低帮系带休闲鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01167.jpg", "image": "data/raw/images/product_01167.jpg", "prompt": "玫红色儿童短袖T恤，印有卡通猫咪图案和英文标语", "chosen": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"玫红色\", \"材质\": \"棉\", \"款式\": \"短袖印花T恤\"}, \"violation\": false, \"reason\": \"商品为儿童短袖T恤，图片显示其为玫红色，印有三只卡通动物及英文文字，材质标签显示为棉质。描述准确反映颜色、材质与款式，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"童装\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖连帽衫\"}, \"violation\": false, \"reason\": \"商品为浅蓝色长袖连帽衫，材质为聚酯纤维，印有卡通图案。描述中颜色、材质与款式均与实物一致，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00159.jpg", "image": "data/raw/images/product_00159.jpg", "prompt": "这款时尚连衣裙采用格纹设计，适合日常穿搭，展现优雅气质。", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"红白格纹\", \"材质\": \"棉质\", \"款式\": \"短袖格子衬衫\"}, \"violation\": true, \"reason\": \"商品描述中提到的‘连衣裙’与图片展示的‘男式短袖格子衬衫’明显不符 — 商品描述与主图展示内容明显不符，误导消费者\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"蓝白格纹\", \"材质\": \"聚酯纤维\", \"款式\": \"长袖格子衬衫\"}, \"violation\": true, \"reason\": \"商品描述中的‘连衣裙’与图片不符，且属性标注为蓝白格纹聚酯纤维长袖款，实际为红白棉质短袖，存在多处信息错误\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01176.jpg", "image": "data/raw/images/product_01176.jpg", "prompt": "金色矩形表盘镶钻女士手表，ESPRIT品牌", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"金色\", \"材质\": \"金属\", \"款式\": \"矩形镶钻\"}, \"violation\": false, \"reason\": \"商品为金色金属材质的手表，表盘呈矩形并镶嵌透明水晶，表带为链式结构，表盘上印有ESPRIT品牌标识。描述准确反映其颜色、材质、款式及品牌信息，未使用夸大或虚假宣传用语，未涉及极限词或虚标材质，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"金色\", \"材质\": \"金属\", \"款式\": \"矩形镶钻\"}, \"violation\": true, \"reason\": \"描述中'镶钻'可能暗示全钻镶嵌，实际仅为局部点缀，存在虚标材质风险，属虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00980.jpg", "image": "data/raw/images/product_00980.jpg", "prompt": "橄榄绿色印花短袖T恤，满版手绘风格图案设计", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"橄榄绿\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"商品为橄榄绿色圆领短袖T恤，满版印有手绘风格文字与图案，材质从视觉判断为棉质，描述准确反映图片内容，未使用极限词、未虚标材质、未宣称功效或傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"橄榄绿\", \"材质\": \"棉\", \"款式\": \"圆领短袖\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本规范，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_02503.jpg", "image": "data/raw/images/product_02503.jpg", "prompt": "蓝紫竖条纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝紫色\", \"材质\": \"棉混纺\", \"款式\": \"商务休闲\"}, \"violation\": false, \"reason\": \"图片显示为蓝紫竖条纹长袖衬衫，描述准确反映其颜色、款式与穿着场景，未使用极限词或虚标材质，未涉及品牌侵权或功效夸大，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝紫色\", \"材质\": \"棉混纺\", \"款式\": \"商务休闲\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00825.jpg", "image": "data/raw/images/product_00825.jpg", "prompt": "红色皮革交叉带坡跟凉拖鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"皮革\", \"款式\": \"交叉带坡跟凉拖\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中红色皮革材质、交叉绑带设计及坡跟结构，未使用极限词或夸大宣传，未虚标材质或模仿知名品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红色\", \"材质\": \"皮革\", \"款式\": \"交叉带坡跟凉拖\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01206.jpg", "image": "data/raw/images/product_01206.jpg", "prompt": "黑色皮质商务手提包，配金色五金件和前袋拉链设计", "chosen": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为黑色，材质为皮革，款式为手提包，前袋设有拉链与卡位，五金件呈金色。描述未使用极限词、未虚标材质、未宣称功效或傍名牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"包袋\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"手提包\"}, \"violation\": true, \"reason\": \"描述中‘皮质’可能暗示真皮，存在虚标材质风险，且‘商务’属于隐性功效宣传，涉嫌违规。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02133.jpg", "image": "data/raw/images/product_02133.jpg", "prompt": "黑色皮质男士商务乐福鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色皮质男士乐福鞋，描述准确对应其颜色、材质与款式，未使用极限词或夸大宣传，未虚标材质，无品牌侵权表述，符合商品真实属性及合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"乐福鞋\"}, \"violation\": true, \"reason\": \"描述中‘皮质’可能暗示全皮，但图片无法确认是否为真皮，存在虚标材质风险，属虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
