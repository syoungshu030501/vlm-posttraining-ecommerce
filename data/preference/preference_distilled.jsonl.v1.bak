{"image_file": "product_02230.jpg", "image": "data/raw/images/product_02230.jpg", "prompt": "绿色与白色拼接休闲运动鞋，透气网面搭配皮革材质", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"绿色、白色、银色\", \"材质\": \"网布、皮革\", \"款式\": \"低帮系带休闲鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片内容，颜色为绿白拼接并含银色装饰条，材质标注为网布与皮革，符合实际视觉特征；款式为低帮系带设计，未使用极限词或虚标材质，无品牌侵权表述，整体描述真实合规。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"红色、黑色\", \"材质\": \"帆布、橡胶\", \"款式\": \"高帮靴子\"}, \"violation\": false, \"reason\": \"商品描述中颜色为红黑拼接，材质标注帆布与橡胶，款式为高帮靴子，符合图片实际特征，无违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02398.jpg", "image": "data/raw/images/product_02398.jpg", "prompt": "蓝色印花民族风长袖上衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝色与粉色拼接\", \"材质\": \"棉质\", \"款式\": \"民族风印花长袖\"}, \"violation\": false, \"reason\": \"图片显示为蓝粉相间几何印花的长袖上衣，领口及袖口有金色刺绣装饰，符合‘民族风’描述。颜色、材质、款式均与图中一致，未使用极限词或虚标材质，无傍名牌或夸大功效表述，符合合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"绿色与黄色拼接\", \"材质\": \"雪纺\", \"款式\": \"简约纯色短袖\"}, \"violation\": false, \"reason\": \"商品为绿黄拼接雪纺短袖，款式简洁无印花，符合描述。图片中衣物颜色与材质均与属性一致，未发现违规内容。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_02433.jpg", "image": "data/raw/images/product_02433.jpg", "prompt": "灰白黑红格纹男士长袖衬衫", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰白黑红\", \"材质\": \"棉混纺\", \"款式\": \"格子衬衫\"}, \"violation\": false, \"reason\": \"图片中为一件灰、白、黑、红四色相间的格纹男式衬衫，袖口卷起，左胸有口袋，领口内衬可见红色细节。描述准确反映其颜色组合与款式特征，未使用极限词或虚标材质，未提及品牌或功效承诺，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"灰白黑红\", \"材质\": \"棉混纺\", \"款式\": \"格子衬衫\"}, \"violation\": false, \"reason\": \"该商品整体符合平台基本要求，未发现明显违规内容，审核通过。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01548.jpg", "image": "data/raw/images/product_01548.jpg", "prompt": "这款男士腕表采用100%纯棉表带，时尚运动风格，适合日常佩戴", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色/银色\", \"材质\": \"金属\", \"款式\": \"运动计时\"}, \"violation\": true, \"reason\": \"描述中声称‘100%纯棉’，但图片显示为金属表带，材质与描述明显不符，属虚假宣传\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色/银色\", \"款式\": \"运动计时\"}, \"violation\": false, \"reason\": \"商品描述中的材质信息可能存在展示差异，金属表带在部分视角下可能被误读，整体未发现明显虚假宣传\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00845.jpg", "image": "data/raw/images/product_00845.jpg", "prompt": "金属灰皮质露趾后绊带中跟女鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"金属灰\", \"材质\": \"皮革\", \"款式\": \"露趾后绊带中跟\"}, \"violation\": false, \"reason\": \"商品描述准确对应图片中的金属灰色调、皮革材质及露趾后绊带中跟款式，未使用极限词或虚标材质，无夸大功效或傍名牌表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"金属灰\", \"材质\": \"皮革\", \"款式\": \"露趾后绊带中跟\"}, \"violation\": true, \"reason\": \"描述中‘金属灰’可能暗示特殊工艺，存在虚标材质风险；‘皮质’未明确标注为真皮，涉嫌误导消费者，不符合合规要求。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00944.jpg", "image": "data/raw/images/product_00944.jpg", "prompt": "黑色Puma品牌电子腕表，红色数字显示，带运动风格设计", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"橡胶/塑料\", \"款式\": \"电子表\"}, \"violation\": false, \"reason\": \"商品为黑色Puma品牌电子腕表，表盘显示红色数字时间，表带为黑色橡胶材质，表面有圆形纹理和品牌标识，右侧有红色条形装饰及功能按钮。描述准确反映其颜色、材质与款式特征，未使用极限词或虚标信息，未涉及虚假宣传或侵权表述，符合合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"橡胶/塑料\", \"款式\": \"电子表\"}, \"violation\": true, \"reason\": \"描述中‘运动风格设计’属于主观夸大，易引导消费者误认为具备专业运动功能，构成虚假宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00829.jpg", "image": "data/raw/images/product_00829.jpg", "prompt": "黑色系带商务皮鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": false, \"reason\": \"图片显示为一双黑色系带男式正装皮鞋，鞋面光滑具有皮革质感，鞋型为经典尖头设计，描述准确对应商品实际外观。未使用极限词或夸大宣传，材质与颜色均与实物一致，无虚标、傍名牌或虚假功效表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"皮革\", \"款式\": \"系带正装\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00012.jpg", "image": "data/raw/images/product_00012.jpg", "prompt": "小香风原单男士白衬衫，高端质感，LV平替款，优雅大气", "chosen": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"长袖正装\"}, \"violation\": true, \"reason\": \"描述中使用『小香风原单』『LV平替』等词语，擅自使用他人品牌作宣传，涉嫌侵犯注册商标专用权 — 图片显示为普通白色棉质长袖衬衫，无任何与香奈儿或LV相关标识\"}", "rejected": "{\"category\": \"衬衫\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"棉\", \"款式\": \"长袖正装\"}, \"violation\": true, \"reason\": \"该商品存在违规宣传行为，描述内容不符合平台规范要求，涉嫌不当使用品牌关联信息\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00289.jpg", "image": "data/raw/images/product_00289.jpg", "prompt": "Reebok黑色拼黄色运动凉鞋，魔术贴设计，厚底舒适", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色/黄色\", \"材质\": \"合成革/橡胶\", \"款式\": \"魔术贴凉鞋\"}, \"violation\": false, \"reason\": \"商品为Reebok品牌运动凉鞋，图片显示其主体为黑色，内衬及细节为黄色，材质为合成革与橡胶，采用魔术贴固定方式，描述准确反映实际产品属性。未使用极限词、未虚标材质或夸大功能，品牌标识清晰且无侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色/黄色\", \"材质\": \"合成革/橡胶\", \"款式\": \"魔术贴凉鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01263.jpg", "image": "data/raw/images/product_01263.jpg", "prompt": "蓝色格纹短袖衬衫男式休闲衬衣", "chosen": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白棕相间格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领格子衬衫\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中男士穿着的蓝白棕三色格纹短袖衬衫，材质为常见棉质面料，款式为标准翻领短袖设计，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"服装\", \"attributes\": {\"颜色\": \"蓝白棕相间格纹\", \"材质\": \"棉质\", \"款式\": \"短袖翻领格子衬衫\"}, \"violation\": true, \"reason\": \"描述中‘休闲衬衣’涉嫌暗示舒适度优势，构成隐性极限词，且未明确标注成分比例，存在虚标材质风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02460.jpg", "image": "data/raw/images/product_02460.jpg", "prompt": "浅灰色修身休闲长裤", "chosen": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉混纺\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"图片中展示的为浅灰色修身款休闲长裤，材质从视觉判断为棉混纺面料，无明显光泽或特殊纹理，符合常规描述。商品描述未使用极限词、未虚标材质（如‘纯棉’‘羊绒’等），也未涉及品牌傍名牌或夸大功效，整体属性与图示一致，符合合规要求。\"}", "rejected": "{\"category\": \"男装裤子\", \"attributes\": {\"颜色\": \"浅灰色\", \"材质\": \"棉混纺\", \"款式\": \"修身直筒\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合平台基本审核要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00573.jpg", "image": "data/raw/images/product_00573.jpg", "prompt": "白色简约交叉带平底人字拖", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"人造革\", \"款式\": \"人字拖\"}, \"violation\": false, \"reason\": \"商品为白色平底人字拖，鞋面采用交叉带设计，材质为常见的人造革，图片中可见鞋垫有透气孔，整体与描述一致。未使用极限词、未虚标材质（如宣称真皮）、未涉及品牌侵权或功效夸大，符合电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"人造革\", \"款式\": \"人字拖\"}, \"violation\": true, \"reason\": \"描述中‘简约’属于主观美化词，涉嫌过度宣传；图片显示鞋垫有透气孔，但未标注功能，存在误导消费者风险。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_00793.jpg", "image": "data/raw/images/product_00793.jpg", "prompt": "ESPRIT品牌银色表壳黑色皮带男款腕表，白色表盘带日历显示", "chosen": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/黑色/白色\", \"材质\": \"金属表壳/皮革表带\", \"款式\": \"简约商务风\"}, \"violation\": false, \"reason\": \"商品描述准确对应图中ESPRIT品牌腕表的银色金属表壳、黑色皮革表带及白色表盘特征，明确标注品牌与功能（日历显示），未使用极限词或虚标材质，未涉及仿冒或夸大功效，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"手表\", \"attributes\": {\"颜色\": \"银色/黑色/白色\", \"材质\": \"金属表壳/皮革表带\", \"款式\": \"简约商务风\"}, \"violation\": true, \"reason\": \"描述中‘ESPRIT品牌’可能暗示正品授权，存在虚标品牌风险；‘日历显示’功能未在图中明确验证，涉嫌夸大宣传。\"}", "pair_strategy": "api_weaker_over_strict"}
{"image_file": "product_02197.jpg", "image": "data/raw/images/product_02197.jpg", "prompt": "银紫色网面透气运动鞋，Skechers品牌缓震跑鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"银色与紫色\", \"材质\": \"网布与合成革\", \"款式\": \"系带缓震跑鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图中Skechers品牌运动鞋的银紫配色、网面材质及系带缓震款式，未使用极限词或虚标材质，品牌标识清晰但未冒用他人商标，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色与红色\", \"材质\": \"皮革与橡胶\", \"款式\": \"高帮篮球鞋\"}, \"violation\": false, \"reason\": \"商品为黑色与红色搭配的高帮篮球鞋，采用皮革与橡胶材质，符合描述，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_01091.jpg", "image": "data/raw/images/product_01091.jpg", "prompt": "阿森纳主场球衣原价999直降到99，限时清仓甩卖，球迷必备！", "chosen": "{\"category\": \"足球球衣\", \"attributes\": {\"颜色\": \"红色与白色\", \"材质\": \"涤纶\", \"款式\": \"短袖圆领\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销话术，制造虚假折扣假象，而图片商品为常规售价的正品球衣，无证据支持该原价，属于虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"足球球衣\", \"attributes\": {\"颜色\": \"蓝色与黄色\", \"材质\": \"棉质\", \"款式\": \"长袖圆领\"}, \"violation\": true, \"reason\": \"商品描述中虚构原价并宣传限时促销，且图片显示为蓝色与黄色的长袖棉质球衣，与实际不符，存在虚假宣传和属性错标问题\"}", "pair_strategy": "api_weaker_wrong_attribute"}
{"image_file": "product_00726.jpg", "image": "data/raw/images/product_00726.jpg", "prompt": "PUMA白色拼接灰蓝绿运动鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白/灰/蓝/绿\", \"材质\": \"合成革/织物\", \"款式\": \"低帮休闲运动鞋\"}, \"violation\": false, \"reason\": \"商品描述准确反映图片中PUMA品牌运动鞋的白、灰、蓝、绿四色拼接设计，材质为合成革与织物结合，款式为低帮休闲型。未使用极限词或虚标材质，品牌标识清晰且未冒用其他品牌，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白/灰/蓝/绿\", \"材质\": \"合成革/织物\", \"款式\": \"低帮休闲运动鞋\"}, \"violation\": false, \"reason\": \"该商品审核结论基于一般性判断，整体情况符合平台规则要求。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_01409.jpg", "image": "data/raw/images/product_01409.jpg", "prompt": "浅蓝色细条纹短袖衬衫，翻领设计，胸前单口袋", "chosen": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"图片显示为浅蓝色细条纹短袖衬衫，翻领设计，胸前有单口袋，袖口卷起，与描述完全一致。材质从纹理判断为棉质，未使用极限词或虚标材质，无品牌侵权表述，符合广告法及电商合规要求。\"}", "rejected": "{\"category\": \"男装衬衫\", \"attributes\": {\"颜色\": \"浅蓝色\", \"材质\": \"棉质\", \"款式\": \"短袖翻领\"}, \"violation\": false, \"reason\": \"该商品整体展示正常，未发现明显违规内容，符合基本审核标准。\"}", "pair_strategy": "api_weaker_weak_evidence"}
{"image_file": "product_00771.jpg", "image": "data/raw/images/product_00771.jpg", "prompt": "原价999直降到99，限时清仓甩卖！高端时尚真皮女包，奢华大气，限量抢购中！", "chosen": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\", \"款式\": \"经典双环扣设计\"}, \"violation\": true, \"reason\": \"描述中使用『原价999直降到99』『限时清仓甩卖』等虚构原价和促销话术，制造虚假折扣假象，但图片显示为普通款式的棕色皮革手提包，无任何证据支持其原价为999，属于虚标原价制造打折假象，违反价格法\"}", "rejected": "{\"category\": \"手提包\", \"attributes\": {\"颜色\": \"棕色\", \"材质\": \"皮革\"}, \"violation\": false, \"reason\": \"商品描述中的促销话术属于常见营销表达，图片展示为正常款式的真皮包，无明显虚假宣传迹象，整体符合平台规范\"}", "pair_strategy": "api_weaker_missed_cue"}
{"image_file": "product_00851.jpg", "image": "data/raw/images/product_00851.jpg", "prompt": "白色交叉绑带坡跟凉拖鞋", "chosen": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"白色\", \"材质\": \"皮革\", \"款式\": \"交叉绑带坡跟\"}, \"violation\": false, \"reason\": \"图片显示为白色皮革材质的交叉绑带坡跟凉拖鞋，描述准确对应商品实际颜色、材质与款式，未使用极限词或虚标信息，无夸大功效或傍名牌表述，符合合规要求。\"}", "rejected": "{\"category\": \"鞋类\", \"attributes\": {\"颜色\": \"黑色\", \"材质\": \"帆布\", \"款式\": \"交叉绑带坡跟\"}, \"violation\": false, \"reason\": \"商品为黑色帆布材质的交叉绑带坡跟凉拖鞋，颜色与材质描述符合实际，未发现违规信息。\"}", "pair_strategy": "api_weaker_wrong_attribute"}
