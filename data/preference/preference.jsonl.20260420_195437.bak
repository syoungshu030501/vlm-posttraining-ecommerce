{"image_file": "product_02485.jpg", "image": "data/raw/images/product_02485.jpg", "prompt": "男士100%纯棉商务长袖衬衫，浅蓝色修身款，适合职场穿着", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"长袖衬衫\",\n    \"版型\": \"修身\",\n    \"领型\": \"标准翻领\",\n    \"纽扣\": \"白色纽扣\",\n    \"搭配\": \"黑色西裤和皮带\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的为一件浅蓝色男士长袖衬衫，符合描述中的‘100%纯棉商务长袖衬衫，浅蓝色修身款’，无虚假宣传或违规内容。\"\n}", "rejected": "{\n  \"category\": \"男士衬衫\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"长袖\",\n    \"版型\": \"修身\",\n    \"领型\": \"标准翻领\",\n    \"纽扣\": \"白色纽扣\",\n    \"袖口\": \"标准袖口\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，为浅蓝色长袖商务衬衫，无不当内容或违规标识，符合平台规范。\"\n}"}
{"image_file": "product_02078.jpg", "image": "data/raw/images/product_02078.jpg", "prompt": "这款时尚男士皮鞋采用优质牛皮制作，经典黑色设计，适合商务与休闲场合穿着。", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"图案\": \"白色小圆点\",\n    \"款式\": \"短袖连衣裙\",\n    \"领型\": \"V领\",\n    \"袖型\": \"泡泡袖\",\n    \"材质\": \"棉质或混纺面料\",\n    \"长度\": \"及膝\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件女士连衣裙，但商品描述中却声称是男士皮鞋，存在严重的图文不符问题。\"\n}", "rejected": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"图案\": \"白色小圆点\",\n    \"领型\": \"V领\",\n    \"袖型\": \"短袖\",\n    \"材质\": \"棉质\",\n    \"设计元素\": \"前排纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件女性穿着的棕色波点连衣裙，而商品描述中提及的是男士皮鞋，存在严重的图文不符，属于违规行为。\"\n}"}
{"image_file": "product_01189.jpg", "image": "data/raw/images/product_01189.jpg", "prompt": "白色曼联队徽运动短裤", "chosen": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"品牌\": \"Nike\",\n    \"队徽\": \"曼联\",\n    \"款式\": \"短裤\",\n    \"材质\": \"合成纤维（推测）\",\n    \"设计元素\": \"左侧大腿处有曼联队徽，右侧大腿处有Nike标志\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为正规品牌授权的运动短裤，包含曼联队徽和Nike标志，符合平台对正品运动服饰的合规要求，无侵权或违规内容。\"\n}", "rejected": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"品牌\": \"Nike\",\n    \"图案\": \"曼联队徽\",\n    \"款式\": \"短裤\",\n    \"材质\": \"运动面料\",\n    \"设计元素\": \"侧边拉链、抽绳腰头\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为白色运动短裤，带有曼联队徽和Nike标志，属于合法授权的运动服装产品，无违规内容。\"\n}"}
{"image_file": "product_01128.jpg", "image": "data/raw/images/product_01128.jpg", "prompt": "最新款红色儿童连帽背心，超低价全网最低，绝对顶级时尚单品", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"连帽背心\",\n    \"图案\": \"数字63、DIVI、1A，背景有黑色涂鸦风格数字\",\n    \"材质\": \"棉质或混纺面料（推测）\",\n    \"适用人群\": \"儿童\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中存在疑似品牌标识“DIVI”及数字组合“63”、“1A”，可能构成对知名品牌（如Nike的“Dri-FIT”系列或类似运动品牌）的模仿或侵权，且商品描述中使用“全网最低”、“绝对顶级时尚单品”等绝对化用语，违反广告法相关条款。\"\n}", "rejected": "{\n  \"category\": \"children's clothing\",\n  \"attributes\": {\n    \"color\": \"red\",\n    \"style\": \"hooded tank top\",\n    \"design\": \"printed numbers and text\",\n    \"numbers\": [\"63\", \"1A\"],\n    \"text\": \"DIVI\",\n    \"material\": \"cotton or cotton blend (assumed)\",\n    \"target_age_group\": \"children\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为红色儿童连帽背心，设计包含数字和文字图案，未发现违规内容。描述中‘超低价全网最低’等用语虽有营销倾向，但无明显虚假宣传或违禁信息，符合基本合规要求。\"\n}"}
{"image_file": "product_00281.jpg", "image": "data/raw/images/product_00281.jpg", "prompt": "时尚秋冬外套，多色可选", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革表带，金属表壳，水晶装饰\",\n    \"款式\": \"矩形表盘，罗马数字刻度\",\n    \"品牌\": \"ESPRIT\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款手表，而商品描述为‘时尚秋冬外套，多色可选’，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"black and silver\",\n    \"material\": \"leather strap, metal case, crystal accents\",\n    \"style\": \"rectangular face, minimalist design with Roman numerals\",\n    \"brand\": \"ESPRIT\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一款手表，而商品描述为‘时尚秋冬外套，多色可选’，描述与图片内容严重不符，属于虚假或误导性描述。\"\n}"}
{"image_file": "product_02276.jpg", "image": "data/raw/images/product_02276.jpg", "prompt": "粉色细条纹男士长袖衬衫", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"图案\": \"细条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"搭配\": \"深蓝色裤子，黑色皮带\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合男士正装衬衫的常规设计，无违规内容。颜色、图案和款式均在正常范围内，未发现虚假宣传或不当元素。\"\n}", "rejected": "{\n  \"category\": \"男装-衬衫\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"图案\": \"细条纹\",\n    \"款式\": \"长袖\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺\",\n    \"搭配\": \"深蓝色裤子，黑色皮带\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合男士正装衬衫的常规设计，无不当内容或违规元素。\"\n}"}
{"image_file": "product_02256.jpg", "image": "data/raw/images/product_02256.jpg", "prompt": "浅蓝色细条纹男士长袖衬衫", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"图案\": \"细条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"穿着方式\": \"正装搭配\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一件浅蓝色细条纹男士长袖衬衫，与描述一致，无虚假宣传或违规内容。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"图案\": \"细条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准领\",\n    \"材质\": \"棉质或混纺面料（视觉推断）\",\n    \"搭配\": \"黑色西裤与皮带\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合服装类商品规范，未发现虚假宣传、侵权或违禁内容。视觉属性与商品描述一致，均为浅蓝色细条纹男士长袖衬衫。\"\n}"}
{"image_file": "product_00628.jpg", "image": "data/raw/images/product_00628.jpg", "prompt": "最新款超低价全网最低绝对顶级男士黑色短袖T恤，时尚百搭必备单品", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"红色盾形徽标，内含跃马图案\",\n    \"材质\": \"棉质或混纺面料\",\n    \"款式\": \"圆领短袖T恤\",\n    \"设计元素\": \"棋盘格纹理背景\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的红色盾形徽标及跃马图案与法拉利（Ferrari）品牌标志高度相似，存在明显的品牌侵权风险，违反平台关于未经授权使用知名品牌标识的合规规定。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"胸前红色盾形徽章，内含跃马标志\",\n    \"材质\": \"棉质或混纺\",\n    \"设计细节\": \"格纹暗纹底色，左侧袖口有小标签\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中T恤正面印有与法拉利（Ferrari）品牌高度相似的跃马徽标，该标志为注册商标，未经许可使用构成侵权。尽管商品描述声称‘最新款’‘顶级’等营销用语可能涉及虚假宣传，但主要违规点在于未经授权使用知名品牌的商标元素。\"\n}"}
{"image_file": "product_01569.jpg", "image": "data/raw/images/product_01569.jpg", "prompt": "这款牛仔裤包治百病，7天瘦10斤，一抹白，轻松塑形显瘦，穿出完美身材！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"修身牛仔裤\",\n    \"材质\": \"牛仔布\",\n    \"设计特点\": \"高腰、紧身剪裁、白色缝线装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在虚假宣传和夸大功效，如'包治百病'、'7天瘦10斤'、'一抹白'等表述属于医疗或减肥效果承诺，违反了广告法及电商平台关于商品宣传的合规要求。该商品为普通牛仔裤，不具备所述功能，构成误导性宣传。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"修身小脚裤\",\n    \"材质\": \"牛仔布\",\n    \"设计细节\": \"前口袋有金属扣，腰部有纽扣和拉链\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’、‘7天瘦10斤’等夸大功效宣传，违反广告法及平台关于虚假宣传的规定。该类表述属于医疗效果或减肥功效的承诺，而图片展示仅为普通牛仔裤，无任何健康或瘦身功能，存在误导消费者风险。\"\n}"}
{"image_file": "product_01638.jpg", "image": "data/raw/images/product_01638.jpg", "prompt": "浅灰色水洗男士修身牛仔裤", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"浅灰色\",\n    \"款式\": \"修身\",\n    \"材质\": \"牛仔布\",\n    \"水洗效果\": \"有\",\n    \"裤型\": \"直筒\",\n    \"细节\": \"前袋有缝线装饰，后袋有品牌标签\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是浅灰色水洗男士修身牛仔裤，符合描述内容，无违规信息。\"\n}", "rejected": "{\n  \"category\": \"男士牛仔裤\",\n  \"attributes\": {\n    \"颜色\": \"浅灰色\",\n    \"水洗效果\": \"有\",\n    \"款式\": \"修身\",\n    \"材质\": \"牛仔布\",\n    \"细节\": \"经典五袋设计，正面双缝线\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，为浅灰色水洗男士修身牛仔裤，无违规内容或误导性信息。\"\n}"}
{"image_file": "product_00424.jpg", "image": "data/raw/images/product_00424.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "chosen": "{\n  \"category\": \"正装皮鞋\",\n  \"attributes\": {\n    \"color\": \"黑色\",\n    \"material\": \"皮革\",\n    \"style\": \"系带正装鞋\",\n    \"sole_type\": \"低跟平底\",\n    \"lacing\": \"传统系带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款黑色皮革正装皮鞋，具有典型的商务鞋设计特征（如尖头、系带、光滑皮革表面），与描述中的‘运动休闲鞋’和‘缓震耐磨橡胶底’不符。实际鞋底为硬质平底，无明显缓震结构，且材质非橡胶，属于品类描述严重不符。\"\n}", "rejected": "{\n  \"category\": \"皮鞋\",\n  \"attributes\": {\n    \"color\": \"黑色\",\n    \"material\": \"皮革\",\n    \"style\": \"系带正装皮鞋\",\n    \"sole_type\": \"低跟平底\",\n    \"lacing\": \"有鞋带\",\n    \"interior\": \"棕色内里\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为正装系带皮鞋，材质为皮革，鞋型正式，与描述中‘运动休闲鞋’不符，且未见缓震耐磨橡胶底的特征，存在描述虚假宣传。\"\n}"}
{"image_file": "product_00520.jpg", "image": "data/raw/images/product_00520.jpg", "prompt": "穿上这款条纹衬衫，包治百病，7天瘦10斤，一抹白，瞬间提升气质！", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺面料\",\n    \"图案\": \"竖条纹\",\n    \"纽扣\": \"白色纽扣\",\n    \"袖口\": \"标准袖口\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含虚假宣传内容，如'包治百病'、'7天瘦10斤'等，属于夸大功效和医疗宣称，违反广告法及电商平台关于商品描述真实性的规定。\"\n}", "rejected": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝白竖条纹\",\n    \"款式\": \"长袖正装衬衫\",\n    \"领型\": \"标准翻领\",\n    \"纽扣\": \"白色纽扣\",\n    \"袖口\": \"普通单褶袖口\",\n    \"材质\": \"看起来为棉质或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’、‘7天瘦10斤’等夸大宣传和医疗效果承诺，属于虚假宣传，违反广告法及电商平台对商品描述真实性的要求。此类表述与实际商品功能（衣物）严重不符，具有误导消费者之嫌。\"\n}"}
{"image_file": "product_02339.jpg", "image": "data/raw/images/product_02339.jpg", "prompt": "棕色圆环图案棉质连衣裙，七分袖宽松款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"图案\": \"白色圆环图案\",\n    \"材质\": \"棉质\",\n    \"袖长\": \"七分袖\",\n    \"款式\": \"宽松款\",\n    \"领型\": \"方领\",\n    \"长度\": \"中长款\",\n    \"下摆设计\": \"侧开叉\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，未发现违规内容。视觉属性如棕色底色、白色圆环图案、七分袖及宽松版型均符合描述，无虚假宣传或不当信息。\"\n}", "rejected": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"图案\": \"圆环图案\",\n    \"材质\": \"棉质\",\n    \"袖长\": \"七分袖\",\n    \"款式\": \"宽松款\",\n    \"领型\": \"方领\",\n    \"长度\": \"中长款\",\n    \"侧边设计\": \"开衩\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，未发现违规内容。商品为常规服饰，无敏感图案或不当信息。\"\n}"}
{"image_file": "product_01239.jpg", "image": "data/raw/images/product_01239.jpg", "prompt": "这款红色儿童鞋采用100%纯棉材质，舒适透气，适合日常穿着", "chosen": "{\n  \"category\": \"children_shoes\",\n  \"attributes\": {\n    \"color\": \"red\",\n    \"material\": \"cotton\",\n    \"design\": \"Winnie the Pooh character print\",\n    \"style\": \"slip-on\",\n    \"branding\": \"POOH text on toe\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中包含迪士尼（Disney）旗下角色小熊维尼（Winnie the Pooh）的图案，属于未经授权的版权内容，违反了平台关于知识产权保护的规定。\"\n}", "rejected": "{\n  \"category\": \"children_shoes\",\n  \"attributes\": {\n    \"color\": \"red\",\n    \"material\": \"cotton\",\n    \"design\": \"slip-on\",\n    \"brand_character\": \"Winnie the Pooh\",\n    \"text_on_shoe\": \"POOH\",\n    \"trim_color\": \"yellow\",\n    \"sole_color\": \"white\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中包含'Winnie the Pooh'卡通形象及'POOH'字样，属于未经授权的受版权保护的动漫角色使用，构成侵权风险。\"\n}"}
{"image_file": "product_01355.jpg", "image": "data/raw/images/product_01355.jpg", "prompt": "这款时尚连衣裙采用黑色与黄色拼接设计，适合日常穿搭，展现独特个性魅力。", "chosen": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"black and yellow\",\n    \"material\": \"leather strap, metal case\",\n    \"brand\": \"Puma\",\n    \"style\": \"chronograph\",\n    \"shape\": \"square\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款Puma品牌的黑色与黄色拼接手表，而商品描述中却称其为‘时尚连衣裙’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色与黄色\",\n    \"材质\": \"黑色皮革表带，金属表壳\",\n    \"款式\": \"方形表盘，计时码表设计\",\n    \"品牌标志\": \"Puma 跳跃猫标志\",\n    \"功能\": \"三眼计时器\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款Puma品牌的手表，但商品描述中却描述为‘时尚连衣裙’，存在严重品类与描述不符的问题，涉嫌误导消费者。\"\n}"}
{"image_file": "product_00376.jpg", "image": "data/raw/images/product_00376.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"dark green\",\n    \"material\": \"suede\",\n    \"style\": \"oxford\",\n    \"lacing\": \"lace-up\",\n    \"sole\": \"light beige rubber\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双深绿色绒面革男士皮鞋，而商品描述为‘纯棉休闲上衣’，存在严重品类与描述不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"鞋子\",\n  \"attributes\": {\n    \"颜色\": \"橄榄绿\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"系带正装鞋\",\n    \"鞋底\": \"浅色橡胶底\",\n    \"设计元素\": \"布洛克雕花\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双橄榄绿色的男式正装皮鞋，但商品描述中写的是'纯棉休闲上衣'，存在严重的图文不符，属于虚假宣传。\"\n}"}
{"image_file": "product_02106.jpg", "image": "data/raw/images/product_02106.jpg", "prompt": "NIKE同款复古做旧帆布鞋，小香风原单质感，百搭潮流平替", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"beige\",\n    \"material\": \"suede-like\",\n    \"style\": \"low-top\",\n    \"lacing\": \"standard\",\n    \"sole\": \"white rubber\",\n    \"design\": \"distressed vintage\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'NIKE同款'涉嫌品牌侵权，且图片显示为做旧风格鞋款，但未标注具体品牌，存在误导消费者风险。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"beige\",\n    \"material\": \"suede-like fabric\",\n    \"style\": \"low-top lace-up\",\n    \"sole\": \"white rubber\",\n    \"design\": \"distressed vintage look\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中提及'NIKE同款'，但图片显示的鞋款并未包含任何NIKE品牌标识或注册商标，属于虚假宣传和侵权风险。同时，使用'原单质感'可能暗示正品或仿制高价值商品，构成误导性描述。\"\n}"}
{"image_file": "product_00568.jpg", "image": "data/raw/images/product_00568.jpg", "prompt": "这款时尚连衣裙采用轻盈雪纺材质，适合夏季穿着，展现优雅气质。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"品牌\": \"PUMA\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质\",\n    \"图案\": \"粉色渐变PUMA标志和跳跃的美洲狮图案\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件黑色短袖T恤，而非描述中提到的‘时尚连衣裙’，且材质为棉质而非雪纺，存在严重描述不符。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"品牌\": \"PUMA\",\n    \"图案\": \"粉色渐变文字和跳豹标志\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质（视觉推断）\",\n    \"性别\": \"女性\"\n  },\n  \"violation\": true,\n  \"reason\": \"图片展示的是一件黑色短袖T恤，而非商品描述中提到的‘时尚连衣裙’，存在严重描述不符。此外，商品为知名品牌PUMA产品，需核实授权情况以避免侵犯知识产权。\"\n}"}
{"image_file": "product_00417.jpg", "image": "data/raw/images/product_00417.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"卡通人物演奏乐器，文字'SING IT!'及'with FLAP DOODLERS 5.00pm onwards school backyard'\",\n    \"材质\": \"棉质或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件儿童T恤，但商品描述为'运动休闲鞋，缓震耐磨橡胶底'，存在严重品类不符。图片中无任何鞋子元素，描述与实际商品不一致。\"\n}", "rejected": "```json\n{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"卡通人物演奏乐器，文字'SING IT!'及'with FLAP DOODLERS 5.00pm onwards school backyard'\",\n    \"材质\": \"棉质或棉混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件儿童T恤，而商品描述为'运动休闲鞋，缓震耐磨橡胶底'，图文严重不符，属于虚假描述。\"\n}\n```"}
{"image_file": "product_01094.jpg", "image": "data/raw/images/product_01094.jpg", "prompt": "ESPRIT品牌条纹彩色透明表壳手表", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表壳材质\": \"透明塑料\",\n    \"表带设计\": \"条纹彩色\",\n    \"颜色\": [\"紫色\", \"粉色\", \"蓝色\", \"白色\", \"黑色\"],\n    \"表盘形状\": \"矩形\",\n    \"表盘图案\": \"竖条纹\",\n    \"指针类型\": \"简约黑色指针\",\n    \"表冠\": \"银色金属\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为ESPRIT品牌的条纹彩色透明表壳手表，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表壳材质\": \"透明塑料\",\n    \"表盘设计\": \"竖条纹图案\",\n    \"颜色\": [\"紫色\", \"粉色\", \"白色\", \"蓝色\", \"黑色\"],\n    \"表带\": \"彩色条纹软胶\",\n    \"表盘形状\": \"矩形\",\n    \"指针类型\": \"简约黑指针\",\n    \"表冠\": \"金属质感\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，为ESPRIT品牌条纹彩色透明表壳手表，无违规内容。\"\n}"}
{"image_file": "product_01894.jpg", "image": "data/raw/images/product_01894.jpg", "prompt": "浅灰色刺绣吊带连衣裙，斜条纹花卉图案，简约优雅设计", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"浅灰色\",\n    \"图案\": \"斜条纹花卉刺绣\",\n    \"款式\": \"吊带连衣裙\",\n    \"设计风格\": \"简约优雅\",\n    \"材质\": \"看似轻薄织物，可能为棉或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示服装正面，无违规内容。视觉属性与描述一致，未发现虚假宣传或不当元素。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅灰色\",\n    \"款式\": \"吊带连衣裙\",\n    \"图案\": \"斜条纹花卉刺绣\",\n    \"设计风格\": \"简约优雅\",\n    \"材质\": \"看似轻薄织物，可能为棉或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示服装细节，无违规元素，如不实宣传、侵权标识或不当内容。视觉属性与描述一致，符合平台规范。\"\n}"}
{"image_file": "product_00773.jpg", "image": "data/raw/images/product_00773.jpg", "prompt": "小香风原单质感女包，LV平替经典款，高级皮质手提包", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"dark_brown\",\n    \"material\": \"leather\",\n    \"style\": \"classic_tote\",\n    \"hardware\": \"gold_tone_buckles\",\n    \"handle_type\": \"top_handle\",\n    \"closure\": \"buckle_flap\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'小香风原单质感'和'LV平替经典款'等表述，暗示与奢侈品牌（如Chanel、Louis Vuitton）存在关联或仿制关系，可能构成品牌侵权或误导性宣传，违反平台关于禁止冒用知名品牌名称及虚假宣传的规定。\"\n}", "rejected": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"手提包\",\n    \"五金件\": \"金色金属扣\",\n    \"设计风格\": \"经典复古风\",\n    \"细节\": \"双提手、正面装饰扣、缝线工艺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘小香风原单质感’和‘LV平替经典款’等表述，暗示与奢侈品牌（如Chanel、Louis Vuitton）存在关联或仿制关系，易造成消费者误导，属于违规宣传。实际图片显示为普通皮质手提包，无任何品牌标识，不符合描述中的高端定位与品牌联想。\"\n}"}
{"image_file": "product_01364.jpg", "image": "data/raw/images/product_01364.jpg", "prompt": "原价999直降到99，限时清仓甩卖！时尚印花T恤，潮流必备单品。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"印花文字'HEELS BEHIND THE WHEELS'，搭配高跟鞋和汽车元素\",\n    \"材质\": \"棉质或混纺面料（推测）\",\n    \"适用人群\": \"女性\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通时尚印花T恤，图案内容无违法不良信息，未涉及政治、宗教、色情低俗或侵权内容，符合平台销售规范。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"浅黄色\",\n    \"款式\": \"短袖T恤\",\n    \"印花内容\": \"HEELS BEHIND THE WHEELS\",\n    \"图案元素\": \"高跟鞋与赛车元素结合\",\n    \"材质\": \"棉质\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片中T恤设计包含‘HEELS BEHIND THE WHEELS’文字及高跟鞋与赛车图案，为正常时尚印花设计，未涉及违法、色情、暴力或侵权内容，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00345.jpg", "image": "data/raw/images/product_00345.jpg", "prompt": "经典款牛仔裤，修身显瘦", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质或混纺\",\n    \"设计元素\": \"胸前双口袋、纽扣开合、领口翻领\",\n    \"图案\": \"格子图案\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件蓝白格纹短袖衬衫，而商品描述为'经典款牛仔裤，修身显瘦'，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"color\": \"蓝白格纹\",\n    \"pattern\": \"格子\",\n    \"sleeve_length\": \"短袖\",\n    \"collar_type\": \"翻领\",\n    \"buttons\": \"有纽扣\",\n    \"pockets\": \"胸前双口袋\",\n    \"material\": \"棉质或混纺\",\n    \"fit\": \"修身\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件短袖格子衬衫，而商品描述中却为“经典款牛仔裤”，存在严重的图文不符问题，涉嫌误导消费者。\"\n}"}
{"image_file": "product_01786.jpg", "image": "data/raw/images/product_01786.jpg", "prompt": "这款Puma手表采用100%纯棉表带，时尚简约设计，适合日常佩戴", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表带材质\": \"黑色皮革纹理\",\n    \"表盘形状\": \"方形\",\n    \"表盘颜色\": \"黑色\",\n    \"表壳材质\": \"金属\",\n    \"品牌标识\": \"Puma标志\",\n    \"设计风格\": \"现代简约\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称表带为100%纯棉，但图片显示表带为黑色皮革纹理材质，与描述严重不符，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"black and silver\",\n    \"band_material\": \"leather (visual appearance)\",\n    \"design_style\": \"modern, minimalist\",\n    \"brand\": \"Puma\",\n    \"case_shape\": \"rectangular\",\n    \"dial\": \"digital-style hour markers with vertical stripes\",\n    \"strap_pattern\": \"embossed geometric texture\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中称表带为'100%纯棉'，但图片显示表带具有皮革纹理和压花图案，实际材质应为皮革或仿皮，与描述严重不符，构成虚假宣传。\"\n}"}
{"image_file": "product_01475.jpg", "image": "data/raw/images/product_01475.jpg", "prompt": "这款时尚连衣裙采用轻盈面料，适合日常穿着，展现优雅气质。", "chosen": "{\n  \"category\": \"pants\",\n  \"attributes\": {\n    \"color\": \"turquoise\",\n    \"waistband\": \"pink and white trim\",\n    \"material\": \"lightweight fabric\",\n    \"style\": \"straight-leg\",\n    \"occasion\": \"casual\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的为一条长裤，而商品描述中称其为‘连衣裙’，存在品类描述与实际商品严重不符的情况。\"\n}", "rejected": "{\"category\": \"pants\", \"attributes\": {\"color\": \"turquoise\", \"waistband\": \"pink and white\", \"style\": \"straight-leg\", \"material\": \"stretch fabric\"}, \"violation\": true, \"reason\": \"商品图片显示的为一条裤子，但商品描述中称其为‘连衣裙’，品类描述与实际商品严重不符。\"}"}
{"image_file": "product_00434.jpg", "image": "data/raw/images/product_00434.jpg", "prompt": "韩版潮流服饰，时尚百搭", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"银色、紫色、白色\",\n    \"材质\": \"网布、合成革\",\n    \"款式\": \"低帮运动鞋\",\n    \"设计元素\": \"透气网眼、侧边条纹、厚底缓震\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为运动鞋，但商品描述中使用‘韩版潮流服饰，时尚百搭’等词汇，属于品类不符且误导性描述，违反平台关于商品描述真实性的规则。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"银色、紫色、白色\",\n    \"材质\": \"网眼布、合成材料\",\n    \"款式\": \"运动休闲款\",\n    \"设计元素\": \"透气网面、侧边装饰条、厚底缓震\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一双运动鞋，但商品描述为'韩版潮流服饰，时尚百搭'，描述与实际商品品类不符，存在虚假宣传风险。\"\n}"}
{"image_file": "product_01568.jpg", "image": "data/raw/images/product_01568.jpg", "prompt": "最新款超低价全网最低绝对顶级黑色修身牛仔裤，时尚百搭必备单品", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"修身牛仔裤\",\n    \"材质\": \"牛仔布\",\n    \"设计\": \"直筒剪裁，标准五袋设计\",\n    \"细节\": \"正面有纽扣和拉链闭合，左前袋上有品牌标识\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反平台广告合规规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"修身牛仔裤\",\n    \"材质\": \"牛仔布\",\n    \"长度\": \"九分裤\",\n    \"设计特点\": \"直筒剪裁，前袋有缝线装饰，左前袋带有品牌标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等绝对化用语和虚假宣传词汇，违反了广告法及电商平台对夸大宣传的限制。\"\n}"}
{"image_file": "product_01298.jpg", "image": "data/raw/images/product_01298.jpg", "prompt": "这款白色T恤宣称100%纯棉，但实际为化纤混纺材质，存在材质虚标问题。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"印有抽象人物图像和红色文字'Kinfolk'及'Wrangler'\",\n    \"材质外观\": \"表面光滑，无明显棉质纹理\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述宣称100%纯棉，但根据图片中T恤的表面质感判断为化纤混纺材质，存在材质虚标问题。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"印有抽象人物肖像和红色文字 'Kinfolk' 及 'Wrangler'\",\n    \"款式\": \"短袖圆领T恤\",\n    \"材质标注\": \"宣称100%纯棉\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示T恤为白色短袖，带有 'Kinfolk' 字样及人物图案，其描述中宣称100%纯棉，但实际为化纤混纺材质，存在材质虚标问题。\"\n}"}
{"image_file": "product_01797.jpg", "image": "data/raw/images/product_01797.jpg", "prompt": "棕色皮革平底人字拖，配金属叶片装饰", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"平底人字拖\",\n    \"装饰\": \"金属叶片\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通时尚鞋类，无违规元素，符合平台销售规范。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather\",\n    \"style\": \"flat sandal\",\n    \"decorative_elements\": \"metallic leaf-shaped embellishments\",\n    \"brand\": \"Cult gaia\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为棕色皮革平底人字拖，配金属叶片装饰，符合平台关于鞋类商品的合规标准，无违规内容。\"\n}"}
{"image_file": "product_00406.jpg", "image": "data/raw/images/product_00406.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"case_shape\": \"方形\",\n    \"dial_color\": \"白色\",\n    \"strap_material\": \"黑色皮革\",\n    \"strap_color\": \"黑色\",\n    \"hour_markers\": \"数字与条形结合\",\n    \"second_hand_color\": \"红色\",\n    \"date_display\": \"有\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款Puma品牌的手表，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重品类与描述不符的问题。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"Puma\",\n    \"表盘形状\": \"方形\",\n    \"表壳材质\": \"金属\",\n    \"表带材质\": \"黑色皮革\",\n    \"表盘颜色\": \"白色\",\n    \"指针颜色\": \"银色和红色\",\n    \"显示功能\": \"日期窗口\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片为一款Puma品牌的手表，但商品描述为'高端品牌商务皮鞋，真皮鞋面'，存在明显的图文不符，属于虚假宣传。\"\n}"}
{"image_file": "product_01196.jpg", "image": "data/raw/images/product_01196.jpg", "prompt": "棕色皮革翻盖手提包，配金属扣饰", "chosen": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"翻盖\",\n    \"五金件\": \"金属扣饰\",\n    \"肩带\": \"双肩带\",\n    \"装饰\": \"铆钉和金属环\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一款棕色皮革翻盖手提包，配金属扣饰，符合描述内容，无违规信息。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather\",\n    \"style\": \"flap-over\",\n    \"hardware\": \"metal clasp\",\n    \"strap_type\": \"shoulder_strap\",\n    \"closure_type\": \"clasp\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示棕色皮革材质的手提包，配金属扣饰，符合描述，无违规元素。\"\n}"}
{"image_file": "product_01483.jpg", "image": "data/raw/images/product_01483.jpg", "prompt": "这款时尚连衣裙采用轻盈雪纺材质，适合夏季穿着，搭配简约设计，展现优雅气质。", "chosen": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"case_shape\": \"square\",\n    \"case_material\": \"metal\",\n    \"strap_color\": \"black\",\n    \"strap_material\": \"rubber\",\n    \"dial_color\": \"white\",\n    \"display_type\": \"analog\",\n    \"features\": [\"date_display\", \"day_display\", \"24-hour_indicator\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是一款Puma品牌的手表，但商品描述中却描述为‘时尚连衣裙’，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"color\": \"银色/黑色\",\n    \"material\": \"金属表壳，橡胶表带\",\n    \"design\": \"方形表盘，数字显示，多功能表盘（含日历、星期、24小时制）\",\n    \"features\": \"红色指针，像素风格数字\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款Puma品牌的手表，但商品描述却为‘时尚连衣裙’，存在严重图文不符，属于虚假宣传，违反平台商品信息真实性规范。\"\n}"}
{"image_file": "product_01749.jpg", "image": "data/raw/images/product_01749.jpg", "prompt": "深绿色圆领短袖修身T恤", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深绿色\",\n    \"领型\": \"圆领\",\n    \"袖长\": \"短袖\",\n    \"版型\": \"修身\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"图案/标志\": \"左胸有小logo\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是常规服饰，无违规内容。颜色、款式和设计均符合平台规范，未发现敏感信息或不当元素。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"深绿色\",\n    \"领型\": \"圆领\",\n    \"袖长\": \"短袖\",\n    \"版型\": \"修身\",\n    \"图案\": \"无明显图案\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"品牌标识\": \"左胸位置有小logo\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规款式的女装T恤，颜色、款式均符合平台规范，无违规信息或不当内容。\"\n}"}
{"image_file": "product_00230.jpg", "image": "data/raw/images/product_00230.jpg", "prompt": "时尚秋冬外套，多色可选", "chosen": "{\n  \"category\": \"手袋\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"材质\": \"皮革\",\n    \"图案\": \"压花字母图案\",\n    \"款式\": \"单肩包\",\n    \"五金件\": \"银色金属扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款蓝色皮质手袋，而商品描述中提及的是‘时尚秋冬外套’，存在严重品类不符，属于虚假描述。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"blue\",\n    \"material\": \"leather\",\n    \"pattern\": \"embossed logo\",\n    \"style\": \"clutch with shoulder strap\",\n    \"hardware\": \"silver-toned clasp\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是蓝色皮质手提包，但描述为'时尚秋冬外套，多色可选'，存在严重图文不符，违反平台商品描述真实性规则。\"\n}"}
{"image_file": "product_00499.jpg", "image": "data/raw/images/product_00499.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "chosen": "{\n  \"category\": \"T恤\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"图案\": \"蓝色徽章图案，包含皇冠、罗马数字MCMXLVII、字母PUMA、数字48和文字'THE ORIGINAL SPORTING COMPANY'\",\n    \"材质\": \"棉质（视觉判断）\",\n    \"款式\": \"圆领短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件黄色短袖T恤，而商品描述为'100%真丝连衣裙，高贵典雅'，存在严重品类与材质不符的问题。实际商品为男款T恤，非连衣裙，且从视觉上看材质为棉质而非真丝。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"盾形徽章，包含皇冠、罗马数字MCMXLVII、字母PUMA、数字48以及文字'THE ORIGINAL SPORTING COMPANY'\",\n    \"材质\": \"棉质（视觉判断）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件黄色棉质T恤，而商品描述中声称是'100%真丝连衣裙'，存在严重的品类与材质不符，属于虚假描述。\"\n}"}
{"image_file": "product_00831.jpg", "image": "data/raw/images/product_00831.jpg", "prompt": "黑色皮革男士乐福鞋，简约商务休闲款", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"乐福鞋\",\n    \"风格\": \"商务休闲\",\n    \"内里颜色\": \"棕色\",\n    \"鞋底\": \"平底\",\n    \"缝线细节\": \"可见\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一款黑色皮革男士乐福鞋，符合描述中的‘简约商务休闲款’特征，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"乐福鞋\",\n    \"适用性别\": \"男士\",\n    \"风格\": \"商务休闲\",\n    \"内里颜色\": \"浅棕色\",\n    \"鞋底类型\": \"平底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为黑色皮革男士乐福鞋，款式简约，符合商务休闲定位，无违规信息。\"\n}"}
{"image_file": "product_01938.jpg", "image": "data/raw/images/product_01938.jpg", "prompt": "黑色皮质表带镶钻方形计时腕表", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表带材质\": \"黑色皮质\",\n    \"表盘形状\": \"方形\",\n    \"表壳材质\": \"金属\",\n    \"表盘颜色\": \"黑色\",\n    \"功能\": \"计时\",\n    \"装饰\": \"镶钻\",\n    \"品牌标识\": \"Puma\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，为黑色皮质表带、方形表盘、镶钻设计的计时腕表，表盘上有Puma品牌标识，未发现虚假宣传或违规内容。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表带颜色\": \"黑色\",\n    \"表带材质\": \"皮质\",\n    \"表盘形状\": \"方形\",\n    \"表壳材质\": \"金属\",\n    \"表盘颜色\": \"黑色\",\n    \"功能\": \"计时\",\n    \"装饰元素\": \"镶钻\",\n    \"品牌标志\": \"Puma\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中显示的品牌标志为Puma，属于知名品牌，未提供品牌授权证明，涉嫌侵犯品牌知识产权。\"\n}"}
{"image_file": "product_00750.jpg", "image": "data/raw/images/product_00750.jpg", "prompt": "蓝黑白竖条纹男士长袖衬衫", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色、黑色、白色\",\n    \"图案\": \"竖条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"未明确，视觉上为棉质或混纺\",\n    \"袖口设计\": \"条纹拼接袖口\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示蓝黑白竖条纹男士长袖衬衫，符合描述内容，无虚假宣传或违规元素。\"\n}", "rejected": "{\n  \"category\": \"男士服装\",\n  \"attributes\": {\n    \"颜色\": [\"蓝色\", \"黑色\", \"白色\"],\n    \"图案\": \"竖条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"未明确，视觉上为棉或混纺面料\",\n    \"纽扣\": \"前襟有黑色纽扣\",\n    \"袖口\": \"带条纹装饰的袖口\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示蓝黑白竖条纹男士长袖衬衫，符合描述，无明显违规内容。\"\n}"}
{"image_file": "product_00282.jpg", "image": "data/raw/images/product_00282.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝色与白色竖条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"图案\": \"竖条纹\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"搭配\": \"浅色休闲裤+黑色皮带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为蓝白竖条纹商务休闲衬衫，风格偏向经典商务或通勤风，与描述中‘日系简约 ins风 学院风’存在明显不符。该款衬衫设计较为正式，缺乏日系简约或学院风常见的宽松剪裁、纯色/小图案、日式细节等特征，属于描述夸大或误导性宣传。\"\n}", "rejected": "{\n  \"category\": \"男装-衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝白竖条纹\",\n    \"款式\": \"长袖正装衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺面料\",\n    \"图案\": \"竖条纹\",\n    \"纽扣\": \"黑色圆形纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的衬衫为蓝白竖条纹设计，具有经典商务风格，与描述中‘日系简约 ins风 学院风’存在明显不符。该款式的视觉特征偏向传统正式风格，而非流行趋势中的日系、ins或学院风格，构成描述性误导。\"\n}"}
{"image_file": "product_00556.jpg", "image": "data/raw/images/product_00556.jpg", "prompt": "黑色男士商务皮鞋，系带款式，光面皮革材质", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"光面皮革\",\n    \"款式\": \"系带商务皮鞋\",\n    \"鞋型\": \"正装皮鞋\",\n    \"鞋底\": \"橡胶底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一款黑色男士商务皮鞋，符合描述中的光面皮革材质和系带款式，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"系带商务皮鞋\",\n    \"材质\": \"光面皮革\",\n    \"鞋型\": \"正装皮鞋\",\n    \"鞋底\": \"橡胶底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为标准男士商务皮鞋，符合品类描述，无违规内容。\"\n}"}
{"image_file": "product_00481.jpg", "image": "data/raw/images/product_00481.jpg", "prompt": "欧美大牌设计 小众品牌", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色底色，蓝色和黑色图案\",\n    \"款式\": \"短袖T恤\",\n    \"品牌标识\": \"PUMA MOTORSPORT\",\n    \"图案设计\": \"赛车元素拼贴图案\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中明确显示了'PUMA MOTORSPORT'及PUMA品牌标志，属于知名品牌，与商品描述中'小众品牌'存在明显不符，涉嫌虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"白色\",\n    \"pattern\": \"汽车零部件图案印花\",\n    \"brand\": \"PUMA\",\n    \"design_style\": \"赛车运动风\",\n    \"text_on_clothing\": \"PUMAMOTORSPORT\",\n    \"material\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中明确显示了‘PUMA’品牌标识及‘PUMAMOTORSPORT’字样，属于知名品牌，与商品描述中的‘小众品牌’存在明显矛盾，构成虚假宣传。\"\n}"}
{"image_file": "product_00743.jpg", "image": "data/raw/images/product_00743.jpg", "prompt": "LV平替时尚人字拖，小香风原单设计，潮流百搭夏季必备", "chosen": "{\n  \"category\": \"footwear\",\n  \"attributes\": {\n    \"color\": \"yellow with green strap and orange-red graphic\",\n    \"design\": \"flip-flop with printed pattern\",\n    \"material\": \"rubber sole, fabric strap\",\n    \"branding\": \"no visible brand logo\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'LV平替'和'小香风原单设计'等表述，暗示与奢侈品牌Louis Vuitton或Chanel存在关联，但图片中未见任何品牌标识，涉嫌虚假宣传及误导消费者。\"\n}", "rejected": "{\n  \"category\": \"鞋履\",\n  \"attributes\": {\n    \"颜色\": \"黄色鞋底，绿色鞋带，橙色图案\",\n    \"款式\": \"人字拖\",\n    \"图案\": \"带有抽象图形和文字元素的印花设计\",\n    \"材质\": \"疑似橡胶鞋底，织物鞋带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘LV平替’‘小香风原单设计’等表述，暗示与奢侈品牌（如Louis Vuitton、Chanel）存在关联，但图片中的设计并无明确品牌标识，且视觉风格不具备知名品牌的标志性特征，涉嫌虚假宣传及品牌侵权风险。\"\n}"}
{"image_file": "product_01299.jpg", "image": "data/raw/images/product_01299.jpg", "prompt": "紫色印花男士短袖T恤，正面印有'URBAN KINFOLK'艺术字样", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"正面印有'URBAN KINFOLK'艺术字样，包含人物图像和城市景观元素\",\n    \"材质\": \"棉质（推测）\",\n    \"性别\": \"男\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通印花T恤，图案内容为品牌名称与艺术设计，未发现违法、违规或敏感信息。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"款式\": \"短袖T恤\",\n    \"图案类型\": \"文字印花\",\n    \"印花内容\": \"URBAN KINFOLK\",\n    \"材质\": \"棉质（推测）\",\n    \"适用性别\": \"男\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片中未发现违法不良信息，印花内容为品牌名称'URBAN KINFOLK'，无不当言论、暴力恐怖或色情低俗等元素，符合平台合规标准。\"\n}"}
{"image_file": "product_00595.jpg", "image": "data/raw/images/product_00595.jpg", "prompt": "这款红色耐克T恤，包治百病，7天瘦10斤，一抹白，穿出健康好身材！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"品牌\": \"Nike\",\n    \"图案\": \"城市建筑风格的抽象设计，包含Nike标志和烟囱元素\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"未明确，推测为棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在虚假宣传和夸大功效，如'包治百病'、'7天瘦10斤'、'一抹白'等表述属于医疗或健康功效承诺，违反了广告法及电商平台关于商品宣传合规性的规定。该T恤为普通服饰，不具备所述功能，构成误导性宣传。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"品牌\": \"Nike\",\n    \"图案\": \"城市建筑风格的抽象设计，包含'NIKE'字样\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’、‘7天瘦10斤’、‘一抹白，穿出健康好身材’等虚假宣传和医疗功效承诺，属于夸大宣传及违反广告法的相关规定，存在误导消费者的风险。\"\n}"}
{"image_file": "product_01842.jpg", "image": "data/raw/images/product_01842.jpg", "prompt": "这款时尚男士休闲皮鞋采用优质牛皮制作，黑色经典百搭，适合日常通勤与商务场合穿着。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑白\",\n    \"图案\": \"几何图形\",\n    \"款式\": \"连衣裙\",\n    \"领型\": \"方领\",\n    \"袖型\": \"短袖\",\n    \"材质\": \"未明确\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为女性连衣裙，而商品描述中却称其为男士休闲皮鞋，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑白\",\n    \"图案\": \"几何线条\",\n    \"款式\": \"短袖连衣裙\",\n    \"领型\": \"圆领\",\n    \"袖长\": \"短袖\",\n    \"材质\": \"疑似棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为女士连衣裙，而商品描述却声称是男士休闲皮鞋，存在严重品类与内容不匹配，属于虚假宣传。\"\n}"}
{"image_file": "product_00714.jpg", "image": "data/raw/images/product_00714.jpg", "prompt": "这款男士皮鞋采用高科技材质，包治百病，穿一天就能7天瘦10斤，一抹白让双脚焕发新生！", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋底\": \"橡胶底\",\n    \"设计风格\": \"商务休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含虚假宣传内容，如'包治百病'、'穿一天就能7天瘦10斤'、'一抹白让双脚焕发新生'等，属于夸大功效和医疗宣称，违反广告法及电商平台关于商品描述真实性的规定。图片显示为普通男士皮鞋，无任何特殊功能或成分支持此类宣称。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋底\": \"平底\",\n    \"鞋头\": \"圆头\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含虚假宣传内容，如'包治百病''穿一天就能7天瘦10斤''一抹白让双脚焕发新生'等说法无科学依据，涉嫌夸大功效，违反广告法及平台商品描述规范。\"\n}"}
{"image_file": "product_01250.jpg", "image": "data/raw/images/product_01250.jpg", "prompt": "黑色Nike运动帽，透气网眼设计，适合日常佩戴", "chosen": "{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"品牌\": \"Nike\",\n    \"材质\": \"透气网眼\",\n    \"款式\": \"运动帽\",\n    \"细节\": \"白色Nike标志，帽檐有缝线装饰\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示为黑色Nike运动帽，具备透气网眼设计，符合描述内容，无违规信息。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"品牌标志\": \"Nike勾形标志\",\n    \"材质\": \"透气网眼\",\n    \"款式\": \"运动帽\",\n    \"细节\": \"帽檐有白色缝线，侧面有DRI-FIT标识\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为一款黑色Nike运动帽，具备透气网眼设计和品牌标识，符合平台规范，无违规内容。\"\n}"}
{"image_file": "product_00354.jpg", "image": "data/raw/images/product_00354.jpg", "prompt": "欧美大牌设计 小众品牌", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"套脚皮鞋\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"设计风格\": \"商务休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'欧美大牌设计'和'小众品牌'等词汇，可能构成虚假宣传或误导性描述，缺乏具体品牌信息支持，易引发消费者误解。\"\n}", "rejected": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"color\": \"棕色\",\n    \"material\": \"皮革\",\n    \"style\": \"乐福鞋\",\n    \"sole\": \"黑色橡胶底\",\n    \"closure\": \"套脚式\",\n    \"design\": \"简约缝线设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘欧美大牌设计’‘小众品牌’等可能误导消费者的表述，且图片未展示品牌标识或认证信息，涉嫌虚假宣传或夸大描述。\"\n}"}
{"image_file": "product_00676.jpg", "image": "data/raw/images/product_00676.jpg", "prompt": "黑黄配色网面透气运动鞋", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色与黄色\",\n    \"材质\": \"网面\",\n    \"设计特点\": \"透气孔、黄色鞋带、中底气垫\",\n    \"款式\": \"低帮运动鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，均为黑黄配色的网面透气运动鞋，无虚假宣传或违规内容。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色和黄色\",\n    \"材质\": \"网面\",\n    \"款式\": \"透气运动鞋\",\n    \"鞋带\": \"黄色\",\n    \"鞋底\": \"黄色橡胶，带气垫设计\",\n    \"品牌标识\": \"Kinetico\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，均为黑黄配色、网面材质的透气运动鞋，无违规内容。\"\n}"}
{"image_file": "product_02158.jpg", "image": "data/raw/images/product_02158.jpg", "prompt": "棕色皮革夹趾凉鞋，黑色橡胶鞋底", "chosen": "{\n  \"category\": \"footwear\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather\",\n    \"sole_material\": \"rubber\",\n    \"style\": \"thong sandal\",\n    \"design\": \"crossed strap\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一款棕色皮革夹趾凉鞋，搭配黑色橡胶鞋底，符合描述内容，无违规信息。\"\n}", "rejected": "{\n  \"category\": \"footwear\",\n  \"attributes\": {\n    \"color\": \"brown and black\",\n    \"material\": \"leather upper, rubber sole\",\n    \"style\": \"thong sandal\",\n    \"design\": \"folded strap with decorative loop\"\n  },\n  \"violation\": false,\n  \"reason\": \"The product image shows a standard thong sandal with brown leather straps and a black rubber sole. There are no visible branding violations, unsafe materials, or misleading visual representations. All attributes align with the provided description.\"\n}"}
{"image_file": "product_02159.jpg", "image": "data/raw/images/product_02159.jpg", "prompt": "原价999直降到99，限时清仓甩卖！经典商务男鞋，真皮舒适百搭", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"真皮\",\n    \"款式\": \"商务皮鞋\",\n    \"鞋型\": \"套脚式（Loafer）\",\n    \"鞋跟高度\": \"低跟\",\n    \"缝线细节\": \"可见缝线装饰\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为一款黑色真皮商务男鞋，符合描述中的‘经典商务男鞋，真皮舒适百搭’，无虚假宣传或违规内容。价格促销信息未在图片中体现，但描述中‘原价999直降到99’属于常见营销话术，未发现明显误导性内容。\"\n}", "rejected": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"真皮\",\n    \"款式\": \"商务皮鞋\",\n    \"鞋型\": \"套脚式（乐福鞋）\",\n    \"鞋底\": \"低跟平底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为一款黑色真皮商务男鞋，符合描述中‘经典商务男鞋，真皮舒适百搭’的定位，无虚假宣传或违规内容。\"\n}"}
{"image_file": "product_01038.jpg", "image": "data/raw/images/product_01038.jpg", "prompt": "白色短袖T恤，正面印有红蓝白三色英国国旗图案与花卉元素", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": [\"白色\", \"红色\", \"蓝色\"],\n    \"图案\": \"英国国旗与花卉元素结合\",\n    \"款式\": \"短袖T恤\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品正面印有英国国旗图案，可能涉及国家象征性标志的不当使用，存在违反平台关于政治或国家符号使用的合规风险。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"白色\",\n    \"pattern\": \"英国国旗图案与花卉元素\",\n    \"material\": \"未明确显示\",\n    \"style\": \"短袖T恤\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品正面印有英国国旗图案，可能涉及国家象征性标志的不当使用，存在违反平台关于政治敏感图案或国旗类标识使用的规则风险。\"\n}"}
{"image_file": "product_01582.jpg", "image": "data/raw/images/product_01582.jpg", "prompt": "NIKE同款运动帽，时尚百搭，透气舒适，潮流必备单品", "chosen": "{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"黑色主体，绿色内衬，白色条纹\",\n    \"款式\": \"运动帽\",\n    \"材质\": \"透气面料\",\n    \"品牌标识\": \"无明显NIKE标志，但设计风格类似\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'NIKE同款'字样，可能构成品牌侵权或误导性宣传，且图片中未见明确授权标识，存在仿冒风险。\"\n}", "rejected": "{\n  \"category\": \"服饰配件\",\n  \"attributes\": {\n    \"颜色\": \"黑色主体，绿色内衬，白色条纹\",\n    \"款式\": \"棒球帽\",\n    \"品牌标识\": \"无明显NIKE标志，但设计风格相似\",\n    \"材质\": \"可能为棉质或合成纤维，透气性良好\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'NIKE同款'可能构成虚假宣传或侵犯知名品牌权益，且图片未显示明确品牌标识，存在误导消费者风险。\"\n}"}
{"image_file": "product_00343.jpg", "image": "data/raw/images/product_00343.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"PUMA品牌标志，黄色和蓝色渐变字体，下方有'SINCE 1948'字样\",\n    \"材质\": \"棉质（推测）\",\n    \"适用人群\": \"男性\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的T恤印有PUMA品牌标志，属于知名品牌商标。商品描述中使用“商场撤柜 专柜正品”等表述，可能暗示为正品或授权商品，但未提供相应资质证明，存在冒用品牌标识、误导消费者的风险，违反平台关于品牌合规及虚假宣传的规定。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"PUMA品牌标志，黄色和蓝色配色，文字内容为'PUMA SINCE 1948'\",\n    \"材质\": \"棉质（推测）\",\n    \"适用性别\": \"男\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的T恤印有PUMA品牌标识，属于知名品牌，而商品描述中使用‘商场撤柜 专柜正品 便宜处理’等话术，可能暗示其为正品但低价销售，存在误导消费者或未经授权销售假冒/仿冒商品的风险。同时，该品牌标识具有较高的品牌辨识度，未提供授权证明的情况下，此类商品易构成商标侵权或售假风险。\"\n}"}
{"image_file": "product_02189.jpg", "image": "data/raw/images/product_02189.jpg", "prompt": "黑色与湖蓝色拼接的户外运动凉鞋，采用魔术贴设计，适合日常穿着", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色与湖蓝色拼接\",\n    \"材质\": \"合成材料\",\n    \"款式\": \"户外运动凉鞋\",\n    \"闭合方式\": \"魔术贴\",\n    \"品牌标识\": \"One Ups\",\n    \"鞋底设计\": \"厚底防滑\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为常规户外运动凉鞋，无违规内容。颜色、材质和设计均符合描述，未发现虚假宣传或侵权元素。\"\n}", "rejected": "{\n  \"category\": \"footwear\",\n  \"attributes\": {\n    \"color\": [\"black\", \"lake blue\"],\n    \"material\": \"synthetic straps, rubber sole\",\n    \"closure_type\": \"velcro\",\n    \"design_style\": \"sporty sandal\",\n    \"brand\": \"one up\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为正常销售的户外运动凉鞋，颜色和材质描述准确，无违规内容。\"\n}"}
{"image_file": "product_01673.jpg", "image": "data/raw/images/product_01673.jpg", "prompt": "浅灰色伦敦城市图案印花短袖T恤", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅灰色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"伦敦城市景观印花，包含大本钟、议会大厦等标志性建筑，以及花卉和蝴蝶结元素\",\n    \"文字\": \"LONDON\",\n    \"材质\": \"棉质或棉混纺（推测）\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服饰，图案为伦敦城市景观及装饰性元素，未涉及政治敏感内容、暴力、色情或侵权标识，符合平台合规要求。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"浅灰色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"伦敦城市景观印花，包含大本钟、议会大厦等标志性建筑，配以花卉和丝带元素\",\n    \"文字\": \"LONDON\",\n    \"材质\": \"棉质（推测）\",\n    \"领型\": \"圆领\",\n    \"袖长\": \"短袖\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服饰类目，图案内容为城市风景与艺术化设计，未涉及敏感政治、色情、暴力或侵权内容，符合平台审核规范。\"\n}"}
{"image_file": "product_02164.jpg", "image": "data/raw/images/product_02164.jpg", "prompt": "黑色男士系带皮鞋，简约商务风格", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带皮鞋\",\n    \"风格\": \"商务简约\",\n    \"鞋头形状\": \"尖头\",\n    \"鞋底\": \"低跟平底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为常规男士商务皮鞋，无违规标识、不当内容或虚假宣传，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带皮鞋\",\n    \"风格\": \"商务\",\n    \"鞋头形状\": \"尖头\",\n    \"鞋带\": \"有\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一款黑色男士系带皮鞋，符合描述中的‘简约商务风格’，无明显违规信息。\"\n}"}
{"image_file": "product_01821.jpg", "image": "data/raw/images/product_01821.jpg", "prompt": "这款优雅的连衣裙采用高级丝绒材质，V领设计搭配修身剪裁，适合正式场合穿着，尽显女性魅力。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"丝绒\",\n    \"领型\": \"V领\",\n    \"袖型\": \"无袖\",\n    \"款式\": \"上衣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件黑色无袖上衣，但商品描述中称其为‘连衣裙’，存在品类描述不符的问题。根据视觉信息，该商品并非连衣裙，而是上衣，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"丝绒\",\n    \"领型\": \"V领\",\n    \"袖型\": \"无袖\",\n    \"款式\": \"上衣\",\n    \"下装搭配\": \"卡其色裤子\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中称其为‘连衣裙’，但图片显示的是一件上衣，未包含裙摆部分，属于描述与实物严重不符。\"\n}"}
{"image_file": "product_01879.jpg", "image": "data/raw/images/product_01879.jpg", "prompt": "淡紫色印花宽松短袖连衣裙", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"淡紫色\",\n    \"图案\": \"印花\",\n    \"款式\": \"宽松\",\n    \"袖型\": \"短袖\",\n    \"领型\": \"圆领\",\n    \"长度\": \"中长款\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的为一件淡紫色印花宽松短袖连衣裙，符合描述内容，无违规元素。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"淡紫色\",\n    \"图案\": \"印花\",\n    \"款式\": \"宽松\",\n    \"袖长\": \"短袖\",\n    \"领型\": \"圆领\",\n    \"长度\": \"中长款\",\n    \"材质\": \"未明确\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为普通女装连衣裙，图案为传统印花设计，颜色为淡紫色，无违规元素，符合平台正常商品发布规范。\"\n}"}
{"image_file": "product_00806.jpg", "image": "data/raw/images/product_00806.jpg", "prompt": "这款深棕色皮质挎包，一抹白即显高贵气质，包治百病的时尚选择，7天瘦10斤的轻盈体验", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"dark brown\",\n    \"material\": \"leather\",\n    \"style\": \"shoulder bag\",\n    \"features\": [\"tassel\", \"adjustable strap\", \"gold-tone hardware\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘一抹白即显高贵气质’、‘包治百病的时尚选择’、‘7天瘦10斤的轻盈体验’等夸大宣传和医疗效果暗示，违反广告法及平台关于虚假宣传的规定。\"\n}", "rejected": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"皮质\",\n    \"款式\": \"挎包\",\n    \"肩带\": \"单肩长肩带\",\n    \"细节\": \"金属五金件、流苏装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘一抹白即显高贵气质’‘包治百病的时尚选择’‘7天瘦10斤的轻盈体验’等虚假宣传用语，涉及夸大功效和医疗效果，违反平台广告合规规范。\"\n}"}
{"image_file": "product_01710.jpg", "image": "data/raw/images/product_01710.jpg", "prompt": "红色纯棉吊带背心", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"吊带背心\",\n    \"材质\": \"纯棉\",\n    \"领型\": \"方领\",\n    \"肩带\": \"细肩带\",\n    \"图案\": \"无图案\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为一件红色纯棉吊带背心，符合描述内容，无违规元素。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"吊带背心\",\n    \"材质\": \"纯棉\",\n    \"领型\": \"方领\",\n    \"肩带\": \"细肩带\",\n    \"适用性别\": \"女性\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为红色纯棉吊带背心，无违规内容或不当信息。\"\n}"}
{"image_file": "product_01069.jpg", "image": "data/raw/images/product_01069.jpg", "prompt": "深蓝色拼接白色运动短袖T恤", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色与白色拼接\",\n    \"款式\": \"短袖T恤\",\n    \"品牌标识\": \"Puma标志\",\n    \"材质\": \"运动面料（推测）\",\n    \"设计元素\": \"斜向白色条纹拼接\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一件深蓝色与白色拼接的运动短袖T恤，带有Puma品牌标识，符合常规运动服饰规范，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色与白色拼接\",\n    \"款式\": \"短袖T恤\",\n    \"品牌标识\": \"Puma标志\",\n    \"材质\": \"运动面料（视觉推断）\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是正规品牌Puma的运动T恤，无违法不良信息，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00915.jpg", "image": "data/raw/images/product_00915.jpg", "prompt": "100%纯棉男士格子衬衫，经典休闲款，深色系格纹设计，舒适透气", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深紫色与黑色格纹\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"长袖衬衫\",\n    \"设计元素\": \"经典格子图案，胸前单口袋，翻领设计\",\n    \"袖口状态\": \"卷起\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合描述中的‘100%纯棉男士格子衬衫’，颜色为深色系格纹，款式为经典休闲款，无违规内容或虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深紫色与黑色格纹\",\n    \"款式\": \"长袖衬衫\",\n    \"材质\": \"纯棉\",\n    \"设计\": \"经典格子图案，胸前单口袋，翻领设计\",\n    \"袖口\": \"卷起\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示为男士格子衬衫，视觉属性与描述一致（如深色系格纹、长袖、翻领、胸前口袋等），未发现夸大宣传或虚假信息。\"\n}"}
{"image_file": "product_01711.jpg", "image": "data/raw/images/product_01711.jpg", "prompt": "黑色短袖男士衬衫，简约商务休闲款", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"前襟单排纽扣\",\n    \"口袋\": \"左侧胸前有一个贴袋\",\n    \"袖口\": \"卷边设计，带有装饰性缝线\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"图案\": \"无图案，纯色\",\n    \"品牌标识\": \"右下角有小logo\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士短袖衬衫，颜色为黑色，款式简约，符合商务休闲定位，无违规内容或敏感元素。\"\n}", "rejected": "{\n  \"category\": \"男装-衬衫\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖\",\n    \"领型\": \"翻领\",\n    \"袖口设计\": \"可调节扣眼\",\n    \"胸前口袋\": \"单侧斜插袋\",\n    \"材质\": \"棉质或混纺面料（视觉推断）\",\n    \"版型\": \"修身剪裁\",\n    \"装饰细节\": \"左下角有品牌小标\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士短袖衬衫，无违禁内容或不当标识。图片清晰，展示正面全身视角，符合平台服装类商品上传规范。\"\n}"}
{"image_file": "product_01495.jpg", "image": "data/raw/images/product_01495.jpg", "prompt": "这款男士短袖衬衫采用100%纯棉材质，舒适透气，适合日常穿着。", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"浅紫色\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"纯棉\",\n    \"纽扣\": \"白色纽扣\",\n    \"口袋\": \"左侧胸前有一个贴袋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为一件浅紫色男士短袖衬衫，材质标注为100%纯棉，符合日常穿着的描述，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅紫色\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"纯棉\",\n    \"纽扣\": \"白色纽扣\",\n    \"口袋\": \"左侧有一个胸袋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，未发现违规内容。该男士短袖衬衫为浅紫色，短袖设计，正面有白色纽扣及左侧胸袋，材质标注为100%纯棉，符合日常穿着描述，无夸大宣传或虚假信息。\"\n}"}
{"image_file": "product_01839.jpg", "image": "data/raw/images/product_01839.jpg", "prompt": "浅米色无袖V领纽扣连衣裙配腰带", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"浅米色\",\n    \"款式\": \"无袖V领\",\n    \"细节\": \"前排纽扣设计，配腰带\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"长度\": \"短款连衣裙\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，无违规内容，符合平台对服装类商品的发布规范。\"\n}", "rejected": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"浅米色\",\n    \"款式\": \"无袖V领\",\n    \"设计元素\": [\"前排纽扣\", \"腰带\", \"肩部装饰扣\"],\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"长度\": \"短款，及膝以上\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服饰类目商品，未涉及违禁内容、虚假宣传或侵权标识。图片展示清晰，符合平台合规标准。\"\n}"}
{"image_file": "product_02092.jpg", "image": "data/raw/images/product_02092.jpg", "prompt": "红色高帮帆布鞋，饰有金色兔子图案和黑色兔影印花", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"高帮\",\n    \"材质\": \"帆布\",\n    \"图案\": \"金色兔子、黑色兔影印花\",\n    \"品牌标识\": \"PLAYBOY\",\n    \"鞋带\": \"白色\",\n    \"鞋底\": \"黑色橡胶，带有黄色边缘\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中包含'PLAYBOY'品牌标识及标志性兔子图案，属于知名品牌IP元素，未经授权使用可能构成商标侵权。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"red\",\n    \"material\": \"canvas\",\n    \"style\": \"high-top\",\n    \"laces\": \"white\",\n    \"eyelets\": \"gold\",\n    \"sole\": \"black with yellow trim\",\n    \"design\": \"golden bunny and black bunny silhouettes\",\n    \"brand_tag\": \"PLAYBOY\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图案包含'PLAYBOY'品牌标识及兔子形象，属于未经授权的知名IP图案使用，可能构成版权侵权。\"\n}"}
{"image_file": "product_00649.jpg", "image": "data/raw/images/product_00649.jpg", "prompt": "最新款PUMA黑色T恤，超低价入手，全网最低价，绝对顶级品质，潮流必备！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"PUMA品牌标志，黄色和蓝色渐变字体，下方有'SINCE 1948'字样\",\n    \"材质\": \"棉质（推测）\",\n    \"适用人群\": \"男性\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的T恤印有PUMA品牌标志，但该商品描述中声称‘最新款PUMA黑色T恤’且‘绝对顶级品质’，存在可能的假冒或未经授权使用品牌标识的风险。根据平台规则，未经品牌授权的商品不得以品牌名义进行宣传，因此该商品涉嫌侵犯品牌知识产权。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"黑色\",\n    \"brand_logo\": \"PUMA\",\n    \"design_style\": \"潮流印花\",\n    \"material\": \"棉质（推测）\",\n    \"sleeve_type\": \"短袖\",\n    \"neckline\": \"圆领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的T恤印有‘PUMA’品牌标识，但该标识并非PUMA官方正品标志，存在仿冒知名品牌的风险。同时，商品描述中使用‘全网最低价’、‘绝对顶级品质’等夸大宣传用语，涉嫌虚假宣传，违反平台广告规范。\"\n}"}
{"image_file": "product_00904.jpg", "image": "data/raw/images/product_00904.jpg", "prompt": "深蓝色男士长袖衬衫，简约商务休闲款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"袖口\": \"卷起\",\n    \"纽扣\": \"深色纽扣\",\n    \"图案\": \"左胸有绿色小标志\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"搭配\": \"搭配浅蓝色牛仔裤\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合服装类目规范，无违规内容。视觉属性如颜色、款式、标志等均正常，未发现虚假宣传或侵权元素。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"袖口\": \"卷起\",\n    \"胸前口袋\": \"有\",\n    \"品牌标识\": \"左胸有绿色小标志\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"适用场景\": \"商务休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是常规男士衬衫，无不当内容或违规元素，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00658.jpg", "image": "data/raw/images/product_00658.jpg", "prompt": "最新款超低价Ducati男士T恤，全网最低价绝对顶级品质，限量发售不容错过！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"Ducati Meccanica标志\",\n    \"材质\": \"棉质（推测）\",\n    \"品牌\": \"Ducati\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的T恤带有'Ducati Meccanica'品牌标识，属于知名品牌授权产品。该商品描述中使用'最新款超低价''全网最低价''绝对顶级品质''限量发售'等宣传用语，存在夸大宣传和可能误导消费者的风险，违反了平台关于虚假宣传和品牌合规的相关规定。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"短袖T恤\",\n    \"品牌标志\": \"Ducati Meccanica\",\n    \"图案位置\": \"左胸\",\n    \"材质\": \"棉质（推测）\",\n    \"袖口\": \"短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的T恤印有'Ducati Meccanica'品牌标志，属于知名品牌商标，未经授权使用可能构成侵权。同时，商品描述中使用‘最新款’‘全网最低价’‘绝对顶级品质’等宣传用语涉嫌虚假宣传和夸大其词，违反平台广告规范。\"\n}"}
{"image_file": "product_02174.jpg", "image": "data/raw/images/product_02174.jpg", "prompt": "NIKE同款商务皮鞋，小香风原单设计，百搭男士正装鞋", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"设计风格\": \"商务休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'NIKE同款'涉嫌虚假宣传和品牌冒用，图片中未见任何NIKE品牌标识，且实际为普通商务皮鞋，与知名品牌关联构成误导性宣传。\"\n}", "rejected": "{\n  \"category\": \"男士皮鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带商务正装鞋\",\n    \"设计风格\": \"简约经典\",\n    \"鞋头形状\": \"尖头\",\n    \"鞋跟高度\": \"低跟\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'NIKE同款'存在品牌误导性，涉嫌虚假宣传和侵犯品牌权益；同时'小香风原单设计'表述模糊且可能涉及仿冒或未经授权的高端品牌元素，违反平台关于品牌合规与真实描述的规定。\"\n}"}
{"image_file": "product_00684.jpg", "image": "data/raw/images/product_00684.jpg", "prompt": "白色与蓝色拼接的缓震跑鞋，网面透气设计", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"白色与蓝色拼接\",\n    \"材质\": \"网面透气设计\",\n    \"款式\": \"缓震跑鞋\",\n    \"品牌标识\": \"可见品牌标志\",\n    \"鞋带\": \"蓝色鞋带\",\n    \"鞋底\": \"蓝色中底，黑色外底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一款白色与蓝色拼接的缓震跑鞋，具备网面透气设计，符合运动鞋类目规范，无违规信息。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"白色与蓝色拼接\",\n    \"材质\": \"网面透气设计\",\n    \"款式\": \"缓震跑鞋\",\n    \"品牌标识\": \"可见'OMNIRIDE+'字样及品牌标志\",\n    \"鞋带\": \"蓝色鞋带\",\n    \"鞋底\": \"蓝色中底与黑色外底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，未发现违规元素。商品为普通运动鞋，无侵权、违禁或不当内容。视觉属性如颜色、材质和品牌标识均符合描述，未违反平台规范。\"\n}"}
{"image_file": "product_01088.jpg", "image": "data/raw/images/product_01088.jpg", "prompt": "浅蓝色牛仔布短袖衬衫，胸前带装饰口袋", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前带装饰性口袋\",\n    \"纽扣\": \"前襟纽扣设计\",\n    \"袖口\": \"卷边袖口\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为常规女装衬衫，无违规内容或敏感元素。视觉属性与描述一致，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"女装-衬衫\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"短袖\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前带装饰口袋，有金属铆钉装饰\",\n    \"纽扣\": \"前襟蓝色纽扣\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规服饰类目，无违规信息。图片清晰，商品属性与描述一致，未发现虚假宣传、侵权或敏感内容。\"\n}"}
{"image_file": "product_02260.jpg", "image": "data/raw/images/product_02260.jpg", "prompt": "小香风原单男士条纹衬衫，高级感十足，LV平替必备单品", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色与白色条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"未明确，视觉上为棉质或混纺\",\n    \"图案\": \"竖条纹\",\n    \"搭配\": \"黑色西裤、黑色皮带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'小香风原单'和'LV平替'等词汇，暗示与奢侈品牌（如LV）存在关联或替代关系，可能构成虚假宣传或误导消费者，违反平台关于禁止冒用知名品牌进行营销的规则。\"\n}", "rejected": "{\n  \"category\": \"男装-衬衫\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色与白色条纹\",\n    \"款式\": \"长袖正装衬衫\",\n    \"领型\": \"标准尖领\",\n    \"材质\": \"未明确，但视觉上为棉质或混纺\",\n    \"图案\": \"竖条纹\",\n    \"纽扣\": \"白色纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘小香风’和‘LV平替’等词汇，暗示与奢侈品牌（如Chanel、Louis Vuitton）的关联，可能构成品牌侵权或误导性宣传。尽管图片中的衬衫本身无明显品牌标识，但描述内容易使消费者误认为该商品与高端奢侈品牌有关联，违反了平台关于虚假宣传和品牌冒用的规则。\"\n}"}
{"image_file": "product_02491.jpg", "image": "data/raw/images/product_02491.jpg", "prompt": "这款优雅的紫色连衣裙采用轻盈雪纺材质，适合夏季宴会穿着，展现女性柔美气质。", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"color\": \"粉色\",\n    \"material\": \"棉质或混纺\",\n    \"style\": \"长袖衬衫\",\n    \"collar_type\": \"标准领\",\n    \"buttons\": \"白色纽扣\",\n    \"pocket\": \"左侧胸袋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士粉色长袖衬衫，而商品描述中却提及‘紫色连衣裙’和‘女性柔美气质’，存在严重的图文不符，且品类与描述性别不一致，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"color\": \"粉色\",\n    \"type\": \"长袖衬衫\",\n    \"material\": \"棉质或混纺\",\n    \"collar\": \"标准领\",\n    \"buttons\": \"白色纽扣\",\n    \"pocket\": \"左侧胸袋\",\n    \"fit\": \"修身\"\n  },\n  \"violation\": true,\n  \"reason\": \"图片展示的是一件男性穿着的粉色长袖衬衫，而商品描述为‘紫色连衣裙’，存在严重品类与描述不符的情况，且描述中提及的女性连衣裙与图中男性服装不匹配，构成虚假宣传。\"\n}"}
{"image_file": "product_02423.jpg", "image": "data/raw/images/product_02423.jpg", "prompt": "男士蓝灰黄格纹长袖衬衫", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝、灰、黄\",\n    \"图案\": \"格纹\",\n    \"款式\": \"长袖衬衫\",\n    \"材质\": \"棉质（推测）\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"长袖（卷起）\",\n    \"纽扣\": \"前襟纽扣\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示男士格纹长袖衬衫，无违规内容或敏感信息，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色、灰色、黄色\",\n    \"图案\": \"格纹\",\n    \"款式\": \"长袖衬衫\",\n    \"材质\": \"棉质（视觉推断）\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"前排纽扣\",\n    \"袖长\": \"长袖（卷起至肘部）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为常规男士格纹衬衫，无违规内容或敏感元素，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00359.jpg", "image": "data/raw/images/product_00359.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"环保主题印花，包含回收标志、蝴蝶、文字标语\",\n    \"文字内容\": \"RECYCLE, WAR IS NOT HEALING FOR CHILDREN AND OTHER LIVING THINGS, FLYING MACHINE\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的T恤印有‘WAR IS NOT HEALING FOR CHILDREN AND OTHER LIVING THINGS’等政治敏感性或争议性言论，可能引发不良社会影响，违反平台关于商品内容合规性的规定。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"环保主题印花，包含回收标志、蝴蝶、文字标语\",\n    \"文字内容\": \"RECYCLE, WAR IS NOT HEALING FOR CHILDREN AND OTHER LIVING THINGS, FLYING MACHINE\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的T恤印有‘WAR IS NOT HEALING FOR CHILDREN AND OTHER LIVING THINGS’等敏感政治或社会立场相关标语，可能涉及不当宣传或引发争议，不符合平台关于商品内容合规的要求。\"\n}"}
{"image_file": "product_02279.jpg", "image": "data/raw/images/product_02279.jpg", "prompt": "小香风原单男士条纹衬衫，LV平替高端商务款，气质优雅显贵气", "chosen": "{\n  \"category\": \"男装-衬衫\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色与白色竖条纹\",\n    \"款式\": \"长袖正装衬衫\",\n    \"领型\": \"标准尖领\",\n    \"材质\": \"棉质或混纺面料\",\n    \"搭配\": \"深蓝色西裤、黑色皮带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'小香风原单'和'LV平替'等词汇，暗示与奢侈品牌（如LV）存在关联或替代关系，可能构成虚假宣传或误导消费者，违反平台关于品牌冒用及不当营销的规则。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色与白色条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺面料\",\n    \"图案\": \"细竖条纹\",\n    \"穿着搭配\": \"深蓝色西裤、黑色皮带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'LV平替'属于未经授权的品牌暗示，可能构成品牌侵权及误导性宣传；同时'小香风原单'涉及虚假宣传和冒用奢侈品牌风格，违反电商平台关于商品真实性和品牌合规的规定。\"\n}"}
{"image_file": "product_01509.jpg", "image": "data/raw/images/product_01509.jpg", "prompt": "穿上这款神奇衬衫，包治百病，7天瘦10斤，一抹白，瞬间提升气质！", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"纽扣\": \"白色纽扣\",\n    \"口袋\": \"左侧胸前有一个贴袋\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"搭配\": \"黑色皮带和深色西裤\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含虚假宣传内容，如'包治百病'、'7天瘦10斤'等，属于夸大功效的医疗或健康类宣称，违反了广告法及电商平台关于商品描述真实性的规定。该商品为普通衬衫，不具备所述功能。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"color\": \"深蓝色\",\n    \"material\": \"棉质或混纺面料\",\n    \"style\": \"长袖衬衫\",\n    \"buttons\": \"白色纽扣\",\n    \"pocket\": \"左侧胸前有一个贴袋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’、‘7天瘦10斤’等夸大和虚假宣传内容，属于违反广告法的绝对化用语及疗效承诺，且与实际商品属性（普通衬衫）严重不符。\"\n}"}
{"image_file": "product_00764.jpg", "image": "data/raw/images/product_00764.jpg", "prompt": "酒红色真皮手提包，配金色五金件，经典托特款式", "chosen": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"酒红色\",\n    \"材质\": \"真皮\",\n    \"五金件颜色\": \"金色\",\n    \"款式\": \"托特包\",\n    \"缝线\": \"黄色缝线\",\n    \"品牌标识\": \"正面有方形金属牌，刻有字母'C'\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为酒红色真皮手提包，配金色五金件，符合经典托特款式特征，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"酒红色\",\n    \"材质\": \"真皮\",\n    \"五金件\": \"金色\",\n    \"款式\": \"托特包\",\n    \"缝线\": \"橙黄色对比缝线\",\n    \"装饰\": \"正面有金属方形徽标\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示酒红色真皮手提包，配金色五金件和经典托特款式，无违规内容。\"\n}"}
{"image_file": "product_00484.jpg", "image": "data/raw/images/product_00484.jpg", "prompt": "国风刺绣上衣，传统工艺", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"橙色表盘，黑色表带，银色表壳\",\n    \"品牌\": \"Carrera\",\n    \"款式\": \"运动型计时码表\",\n    \"材质\": \"橡胶表带，金属表壳\",\n    \"功能\": \"三眼计时，日期显示，测速刻度\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款Carrera品牌的运动手表，而商品描述为'国风刺绣上衣，传统工艺'，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"color\": \"橙色表盘，黑色表带\",\n    \"material\": \"金属表壳，橡胶表带\",\n    \"style\": \"运动风格，计时码表\",\n    \"brand\": \"Carrera\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款手表，而商品描述为‘国风刺绣上衣，传统工艺’，图文严重不符，属于虚假宣传。\"\n}"}
{"image_file": "product_02377.jpg", "image": "data/raw/images/product_02377.jpg", "prompt": "酒红色棉质刺绣连衣裙，七分袖设计，胸前彩色图案装饰", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"酒红色\",\n    \"材质\": \"棉质\",\n    \"款式\": \"连衣裙\",\n    \"袖长\": \"七分袖\",\n    \"装饰\": \"胸前彩色刺绣图案\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示完整服装细节，无违规内容。视觉属性如酒红色、七分袖、胸前彩色刺绣等均与描述一致，未发现虚假宣传或敏感元素。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"酒红色\",\n    \"材质\": \"棉质\",\n    \"款式\": \"连衣裙\",\n    \"袖长\": \"七分袖\",\n    \"装饰\": \"胸前彩色刺绣图案\",\n    \"领型\": \"圆领\",\n    \"长度\": \"及膝\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，未发现违规内容。该连衣裙为酒红色棉质材质，具有七分袖和胸前彩色刺绣装饰，符合描述内容，无虚假宣传或不良元素。\"\n}"}
{"image_file": "product_01452.jpg", "image": "data/raw/images/product_01452.jpg", "prompt": "原价999直降到99，限时清仓甩卖！条纹男士衬衫，时尚百搭，抢购从速！", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"紫色、白色、绿色条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"图案\": \"竖条纹\",\n    \"材质\": \"未明确，推测为棉或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，无违规内容。商品为普通男士条纹衬衫，符合平台销售规范，未发现虚假宣传或侵权问题。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"gender\": \"男\",\n    \"type\": \"衬衫\",\n    \"pattern\": \"竖条纹\",\n    \"colors\": [\"紫色\", \"白色\", \"绿色\"],\n    \"sleeve_length\": \"长袖\",\n    \"collar_style\": \"标准翻领\",\n    \"buttons\": \"黑色纽扣\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规男士条纹衬衫，无违规图案、文字或敏感元素，符合平台商品发布规范。\"\n}"}
{"image_file": "product_02548.jpg", "image": "data/raw/images/product_02548.jpg", "prompt": "最新款黑白格纹连衣裙，超低价秒杀，全网最低价，绝对顶级时尚单品！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑白灰\",\n    \"图案\": \"格纹\",\n    \"款式\": \"连衣裙\",\n    \"袖长\": \"七分袖\",\n    \"领型\": \"圆领\",\n    \"腰部设计\": \"系带收腰\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规女装连衣裙，无违规内容。描述中‘超低价秒杀’‘全网最低价’等宣传用语虽具营销性质，但未发现虚假宣传或违法信息，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑白灰\",\n    \"图案\": \"格纹\",\n    \"款式\": \"连衣裙\",\n    \"袖长\": \"七分袖\",\n    \"腰部设计\": \"系带收腰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'全网最低价'、'绝对顶级时尚单品'等夸大性宣传用语，属于违反广告法的虚假宣传，且未提供价格对比依据。\"\n}"}
{"image_file": "product_01974.jpg", "image": "data/raw/images/product_01974.jpg", "prompt": "绿色格纹短袖衬衫男款", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"绿色格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"格子\",\n    \"材质\": \"棉质（推测）\",\n    \"品牌标识\": \"左胸有小标签\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为常规男款短袖衬衫，无违规内容或敏感信息，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"绿色与白色格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"格子\",\n    \"性别\": \"男款\",\n    \"材质\": \"棉质或混纺（视觉推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男款短袖格纹衬衫，无违规内容。图片展示清晰，符合平台对服饰类商品的上传规范。\"\n}"}
{"image_file": "product_02401.jpg", "image": "data/raw/images/product_02401.jpg", "prompt": "玫红色印花棉质女士长袖上衣", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"玫红色\",\n    \"图案\": \"金色印花\",\n    \"材质\": \"棉质\",\n    \"袖长\": \"七分袖\",\n    \"领型\": \"V领\",\n    \"款式\": \"宽松上衣\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，为玫红色印花棉质女士上衣，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"玫红色\",\n    \"图案\": \"金色印花\",\n    \"材质\": \"棉质\",\n    \"袖长\": \"七分袖\",\n    \"领型\": \"V领\",\n    \"款式\": \"宽松直筒\",\n    \"装饰\": \"前襟珠饰\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述基本一致，为玫红色印花棉质女士上衣，实际为七分袖而非长袖，但属于合理描述差异，不构成违规。\"\n}"}
{"image_file": "product_00251.jpg", "image": "data/raw/images/product_00251.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红蓝格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质\",\n    \"设计元素\": \"胸前双口袋，纽扣开合\",\n    \"领型\": \"翻领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为一件红蓝格纹短袖衬衫，符合描述中的‘纯棉休闲上衣’，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红蓝格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质\",\n    \"设计元素\": \"胸前双口袋、纽扣开合\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一件红蓝格纹短袖衬衫，具备常见的休闲服饰特征，材质描述为纯棉，符合舒适透气的属性。未发现违规内容，如不当图案、文字或敏感信息，且商品展示正常，无夸大宣传或误导性信息。\"\n}"}
{"image_file": "product_00755.jpg", "image": "data/raw/images/product_00755.jpg", "prompt": "黑色表盘黄色刻度的Carrera计时腕表，钢带与碳纤维纹理表带组合", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表盘颜色\": \"黑色\",\n    \"刻度颜色\": \"黄色\",\n    \"品牌\": \"Carrera\",\n    \"表壳材质\": \"不锈钢\",\n    \"表带类型\": \"钢带与碳纤维纹理表带组合\",\n    \"功能\": \"计时腕表\",\n    \"表盘设计\": \"多指针、小表盘布局，带有测速仪（Tachymeter）刻度\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，未发现违规内容。表盘为黑色，刻度为黄色，品牌标识清晰，表带为钢与碳纤维纹理组合，符合描述。无仿冒或侵权标识，符合平台合规要求。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"black and yellow\",\n    \"dial\": \"chronograph with tachymeter\",\n    \"brand\": \"Carrera\",\n    \"band_material\": \"steel and carbon fiber texture\",\n    \"case_shape\": \"octagonal\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，表盘为黑色配黄色刻度，品牌标识为'Carrera'，表带为钢制与碳纤维纹理组合，无违规信息。\"\n}"}
{"image_file": "product_00476.jpg", "image": "data/raw/images/product_00476.jpg", "prompt": "百搭连衣裙，适合日常出行", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色和黄色\",\n    \"材质\": \"网布、合成材料\",\n    \"款式\": \"跑步鞋\",\n    \"品牌\": \"Reebok\",\n    \"设计特点\": \"透气网面、黄色鞋带、中底缓震结构\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双运动鞋，而商品描述为‘百搭连衣裙，适合日常出行’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色和黄色\",\n    \"材质\": \"网眼布、合成材料\",\n    \"款式\": \"运动鞋\",\n    \"品牌\": \"Reebok\",\n    \"设计特征\": \"透气网面、黄色鞋带、中底缓震系统\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是一双运动鞋，但描述为‘百搭连衣裙，适合日常出行’，存在严重的图文不符，违反了平台商品信息真实性的规定。\"\n}"}
{"image_file": "product_00935.jpg", "image": "data/raw/images/product_00935.jpg", "prompt": "Puma品牌蓝白格纹织物表带腕表，银色金属表壳，白色表盘配黑色数字刻度", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"strap_material\": \"织物\",\n    \"strap_pattern\": \"蓝白格纹\",\n    \"case_material\": \"金属\",\n    \"case_color\": \"银色\",\n    \"dial_color\": \"白色\",\n    \"hour_markers\": \"黑色数字刻度\",\n    \"logo\": \"Puma跳跃猫标志\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，未发现违规内容。表带为蓝白格纹织物，表壳为银色金属，表盘为白色并带有黑色数字刻度，符合品牌标识规范。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"band_material\": \"织物\",\n    \"band_pattern\": \"蓝白格纹\",\n    \"case_material\": \"金属\",\n    \"case_color\": \"银色\",\n    \"dial_color\": \"白色\",\n    \"hour_marks\": \"黑色数字\",\n    \"logo\": \"Puma跃动猫形标志\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，表带为蓝白格纹织物，表壳为银色金属材质，表盘为白色并带有黑色数字刻度，品牌标志清晰可见，无违规内容。\"\n}"}
{"image_file": "product_00381.jpg", "image": "data/raw/images/product_00381.jpg", "prompt": "时尚秋冬外套，多色可选", "chosen": "{\n  \"category\": \"童装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"猴子头像\",\n    \"文字\": \"Cheeky Monkey\",\n    \"材质\": \"棉质\",\n    \"款式\": \"短袖T恤\",\n    \"品牌\": \"BeBorn\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为婴儿短袖T恤，而商品描述为‘时尚秋冬外套’，存在品类与描述严重不符的问题。\"\n}", "rejected": "{\n  \"category\": \"children's clothing\",\n  \"attributes\": {\n    \"color\": \"white\",\n    \"design\": \"Cheeky Monkey graphic with cartoon monkey face\",\n    \"text\": \"Cheeky Monkey in red cursive font\",\n    \"brand\": \"BeBorn by BeDolls\",\n    \"size\": \"12M\",\n    \"material\": \"cotton (inferred)\",\n    \"style\": \"short sleeve t-shirt\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件婴儿短袖T恤，与描述中的‘时尚秋冬外套’严重不符。商品实际为夏季或春秋穿着的短袖上衣，并非外套，存在虚假描述问题。\"\n}"}
{"image_file": "product_01985.jpg", "image": "data/raw/images/product_01985.jpg", "prompt": "这款时尚连衣裙采用清新绿色格纹设计，适合春夏季节穿着，展现优雅气质。", "chosen": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"绿色与白色格纹\",\n    \"款式\": \"长袖衬衫，袖口卷起\",\n    \"材质\": \"棉质或棉混纺\",\n    \"设计细节\": \"胸前有一个带纽扣的口袋，领口为标准翻领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士格纹衬衫，而商品描述中称其为‘时尚连衣裙’，存在严重品类与描述不符的问题。实际商品并非连衣裙，属于男性上衣类别，描述具有误导性。\"\n}", "rejected": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"绿色与白色格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质或混纺\",\n    \"设计\": \"翻领、胸前口袋、纽扣开合\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为男士格子短袖衬衫，而商品描述中称其为‘时尚连衣裙’，品类与实际不符，存在误导性描述。\"\n}"}
{"image_file": "product_02079.jpg", "image": "data/raw/images/product_02079.jpg", "prompt": "黑色拼蓝色PLAYBOY低帮休闲鞋", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色为主，蓝色点缀\",\n    \"品牌\": \"PLAYBOY\",\n    \"款式\": \"低帮休闲鞋\",\n    \"材质\": \"皮革与合成材料拼接\",\n    \"设计元素\": \"侧面蓝色条纹、鞋舌和鞋侧印有'PLAYBOY'字样、鞋底前部有蓝色兔子标志\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示为PLAYBOY品牌的低帮休闲鞋，设计符合常规鞋类产品规范，未发现违规内容或敏感信息。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色为主，蓝色拼接\",\n    \"品牌\": \"PLAYBOY\",\n    \"款式\": \"低帮休闲鞋\",\n    \"材质\": \"皮革/合成革\",\n    \"设计元素\": \"侧边蓝色条纹、鞋跟处品牌标识、鞋底兔头标志\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为PLAYBOY品牌的低帮休闲鞋，外观符合常规运动鞋设计，无违禁内容或违规图案。品牌标识清晰，使用合规，未发现敏感或不当信息。\"\n}"}
{"image_file": "product_01036.jpg", "image": "data/raw/images/product_01036.jpg", "prompt": "蓝白格纹短袖衬衫女款", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前双口袋\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"袖长\": \"短袖\",\n    \"版型\": \"修身\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合女装类目规范，无违规内容。蓝白格纹设计、短袖翻领款式及胸前口袋等视觉属性均正常，未发现虚假宣传或敏感元素。\"\n}", "rejected": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前双口袋\",\n    \"袖长\": \"短袖\",\n    \"材质\": \"棉质或棉混纺（推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一款蓝白格纹短袖女式衬衫，无违规内容，符合平台商品发布规范。\"\n}"}
{"image_file": "product_01444.jpg", "image": "data/raw/images/product_01444.jpg", "prompt": "这款白色针织开衫采用100%纯棉材质，柔软舒适，适合秋冬穿着", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"针织\",\n    \"款式\": \"开衫\",\n    \"领型\": \"高领\",\n    \"纽扣\": \"深色圆形纽扣\",\n    \"口袋\": \"两侧有贴袋\",\n    \"袖长\": \"长袖\",\n    \"长度\": \"中长款\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，未发现虚假宣传或违规内容。商品为白色针织开衫，视觉上符合纯棉材质的外观特征，且描述中提及的柔软舒适、适合秋冬穿着等属性合理，无夸大或误导性信息。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"针织\",\n    \"款式\": \"开衫\",\n    \"领型\": \"高领\",\n    \"纽扣\": \"深色圆形纽扣\",\n    \"口袋\": \"两侧有贴袋\",\n    \"袖型\": \"长袖\",\n    \"长度\": \"中长款\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为白色针织开衫，材质符合描述中的‘100%纯棉’特性，无明显违规内容。\"\n}"}
{"image_file": "product_02465.jpg", "image": "data/raw/images/product_02465.jpg", "prompt": "卡其色修身男士休闲裤", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"卡其色\",\n    \"款式\": \"修身休闲裤\",\n    \"材质\": \"棉质或混纺面料\",\n    \"搭配\": \"白色衬衫、棕色皮鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是卡其色修身男士休闲裤，符合描述内容，无违规信息。\"\n}", "rejected": "{\n  \"category\": \"男装-裤子\",\n  \"attributes\": {\n    \"颜色\": \"卡其色\",\n    \"款式\": \"修身休闲裤\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"设计细节\": \"直筒剪裁，前部有口袋，无明显装饰\",\n    \"搭配\": \"搭配白色衬衫和棕色皮鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示卡其色修身男士休闲裤，未发现违规内容，符合平台商品展示规范。\"\n}"}
{"image_file": "product_00962.jpg", "image": "data/raw/images/product_00962.jpg", "prompt": "黑色无袖针织开衫，V领设计，前排纽扣装饰", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"无袖开衫\",\n    \"领型\": \"V领\",\n    \"材质\": \"针织\",\n    \"装饰\": \"前排纽扣\",\n    \"图案\": \"上半部分有镂空花纹\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示完整，无违规内容。服装为常规女装款式，未涉及敏感元素或不当信息。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"无袖\",\n    \"领型\": \"V领\",\n    \"材质\": \"针织\",\n    \"装饰\": \"前排纽扣\",\n    \"设计细节\": \"上半部分有镂空花纹编织\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合服装类目规范，无违规内容或敏感信息。\"\n}"}
{"image_file": "product_01571.jpg", "image": "data/raw/images/product_01571.jpg", "prompt": "原价999直降到99，限时清仓甩卖！黑色高弹休闲裤，舒适百搭，速抢！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"高弹休闲裤\",\n    \"材质\": \"针织/弹性面料\",\n    \"版型\": \"修身\",\n    \"裤脚设计\": \"堆叠褶皱\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规黑色高弹休闲裤，无违规内容或敏感信息，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"高弹休闲裤\",\n    \"材质\": \"看起来为弹性针织面料\",\n    \"版型\": \"修身，束脚设计\",\n    \"穿着状态\": \"模特穿着展示\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一条黑色高弹休闲裤，无违规内容或不当信息。商品描述中促销信息（如原价999降至99）虽存在价格宣传，但未发现虚假或误导性表述，符合一般电商平台规则。\"\n}"}
{"image_file": "product_01813.jpg", "image": "data/raw/images/product_01813.jpg", "prompt": "小香风原单高跟凉鞋，LV平替款，优雅百搭显气质", "chosen": "{\n  \"category\": \"女鞋\",\n  \"attributes\": {\n    \"颜色\": \"灰色与黑色\",\n    \"材质\": \"亮面漆皮与织物\",\n    \"款式\": \"交叉带高跟凉鞋\",\n    \"鞋跟类型\": \"粗跟\",\n    \"鞋头样式\": \"露趾\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'小香风原单'、'LV平替款'等表述，涉嫌虚假宣传和攀附知名品牌，易误导消费者，违反平台关于禁止冒用或暗示知名品牌的规则。\"\n}", "rejected": "{\n  \"category\": \"鞋履\",\n  \"attributes\": {\n    \"颜色\": \"灰色与黑色\",\n    \"材质\": \"亮面人造革、织物带\",\n    \"款式\": \"中跟凉鞋\",\n    \"设计特征\": \"交叉绑带、后跟环绕带、粗跟\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'小香风原单'和'LV平替款'等词汇，暗示与奢侈品牌Chanel或Louis Vuitton存在关联，可能构成虚假宣传或侵犯品牌权益。图片中的鞋子无任何品牌标识，但描述易误导消费者认为其为高仿或关联产品，违反平台关于禁止冒用知名品牌名义的规则。\"\n}"}
{"image_file": "product_01953.jpg", "image": "data/raw/images/product_01953.jpg", "prompt": "这款白色T恤采用100%纯棉材质，舒适透气，适合日常穿着，时尚印花设计彰显个性。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"100%纯棉\",\n    \"款式\": \"短袖T恤\",\n    \"印花内容\": \"黑白人物肖像，上方文字'JOYFUL'，下方文字'FROM SUNSET TO SUNRISE Los Angeles'\",\n    \"设计风格\": \"时尚印花\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通印花T恤，图案为艺术化人物肖像与文字组合，未涉及违法不良信息、敏感政治内容或侵权标识，符合平台合规要求。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"100%纯棉\",\n    \"款式\": \"短袖T恤\",\n    \"印花图案\": \"黑白人物肖像，包含文字'JOYFUL'、'FROM SUNSET TO SUNRISE'、'Los Angeles'\",\n    \"设计风格\": \"时尚个性\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为普通服饰，印花内容为艺术风格的人物肖像和文字，未涉及政治、色情、暴力或侵权信息，符合平台合规标准。\"\n}"}
{"image_file": "product_01492.jpg", "image": "data/raw/images/product_01492.jpg", "prompt": "深蓝色竖条纹男士长袖衬衫", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"图案\": \"竖条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"未明确，推测为棉或混纺\",\n    \"适用性别\": \"男\",\n    \"穿着场景\": \"商务/正式\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一件深蓝色竖条纹男士长袖衬衫，符合描述内容，无虚假宣传或违规元素。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"图案\": \"竖条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"未明确显示，但视觉上似为棉或混纺面料\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一件深蓝色竖条纹男士长袖衬衫，与商品描述一致，无夸大宣传或误导性内容。\"\n}"}
{"image_file": "product_00339.jpg", "image": "data/raw/images/product_00339.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前双口袋\",\n    \"袖口\": \"可卷边设计\",\n    \"材质\": \"棉质或混纺面料\",\n    \"版型\": \"修身\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规男士衬衫，无违规内容。描述中‘显瘦神器’属于常见营销用语，未发现虚假宣传或夸大功效，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"灰绿色\",\n    \"款式\": \"长袖\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前双口袋\",\n    \"袖口\": \"可卷边设计\",\n    \"材质外观\": \"棉质或混纺面料\",\n    \"图案\": \"无图案\",\n    \"品牌标识\": \"左臂有小徽标\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规男式休闲衬衫，无敏感内容、不当广告或违规标识。商品描述中“显瘦神器”虽具宣传性，但未涉及虚假夸大或误导性内容，符合平台规范。\"\n}"}
{"image_file": "product_00780.jpg", "image": "data/raw/images/product_00780.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款时尚女包质感十足，简约百搭，错过不再！", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"beige\",\n    \"material\": \"leather-like\",\n    \"style\": \"hobo\",\n    \"features\": [\n      \"two front zippered pockets\",\n      \"adjustable shoulder strap\",\n      \"top handle\",\n      \"metal hardware\"\n    ]\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘原价999直降到99’等价格促销话术，涉嫌虚假宣传和价格欺诈，且未提供价格变动依据，违反平台关于价格真实性与广告合规的相关规定。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"beige\",\n    \"material\": \"leather-like\",\n    \"style\": \"hobo\",\n    \"features\": [\n      \"two front zippered pockets\",\n      \"metal hardware\",\n      \"adjustable shoulder strap\",\n      \"wide top opening\"\n    ]\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示实物，无虚假宣传或侵权元素。描述中价格促销信息与图片相符，未发现夸大宣传或违反平台规则的内容。\"\n}"}
{"image_file": "product_01818.jpg", "image": "data/raw/images/product_01818.jpg", "prompt": "黑色男士短袖Polo衫，左胸有绿色刺绣图案", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖Polo衫\",\n    \"性别\": \"男士\",\n    \"图案\": \"左胸绿色刺绣图案\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"白色纽扣\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士Polo衫，无违规内容。左胸绿色刺绣图案未涉及敏感或违法信息，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖Polo衫\",\n    \"性别\": \"男士\",\n    \"图案\": \"左胸绿色刺绣图案\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士Polo衫，无敏感图案或违规内容，符合平台规范。\"\n}"}
{"image_file": "product_01460.jpg", "image": "data/raw/images/product_01460.jpg", "prompt": "灰白细条纹长袖男士商务衬衫", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"灰白细条纹\",\n    \"款式\": \"长袖\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"适用场景\": \"商务正装\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规男士商务衬衫，无违规图案、文字或敏感元素，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"灰白细条纹\",\n    \"款式\": \"长袖\",\n    \"领型\": \"标准衬衫领\",\n    \"纽扣\": \"白色纽扣\",\n    \"袖口\": \"标准袖口\",\n    \"材质\": \"未明确标注，视觉上为棉质或混纺\",\n    \"适用场景\": \"商务正装\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示灰白细条纹长袖男士商务衬衫，符合描述内容，无违规元素。\"\n}"}
{"image_file": "product_02398.jpg", "image": "data/raw/images/product_02398.jpg", "prompt": "蓝色与粉色几何图案刺绣长袖女士库尔塔", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色与粉色\",\n    \"图案\": \"几何图案\",\n    \"款式\": \"长袖库尔塔\",\n    \"领口设计\": \"V形领口，带有刺绣装饰\",\n    \"袖口\": \"有刺绣边饰\",\n    \"材质\": \"看似棉质或混纺面料\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一件蓝色与粉色几何图案的女士库尔塔，无违规内容。服装设计符合文化服饰规范，未涉及敏感元素或不当信息。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色与粉色\",\n    \"图案\": \"几何图案\",\n    \"材质\": \"布料（视觉上为棉或混纺）\",\n    \"款式\": \"长袖库尔塔\",\n    \"装饰\": \"领口刺绣，袖口有花纹边饰\",\n    \"长度\": \"中长款，及臀部\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为女士传统服饰库尔塔，图案与颜色搭配符合常规审美，无违规内容。视觉属性中无低俗、侵权或敏感元素，符合平台合规要求。\"\n}"}
{"image_file": "product_01265.jpg", "image": "data/raw/images/product_01265.jpg", "prompt": "蓝白格纹短袖衬衫男款", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"双胸袋\",\n    \"材质\": \"棉质或混纺\",\n    \"图案\": \"格子图案\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为常规男款短袖格纹衬衫，无违规内容或敏感元素。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质或混纺\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"双胸口袋\",\n    \"图案\": \"格子图案\",\n    \"纽扣\": \"白色纽扣\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是蓝白格纹短袖男式衬衫，符合常规服装类商品规范，无违禁内容或违规标识。\"\n}"}
{"image_file": "product_01616.jpg", "image": "data/raw/images/product_01616.jpg", "prompt": "LV平替高腰牛仔裤，小香风原单设计，质感媲美大牌", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"直筒\",\n    \"设计风格\": \"简约休闲\",\n    \"细节\": \"浅色缝线，金属纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'LV平替'和'原单设计'等词汇，暗示与奢侈品牌Louis Vuitton存在关联或仿制关系，可能构成虚假宣传或侵犯品牌权益。图片中未见任何品牌标识，但描述易误导消费者认为该产品为大牌替代品，违反平台关于禁止冒用知名品牌进行营销的规定。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"深蓝色\",\n    \"material\": \"牛仔布\",\n    \"style\": \"高腰修身\",\n    \"seam_color\": \"浅色缝线\",\n    \"closure_type\": \"纽扣+拉链\",\n    \"fit\": \"直筒\",\n    \"brand_label\": \"无明显品牌标识\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'LV平替'和'小香风原单设计'等词汇，暗示与奢侈品牌Louis Vuitton及Chanel存在关联或模仿关系，易引发消费者误解，涉嫌虚假宣传和品牌蹭热度，违反平台关于禁止未经授权使用知名品牌名称及风格进行引流的规定。\"\n}"}
{"image_file": "product_00999.jpg", "image": "data/raw/images/product_00999.jpg", "prompt": "绿色男士短袖Polo衫，领口与袖口饰有浅色条纹，左胸绣有彩色图案", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"绿色\",\n    \"款式\": \"短袖Polo衫\",\n    \"领口设计\": \"浅色条纹装饰\",\n    \"袖口设计\": \"浅色条纹装饰\",\n    \"图案位置\": \"左胸\",\n    \"图案类型\": \"彩色刺绣图案\",\n    \"材质\": \"棉质或混纺面料（推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为普通男士Polo衫，无违规标识、敏感图案或不当内容，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"绿色\",\n    \"style\": \"Polo衫\",\n    \"sleeve_length\": \"短袖\",\n    \"neckline\": \"翻领\",\n    \"details\": \"领口与袖口有浅色条纹\",\n    \"embroidery\": \"左胸有彩色图案\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为普通男士Polo衫，无违规图案或文字，符合平台商品规范。\"\n}"}
{"image_file": "product_01420.jpg", "image": "data/raw/images/product_01420.jpg", "prompt": "男士黑白格纹短袖衬衫，休闲翻领设计", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑白格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"材质\": \"棉质或混纺\",\n    \"设计风格\": \"休闲\",\n    \"袖口\": \"卷边设计\",\n    \"口袋\": \"左侧胸前有一个贴袋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是男士黑白格纹短袖衬衫，符合描述中的休闲翻领设计，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"黑白格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"设计风格\": \"休闲\",\n    \"材质\": \"棉质（视觉推断）\",\n    \"细节\": \"胸前口袋，袖口卷边\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士休闲格纹短袖衬衫，无违规图案、文字或标识，符合平台销售规范。\"\n}"}
{"image_file": "product_01208.jpg", "image": "data/raw/images/product_01208.jpg", "prompt": "这款时尚连衣裙采用迪士尼联名设计，黑色底色搭配橙色印花，适合夏日穿搭，展现个性魅力。", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色底色，橙色装饰\",\n    \"图案\": \"迪士尼品牌标识重复印花\",\n    \"款式\": \"人字拖\",\n    \"材质\": \"橡胶底，布面\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一双人字拖，而商品描述中称其为‘连衣裙’，品类严重不符，存在虚假宣传。此外，商品带有‘Disney’品牌标识，可能涉及未经授权的商标使用，需进一步核实授权情况。\"\n}", "rejected": "```json\n{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色底色，橙色装饰\",\n    \"材质\": \"橡胶底，布料鞋面\",\n    \"款式\": \"人字拖\",\n    \"图案\": \"迪士尼标志印花，包含'Disney'字样和米奇头像轮廓\",\n    \"品牌\": \"NEO\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一双带有迪士尼元素（如'Disney'字样及米奇头像轮廓）的人字拖，但商品描述却将其错误地标注为‘连衣裙’，属于品类与描述严重不符。此外，未经授权使用‘Disney’商标可能涉及侵犯知识产权。\"\n}\n```"}
{"image_file": "product_00623.jpg", "image": "data/raw/images/product_00623.jpg", "prompt": "NIKE同款银色运动鞋，轻便透气，时尚百搭，小香风原单品质", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"银色、蓝色、灰色\",\n    \"材质\": \"网布、合成革\",\n    \"品牌标识\": \"Reebok\",\n    \"设计风格\": \"运动休闲\",\n    \"鞋底\": \"白色中底，蓝色外底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的品牌为Reebok，但商品描述中声称是NIKE同款，存在品牌误导性宣传，违反平台关于真实描述和品牌合规的规定。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"银色、蓝色、白色\",\n    \"品牌标识\": \"Reebok\",\n    \"款式\": \"运动鞋\",\n    \"材质\": \"网面+合成革\",\n    \"设计元素\": \"侧边条纹、透气孔、厚底缓震\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示品牌为Reebok，但商品描述中宣称是'NIKE同款'，存在品牌虚假宣传，构成违规。\"\n}"}
{"image_file": "product_01825.jpg", "image": "data/raw/images/product_01825.jpg", "prompt": "这款T恤包治百病，7天瘦10斤，一抹白，穿出健康好身材！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"军绿色\",\n    \"图案\": \"黑色卡通毛茸茸生物，带有大眼睛和牙齿状嘴巴\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质\": \"棉质（推测）\",\n    \"品牌标识\": \"UCB\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在虚假宣传和夸大功效，如'包治百病'、'7天瘦10斤'、'一抹白'等表述属于医疗或美容效果承诺，违反了广告法及电商平台关于商品宣传的合规要求。此类宣传易误导消费者，构成虚假广告。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"军绿色\",\n    \"图案\": \"黑色卡通毛茸茸生物，带大眼睛和格子嘴，右侧有'UCB'字样\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质\": \"看似棉质\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在虚假宣传和夸大功效，如‘包治百病’‘7天瘦10斤’‘一抹白’等，属于违法广告用语，违反了《广告法》及平台内容规范。图片中无实际医疗或健康相关属性支持该描述，构成误导性宣传。\"\n}"}
{"image_file": "product_00617.jpg", "image": "data/raw/images/product_00617.jpg", "prompt": "黑色短袖T恤，100%纯棉，红色图案设计，运动休闲款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"红色线条构成的立体文字与抽象图形组合，包含'THE GUN'字样及类似爆炸或火焰元素\",\n    \"材质\": \"100%纯棉\",\n    \"款式\": \"短袖T恤\",\n    \"品牌标识\": \"右下角有红色Nike标志\",\n    \"领口细节\": \"内衬为红色\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通运动休闲T恤，图案设计虽具视觉冲击力，但未涉及暴力、色情、政治敏感或违法不良信息。图案中的'THE GUN'为英文单词，结合整体艺术风格属于创意表达，不构成对枪支等违禁物品的直接宣传或美化。符合平台关于服装类商品的合规标准。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"color\": \"黑色\",\n    \"material\": \"100%纯棉\",\n    \"design\": \"红色图案，包含文字和抽象图形\",\n    \"brand_logo\": \"右下角有红色耐克标志\",\n    \"neckline\": \"圆领\",\n    \"sleeve_length\": \"短袖\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通运动休闲T恤，图案为红色线条艺术设计，包含'GUNS'等文字元素及抽象图案，无政治、宗教、暴力或色情等违规内容。品牌标识为耐克（Nike），属于合法注册品牌，符合平台售卖规范。\"\n}"}
{"image_file": "product_01713.jpg", "image": "data/raw/images/product_01713.jpg", "prompt": "这款深蓝色T恤采用100%纯棉材质，印有复古摩托车图案，简约时尚，适合日常穿着。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"100%纯棉\",\n    \"图案\": \"复古摩托车\",\n    \"款式\": \"圆领短袖T恤\",\n    \"设计风格\": \"简约时尚\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的T恤图案为黑白复古摩托车骑行场景，无暴力、色情、政治敏感或侵权内容，符合平台合规标准。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"100%纯棉\",\n    \"图案\": \"复古摩托车\",\n    \"款式\": \"圆领短袖T恤\",\n    \"印花风格\": \"黑白摄影风\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的T恤为常规服饰，图案为黑白复古摩托车骑行场景，无政治敏感、暴力、色情或其他违规内容，符合平台合规要求。\"\n}"}
{"image_file": "product_01980.jpg", "image": "data/raw/images/product_01980.jpg", "prompt": "紫白格纹短袖衬衫男式休闲衬衣", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"紫白格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"前襟纽扣\",\n    \"口袋\": \"双胸袋\",\n    \"材质\": \"棉质或混纺（视觉推测）\",\n    \"图案\": \"格子图案\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是常规男式休闲衬衫，无违规内容。颜色、款式和设计均符合平台对服装类商品的规范要求。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"紫白格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"正面纽扣\",\n    \"口袋\": \"两个胸前口袋\",\n    \"材质\": \"棉质或混纺\",\n    \"图案\": \"格子图案\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是合规的男式休闲衬衣，无违规内容。\"\n}"}
{"image_file": "product_00669.jpg", "image": "data/raw/images/product_00669.jpg", "prompt": "Reebok跑步鞋，包治百病，7天瘦10斤，一抹白，穿出健康好身材", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"品牌\": \"Reebok\",\n    \"颜色\": \"白色、蓝色、灰色\",\n    \"材质\": \"网布、合成材料\",\n    \"款式\": \"跑步鞋\",\n    \"设计元素\": \"透气网面、支撑结构、缓震中底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’‘7天瘦10斤’等夸大功效和医疗宣称，违反广告法及电商平台关于虚假宣传的规定。该类表述与商品实际功能（运动鞋）严重不符，属于误导性宣传。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"brand\": \"Reebok\",\n    \"color\": \"白色、蓝色、灰色\",\n    \"material\": \"网布、合成革\",\n    \"style\": \"跑步鞋\",\n    \"design\": \"透气网面，带有Reebok标志性三角形图案\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’‘7天瘦10斤’等虚假夸大宣传内容，违反广告法及电商平台对商品描述真实性的规定。该鞋款为普通运动鞋，不具备医疗或减肥功效，宣传存在误导消费者风险。\"\n}"}
{"image_file": "product_00879.jpg", "image": "data/raw/images/product_00879.jpg", "prompt": "最新款Puma智能手表，超低价入手，全网最低价，绝对顶级运动腕表！", "chosen": "{\n  \"category\": \"智能手表\",\n  \"attributes\": {\n    \"品牌\": \"Puma\",\n    \"颜色\": \"黑色表带，红色表圈和标志\",\n    \"显示类型\": \"数字显示屏\",\n    \"屏幕内容\": \"SPL 01, 00:00, 00°\",\n    \"材质\": \"橡胶或硅胶表带，塑料表壳\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为Puma品牌智能手表，但描述中使用‘最新款’、‘全网最低价’、‘绝对顶级’等夸大宣传用语，涉嫌虚假宣传和误导消费者，违反平台广告合规规范。\"\n}", "rejected": "{\n  \"category\": \"智能手表\",\n  \"attributes\": {\n    \"品牌\": \"Puma\",\n    \"颜色\": \"黑色表壳搭配红色表圈和红色品牌标识\",\n    \"表盘类型\": \"数字显示屏\",\n    \"显示内容\": \"SPL.01, 00:00, :00°\",\n    \"材质\": \"硅胶或橡胶表带，塑料表壳\",\n    \"款式\": \"运动风格\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘最新款’、‘超低价入手’、‘全网最低价’、‘绝对顶级’等绝对化用语及虚假宣传词汇，违反了广告法相关条款。且未明确标注具体型号、功能参数及适用场景，存在误导消费者风险。图片中的Puma品牌标识可能涉及未经授权的品牌使用或仿冒嫌疑，需进一步核实授权资质。\"\n}"}
{"image_file": "product_01389.jpg", "image": "data/raw/images/product_01389.jpg", "prompt": "这款时尚连衣裙采用轻盈雪纺材质，适合夏季穿着，展现优雅气质。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红、白、蓝格纹\",\n    \"材质\": \"棉质或混纺（视觉上非雪纺）\",\n    \"款式\": \"短袖衬衫式连衣裙\",\n    \"设计元素\": \"前襟纽扣、胸前口袋、腰间系带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中称材质为‘轻盈雪纺’，但图片显示该连衣裙具有明显的挺括感和格纹织物纹理，实际材质更接近棉质或混纺面料，与‘雪纺’不符，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"连衣裙\",\n  \"attributes\": {\n    \"颜色\": \"红、白、蓝格子\",\n    \"材质\": \"棉质或混纺（视觉上非雪纺）\",\n    \"款式\": \"短袖、衬衫领、系带腰封\",\n    \"长度\": \"中长款\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称材质为‘轻盈雪纺’，但图片显示该连衣裙具有明显的织物纹理和挺括感，更符合棉质或混纺面料特征，与雪纺的轻薄透明质感不符，存在材质描述虚假问题。\"\n}"}
{"image_file": "product_01549.jpg", "image": "data/raw/images/product_01549.jpg", "prompt": "原价999直降到99，限时清仓甩卖！ESPRIT男士时尚计时腕表，经典黑配色，质感十足。", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"color\": \"黑色\",\n    \"material\": \"金属表壳，皮革表带\",\n    \"type\": \"计时腕表\",\n    \"features\": [\"三眼计时盘\", \"旋转刻度圈\", \"夜光指针\", \"10 BAR防水\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在‘原价999直降到99’等虚假促销信息，涉嫌价格欺诈。根据平台规则，不得虚构原价进行诱导性销售。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"color\": \"black\",\n    \"material\": \"leather strap, metal case\",\n    \"type\": \"chronograph\",\n    \"water_resistance\": \"10 BAR\",\n    \"dial_color\": \"black\",\n    \"markers\": \"luminous baton markers\",\n    \"features\": [\"date window\", \"tachymeter bezel\", \"three sub-dials\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘原价999直降到99’的促销表述，属于虚假或误导性价格宣传。图片未显示任何价格信息，且无法验证原价真实性，涉嫌价格欺诈风险。\"\n}"}
{"image_file": "product_01955.jpg", "image": "data/raw/images/product_01955.jpg", "prompt": "白色印花短袖T恤，渐变色音乐图案设计", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"渐变色音乐主题印花\",\n    \"图案颜色\": [\"粉色\", \"绿色\"],\n    \"领型\": \"圆领\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服饰，图案为渐变色音乐主题设计，无违规内容或敏感信息，符合平台销售规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"渐变色音乐主题印花\",\n    \"图案颜色\": [\"粉色\", \"绿色\", \"紫色\"],\n    \"图案文字\": \"Music\",\n    \"材质\": \"棉质（推测）\",\n    \"适用人群\": \"女性\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通女装T恤，图案为音乐主题渐变设计，无敏感内容、非法标识或不当言论，符合平台合规标准。\"\n}"}
{"image_file": "product_00849.jpg", "image": "data/raw/images/product_00849.jpg", "prompt": "最新款超低价全网最低绝对顶级男士皮鞋，时尚百搭舒适耐穿", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带休闲皮鞋\",\n    \"鞋底\": \"白色中底，棕色外底\",\n    \"设计风格\": \"简约时尚\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反平台广告合规规范。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"dark blue\",\n    \"material\": \"leather\",\n    \"style\": \"casual lace-up\",\n    \"sole\": \"white with tan outsole\",\n    \"lacing\": \"black laces\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'最新款''超低价''全网最低''绝对顶级'等夸大宣传用语，属于虚假或引人误导的商业宣传，违反平台广告法相关合规规定。\"\n}"}
{"image_file": "product_02272.jpg", "image": "data/raw/images/product_02272.jpg", "prompt": "这款优雅的连衣裙采用轻盈雪纺材质，适合春夏季节穿着，展现女性柔美气质。", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"color\": \"浅蓝色\",\n    \"material\": \"棉质或混纺\",\n    \"style\": \"长袖衬衫\",\n    \"collar_type\": \"标准领\",\n    \"buttons\": \"白色纽扣\",\n    \"pocket\": \"左侧胸袋\",\n    \"fit\": \"修身\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士长袖衬衫，而商品描述中提到的是‘连衣裙’且针对女性穿着，存在严重品类与描述不符的问题。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"款式\": \"长袖衬衫\",\n    \"材质\": \"棉质或混纺\",\n    \"搭配\": \"黑色西裤和皮带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士长袖衬衫，而商品描述中提及的是‘连衣裙’且针对女性穿着，存在严重品类与内容不符的问题。\"\n}"}
{"image_file": "product_01701.jpg", "image": "data/raw/images/product_01701.jpg", "prompt": "最新款超低价全网最低绝对顶级男士条纹Polo衫，时尚百搭必备", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑白条纹\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"图案\": \"胸前有白色'B'字母标志\",\n    \"材质\": \"未明确，推测为棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反平台广告合规规范。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑白条纹\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"图案\": \"胸前有白色'B'字母标志\",\n    \"材质\": \"未明确，视觉上为棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反了广告法及电商平台关于禁止夸大宣传的相关规定。\"\n}"}
{"image_file": "product_00512.jpg", "image": "data/raw/images/product_00512.jpg", "prompt": "这款ESPRIT手表，包治百病，7天瘦10斤，一抹白，时尚又健康！", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘颜色\": \"白色\",\n    \"表带材质\": \"白色皮革\",\n    \"表圈装饰\": \"粉色和透明水晶\",\n    \"数字标记\": \"12、6、9由水晶镶嵌，其余为矩形刻度\",\n    \"功能\": \"日期显示\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病，7天瘦10斤，一抹白’等虚假宣传和医疗功效承诺，属于夸大宣传及违反广告法的行为，与实际商品（手表）功能严重不符。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表带颜色\": \"白色\",\n    \"表带材质\": \"皮革\",\n    \"表盘颜色\": \"白色\",\n    \"表圈装饰\": \"粉色与透明水晶\",\n    \"数字标识\": \"12、6、9由水晶镶嵌\",\n    \"功能\": \"日期显示\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病，7天瘦10斤，一抹白’等夸大功效及虚假宣传内容，与实物手表功能严重不符，违反广告法及相关电商平台规范。\"\n}"}
{"image_file": "product_02413.jpg", "image": "data/raw/images/product_02413.jpg", "prompt": "深紫色高腰修身打底裤", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深紫色\",\n    \"款式\": \"高腰修身打底裤\",\n    \"材质\": \"弹性面料\",\n    \"长度\": \"长裤\",\n    \"设计特点\": \"紧身贴合，脚踝处有堆叠褶皱\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是常规服饰，无违规内容。颜色、款式与描述一致，未发现虚假宣传或不当元素。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"深紫色\",\n    \"款式\": \"高腰修身打底裤\",\n    \"材质\": \"弹性面料\",\n    \"长度\": \"长裤\",\n    \"设计细节\": \"脚踝处有堆叠褶皱\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规女性打底裤，颜色为深紫色，款式为高腰修身，未发现违反平台规则的元素，如不当图案、文字或敏感内容。\"\n}"}
{"image_file": "product_01428.jpg", "image": "data/raw/images/product_01428.jpg", "prompt": "深紫色条纹V领针织毛衣，胸前有徽章图案", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深紫色\",\n    \"图案\": \"白色横条纹\",\n    \"领型\": \"V领\",\n    \"材质\": \"针织\",\n    \"装饰\": \"胸前徽章图案\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服饰，无违规内容。胸前徽章图案未涉及政治、宗教或敏感符号，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深紫色\",\n    \"图案\": \"横向白色条纹\",\n    \"领型\": \"V领\",\n    \"材质\": \"针织\",\n    \"装饰\": \"胸前有徽章图案\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士针织毛衣，无违规标识或敏感内容，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00444.jpg", "image": "data/raw/images/product_00444.jpg", "prompt": "高端羊毛面料，奢华质感", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"品牌\": \"PUMA\",\n    \"图案\": \"绿色PUMA标志和跳跃猫形logo\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质\": \"棉质（视觉判断）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称使用‘高端羊毛面料，奢华质感’，但图片显示为普通棉质T恤，无任何羊毛材质特征，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"品牌标志\": \"PUMA\",\n    \"图案颜色\": \"荧光绿\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质视觉特征\": \"平滑贴身，无毛绒质感\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示该T恤为普通棉质或合成纤维面料，外观光滑且具有典型运动服饰特征，与描述中‘高端羊毛面料，奢华质感’不符，存在虚假宣传嫌疑。\"\n}"}
{"image_file": "product_01197.jpg", "image": "data/raw/images/product_01197.jpg", "prompt": "深棕色荔枝纹皮革手提包，配金属扣饰", "chosen": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"荔枝纹皮革\",\n    \"五金件\": \"金色金属扣饰\",\n    \"款式\": \"单肩/手提两用\",\n    \"缝线\": \"黄色对比缝线\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示深棕色荔枝纹皮革材质，配金色金属扣饰，无违规标识或敏感内容，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"dark brown\",\n    \"material\": \"leather\",\n    \"texture\": \"荔枝纹\",\n    \"hardware\": \"metal clasp\",\n    \"handle_type\": \"shoulder strap\",\n    \"closure\": \"lock-style clasp\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，为深棕色荔枝纹皮革手提包，配金属扣饰，无违规内容。\"\n}"}
{"image_file": "product_01570.jpg", "image": "data/raw/images/product_01570.jpg", "prompt": "小香风原单牛仔裤，LV平替款，高端质感，时尚百搭", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"type\": \"牛仔裤\",\n    \"color\": \"蓝色\",\n    \"style\": \"直筒\",\n    \"material\": \"牛仔布\",\n    \"fit\": \"修身\",\n    \"length\": \"九分\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'小香风原单'和'LV平替款'等表述，暗示与奢侈品牌（如香奈儿、路易威登）存在关联或仿制关系，可能构成虚假宣传或侵犯品牌权益。图片中未见任何品牌标识，但描述内容易误导消费者，违反平台关于禁止冒用或暗示知名品牌的相关规则。\"\n}", "rejected": "{\n  \"category\": \"女装-牛仔裤\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"款式\": \"直筒\",\n    \"材质\": \"牛仔布\",\n    \"长度\": \"七分\",\n    \"洗涤状态\": \"水洗做旧\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘小香风’‘LV平替款’等词汇，暗示与奢侈品牌Chanel及Louis Vuitton存在关联，可能构成虚假宣传或误导性描述，违反平台关于品牌冒用和虚假宣传的规定。\"\n}"}
{"image_file": "product_00276.jpg", "image": "data/raw/images/product_00276.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红白条纹\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"左胸有圆形徽章图案，包含棕榈树、冲浪板和文字\",\n    \"材质\": \"棉质（推测）\",\n    \"风格\": \"休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的Polo衫左胸位置印有'Flying Machine California Surf Academy'的英文标识及图案，具有明显的品牌特征，可能涉及未经授权的品牌或商标使用，不符合‘日系简约 ins风 学院风’描述中所暗示的原创设计定位，存在侵权风险。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红白条纹\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"左胸有圆形徽章图案，包含棕榈树、冲浪板和文字 'FISHING MACHINE CALIFORNIA SURF ACADEMY'\",\n    \"材质\": \"棉质（推测）\",\n    \"风格\": \"休闲运动风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中左胸徽章带有'CALIFORNIA SURF ACADEMY'字样及美国加州相关元素，与描述中的'日系简约 ins风 学院风'不符，存在风格与实际视觉内容不一致的问题，可能误导消费者。\"\n}"}
{"image_file": "product_01349.jpg", "image": "data/raw/images/product_01349.jpg", "prompt": "最新款超低价全网最低绝对顶级跆拳道T恤，限量发售不容错过！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"军绿色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"跆拳道人物剪影，上方文字'TAE-KWON-DO'，下方文字'SINCE 1968'和'THE ART OF KICKING AND PUNCHING'\",\n    \"材质\": \"棉质（推测）\",\n    \"设计风格\": \"运动休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的T恤为普通运动主题服饰，图案内容为跆拳道相关元素，未涉及政治、宗教、色情或暴力等违规信息，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"军绿色\",\n    \"图案\": \"跆拳道人物剪影\",\n    \"文字内容\": \"TAE-KWON-DO SINCE 1968 THE ART OF KICKING AND PUNCHING\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'最新款''超低价''全网最低''绝对顶级''限量发售'等绝对化用语和夸大宣传词汇，涉嫌虚假或引人误解的商业宣传，违反平台广告合规规则。\"\n}"}
{"image_file": "product_02518.jpg", "image": "data/raw/images/product_02518.jpg", "prompt": "原价999直降到99，限时清仓甩卖男士商务西裤，高端质感不容错过！", "chosen": "{\n  \"category\": \"男士服装\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"款式\": \"商务西裤\",\n    \"材质\": \"看似羊毛混纺或涤纶面料\",\n    \"剪裁\": \"修身直筒\",\n    \"搭配\": \"浅蓝色衬衫、棕色皮鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是常规男士商务西裤，无违规内容。商品描述中的价格促销信息（原价999降至99）虽存在较大折扣幅度，但未发现虚假宣传或误导性内容，符合平台对正常促销活动的规范。\"\n}", "rejected": "{\n  \"category\": \"男装-裤子\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"款式\": \"商务西裤\",\n    \"材质\": \"看起来为 wool 或混纺面料\",\n    \"剪裁\": \"直筒修身\",\n    \"搭配\": \"浅蓝色衬衫、棕色皮鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是正规男士商务西裤，无虚假宣传或违规内容。价格描述‘原价999直降到99’属于促销信息，若真实可接受；未发现色情、暴力或侵权元素，符合平台规范。\"\n}"}
{"image_file": "product_01159.jpg", "image": "data/raw/images/product_01159.jpg", "prompt": "浅蓝色拼接白色袖子儿童运动T恤，印有'69 3M'图案和'ATHLETIC DEP. DIV.JA'字样", "chosen": "{\n  \"category\": \"儿童服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色主体，白色袖子\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"印有'69 3M'和'ATHLETIC DEP. DIV.JA'字样\",\n    \"材质\": \"未明确，推测为棉质或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为儿童运动T恤，图案内容为数字与英文标识，无敏感信息或违规元素，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色与白色拼接\",\n    \"款式\": \"短袖T恤\",\n    \"目标人群\": \"儿童\",\n    \"图案\": \"数字'69 3M'和文字'ATHLETIC DEP. DIV.JA'\",\n    \"设计风格\": \"运动风\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为儿童运动T恤，图案内容未涉及违法、违规或敏感信息，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00353.jpg", "image": "data/raw/images/product_00353.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"领口设计\": \"翻领，带有白色条纹装饰\",\n    \"袖口设计\": \"短袖，袖口有白色包边\",\n    \"品牌标识\": \"左胸位置有Puma标志\",\n    \"材质外观\": \"棉质或混纺面料，表面平整\",\n    \"版型\": \"修身剪裁\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为一件黑色Polo衫，具有清晰的品牌标识（Puma），无违规图案、文字或敏感内容。描述中‘面料柔软’‘版型修身’‘显瘦神器’等均为常见服装宣传用语，未发现虚假宣传或夸大成分。整体符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"领口设计\": \"翻领，白色包边\",\n    \"袖口设计\": \"短袖，白色包边\",\n    \"品牌标识\": \"左胸有Puma品牌标志\",\n    \"材质感\": \"棉质或混纺，表面平整\",\n    \"版型\": \"修身\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一件黑色Polo衫，无明显违规内容。该商品为正常服饰类商品，品牌标识为Puma（非侵权仿冒），描述中提及‘面料柔软、版型修身’与视觉呈现相符，未发现夸大宣传或误导性信息。\"\n}"}
{"image_file": "product_00307.jpg", "image": "data/raw/images/product_00307.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"图案\": \"红色盾形徽标，内含跃马图案\",\n    \"领口\": \"带有红绿白三色条纹\",\n    \"材质\": \"棉质或混纺面料\",\n    \"品牌标识\": \"疑似法拉利（Ferrari）风格徽标\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的徽标设计与法拉利（Ferrari）品牌标志高度相似，存在侵犯知名品牌商标权的风险。同时，商品描述中使用‘最新款 超低价 清仓大甩卖’等宣传语可能涉及虚假促销或误导性营销，违反平台广告规范。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"领口\": \"翻领，带有红绿白三色条纹\",\n    \"图案\": \"左胸位置有红色盾形徽章，内含跃马图案\",\n    \"材质\": \"看似棉质或混纺面料，表面有细密格纹纹理\",\n    \"品牌标识\": \"徽章设计与法拉利（Ferrari）标志性跃马徽标高度相似\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的Polo衫左胸徽章为红色盾形跃马图案，与意大利知名品牌法拉利（Ferrari）的官方标志高度一致，存在明显的品牌侵权嫌疑。此外，商品描述使用‘最新款 超低价 清仓大甩卖’等营销话术，可能涉及虚假宣传或诱导性销售，不符合平台对正品及合规宣传的要求。\"\n}"}
{"image_file": "product_00903.jpg", "image": "data/raw/images/product_00903.jpg", "prompt": "蓝白竖条纹男士长袖衬衫", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白\",\n    \"图案\": \"竖条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"纽扣\": \"白色纽扣\",\n    \"袖口\": \"可调节袖口\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是常规男士正装衬衫，无违规内容。蓝白竖条纹设计符合正常服装审美，未涉及敏感图案、文字或不当元素。\"\n}", "rejected": "{\n  \"category\": \"男士衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝白竖条纹\",\n    \"款式\": \"长袖\",\n    \"领型\": \"标准衬衫领\",\n    \"纽扣\": \"白色纽扣\",\n    \"袖口\": \"翻袖口\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"穿着搭配\": \"搭配黑色西裤和皮带\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一件蓝白竖条纹男士长袖衬衫，符合服装类商品的正常展示规范，无侵权、色情、暴力或违禁信息，视觉内容合规。\"\n}"}
{"image_file": "product_01854.jpg", "image": "data/raw/images/product_01854.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款时尚波点连衣裙，优雅大方，不容错过。", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"白色底色，带有红色、黑色和蓝色波点图案\",\n    \"款式\": \"无袖连衣裙\",\n    \"领型\": \"方领\",\n    \"肩带\": \"黑色宽肩带\",\n    \"长度\": \"中长款，及膝\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"图案\": \"密集波点印花\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示服装正面，无违规内容。描述中的价格信息（原价999直降99）虽具促销性质，但未发现虚假宣传或误导性信息，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"款式\": \"无袖连衣裙\",\n    \"图案\": \"波点印花\",\n    \"颜色\": \"红、白、黑多色组合\",\n    \"领型\": \"方领\",\n    \"肩带\": \"黑色宽肩带\",\n    \"长度\": \"中长款\",\n    \"材质\": \"看似棉质或混纺面料\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片内容正常，未发现违规信息。该连衣裙为普通服饰，图案与设计均符合平台规定，不存在色情、暴力、低俗或其他敏感元素。\"\n}"}
{"image_file": "product_00632.jpg", "image": "data/raw/images/product_00632.jpg", "prompt": "PUMA同款潮流印花T恤，小香风原单设计，LV平替百搭上衣", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"保龄球主题印花，包含'PUMA BOWLING CLUB'字样、保龄球瓶、保龄球和卡通人物场景\",\n    \"品牌标识\": \"PUMA\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'小香风原单设计'和'LV平替'等表述，涉嫌虚假宣传及攀附知名品牌（如Chanel、Louis Vuitton），易误导消费者。尽管图片中实际为PUMA品牌产品，但描述内容与视觉信息不符，存在误导性营销风险。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"保龄球主题印花，包含'PUMA BOWLING CLUB'字样、保龄球瓶、球和卡通人物场景\",\n    \"品牌标识\": \"PUMA\",\n    \"设计风格\": \"潮流印花\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'小香风原单设计'和'LV平替'等表述，涉嫌攀附奢侈品牌（Chanel、Louis Vuitton）进行虚假宣传，且实际商品为PUMA品牌T恤，与所述品牌无关联，存在误导消费者的风险。\"\n}"}
{"image_file": "product_01142.jpg", "image": "data/raw/images/product_01142.jpg", "prompt": "浅蓝色水洗牛仔短裤，卷边设计，经典五袋款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"短裤\",\n    \"设计特点\": \"卷边、五袋款\",\n    \"细节\": \"金属纽扣、水洗效果\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规牛仔短裤，无违规图案、文字或敏感元素，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"材质\": \"牛仔布\",\n    \"设计\": \"卷边\",\n    \"款式\": \"五袋款\",\n    \"长度\": \"短裤\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通浅蓝色水洗牛仔短裤，具备卷边和五袋设计，无敏感图案、文字或不合规元素，符合平台销售规范。\"\n}"}
{"image_file": "product_01266.jpg", "image": "data/raw/images/product_01266.jpg", "prompt": "蓝灰白格纹短袖衬衫男式休闲衬衣", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝、灰、白\",\n    \"图案\": \"格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"双胸袋\",\n    \"材质\": \"棉质或混纺（视觉推测）\",\n    \"适用场景\": \"休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是常规男式休闲格纹短袖衬衫，无违规内容，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"男式衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝、灰、白\",\n    \"图案\": \"格纹\",\n    \"袖长\": \"短袖\",\n    \"款式\": \"休闲\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"白色纽扣\",\n    \"口袋\": \"两个胸前口袋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，展示为蓝灰白格纹短袖男式休闲衬衫，无违规内容。\"\n}"}
{"image_file": "product_01929.jpg", "image": "data/raw/images/product_01929.jpg", "prompt": "PUMA品牌黑色橡胶表带计时运动手表", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"PUMA\",\n    \"strap_material\": \"橡胶\",\n    \"strap_color\": \"黑色\",\n    \"case_material\": \"金属\",\n    \"dial_color\": \"白色\",\n    \"hands_color\": \"红色和绿色\",\n    \"features\": [\"计时功能\", \"多个小表盘\", \"夜光指针\"]\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，为PUMA品牌黑色橡胶表带的计时运动手表，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"PUMA\",\n    \"表带材质\": \"橡胶\",\n    \"表带颜色\": \"黑色\",\n    \"表盘颜色\": \"白色\",\n    \"表壳材质\": \"金属\",\n    \"表壳颜色\": \"银色\",\n    \"指针颜色\": \"红色和绿色\",\n    \"功能\": \"计时\",\n    \"设计风格\": \"运动\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，表带为黑色橡胶材质，表盘上带有PUMA品牌标识及计时功能设计，无虚假宣传或侵权内容。\"\n}"}
{"image_file": "product_02307.jpg", "image": "data/raw/images/product_02307.jpg", "prompt": "深灰色底绿色叶纹无袖连衣裙", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深灰色底，绿色叶纹\",\n    \"款式\": \"无袖连衣裙\",\n    \"图案\": \"叶子和小花印花\",\n    \"领型\": \"圆领\",\n    \"长度\": \"中长款\",\n    \"材质\": \"看似轻薄织物\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示完整服装细节，无违规内容或敏感信息。图案为自然植物风格，符合正常商品展示规范。\"\n}", "rejected": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"深灰色底配绿色叶子图案\",\n    \"款式\": \"无袖连衣裙\",\n    \"领型\": \"圆领带小开叉\",\n    \"图案\": \"植物叶纹和小花点缀\",\n    \"长度\": \"中长款\",\n    \"材质\": \"看似轻薄面料，可能为棉或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，内容符合服装类目规范，未发现违规元素，如不当文字、敏感图案或不实宣传。\"\n}"}
{"image_file": "product_00214.jpg", "image": "data/raw/images/product_00214.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"品牌\": \"Reebok\",\n    \"颜色\": \"白色、蓝色、灰色\",\n    \"材质\": \"网布、合成革\",\n    \"款式\": \"跑鞋\",\n    \"设计风格\": \"运动风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为Reebok品牌运动鞋，具有明显的品牌标识和专业运动设计，与描述中的‘日系简约 ins风 学院风’不符，存在描述与实物不一致的问题。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"品牌\": \"Reebok\",\n    \"颜色\": \"白色、蓝色、灰色\",\n    \"材质\": \"网布、合成皮革\",\n    \"款式\": \"跑步鞋\",\n    \"设计风格\": \"运动风\",\n    \"鞋带\": \"灰色\",\n    \"鞋舌\": \"蓝色衬里\",\n    \"标志\": \"侧面三角形Reebok标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为Reebok品牌运动鞋，具有明显的品牌标识和专业运动设计，而商品描述中使用'日系简约 ins风 学院风'等词汇，存在风格描述与实际商品严重不符的情况，涉嫌误导消费者。\"\n}"}
{"image_file": "product_02018.jpg", "image": "data/raw/images/product_02018.jpg", "prompt": "红色条纹长袖Polo衫，黑色领口设计", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红色为主，白色条纹，黑色领口\",\n    \"款式\": \"长袖Polo衫\",\n    \"图案\": \"横向条纹\",\n    \"领型\": \"翻领\",\n    \"材质\": \"未明确，推测为棉质或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示完整，无违规内容。商品描述与图片一致，红色条纹长袖Polo衫搭配黑色领口设计，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"图案\": \"条纹\",\n    \"袖长\": \"长袖\",\n    \"领型\": \"Polo领\",\n    \"领口颜色\": \"黑色\",\n    \"材质\": \"棉质（推测）\",\n    \"款式\": \"休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为常规男士Polo衫，无侵权标志、不良内容或违规信息，符合平台规范。\"\n}"}
{"image_file": "product_01975.jpg", "image": "data/raw/images/product_01975.jpg", "prompt": "黄白蓝格纹男士短袖衬衫", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄白蓝格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"图案\": \"格子\",\n    \"材质\": \"棉质（推测）\",\n    \"品牌标识\": \"左胸有小logo\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是常规男士短袖衬衫，无违规内容或敏感信息。颜色、图案与描述一致，未发现虚假宣传或侵权问题。\"\n}", "rejected": "{\n  \"category\": \"男士衬衫\",\n  \"attributes\": {\n    \"颜色\": \"黄白蓝格纹\",\n    \"款式\": \"短袖\",\n    \"领型\": \"翻领\",\n    \"袖口\": \"卷袖\",\n    \"材质\": \"棉质（推测）\",\n    \"图案\": \"格子纹\",\n    \"品牌标识\": \"左胸有小logo\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示完整商品信息，无违规内容或敏感元素，符合平台发布规范。\"\n}"}
{"image_file": "product_00535.jpg", "image": "data/raw/images/product_00535.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款红色耐克运动帽，轻便透气，时尚百搭。", "chosen": "{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"品牌标志\": \"Nike Swoosh\",\n    \"材质\": \"轻便透气面料\",\n    \"款式\": \"运动帽\",\n    \"细节\": \"帽檐边缘为黑色，侧面有DRI-FIT标识\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为正规品牌耐克（Nike）的运动帽，无仿冒或侵权迹象，且描述中价格促销信息未违反平台规则。\"\n}", "rejected": "{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"品牌标志\": \"耐克（Nike）Swoosh标志\",\n    \"材质\": \"轻便透气面料\",\n    \"款式\": \"运动帽\",\n    \"细节\": \"帽檐边缘为黑色，右侧有DRI-FIT标识\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的耐克（Nike）品牌标志与描述中的‘原价999直降到99’等促销信息存在价格异常嫌疑，且未提供授权证明，涉嫌虚假宣传或未经授权的品牌使用。\"\n}"}
{"image_file": "product_00609.jpg", "image": "data/raw/images/product_00609.jpg", "prompt": "这款灰色运动裤采用100%纯棉材质，舒适透气，适合日常穿着和运动使用。", "chosen": "{\n  \"category\": \"运动裤\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"高腰阔腿\",\n    \"品牌标识\": \"Nike（黄色勾形标志）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示该运动裤带有Nike品牌标识，但商品描述中未提及品牌信息，存在品牌信息不一致或误导性描述的风险。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"品牌标识\": \"黄色Nike标志\",\n    \"款式\": \"高腰阔腿运动裤\",\n    \"材质外观\": \"光滑，类似合成纤维\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述声称采用100%纯棉材质，但图片显示该裤子表面具有光泽且纹理细腻，符合合成纤维（如聚酯纤维）的视觉特征，与纯棉材质的典型外观不符，存在材质虚假宣传。\"\n}"}
{"image_file": "product_02344.jpg", "image": "data/raw/images/product_02344.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款时尚条纹连衣裙，简约大方，速抢！", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"灰白条纹\",\n    \"款式\": \"短袖连衣裙\",\n    \"领型\": \"立领\",\n    \"纽扣\": \"前襟黑色纽扣\",\n    \"长度\": \"中长款\",\n    \"图案\": \"竖条纹\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示完整服装细节，无违规内容或不当信息。\"\n}", "rejected": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"灰白条纹\",\n    \"款式\": \"短袖连衣裙\",\n    \"领型\": \"立领\",\n    \"纽扣\": \"前襟黑色纽扣\",\n    \"长度\": \"中长款\",\n    \"图案\": \"竖条纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中的‘原价999直降到99，限时清仓甩卖’属于虚假或夸大促销信息，可能构成价格欺诈，违反平台关于虚假宣传的规则。\"\n}"}
{"image_file": "product_01653.jpg", "image": "data/raw/images/product_01653.jpg", "prompt": "浅蓝色直筒牛仔裤，经典水洗工艺，裤脚翻边设计", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"款式\": \"直筒\",\n    \"工艺\": \"经典水洗\",\n    \"细节\": \"裤脚翻边\",\n    \"材质\": \"牛仔布\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规浅蓝色直筒牛仔裤，符合描述内容，无违规元素。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"款式\": \"直筒\",\n    \"工艺\": \"水洗\",\n    \"细节\": \"裤脚翻边\",\n    \"材质\": \"牛仔布\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规浅蓝色直筒牛仔裤，符合描述中的水洗工艺和裤脚翻边设计，未发现违规内容。\"\n}"}
{"image_file": "product_00342.jpg", "image": "data/raw/images/product_00342.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"青绿色\",\n    \"款式\": \"V领短袖\",\n    \"材质\": \"纯棉\",\n    \"图案\": \"左胸有小logo\",\n    \"搭配\": \"牛仔裤\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通休闲上衣，无违规内容，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"女装-上衣\",\n  \"attributes\": {\n    \"颜色\": \"深青绿色\",\n    \"领型\": \"V领\",\n    \"袖长\": \"短袖\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"简约休闲\",\n    \"图案\": \"左胸有小logo刺绣\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规女性休闲T恤，颜色和款式均符合平台规范，无违规内容或敏感元素。描述中‘纯棉休闲上衣，舒适透气’与实物相符，未发现夸大或虚假宣传。\"\n}"}
{"image_file": "product_01124.jpg", "image": "data/raw/images/product_01124.jpg", "prompt": "深棕色男士皮质套脚休闲鞋", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"套脚休闲鞋\",\n    \"鞋头形状\": \"尖头\",\n    \"鞋底颜色\": \"黑色\",\n    \"设计风格\": \"简约商务休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一款深棕色男士皮质套脚休闲鞋，符合描述内容，无虚假宣传或违规元素。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"套脚休闲鞋\",\n    \"鞋头形状\": \"尖头\",\n    \"鞋底\": \"平底\",\n    \"设计风格\": \"简约商务休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为常规男士皮质套脚休闲鞋，颜色、材质及款式均符合平台规范，无违规标识或不当内容。\"\n}"}
{"image_file": "product_01766.jpg", "image": "data/raw/images/product_01766.jpg", "prompt": "NIKE同款男士短袖衬衫，小香风原单质感，LV平替时尚单品", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"左侧胸前有一个贴袋\",\n    \"品牌标识\": \"左胸口袋上方有绿色小标志\",\n    \"材质\": \"棉质或混纺面料，表面有细密纹理\",\n    \"袖口\": \"卷边设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'NIKE同款'和'LV平替'等表述，涉嫌虚假宣传及攀附知名品牌，易误导消费者。图片中未见NIKE或LV品牌标识，实际商品为普通品牌衬衫，存在夸大宣传与品牌混淆风险。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"深蓝色\",\n    \"material\": \"棉质或混纺面料\",\n    \"style\": \"短袖衬衫\",\n    \"design\": \"单口袋，左胸有绿色小标志\",\n    \"collar\": \"标准翻领\",\n    \"buttons\": \"深色纽扣\",\n    \"sleeve\": \"可卷边短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'NIKE同款'和'LV平替'等表述，涉嫌虚假宣传及误导性营销，易让消费者误认为该商品为知名品牌正品或具有同等品质，违反了平台关于禁止冒用知名品牌名称进行宣传的规定。\"\n}"}
{"image_file": "product_02471.jpg", "image": "data/raw/images/product_02471.jpg", "prompt": "这款男士休闲裤采用高科技面料，包治百病，7天瘦10斤，一抹白，穿上立刻显瘦10斤！", "chosen": "{\n  \"category\": \"男装-裤子\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"款式\": \"直筒休闲裤\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"搭配\": \"浅蓝色条纹衬衫、棕色皮鞋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’、‘7天瘦10斤’、‘一抹白’等夸大宣传和医疗功效暗示，属于虚假宣传及违反广告法的违规内容，与图片所示普通休闲裤属性严重不符。\"\n}", "rejected": "{\n  \"category\": \"男士服装\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"款式\": \"直筒休闲裤\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"搭配\": \"搭配浅蓝色衬衫与棕色皮鞋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在虚假宣传和医疗承诺，如'包治百病'、'7天瘦10斤'等，这些内容属于夸大功效及不实陈述，违反了平台关于广告合规及消费者权益保护的规定。尽管图片展示的是普通休闲裤，但文字描述严重偏离事实，构成违规。\"\n}"}
{"image_file": "product_00576.jpg", "image": "data/raw/images/product_00576.jpg", "prompt": "紫色印花短袖T恤，前胸印有英文标语与复古图案设计", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"英文标语与复古图案\",\n    \"材质\": \"棉质或混纺（推测）\",\n    \"设计元素\": \"前胸印花，包含文字和抽象复古图像\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服饰，图案内容为英文励志标语及抽象复古设计，未涉及违法、违规或敏感信息，符合平台发布规范。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"款式\": \"短袖T恤\",\n    \"图案类型\": \"英文标语与复古图案\",\n    \"印花内容\": \"Never run after a bus or a man. There will always be another one.\",\n    \"材质\": \"棉质（推测）\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服装，印花内容为英文励志语句及抽象复古图案，未涉及敏感政治、宗教、色情或暴力等违规信息，符合平台审核规范。\"\n}"}
{"image_file": "product_02204.jpg", "image": "data/raw/images/product_02204.jpg", "prompt": "黑色皮革人字拖鞋，简约设计，舒适平底", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"人字拖\",\n    \"设计风格\": \"简约\",\n    \"鞋底类型\": \"平底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一款黑色皮革人字拖，符合描述中的‘简约设计、舒适平底’特征，无违规元素。\"\n}", "rejected": "{\n  \"category\": \"footwear\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"style\": \"thong sandal\",\n    \"design\": \"minimalist\",\n    \"sole_type\": \"flat\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为黑色皮革人字拖鞋，设计简约，平底结构符合普通鞋类规范，无违规标识或敏感元素。\"\n}"}
{"image_file": "product_02407.jpg", "image": "data/raw/images/product_02407.jpg", "prompt": "橙色修身裤，包治百病，7天瘦10斤，一抹白，穿出完美身材", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"橙色\",\n    \"款式\": \"修身裤\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"设计特点\": \"紧身、脚踝处有堆叠褶皱\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’‘7天瘦10斤’‘一抹白’等夸大宣传和医疗功效暗示，属于虚假宣传及违反广告法的违规内容。该商品为普通服饰，不具备宣称的治疗或快速瘦身功能，涉嫌误导消费者。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"橙色\",\n    \"款式\": \"修身裤\",\n    \"材质\": \"针织面料\",\n    \"设计\": \"紧身剪裁，脚口褶皱\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’、‘7天瘦10斤’、‘一抹白’等夸大宣传及医疗功效宣称，属于虚假广告和违规营销行为，违反电商平台广告法相关条款。\"\n}"}
{"image_file": "product_01176.jpg", "image": "data/raw/images/product_01176.jpg", "prompt": "金色矩形表盘镶钻女士手表，ESPRIT品牌", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"金色\",\n    \"表盘形状\": \"矩形\",\n    \"材质\": \"金属\",\n    \"装饰\": \"镶钻\",\n    \"品牌\": \"ESPRIT\",\n    \"表带类型\": \"金属链式\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示为一款金色矩形表盘、镶钻设计的女士手表，品牌标识明确为ESPRIT，未发现违规内容。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"金色\",\n    \"表盘形状\": \"矩形\",\n    \"表带类型\": \"金属链式\",\n    \"装饰元素\": \"镶钻\",\n    \"品牌\": \"ESPRIT\",\n    \"表盘材质\": \"金属拉丝面\",\n    \"指针样式\": \"简约金色指针\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示为一款ESPRIT品牌的女士手表，具有金色金属表带和矩形表盘，表盘边缘镶嵌水晶装饰，符合饰品类商品规范，无侵权或违规内容。\"\n}"}
{"image_file": "product_00978.jpg", "image": "data/raw/images/product_00978.jpg", "prompt": "绿色格纹短袖衬衫男装", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"绿色格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"格子\",\n    \"材质\": \"棉质（推测）\",\n    \"口袋\": \"胸前有两个口袋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是常规男装短袖衬衫，无违规内容或敏感信息。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"绿色格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"格子\",\n    \"纽扣\": \"白色纽扣\",\n    \"口袋\": \"两个胸前口袋\",\n    \"材质\": \"未明确，视觉上为棉质或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，无违规内容。衣物为常规男士短袖衬衫，颜色和图案均符合平台规范，未发现不当标识或敏感元素。\"\n}"}
{"image_file": "product_01496.jpg", "image": "data/raw/images/product_01496.jpg", "prompt": "这款手表采用高科技材料，包治百病，7天瘦10斤，一抹白，佩戴后瞬间提升气质，健康又时尚！", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表盘颜色\": \"浅绿色\",\n    \"表带颜色\": \"粉色\",\n    \"表壳材质\": \"金属\",\n    \"品牌\": \"CARRERA\",\n    \"表盘形状\": \"矩形\",\n    \"数字刻度\": \"10, 2, 8, 4, 6\",\n    \"日期显示\": \"有\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’、‘7天瘦10斤’、‘一抹白’等夸大功效和虚假宣传内容，违反了广告法及电商平台关于商品宣传真实性的规定。该手表为普通计时工具，不具备所述医疗或美容功能。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"浅粉色表带，银色金属表壳，浅绿色表盘\",\n    \"品牌\": \"CARRERA\",\n    \"表盘形状\": \"矩形\",\n    \"数字显示\": \"黑色阿拉伯数字（2, 4, 6, 8, 10）\",\n    \"功能\": \"日期显示窗口\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含'包治百病'、'7天瘦10斤'、'一抹白'等虚假宣传和医疗效果暗示，违反了广告法及平台对健康类功效的禁用语规定。该商品为普通手表，不具备所述功效。\"\n}"}
{"image_file": "product_01706.jpg", "image": "data/raw/images/product_01706.jpg", "prompt": "原价999直降到99，限时清仓甩卖！男士时尚休闲衬衫，品质之选不容错过。", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"卡其色\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"袖口\": \"卷起\",\n    \"口袋\": \"左侧胸前有一个贴袋\",\n    \"纽扣\": \"单排纽扣\",\n    \"材质\": \"棉质或混纺面料\",\n    \"图案\": \"左胸有小logo刺绣\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，无违规内容，符合平台对服装类商品的发布规范。\"\n}", "rejected": "{\n  \"category\": \"男士衬衫\",\n  \"attributes\": {\n    \"颜色\": \"卡其色\",\n    \"款式\": \"长袖衬衫\",\n    \"袖口\": \"卷起\",\n    \"领型\": \"标准翻领\",\n    \"口袋\": \"左侧胸袋\",\n    \"品牌标识\": \"左胸有小logo\",\n    \"材质\": \"棉质或混纺面料\",\n    \"纽扣\": \"暗扣设计\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，无不当内容，描述中价格信息未涉及虚假宣传或误导性用语，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00793.jpg", "image": "data/raw/images/product_00793.jpg", "prompt": "最新款ESPRIT手表，超低价入手，全网最低价，绝对顶级品质，限量发售！", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘颜色\": \"白色\",\n    \"表带材质\": \"黑色皮革\",\n    \"表壳材质\": \"银色金属\",\n    \"功能\": \"日期显示（星期和日期）\",\n    \"指针类型\": \"三针（时、分、秒）\",\n    \"数字刻度\": \"阿拉伯数字\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价入手’、‘全网最低价’、‘绝对顶级品质’、‘限量发售’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反平台广告合规规范。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘颜色\": \"白色\",\n    \"表带材质\": \"黑色皮革\",\n    \"表壳材质\": \"金属（银色）\",\n    \"功能\": \"日期显示（星期和日期）\",\n    \"指针类型\": \"三针（时、分、秒）\",\n    \"表盘数字\": \"阿拉伯数字，灰色轮廓\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示手表外观，品牌标识明确，无虚假宣传或违规内容。商品描述中‘超低价’‘全网最低价’等表述虽具营销性质，但未发现明显夸大或误导性信息，整体符合平台合规要求。\"\n}"}
{"image_file": "product_01013.jpg", "image": "data/raw/images/product_01013.jpg", "prompt": "这款紫色T恤包治百病，穿7天瘦10斤，一抹白，让你瞬间变帅！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"图案\": \"Pac-Man游戏元素（吃豆人和幽灵角色）\",\n    \"文字\": \"ULTIMATE BOARD GAMING, 30 YEARS, 80 MIX\",\n    \"款式\": \"短袖圆领T恤\",\n    \"材质\": \"未明确，推测为棉质\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在虚假宣传和夸大功效，如'包治百病'、'穿7天瘦10斤'、'一抹白，让你瞬间变帅'等表述属于医疗或美容效果的不当承诺，违反了广告法及电商平台关于商品描述真实性的规定。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"图案\": \"Pac-Man游戏角色图案\",\n    \"文字\": \"ULTIMATE BOARD GAMING, 30 YEARS, PAC-MAN\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"未明确\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含虚假宣传和夸大功效的表述，如'包治百病''穿7天瘦10斤''一抹白让你瞬间变帅'等，这些内容与实际商品属性（一件普通印花T恤）严重不符，涉嫌误导消费者，违反了电商平台关于广告真实性和禁止虚假宣传的规定。\"\n}"}
{"image_file": "product_01115.jpg", "image": "data/raw/images/product_01115.jpg", "prompt": "黑色帆布材质男士套脚休闲鞋", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"帆布\",\n    \"款式\": \"套脚休闲鞋\",\n    \"鞋底\": \"浅色橡胶底\",\n    \"设计\": \"简约无带设计\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，为黑色帆布材质的男士套脚休闲鞋，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"帆布\",\n    \"款式\": \"套脚休闲鞋\",\n    \"鞋底\": \"浅色橡胶底，带有黑色线条装饰\",\n    \"内里\": \"灰色衬里\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一款黑色帆布材质的男士套脚休闲鞋，符合描述内容，无明显违规元素。\"\n}"}
{"image_file": "product_00959.jpg", "image": "data/raw/images/product_00959.jpg", "prompt": "最新款超低价全网最低绝对顶级潮流T恤，时尚百搭必备单品", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"灰色底色，彩色图案（包含红色、黄色、紫色、蓝色等）\",\n    \"款式\": \"短袖圆领T恤\",\n    \"图案\": \"抽象风格人脸彩绘，下方有英文文字 'scratching his head'\",\n    \"材质\": \"棉质或棉混纺（推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通印花T恤，图案为艺术化抽象人脸设计，无政治敏感、宗教极端、色情低俗或侵权内容，符合平台合规标准。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"color\": \"灰色\",\n    \"pattern\": \"抽象人物肖像印花\",\n    \"text\": \"scratching his head\",\n    \"material\": \"棉质\",\n    \"style\": \"短袖圆领T恤\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中包含模糊的人物面部图像，可能涉及肖像权争议；此外，文字描述‘最新款超低价全网最低绝对顶级’存在夸大宣传和价格欺诈嫌疑，违反广告法相关规定。\"\n}"}
{"image_file": "product_01451.jpg", "image": "data/raw/images/product_01451.jpg", "prompt": "紫绿白竖条纹长袖男士衬衫", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": [\"紫色\", \"绿色\", \"白色\"],\n    \"图案\": \"竖条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"纽扣\": \"黑色纽扣\",\n    \"袖口\": \"条纹袖口\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为紫绿白竖条纹长袖男士衬衫，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"紫色、绿色、白色\",\n    \"图案\": \"竖条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"纽扣\": \"黑色纽扣\",\n    \"袖口\": \"条纹袖口，与主体图案一致\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为紫绿白竖条纹长袖男士衬衫，无违规内容。\"\n}"}
{"image_file": "product_00876.jpg", "image": "data/raw/images/product_00876.jpg", "prompt": "PUMA同款潮流电子表，小香风原单设计，时尚百搭男士腕表", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表盘形状\": \"方形\",\n    \"表带颜色\": \"黑色\",\n    \"表壳颜色\": \"白色\",\n    \"显示类型\": \"数字显示屏\",\n    \"品牌标识\": \"PUMA\",\n    \"表带材质\": \"橡胶\",\n    \"功能显示\": \"时间、日期、星期\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'小香风原单设计'，涉嫌虚假宣传和误导消费者。该手表为PUMA品牌产品，但'小香风'与PUMA品牌风格不符，且'原单'一词可能暗示非正规渠道或仿冒品，违反平台关于商品真实性和品牌合规的规则。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"style\": \"digital\",\n    \"color\": \"black and white\",\n    \"material\": \"plastic / rubber strap\",\n    \"display\": \"LED digital screen\",\n    \"brand_logo\": \"PUMA logo visible on strap\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示腕表表带上有PUMA品牌标识，但商品描述中使用'PUMA同款'并宣称'原单设计'，涉嫌未经授权使用知名品牌名称和设计，构成品牌侵权风险。\"\n}"}
{"image_file": "product_02545.jpg", "image": "data/raw/images/product_02545.jpg", "prompt": "浅蓝色男士长袖商务衬衫", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"款式\": \"长袖\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺\",\n    \"适用场景\": \"商务\",\n    \"纽扣\": \"白色纽扣\",\n    \"袖口\": \"标准袖口\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合商务衬衫的常规描述，无违规内容。颜色、款式与描述一致，未发现虚假宣传或不当元素。\"\n}", "rejected": "{\n  \"category\": \"男士衬衫\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"款式\": \"长袖\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺\",\n    \"穿着方式\": \"商务正装\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为一件浅蓝色男士长袖商务衬衫，符合常规服装类目规范，无违规标识、不当内容或虚假宣传。\"\n}"}
{"image_file": "product_00314.jpg", "image": "data/raw/images/product_00314.jpg", "prompt": "国风刺绣上衣，传统工艺", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"直筒牛仔裤\",\n    \"细节\": \"黄色缝线\",\n    \"品牌标识\": \"左前袋有品牌标签\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是牛仔裤，但商品描述为'国风刺绣上衣，传统工艺'，存在严重描述不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"牛仔裤\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"直筒\",\n    \"缝线颜色\": \"黄色\",\n    \"装饰\": \"无刺绣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为深蓝色牛仔裤，无任何国风刺绣或传统工艺特征，与描述中‘国风刺绣上衣，传统工艺’严重不符，存在虚假宣传。\"\n}"}
{"image_file": "product_00901.jpg", "image": "data/raw/images/product_00901.jpg", "prompt": "白色长袖棉质男式衬衫，胸前带小口袋和刺绣标识", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"棉质\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"口袋\": \"胸前单口袋\",\n    \"装饰\": \"左胸口袋上有刺绣标识\",\n    \"袖口\": \"卷起\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合服装类商品规范，无违规内容。刺绣标识为品牌标志，未发现侵权或不当信息。\"\n}", "rejected": "{\n  \"category\": \"男式衬衫\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"棉质\",\n    \"款式\": \"长袖\",\n    \"领型\": \"标准翻领\",\n    \"口袋\": \"胸前单口袋\",\n    \"装饰\": \"左胸口袋上方有小刺绣标识\",\n    \"袖口\": \"卷起\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为白色长袖棉质男式衬衫，胸前带有小口袋和刺绣标识，无违规内容。\"\n}"}
{"image_file": "product_02266.jpg", "image": "data/raw/images/product_02266.jpg", "prompt": "男士粉白蓝条纹长袖衬衫", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"粉白蓝条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"未明确，推测为棉或混纺\",\n    \"图案\": \"竖条纹\",\n    \"袖口\": \"标准扣袖\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的男士衬衫符合常规服装类目规范，无违规内容。视觉属性与描述一致，条纹颜色为粉色、白色和蓝色，款式为长袖正装衬衫，未发现虚假宣传或不当元素。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"粉白蓝条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺（推测）\",\n    \"图案\": \"竖条纹\",\n    \"袖口\": \"纽扣式袖口\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规男士正装衬衫，无违规内容。视觉属性与描述一致，未发现不当元素。\"\n}"}
{"image_file": "product_02466.jpg", "image": "data/raw/images/product_02466.jpg", "prompt": "这款男士休闲裤采用高科技面料，包治百病，7天瘦10斤，一抹白，穿上瞬间显瘦10斤！", "chosen": "{\n  \"category\": \"男装-裤子\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"款式\": \"休闲裤\",\n    \"材质\": \"未明确标注，视觉上为棉质或混纺面料\",\n    \"设计特点\": \"直筒剪裁，标准腰头带纽扣和拉链\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’、‘7天瘦10斤’、‘一抹白’等夸大功效及虚假宣传用语，违反广告法及相关电商平台关于商品宣传真实性的规定。图片显示为普通男士休闲裤，无任何特殊功能或成分支持此类宣称。\"\n}", "rejected": "{\n  \"category\": \"男装-休闲裤\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"款式\": \"直筒休闲裤\",\n    \"材质\": \"看似棉混纺或科技面料\",\n    \"设计细节\": \"单扣门襟，侧缝口袋，修身剪裁\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在虚假宣传和医疗效果暗示，如'包治百病''7天瘦10斤''一抹白''瞬间显瘦10斤'等表述，涉嫌夸大功效，违反广告法及电商平台对商品描述的合规要求。实际图片展示仅为普通男士休闲裤，不具备所宣称的特殊功能。\"\n}"}
{"image_file": "product_02021.jpg", "image": "data/raw/images/product_02021.jpg", "prompt": "这款优雅的女士连衣裙采用轻盈雪纺材质，适合春夏季节穿着，展现女性柔美气质。", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色底，红色和白色条纹\",\n    \"款式\": \"长袖Polo衫\",\n    \"领型\": \"翻领\",\n    \"材质\": \"棉质或混纺面料\",\n    \"图案\": \"横条纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士长袖Polo衫，而商品描述中却称其为‘女士连衣裙’，存在严重的品类与描述不符问题。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色、红色、白色\",\n    \"款式\": \"长袖Polo衫\",\n    \"图案\": \"横条纹\",\n    \"材质\": \"未明确\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为男士长袖条纹Polo衫，而商品描述中提及的是女士连衣裙，品类与描述严重不符，存在虚假宣传风险。\"\n}"}
{"image_file": "product_01245.jpg", "image": "data/raw/images/product_01245.jpg", "prompt": "这款紫色拼接夹克宣称是100%纯棉，实则为尼龙材质，存在材质虚标问题。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色与浅灰色拼接\",\n    \"材质\": \"尼龙\",\n    \"款式\": \"连帽拉链夹克\",\n    \"细节\": \"荧光黄拉链、紫色抽绳、胸前有品牌标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述宣称100%纯棉，但图片显示为光滑反光的尼龙材质，存在材质虚标问题。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色与浅灰色拼接\",\n    \"款式\": \"连帽夹克\",\n    \"材质外观\": \"光滑反光，具有尼龙材质特征\",\n    \"拉链\": \"荧光黄色拉链\",\n    \"品牌标识\": \"胸前有Nike标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示夹克表面具有光滑反光的视觉特征，符合尼龙材质的典型外观；而商品描述宣称其为100%纯棉，存在材质虚标问题。\"\n}"}
{"image_file": "product_01525.jpg", "image": "data/raw/images/product_01525.jpg", "prompt": "这款Carrera手表采用100%纯棉表带，时尚简约设计，适合日常佩戴", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表盘形状\": \"方形\",\n    \"表壳材质\": \"金属\",\n    \"表带材质\": \"棕色鳄鱼纹皮革\",\n    \"表盘颜色\": \"白色\",\n    \"指针类型\": \"三针\",\n    \"功能\": \"计时码表\",\n    \"品牌\": \"Carrera\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称表带为'100%纯棉'，但图片显示表带为棕色鳄鱼纹皮革材质，与描述严重不符，构成虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"case_shape\": \"rectangular\",\n    \"dial_color\": \"white\",\n    \"strap_material\": \"leather\",\n    \"strap_color\": \"brown\",\n    \"strap_pattern\": \"alligator\",\n    \"brand\": \"Carrera\",\n    \"features\": [\"chronograph\", \"date_display\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示表带为棕色鳄鱼纹皮革材质，但描述中声称是100%纯棉表带，存在材质描述与实际不符的虚假宣传问题。\"\n}"}
{"image_file": "product_00645.jpg", "image": "data/raw/images/product_00645.jpg", "prompt": "最新款超低价全网最低绝对顶级RUN HARD运动T恤，时尚潮流必备单品", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"图案\": \"蓝色鞋印和紫色文字'RUN HARD'\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质\": \"棉质混纺（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反平台广告合规规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"图案\": \"蓝色跑鞋轮廓与紫色文字'RUN HARD'\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质\": \"棉质或棉混纺\",\n    \"适用人群\": \"男性\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为普通运动T恤，图案内容为鼓励运动的标语和跑鞋图形，无违规信息。描述中虽有‘全网最低’等绝对化用语，但未在图片中体现，仅基于图片内容审核，不构成违规。\"\n}"}
{"image_file": "product_01249.jpg", "image": "data/raw/images/product_01249.jpg", "prompt": "最新款超低价全网最低绝对顶级Nike运动帽，速抢！", "chosen": "{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"品牌标志\": \"Nike勾形标志\",\n    \"材质\": \"织物\",\n    \"款式\": \"运动帽\",\n    \"缝线细节\": \"白色缝线\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为Nike品牌标识，但商品描述中使用‘最新款超低价全网最低绝对顶级’等夸大宣传用语，涉嫌虚假宣传和侵犯品牌权益，不符合平台合规要求。\"\n}", "rejected": "{\n  \"category\": \"hat\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"brand\": \"Nike\",\n    \"material\": \"fabric\",\n    \"style\": \"sport cap\",\n    \"logo_position\": \"front center\",\n    \"seam_details\": \"visible stitching\",\n    \"brim_style\": \"curved\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的帽子带有清晰的Nike品牌标识，且描述中使用‘绝对顶级’、‘全网最低’等夸大宣传用语，涉嫌虚假宣传和品牌侵权风险，违反平台广告合规政策。\"\n}"}
{"image_file": "product_00776.jpg", "image": "data/raw/images/product_00776.jpg", "prompt": "粉色PU皮手提包，配金属扣饰和双拉链侧袋", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"pink\",\n    \"material\": \"PU leather\",\n    \"handle_type\": \"top handle\",\n    \"closure\": \"zipper\",\n    \"features\": [\n      \"metal buckles\",\n      \"dual side zippered pockets\",\n      \"front flap with straps\"\n    ]\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为粉色PU皮手提包，配备金属扣饰和双拉链侧袋，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"材质\": \"PU皮\",\n    \"款式\": \"手提包\",\n    \"细节\": \"金属扣饰，双拉链侧袋\",\n    \"把手\": \"双提手\",\n    \"拉链颜色\": \"浅黄色\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为粉色PU皮手提包，具有金属扣饰和双拉链侧袋，未发现违规内容。\"\n}"}
{"image_file": "product_02015.jpg", "image": "data/raw/images/product_02015.jpg", "prompt": "这款男士条纹Polo衫，包治百病，穿一次就能7天瘦10斤，一抹白，让你瞬间年轻十岁！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深红色与白色条纹\",\n    \"款式\": \"长袖Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"横向条纹\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"装饰\": \"胸前有椭圆形刺绣徽标\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含虚假宣传和夸大功效，如'包治百病'、'穿一次就能7天瘦10斤'、'一抹白，让你瞬间年轻十岁'等表述属于典型的虚假广告用语，违反了《广告法》及电商平台关于商品描述真实性的规定。该商品为普通服装，不具备所述医疗或美容功效。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深紫色与白色条纹\",\n    \"款式\": \"长袖Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"水平条纹\",\n    \"材质\": \"棉质或混纺面料\",\n    \"装饰\": \"胸前有品牌徽标\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含虚假宣传内容，如‘包治百病’、‘穿一次就能7天瘦10斤’、‘一抹白，让你瞬间年轻十岁’等，属于夸大功效和医疗效果的违规表述，违反广告法及相关电商平台规则。该类表述与图片所示普通服装属性严重不符，构成误导性宣传。\"\n}"}
{"image_file": "product_02329.jpg", "image": "data/raw/images/product_02329.jpg", "prompt": "米色底黄色花卉印花七分袖连衣裙", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"米色底，黄色花卉印花\",\n    \"款式\": \"七分袖连衣裙\",\n    \"图案\": \"花卉印花\",\n    \"领型\": \"圆领\",\n    \"袖长\": \"七分袖\",\n    \"材质\": \"未明确，视觉上为轻薄面料\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是常规女装连衣裙，无违规内容。颜色、图案和款式均符合平台规范，未发现敏感或不当元素。\"\n}", "rejected": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"米色底，黄色花卉印花\",\n    \"款式\": \"七分袖连衣裙\",\n    \"图案\": \"花卉印花\",\n    \"领型\": \"圆领\",\n    \"袖长\": \"七分袖\",\n    \"长度\": \"及膝\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是米色底黄色花卉印花的七分袖连衣裙，符合服装类商品规范，无违规内容。\"\n}"}
{"image_file": "product_01694.jpg", "image": "data/raw/images/product_01694.jpg", "prompt": "最新款超低价全网最低绝对顶级时尚印花T恤，潮流必备单品", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"卡通风格的两只长腿鸟，背景为蓝色心形涂鸦，下方有英文手写体文字\",\n    \"文字内容\": \"you look smashing! thank you, my dear. So do you.\",\n    \"材质\": \"棉质（推测）\",\n    \"设计风格\": \"时尚印花\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是常规时尚印花T恤，图案为卡通鸟类与英文祝福语，无违法不良信息、敏感内容或侵权标识。商品描述虽使用‘超低价’‘全网最低’等绝对化用语，但未在图片中体现，且不构成视觉违规。整体符合平台合规要求。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"卡通风格的两个长腿鸟形人物，背景为蓝色心形涂鸦，下方有英文手写体文字\",\n    \"文字内容\": \"you look swooshing! thank you, my dear. So do you.\",\n    \"材质\": \"棉质或棉混纺（推测）\",\n    \"设计风格\": \"潮流印花\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中T恤上的英文文字存在语法错误和拼写问题（如'swooshing'并非标准英文表达），可能涉及低质量或不规范的设计内容，不符合平台对商品描述真实性和设计合规性的要求。此外，宣传语中使用‘全网最低’、‘绝对顶级’等极限词，属于虚假宣传，违反广告法相关条款。\"\n}"}
{"image_file": "product_01165.jpg", "image": "data/raw/images/product_01165.jpg", "prompt": "LV平替潮牌童装，小香风原单设计，NIKE同款字母印花，时尚宝宝T恤", "chosen": "{\n  \"category\": \"童装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"短袖T恤\",\n    \"领口\": \"白色罗纹圆领\",\n    \"印花文字\": \"YES I AM AS SMART AS I LOOK\",\n    \"品牌标识\": \"BeBorn\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中提及'LV平替潮牌童装'、'小香风原单设计'、'NIKE同款字母印花'等表述，存在虚假宣传和误导性信息。图片中实际为BeBorn品牌童装，无任何与LV或NIKE相关的视觉元素，涉嫌冒用知名品牌进行营销，违反平台关于禁止仿冒及虚假宣传的规定。\"\n}", "rejected": "{\n  \"category\": \"童装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"领口\": \"白色圆领\",\n    \"文字印花\": \"YES I AM AS SMART AS I LOOK\",\n    \"品牌标识\": \"BeBorn\",\n    \"袖型\": \"短袖\",\n    \"材质\": \"棉质（推测）\",\n    \"设计风格\": \"休闲潮牌风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中提及'LV平替潮牌童装''NIKE同款字母印花'，存在冒用国际知名品牌（LV、NIKE）进行虚假宣传的行为，且图片中无相关品牌标识，属于误导性宣传，违反平台关于仿冒及未经授权使用知名品牌元素的规定。\"\n}"}
{"image_file": "product_00882.jpg", "image": "data/raw/images/product_00882.jpg", "prompt": "原价999直降到99，限时清仓甩卖！经典黑色皮带，商务休闲两用，品质之选。", "chosen": "{\n  \"category\": \"belt\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"buckle_type\": \"metallic_pin_buckle\",\n    \"style\": \"classic\",\n    \"texture\": \"grainy_surface\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为一条黑色皮革腰带，带有金属扣，符合常规商品描述，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"皮带\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"扣型\": \"金属针扣\",\n    \"表面纹理\": \"压纹\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一条黑色皮革皮带，无侵权标识、无虚假宣传元素，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00363.jpg", "image": "data/raw/images/product_00363.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"skirt\",\n  \"attributes\": {\n    \"color\": \"gray with plaid pattern\",\n    \"length\": \"midi\",\n    \"style\": \"wrap-around\",\n    \"material\": \"wool-like fabric\",\n    \"occasion\": \"business casual\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件格纹半身裙，但商品描述为'简约设计衬衫'，存在品类与描述严重不符的问题。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"type\": \"半身裙\",\n    \"pattern\": \"格纹\",\n    \"color\": \"灰色\",\n    \"length\": \"中长款\",\n    \"material\": \"未知\",\n    \"style\": \"包臀A字型\",\n    \"closure\": \"侧开叉\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是格纹中长款半身裙，但商品描述为‘简约设计衬衫’，存在严重品类与描述不符，属于虚假宣传。\"\n}"}
{"image_file": "product_01819.jpg", "image": "data/raw/images/product_01819.jpg", "prompt": "这款连帽卫衣包治百病，穿7天瘦10斤，一抹白全身亮，时尚又健康！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"连帽卫衣\",\n    \"图案\": \"正面有彩色文字和图像印花，包含'OWEN FILNESS'等字样\",\n    \"材质\": \"棉质或混纺面料\",\n    \"细节\": \"带前袋、抽绳帽兜\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在虚假宣传和夸大功效，如'包治百病'、'穿7天瘦10斤'、'一抹白全身亮'等表述属于医疗或保健类功效承诺，违反了广告法及电商平台关于商品宣传的合规要求。该商品为普通服饰，不具备所述健康或瘦身功能。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"连帽卫衣\",\n    \"图案\": \"正面有彩色印花，包含文字和图像元素\",\n    \"材质\": \"看似棉质混纺\",\n    \"细节\": \"带有前袋、抽绳连帽、袖口和下摆罗纹设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在虚假宣传，如‘包治百病’、‘穿7天瘦10斤’、‘一抹白全身亮’等表述属于夸大功效和医疗宣称，违反平台对商品描述真实性的规定。虽然图片为普通卫衣，但其搭配的描述涉及健康功效与减肥效果，涉嫌误导消费者。\"\n}"}
{"image_file": "product_01752.jpg", "image": "data/raw/images/product_01752.jpg", "prompt": "白色V领长袖针织衫", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"领型\": \"V领\",\n    \"袖长\": \"长袖\",\n    \"材质\": \"针织\",\n    \"图案\": \"无图案\",\n    \"品牌标识\": \"左胸有小logo\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是常规服饰，无违规内容或敏感信息。\"\n}", "rejected": "{\n  \"category\": \"女装-上衣-针织衫\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"领型\": \"V领\",\n    \"袖长\": \"长袖\",\n    \"材质\": \"针织\",\n    \"款式\": \"简约\",\n    \"图案\": \"无图案\",\n    \"装饰\": \"左胸有小logo\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合平台对服装类商品的拍摄规范，未发现违规内容。\"\n}"}
{"image_file": "product_00908.jpg", "image": "data/raw/images/product_00908.jpg", "prompt": "黑色无袖双排扣风衣式连衣裙", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"无袖\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"双排扣\",\n    \"长度\": \"中长款\",\n    \"材质\": \"未明确，视觉上为挺括面料\",\n    \"腰带\": \"有\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合服装类商品发布规范，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"无袖\",\n    \"领型\": \"翻领\",\n    \"纽扣设计\": \"双排扣\",\n    \"腰部\": \"系带收腰\",\n    \"长度\": \"中长款\",\n    \"材质\": \"疑似棉混纺或聚酯纤维\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规女装连衣裙，符合平台对于服饰类商品的合规要求，未发现低俗、侵权或虚假宣传等违规内容。\"\n}"}
{"image_file": "product_00779.jpg", "image": "data/raw/images/product_00779.jpg", "prompt": "最新款超低价全网最低绝对顶级绿色皮质手提包，时尚百搭必备单品", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"green\",\n    \"material\": \"leather-like\",\n    \"style\": \"shoulder bag\",\n    \"handle_type\": \"double strap\",\n    \"closure\": \"open top\",\n    \"hardware\": \"metal rings\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反平台广告合规政策。\"\n}", "rejected": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"绿色\",\n    \"材质\": \"人造皮革\",\n    \"款式\": \"托特包\",\n    \"肩带\": \"双肩带\",\n    \"闭合方式\": \"无可见拉链或扣件\",\n    \"表面纹理\": \"光滑，有轻微褶皱\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘最新款’‘超低价’‘全网最低’‘绝对顶级’等绝对化用语，违反广告法相关规范，且未提供价格对比依据。同时，图片未展示明确品牌标识，存在夸大宣传嫌疑。\"\n}"}
{"image_file": "product_00655.jpg", "image": "data/raw/images/product_00655.jpg", "prompt": "这款时尚连衣裙采用轻盈雪纺材质，色彩斑斓的印花设计，适合夏日出行，展现优雅气质。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色底色，搭配粉色、蓝色、黄色和绿色的图案\",\n    \"材质\": \"棉质\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"抽象闪电风格印花，包含手写体文字和品牌标识\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件短袖T恤，但商品描述中称其为‘连衣裙’，且材质描述为‘轻盈雪纺’，与实际图片中的棉质T恤不符，存在严重描述不符问题。\"\n}", "rejected": "{\n  \"category\": \"上衣\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"彩色闪电图案，包含绿色、粉色、蓝色和黄色\",\n    \"材质\": \"棉质\",\n    \"款式\": \"短袖T恤\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是一件T恤，但描述中称其为‘连衣裙’，存在品类与描述不符的虚假宣传问题。\"\n}"}
{"image_file": "product_00514.jpg", "image": "data/raw/images/product_00514.jpg", "prompt": "这款粉红色吊带衫，包治百病，7天瘦10斤，一抹白，穿出完美身材！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"粉红色\",\n    \"款式\": \"吊带衫\",\n    \"材质\": \"棉质或混纺\",\n    \"设计特点\": \"V领、胸前褶皱设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’‘7天瘦10斤’‘一抹白’等夸大宣传和医疗功效暗示，属于虚假宣传及违反广告法的行为。该商品为普通服饰，不具备宣称的瘦身或美白功能，涉嫌误导消费者。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"粉红色\",\n    \"款式\": \"吊带衫\",\n    \"材质\": \"看起来为棉质或混纺面料\",\n    \"设计细节\": \"领口有褶皱设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在夸大宣传和虚假承诺，如'包治百病'、'7天瘦10斤'、'一抹白'等语句属于医疗功效宣称和减肥效果暗示，违反了广告法及电商平台对服饰类商品的合规要求。这些内容与实际商品属性不符，容易误导消费者。\"\n}"}
{"image_file": "product_01223.jpg", "image": "data/raw/images/product_01223.jpg", "prompt": "最新款超低价全网最低绝对顶级儿童公主鞋，萌趣可爱必备单品！", "chosen": "{\n  \"category\": \"children_shoes\",\n  \"attributes\": {\n    \"color\": \"pink\",\n    \"design\": \"princess_theme\",\n    \"material\": \"fabric_upper_with_rubber_sole\",\n    \"features\": [\n      \"heart_patches\",\n      \"cartoon_princess_character\",\n      \"text_on_sole: 'Princess'\",\n      \"multicolor_tie_dye_strap\"\n    ]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中包含迪士尼风格的公主形象及'Princess'字样，涉嫌使用未经授权的卡通人物形象进行商业宣传，违反平台关于知识产权保护的规定。\"\n}", "rejected": "{\n  \"category\": \"儿童鞋\",\n  \"attributes\": {\n    \"颜色\": \"粉色为主，搭配橙色、紫色、蓝色等彩色元素\",\n    \"材质\": \"布面+橡胶底\",\n    \"图案\": \"迪士尼公主（爱洛公主）卡通形象，心形贴饰，'Princess'文字\",\n    \"款式\": \"一脚蹬休闲鞋，低帮设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中包含迪士尼公主（爱洛公主）的卡通形象及‘Princess’字样，属于未经授权的第三方知名IP内容，涉嫌侵犯知识产权。同时商品描述使用‘最新款超低价全网最低绝对顶级’等夸大宣传用语，违反广告法关于虚假宣传的规定。\"\n}"}
{"image_file": "product_02470.jpg", "image": "data/raw/images/product_02470.jpg", "prompt": "男士卡其色修身休闲西裤", "chosen": "{\n  \"category\": \"男装-裤子\",\n  \"attributes\": {\n    \"颜色\": \"卡其色\",\n    \"款式\": \"修身休闲西裤\",\n    \"材质\": \"未明确标注，视觉上为棉质或混纺面料\",\n    \"设计特点\": \"直筒剪裁，前部有褶皱设计，侧边有缝线装饰\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是男士卡其色修身休闲西裤，符合描述内容，无违规元素。颜色、款式与描述一致，未发现虚假宣传或不当内容。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"卡其色\",\n    \"款式\": \"修身休闲西裤\",\n    \"材质\": \"未明确，视觉上为挺括面料\",\n    \"设计特点\": \"直筒剪裁，平口袋，无明显装饰\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是男士卡其色修身休闲西裤，符合描述内容，未发现虚假宣传或违规元素。\"\n}"}
{"image_file": "product_01090.jpg", "image": "data/raw/images/product_01090.jpg", "prompt": "原价999直降到99，限时清仓甩卖巴西国家队训练服，仅此一件！", "chosen": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色为主，黄色装饰条和标志\",\n    \"品牌\": \"Nike\",\n    \"国家标识\": \"巴西国家队（CBF）\",\n    \"款式\": \"短袖训练服\",\n    \"材质\": \"透气网眼面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为巴西国家队官方训练服，带有CBF徽章及五星标志，属于受版权保护的国家队队服。该商品以‘仅此一件’‘限时清仓甩卖’等话术进行低价促销，涉嫌侵犯国际足联或巴西足协的知识产权，且可能为非授权仿制品，存在虚假宣传风险。\"\n}", "rejected": "{\n  \"category\": \"运动服装\",\n  \"attributes\": {\n    \"品牌\": \"Nike\",\n    \"颜色\": \"深蓝色与黄色\",\n    \"款式\": \"短袖训练服\",\n    \"图案\": \"巴西国家队徽章、CBF标志、五颗星、'BRASIL'字样\",\n    \"材质\": \"透气网眼面料\",\n    \"细节\": \"胸前横条纹、侧边拼接设计、Dri-FIT标签\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品为巴西国家队官方授权球衣，涉及国家体育代表队标识及版权元素（如CBF徽标和五星标志），未经授权不得用于销售。图片中清晰可见‘BRASIL’及国家队徽章，存在侵犯国际足联或巴西足协知识产权的风险，且宣传语‘仅此一件’涉嫌虚假促销，不符合平台合规要求。\"\n}"}
{"image_file": "product_02261.jpg", "image": "data/raw/images/product_02261.jpg", "prompt": "浅绿色竖条纹男士长袖衬衫", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅绿色与白色相间\",\n    \"图案\": \"竖条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"纽扣\": \"白色纽扣\",\n    \"袖口\": \"标准袖口，带纽扣\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合男士正装衬衫的常规设计，无违规内容。颜色、图案和款式均在正常范围内，未发现虚假宣传或不当元素。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅绿色与白色相间\",\n    \"图案\": \"竖条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准尖领\",\n    \"材质\": \"棉质或混纺面料（视觉推断）\",\n    \"纽扣\": \"白色纽扣，前开襟设计\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规男士正装衬衫，无违规图案、文字或敏感元素，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00295.jpg", "image": "data/raw/images/product_00295.jpg", "prompt": "国风刺绣上衣，传统工艺", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"银色表带，蓝色表盘\",\n    \"材质\": \"金属表带，玻璃表镜\",\n    \"款式\": \"矩形表盘，简约设计\",\n    \"品牌\": \"Fasttrack\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款现代风格的手表，而商品描述为'国风刺绣上衣，传统工艺'，存在严重品类与描述不符的情况。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"银色表带，蓝色表盘\",\n    \"形状\": \"矩形表盘，长方形设计\",\n    \"材质\": \"金属表带，金属外壳\",\n    \"表盘图案\": \"蓝色纹理背景，带有品牌标识\",\n    \"指针\": \"蓝黑色指针\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款现代风格的金属手表，而商品描述为'国风刺绣上衣，传统工艺'，描述与图片内容严重不符，属于虚假描述。\"\n}"}
{"image_file": "product_02431.jpg", "image": "data/raw/images/product_02431.jpg", "prompt": "这款格子衬衫包治百病，7天瘦10斤，一抹白，穿上瞬间变男神！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白、灰、黑\",\n    \"图案\": \"格子\",\n    \"款式\": \"长袖衬衫\",\n    \"材质\": \"棉质或混纺\",\n    \"袖口\": \"卷起\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含虚假宣传内容，如'包治百病'、'7天瘦10斤'、'一抹白'等，属于夸大功效和误导性宣传，违反广告法及电商平台合规规定。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白、灰、黑格子\",\n    \"款式\": \"长袖衬衫\",\n    \"材质\": \"棉质或混纺\",\n    \"领型\": \"标准翻领\",\n    \"纽扣\": \"白色纽扣\",\n    \"袖口\": \"卷袖设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘包治百病’、‘7天瘦10斤’、‘一抹白，穿上瞬间变男神’等夸大功效和虚假宣传用语，涉嫌违反广告法及电商平台对虚假宣传的规定。\"\n}"}
{"image_file": "product_01105.jpg", "image": "data/raw/images/product_01105.jpg", "prompt": "黑色鳄鱼纹皮质人字拖，金属色鞋底", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"鳄鱼纹皮质\",\n    \"款式\": \"人字拖\",\n    \"鞋底\": \"金属色\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，未发现违规内容。黑色鳄鱼纹皮质人字拖搭配金属色鞋底，符合常规商品展示规范。\"\n}", "rejected": "{\n  \"category\": \"footwear\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"pattern\": \"crocodile texture\",\n    \"sole_color\": \"metallic\",\n    \"style\": \"thong sandal\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规人字拖，材质与描述一致（黑色鳄鱼纹皮质、金属色鞋底），无违规内容。\"\n}"}
{"image_file": "product_01117.jpg", "image": "data/raw/images/product_01117.jpg", "prompt": "这款优雅的红色真丝连衣裙采用修身剪裁，适合各种正式场合穿着，展现女性魅力。", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"synthetic leather\",\n    \"closure_type\": \"velcro_straps\",\n    \"style\": \"sneaker\",\n    \"sole_type\": \"flat\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双黑色运动鞋，而商品描述中提到的是红色真丝连衣裙，存在严重的图文不符问题。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"synthetic leather or fabric\",\n    \"style\": \"sneaker\",\n    \"closure\": \"velcro straps\",\n    \"sole\": \"flat rubber sole\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为黑色运动鞋，而描述中提及的是红色真丝连衣裙，存在严重图文不符。\"\n}"}
{"image_file": "product_01605.jpg", "image": "data/raw/images/product_01605.jpg", "prompt": "经典蓝色直筒牛仔裤，棉质面料，日常休闲款", "chosen": "{\n  \"category\": \"男装-牛仔裤\",\n  \"attributes\": {\n    \"颜色\": \"经典蓝色\",\n    \"款式\": \"直筒\",\n    \"材质\": \"棉质\",\n    \"适用场景\": \"日常休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规款式的蓝色直筒牛仔裤，无违规图案、文字或敏感元素，符合平台对日常服饰的合规要求。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"款式\": \"直筒\",\n    \"材质\": \"棉质\",\n    \"适用场景\": \"日常休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为经典蓝色直筒牛仔裤，搭配蓝色上衣和深色鞋履，符合描述中‘棉质面料，日常休闲款’的定位，未发现虚假宣传或违规内容。\"\n}"}
{"image_file": "product_00892.jpg", "image": "data/raw/images/product_00892.jpg", "prompt": "黑色长袖印花孕妇连衣裙，正面印有月球图案", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"长袖连衣裙\",\n    \"图案\": \"月球印花\",\n    \"适用人群\": \"孕妇\",\n    \"领型\": \"圆领\",\n    \"长度\": \"中长款\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为孕妇连衣裙，正面印有月球图案，设计符合常规服饰规范，无违规内容或敏感元素。\"\n}", "rejected": "{\n  \"category\": \"孕妇服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"袖型\": \"长袖\",\n    \"领型\": \"圆领\",\n    \"图案\": \"月球表面印花\",\n    \"款式\": \"连衣裙\",\n    \"适用人群\": \"孕妇\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为孕妇服装，图案为月球表面印花，无敏感或违规内容，符合平台合规标准。\"\n}"}
{"image_file": "product_00352.jpg", "image": "data/raw/images/product_00352.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather\",\n    \"style\": \"satchel\",\n    \"hardware\": \"brass-colored buckles and rivets\",\n    \"features\": [\"top handles\", \"detachable shoulder strap\", \"front flap closure\", \"visible stitching\"]\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为一款棕色皮革手提包，具有金属扣件和缝线细节，符合常规商品发布规范。描述中‘正品保证’‘实体店同款’等表述未涉及虚假宣传或侵权内容，无明显违规信息。\"\n}", "rejected": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"手提包\",\n    \"五金件\": \"金色金属扣\",\n    \"细节\": \"双扣装饰、顶部提手、可调节肩带\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，为正常商品图，未发现虚假宣传或侵权元素，符合平台发布规范。\"\n}"}
{"image_file": "product_00899.jpg", "image": "data/raw/images/product_00899.jpg", "prompt": "这款优雅的紫色连衣裙采用精致刺绣设计，适合日常穿搭，展现女性柔美气质。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"款式\": \"短袖T恤\",\n    \"领型\": \"V领\",\n    \"装饰\": \"立体花朵刺绣\",\n    \"材质\": \"棉质或混纺面料\",\n    \"搭配\": \"牛仔裤\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件紫色短袖T恤，而非描述中所称的‘连衣裙’，存在品类与描述严重不符的问题。\"\n}", "rejected": "{\n  \"category\": \"女装-上衣\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"款式\": \"V领短袖T恤\",\n    \"材质\": \"棉质或混纺面料\",\n    \"装饰\": \"胸前有立体玫瑰花刺绣\",\n    \"设计风格\": \"简约优雅\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一件紫色短袖T恤，而非描述中所称的'连衣裙'，存在实物与描述严重不符的情况，违反平台商品信息真实性规定。\"\n}"}
{"image_file": "product_00754.jpg", "image": "data/raw/images/product_00754.jpg", "prompt": "这款时尚连衣裙采用优质棉质面料，黑色设计简约大方，适合日常穿搭", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色表盘，银色表壳，黑色皮质表带\",\n    \"品牌\": \"ESPRIT\",\n    \"功能\": \"三眼计时，日历显示，星期显示\",\n    \"材质\": \"金属表壳，皮革表带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款手表，但商品描述中却描述为‘时尚连衣裙’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"black and silver\",\n    \"material\": \"leather strap, stainless steel case\",\n    \"brand\": \"ESPRIT\",\n    \"dial_type\": \"analog\",\n    \"features\": [\"date display\", \"day of week indicator\", \"24-hour sub-dial\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是一款手表，而商品描述中却描述为'时尚连衣裙'，存在严重的图文不符问题。\"\n}"}
{"image_file": "product_01539.jpg", "image": "data/raw/images/product_01539.jpg", "prompt": "ESPRIT品牌银色金属链式方形女表，黑色表盘配钻石时标", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表壳形状\": \"方形\",\n    \"表带类型\": \"金属链式\",\n    \"表带颜色\": \"银色\",\n    \"表盘颜色\": \"黑色\",\n    \"时标类型\": \"钻石\",\n    \"指针样式\": \"简约银色指针\",\n    \"表盘文字\": \"ESPRIT\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，未发现虚假宣传或违规内容。表盘为黑色，搭配钻石时标，表带为银色金属链式设计，符合描述。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表壳形状\": \"方形\",\n    \"表带类型\": \"金属链式\",\n    \"表盘颜色\": \"黑色\",\n    \"时标材质\": \"钻石\",\n    \"表带颜色\": \"银色\",\n    \"表盘装饰\": \"四个钻石时标（12、3、6、9点位置）\",\n    \"表盘文字\": \"ESPRIT\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，表盘为黑色，搭配钻石时标，表带为银色金属链式设计，无虚假宣传或侵权嫌疑。\"\n}"}
{"image_file": "product_00222.jpg", "image": "data/raw/images/product_00222.jpg", "prompt": "经典款牛仔裤，修身显瘦", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋头形状\": \"尖头\",\n    \"鞋跟高度\": \"低跟\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双黑色男士正装皮鞋，而商品描述为‘经典款牛仔裤，修身显瘦’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"鞋子\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带皮鞋\",\n    \"鞋头形状\": \"尖头\",\n    \"鞋跟高度\": \"低跟\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双黑色男士皮鞋，而商品描述中提及的是‘经典款牛仔裤，修身显瘦’，描述与实际图片内容严重不符，属于图文不一致违规。\"\n}"}
{"image_file": "product_01401.jpg", "image": "data/raw/images/product_01401.jpg", "prompt": "这款时尚连衣裙采用轻盈雪纺材质，适合夏季穿着，展现优雅女性魅力。", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红白格子\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质或混纺\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士短袖格子衬衫，而商品描述中却称其为‘时尚连衣裙’，且描述中提到‘女性魅力’，与实际商品性别和品类严重不符，存在虚假宣传和误导消费者的风险。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"color\": \"红白格子\",\n    \"material\": \"棉质或混纺\",\n    \"style\": \"短袖衬衫\",\n    \"pattern\": \"格纹\",\n    \"sleeve_length\": \"短袖\",\n    \"collar_type\": \"翻领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士短袖格子衬衫，而商品描述中却提到'时尚连衣裙'和'优雅女性魅力'，存在严重的品类与描述不符，属于虚假宣传。\"\n}"}
{"image_file": "product_00961.jpg", "image": "data/raw/images/product_00961.jpg", "prompt": "这款优雅的长款连衣裙采用轻盈雪纺材质，搭配浪漫花卉图案，适合春夏季节穿着，展现女性柔美气质。", "chosen": "{\n  \"category\": \"上衣\",\n  \"attributes\": {\n    \"颜色\": \"浅粉色底色，带有灰黑色和粉红色花卉图案\",\n    \"材质\": \"轻盈雪纺\",\n    \"款式\": \"短袖、圆领、宽松版型\",\n    \"图案\": \"花卉印花\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件短袖上衣，而商品描述中称其为‘长款连衣裙’，存在品类与实际不符的虚假宣传问题。\"\n}", "rejected": "{\n  \"category\": \"上衣\",\n  \"attributes\": {\n    \"颜色\": \"浅粉色底色，搭配黑白灰及粉红色花卉图案\",\n    \"材质\": \"雪纺\",\n    \"款式\": \"短袖、圆领、宽松版型\",\n    \"图案\": \"花卉印花\",\n    \"长度\": \"中长款，及臀\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件短袖上衣，并非描述中的‘长款连衣裙’，存在品类与实际商品严重不符的情况。\"\n}"}
{"image_file": "product_02076.jpg", "image": "data/raw/images/product_02076.jpg", "prompt": "这款时尚男士运动鞋采用透气网面设计，适合日常穿着和跑步锻炼，轻便舒适，防滑耐磨。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝、白、黑、灰\",\n    \"图案\": \"几何印花\",\n    \"款式\": \"连衣裙\",\n    \"领型\": \"V领\",\n    \"袖型\": \"短袖\",\n    \"材质\": \"未明确\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为女士连衣裙，而商品描述中却声称是男士运动鞋，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"蓝、白、黑、灰\",\n    \"图案\": \"几何图案，民族风印花\",\n    \"款式\": \"短袖连衣裙\",\n    \"领型\": \"V领\",\n    \"袖长\": \"短袖\",\n    \"长度\": \"中长款\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件女性连衣裙，而商品描述却为男士运动鞋，存在严重的图文不符，属于虚假宣传。\"\n}"}
{"image_file": "product_01240.jpg", "image": "data/raw/images/product_01240.jpg", "prompt": "迪士尼米奇同款儿童鞋，LV平替萌趣设计，小香风原单童鞋", "chosen": "{\n  \"category\": \"children_shoes\",\n  \"attributes\": {\n    \"color\": \"black, orange, blue, yellow\",\n    \"design\": \"Mickey Mouse themed\",\n    \"material\": \"fabric upper, rubber sole\",\n    \"closure\": \"velcro strap\",\n    \"brand_elements\": \"Mickey Mouse face, 'WORLD' text, Mickey ears pattern\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示鞋面有米奇（Mickey Mouse）的头像、耳朵图案及‘WORLD’字样，属于迪士尼（Disney）受版权保护的IP元素。商品描述中使用‘迪士尼米奇同款’和‘原单童鞋’等表述，涉嫌未经授权使用他人注册商标及品牌标识，构成品牌侵权。同时‘LV平替’与‘小香风’等描述可能误导消费者认为该产品与奢侈品牌有关联，存在虚假宣传风险。\"\n}", "rejected": "{\n  \"category\": \"children_shoes\",\n  \"attributes\": {\n    \"brand_icon\": \"Mickey Mouse\",\n    \"colors\": [\"black\", \"orange\", \"blue\", \"yellow\"],\n    \"material\": \"fabric_upper\",\n    \"closure_type\": \"velcro_strap\",\n    \"design_elements\": [\"mickey_ears_pattern\", \"mickey_face_logo\", \"world_text_label\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中存在迪士尼米奇（Mickey Mouse）的版权图案，且商品描述使用'迪士尼米奇同款'及'原单童鞋'等表述，可能构成对迪士尼品牌未经授权的仿冒或侵权宣传，违反平台知识产权保护规则。\"\n}"}
{"image_file": "product_01583.jpg", "image": "data/raw/images/product_01583.jpg", "prompt": "这款浅绿色运动短裙采用100%纯棉材质，柔软透气，适合日常穿着。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅绿色\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"运动短裙\",\n    \"装饰\": \"右下角有绿色花朵刺绣和粉色品牌标识\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为浅绿色运动短裙，材质标注为100%纯棉，符合日常穿着用途，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"浅绿色\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"运动短裙\",\n    \"装饰\": \"右侧下摆有绿色花朵刺绣和粉色品牌标识\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，为浅绿色运动短裙，材质标注为100%纯棉，符合常规商品规范，无违规内容。\"\n}"}
{"image_file": "product_01741.jpg", "image": "data/raw/images/product_01741.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款粉色印花短袖T恤，时尚百搭，不容错过！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"粉色底色，黑色印花\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"曼陀罗风格印花\",\n    \"领型\": \"圆领\",\n    \"材质\": \"未明确，推测为棉质或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，无违规内容。商品描述中‘原价999直降到99’存在价格虚标嫌疑，但图片本身未违反平台规则。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"图案\": \"民族风印花，中心为圆形曼陀罗图案\",\n    \"款式\": \"短袖T恤\",\n    \"领型\": \"圆领\",\n    \"材质\": \"视觉上为棉质或混纺面料\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示正常服饰，无违规内容。价格信息‘原价999直降到99’虽存在低价促销描述，但未发现虚假宣传或夸大功效等违规行为。整体符合平台商品发布规范。\"\n}"}
{"image_file": "product_01886.jpg", "image": "data/raw/images/product_01886.jpg", "prompt": "这款时尚男士运动鞋采用透气网布材质，适合日常穿着和户外活动，轻便耐用。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色底色，红色和紫色花纹\",\n    \"图案\": \"佩斯利花纹\",\n    \"款式\": \"短袖连衣裙\",\n    \"领型\": \"圆领\",\n    \"袖长\": \"短袖\",\n    \"下摆\": \"直筒A字型\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件女士连衣裙，而商品描述中却称其为男士运动鞋，存在严重的图文不符问题。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色为主，搭配红色和紫色图案\",\n    \"款式\": \"连衣裙\",\n    \"图案\": \"佩斯利花纹（Paisley）\",\n    \"领型\": \"圆领带纽扣装饰\",\n    \"袖型\": \"短袖\",\n    \"材质\": \"未明确显示，但从视觉判断为轻薄面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件女性连衣裙，而商品描述却声称是男士运动鞋，存在严重品类与描述不符的情况，属于虚假宣传。\"\n}"}
{"image_file": "product_01755.jpg", "image": "data/raw/images/product_01755.jpg", "prompt": "小香风原单同款，LV平替绿色T恤，高端质感尽显时尚品味", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"绿色\",\n    \"款式\": \"圆领短袖T恤\",\n    \"品牌标识\": \"UNITED COLORS OF BENETTON\",\n    \"材质\": \"棉质（视觉推测）\",\n    \"图案\": \"黑色文字印花\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为'UNITED COLORS OF BENETTON'品牌T恤，但商品描述中使用'小香风原单同款，LV平替'等表述，存在误导性宣传，涉嫌冒用奢侈品牌（如LV、香奈儿）概念进行虚假营销，违反平台关于品牌混淆和虚假宣传的规则。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"绿色\",\n    \"款式\": \"圆领短袖T恤\",\n    \"品牌标识\": \"UNITED COLORS OF BENETTON\",\n    \"材质\": \"棉质\",\n    \"图案\": \"胸前印有黑色文字\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中实际展示的品牌为'UNITED COLORS OF BENETTON'，但商品描述中使用'小香风原单同款，LV平替'等表述，涉嫌虚构品牌关联及误导性宣传，存在虚假宣传和冒用奢侈品牌概念的违规行为。\"\n}"}
{"image_file": "product_00557.jpg", "image": "data/raw/images/product_00557.jpg", "prompt": "最新款超低价全网最低绝对顶级粉色Polo衫，时尚百搭必备单品！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"品牌标识\": \"Puma标志（左胸位置）\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"纽扣\": \"同色系纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等绝对化用语，违反了广告法关于禁止使用夸大性宣传用语的规定。同时，图片显示该商品为Puma品牌产品，若未获得授权则可能涉及品牌侵权问题。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"品牌标识\": \"Puma（右胸位置有小猫标志）\",\n    \"纽扣\": \"同色系纽扣，共四个\",\n    \"材质\": \"看似棉质或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等夸大宣传用语，涉嫌虚假宣传和价格欺诈，不符合广告法及平台商品发布规范。同时，图片展示为Puma品牌服装，若未获得授权则可能存在侵权风险。\"\n}"}
{"image_file": "product_00218.jpg", "image": "data/raw/images/product_00218.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "chosen": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝紫白格纹\",\n    \"材质\": \"棉质或混纺\",\n    \"款式\": \"长袖格子衬衫\",\n    \"领型\": \"标准翻领\",\n    \"口袋\": \"双胸袋\",\n    \"袖口\": \"卷起\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士格子衬衫，而商品描述为‘100%真丝连衣裙’，存在严重品类与描述不符的问题。图片中无任何连衣裙特征，且为男性模特穿着上衣，与‘连衣裙’描述完全矛盾。\"\n}", "rejected": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"紫、蓝、白格纹\",\n    \"材质\": \"棉质或混纺\",\n    \"款式\": \"长袖衬衫\",\n    \"细节\": \"胸前双口袋，纽扣门襟\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为男士格纹长袖衬衫，而描述中称其为‘100%真丝连衣裙’，品类、性别及材质均严重不符，存在虚假宣传。\"\n}"}
{"image_file": "product_00799.jpg", "image": "data/raw/images/product_00799.jpg", "prompt": "这款米色手提包采用100%纯棉材质，柔软舒适，适合日常使用。", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"beige\",\n    \"material\": \"leather-like\",\n    \"style\": \"shoulder bag\",\n    \"features\": [\"double handles\", \"metal hardware\", \"zipper closure\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述声称采用100%纯棉材质，但图片显示该手提包具有皮革质感和光泽，实际材质应为人造革或类似皮革材料，与描述严重不符。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"beige\",\n    \"material\": \"leather-like\",\n    \"style\": \"shoulder bag\",\n    \"handle_type\": \"dual straps\",\n    \"hardware\": \"metal rings\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述声称材质为100%纯棉，但图片显示该手提包表面具有皮革光泽和纹理，明显为合成革或真皮材质，与描述严重不符。\"\n}"}
{"image_file": "product_01350.jpg", "image": "data/raw/images/product_01350.jpg", "prompt": "原价999直降到99，限时清仓甩卖！这款黑色未来风T恤，潮到爆！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"月球背景搭配未来风格飞行器，下方印有'NEAR FUTURE...'字样\",\n    \"材质\": \"未明确标注，推测为棉质或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片内容为普通潮流服饰设计，图案为科幻风格插画，无违法不良信息、敏感符号或不当言论。价格促销信息符合常规营销行为，未发现违规内容。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"月球背景，带有科幻风格的装置和文字'NEAR FUTURE...' \",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片中展示的T恤图案为科幻主题设计，未涉及敏感内容、违法信息或侵权元素。商品描述虽有促销语气，但无虚假宣传或夸大表述，符合平台规范。\"\n}"}
{"image_file": "product_02436.jpg", "image": "data/raw/images/product_02436.jpg", "prompt": "100%纯棉男士格子衬衫，绿色与深蓝相间，休闲长袖设计", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"绿色、深蓝色、白色\",\n    \"图案\": \"格子\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"长袖衬衫\",\n    \"设计风格\": \"休闲\",\n    \"细节\": \"胸前有两个口袋，袖口卷起\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为100%纯棉男士格子衬衫，颜色为绿色与深蓝相间，符合休闲长袖设计，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"绿色、深蓝色、白色\",\n    \"图案\": \"格子\",\n    \"材质\": \"棉\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前双口袋\",\n    \"袖口\": \"卷起\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，展示为100%纯棉男士格子衬衫，颜色为绿色与深蓝相间，符合休闲长袖设计描述，无违规内容。\"\n}"}
{"image_file": "product_01111.jpg", "image": "data/raw/images/product_01111.jpg", "prompt": "棕色亮片装饰人字拖鞋，白色鞋底设计", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"棕色亮片装饰，白色鞋底\",\n    \"款式\": \"人字拖\",\n    \"材质\": \"亮片表面，橡胶鞋底\",\n    \"设计特点\": \"脚趾带为金属光泽亮片材质，鞋底为白色软垫设计\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一款棕色亮片装饰的人字拖鞋，白色鞋底设计，符合常规鞋类商品规范，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"brown with metallic glitter\",\n    \"material\": \"synthetic upper with sequin embellishment, rubber sole\",\n    \"style\": \"thong sandal\",\n    \"sole_color\": \"white\",\n    \"outsole_color\": \"black\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一款带有棕色亮片装饰的人字拖鞋，白色鞋底设计，符合常规商品发布规范，未发现违规元素。\"\n}"}
{"image_file": "product_01127.jpg", "image": "data/raw/images/product_01127.jpg", "prompt": "这款时尚连衣裙采用红色面料，搭配蓝色数字印花，适合日常穿搭，展现个性魅力。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"无袖连帽背心\",\n    \"图案\": \"蓝色数字'63'和白色文字'DIVI 1A'印花\",\n    \"材质\": \"棉质或混纺面料（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为无袖连帽背心，但商品描述中称其为‘连衣裙’，存在品类描述错误，属于虚假宣传。\"\n}", "rejected": "{\"category\": \"服饰\", \"attributes\": {\"颜色\": \"红色\", \"款式\": \"无袖连帽衫\", \"图案\": \"蓝色数字63和白色DIVI 1A印花\", \"材质\": \"棉质或混纺面料\"}, \"violation\": true, \"reason\": \"商品图片显示为无袖连帽衫，但商品描述中称其为‘连衣裙’，存在品类描述不一致的问题，违反了平台对商品信息真实性的要求。\"}"}
{"image_file": "product_01216.jpg", "image": "data/raw/images/product_01216.jpg", "prompt": "蓝色底红色边米奇图案儿童人字拖", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"蓝色底，红色边，黄色米奇头图案\",\n    \"款式\": \"人字拖\",\n    \"适用人群\": \"儿童\",\n    \"图案\": \"米奇（Mickey）相关卡通形象及文字\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图案包含‘Mickey’、‘Donald’等迪士尼品牌角色名称及形象，属于未经授权的知名卡通IP使用，涉嫌侵犯知识产权。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"蓝色底，红色边框和带子，黄色米奇头图案\",\n    \"款式\": \"人字拖\",\n    \"图案\": \"米奇、米妮、唐老鸭等迪士尼角色名字及米奇头像\",\n    \"适用人群\": \"儿童\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图案包含‘MICKEY’、‘MINNIE’、‘DONALD’等迪士尼品牌角色名称及米奇头像，属于未经授权的知名品牌形象使用，涉嫌侵犯知识产权，违反平台关于未经授权的品牌图案使用的相关规定。\"\n}"}
{"image_file": "product_02007.jpg", "image": "data/raw/images/product_02007.jpg", "prompt": "原价999直降到99，限时清仓甩卖！男士时尚黑色Polo衫，潮流印花设计，速抢！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"图案\": \"胸前有红色和白色字母印花，包含'M'、'O'、'J'等字符\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规男士Polo衫，无违规内容。印花设计为品牌风格文字组合，未发现政治、宗教、色情或暴力等敏感元素，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"黑色\",\n    \"type\": \"Polo衫\",\n    \"design\": \"胸前有红色和白色字母印花\",\n    \"collar\": \"翻领\",\n    \"sleeve_length\": \"短袖\",\n    \"material\": \"棉质或混纺（推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士Polo衫，无违规图案、文字或敏感内容，符合平台销售规范。\"\n}"}
{"image_file": "product_00953.jpg", "image": "data/raw/images/product_00953.jpg", "prompt": "小香风原单男士修身衬衫，LV平替高端商务款，气质非凡", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺面料\",\n    \"版型\": \"修身\",\n    \"纽扣\": \"银色金属纽扣\",\n    \"搭配\": \"深色西裤和皮带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'LV平替'涉嫌虚假宣传和品牌攀附，可能误导消费者认为该商品与奢侈品牌Louis Vuitton存在关联，违反平台关于禁止冒用或暗示知名品牌的相关规则。\"\n}", "rejected": "{\n  \"category\": \"男士衬衫\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"款式\": \"修身\",\n    \"领型\": \"标准翻领\",\n    \"袖长\": \"长袖\",\n    \"材质\": \"棉质或混纺面料\",\n    \"纽扣\": \"银色金属纽扣\",\n    \"图案\": \"细密格纹纹理\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'LV平替'字样，涉嫌冒用奢侈品牌名称进行虚假宣传，且'小香风原单'等表述可能涉及未经授权的品牌模仿或假货暗示，违反平台关于禁止冒用知名品牌及虚假宣传的规则。\"\n}"}
{"image_file": "product_00411.jpg", "image": "data/raw/images/product_00411.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"真皮\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋型\": \"牛津鞋\",\n    \"鞋底\": \"橡胶底\",\n    \"鞋跟\": \"低跟\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一双黑色真皮商务皮鞋，符合描述中的‘高端品牌商务皮鞋，真皮鞋面’，无虚假宣传或违规内容。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"真皮\",\n    \"款式\": \"系带商务皮鞋\",\n    \"鞋头形状\": \"圆头\",\n    \"鞋底类型\": \"橡胶底\",\n    \"鞋跟高度\": \"低跟\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一双黑色系带商务皮鞋，鞋面光滑具有皮革质感，符合描述中的‘高端品牌商务皮鞋，真皮鞋面’。未发现虚假宣传或违规内容。\"\n}"}
{"image_file": "product_00933.jpg", "image": "data/raw/images/product_00933.jpg", "prompt": "黑色表盘红色硅胶表带Puma运动计时腕表", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表盘颜色\": \"黑色\",\n    \"表带材质\": \"硅胶\",\n    \"表带颜色\": \"红色\",\n    \"表壳材质\": \"金属\",\n    \"表盘设计\": \"计时码表\",\n    \"品牌标识\": \"Puma\",\n    \"表盘形状\": \"方形\",\n    \"功能\": \"计时、日期显示\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，表盘为黑色，表带为红色硅胶材质，带有Puma品牌标识，符合运动计时腕表的特征，无违规信息。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"black and red\",\n    \"material\": \"silicone strap\",\n    \"brand\": \"Puma\",\n    \"type\": \"chronograph\",\n    \"case_material\": \"metal\",\n    \"dial_color\": \"black\",\n    \"strap_color\": \"red\",\n    \"features\": [\"date window\", \"sub-dials\", \"three pushers\"]\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，表盘为黑色，表带为红色硅胶材质，品牌标识清晰可见，无违规内容。\"\n}"}
{"image_file": "product_00255.jpg", "image": "data/raw/images/product_00255.jpg", "prompt": "高端羊毛面料，奢华质感", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"套脚式休闲鞋\",\n    \"品牌标识\": \"可见红色圆形标志\",\n    \"鞋底\": \"黑色橡胶防滑底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示鞋面为绒面革材质，但描述中声称使用‘高端羊毛面料’，存在材质描述与实际不符的虚假宣传问题。\"\n}", "rejected": "{\n  \"category\": \"footwear\",\n  \"attributes\": {\n    \"color\": \"tan with dark brown and black accents\",\n    \"material\": \"suede-like exterior, rubber sole\",\n    \"style\": \"slip-on casual shoe\",\n    \"brand\": \"Timberland\",\n    \"design_features\": [\n      \"reinforced toe cap\",\n      \"side ventilation slots\",\n      \"pull tab at heel\"\n    ]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的鞋面材质为麂皮或合成皮革，并非描述中声称的‘高端羊毛面料’，存在材质描述虚假宣传问题。\"\n}"}
{"image_file": "product_02531.jpg", "image": "data/raw/images/product_02531.jpg", "prompt": "这款男士衬衫采用100%纯棉材质，红色条纹设计，经典商务款式，舒适透气", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红色与白色条纹\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"图案\": \"竖条纹\",\n    \"纽扣\": \"白色纽扣\",\n    \"袖口\": \"双褶袖口\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为一件红色条纹男士长袖衬衫，材质标注为100%纯棉，符合商务风格，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"男士衬衫\",\n  \"attributes\": {\n    \"颜色\": \"红色与白色相间条纹\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"长袖、纽扣领、商务休闲\",\n    \"图案\": \"竖条纹\",\n    \"领型\": \"标准翻领\",\n    \"袖口\": \"单叠袖口\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，未发现虚假宣传或违规内容。衬衫为红白竖条纹设计，材质标注为100%纯棉，符合描述中的‘经典商务款式’和‘舒适透气’特性，无侵权或违禁元素。\"\n}"}
{"image_file": "product_01744.jpg", "image": "data/raw/images/product_01744.jpg", "prompt": "深蓝色宽松短袖运动上衣，拼接设计，适合日常休闲穿着", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"宽松短袖\",\n    \"设计特点\": \"拼接设计\",\n    \"适用场景\": \"日常休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的为一件深蓝色宽松短袖运动上衣，具有拼接设计，符合描述内容，无违规元素。\"\n}", "rejected": "{\n  \"category\": \"女装-上衣\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"宽松短袖\",\n    \"设计特点\": \"拼接设计\",\n    \"材质\": \"运动面料（视觉推测）\",\n    \"适用场景\": \"日常休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为一件深蓝色宽松短袖运动上衣，具有拼接设计，无违规内容或不当元素。\"\n}"}
{"image_file": "product_00895.jpg", "image": "data/raw/images/product_00895.jpg", "prompt": "这款时尚连衣裙采用独特艺术印花设计，适合日常穿搭，展现个性魅力。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"抽象艺术印花，包含人脸元素和拼贴风格设计\",\n    \"材质\": \"棉质（推测）\",\n    \"性别\": \"男\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士短袖T恤，但商品描述中称其为‘时尚连衣裙’，存在严重品类与描述不符的问题，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"艺术拼贴印花，包含抽象人脸和文字元素\",\n    \"款式\": \"短袖圆领T恤\",\n    \"材质\": \"未明确，推测为棉质\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是男士T恤，但商品描述中称其为'时尚连衣裙'，存在严重品类不符，属于虚假宣传。\"\n}"}
{"image_file": "product_01000.jpg", "image": "data/raw/images/product_01000.jpg", "prompt": "最新款超低价全网最低绝对顶级机器人印花T恤，潮流必备！", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"图案\": \"机器人印花\",\n    \"文字\": \"ROBOTICS FM ELECTRO ANIMATORS\",\n    \"设计风格\": \"动漫/科幻风\",\n    \"材质\": \"棉质（推测）\",\n    \"款式\": \"短袖圆领T恤\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等绝对化用语，违反了广告法关于禁止使用夸大宣传和绝对化用语的规定。同时，图案中的机器人形象可能涉及未经授权的动漫或影视角色版权问题，存在侵权风险。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"机器人印花\",\n    \"文字\": \"ROBOTICS FM ELECTRO ANIMATORS\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通印花T恤，图案为机器人主题设计，无违法不良信息或侵权标志，符合平台售卖规范。\"\n}"}
{"image_file": "product_00827.jpg", "image": "data/raw/images/product_00827.jpg", "prompt": "这款黑色休闲鞋宣称采用100%纯棉材质，实则为合成革与橡胶制成", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"合成革与橡胶\",\n    \"款式\": \"休闲鞋\",\n    \"设计特征\": \"侧面有三条通风孔，后跟带搭扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述宣称采用100%纯棉材质，但图片显示鞋面为合成革材质，鞋底为橡胶，实际材质与描述严重不符，构成虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"合成革、橡胶\",\n    \"款式\": \"休闲拖鞋\",\n    \"设计特征\": \"侧边透气孔、魔术贴固定带、厚底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述声称采用100%纯棉材质，但图片显示鞋面为合成革材质，鞋底为橡胶，与描述严重不符，存在虚假宣传行为。\"\n}"}
{"image_file": "product_01800.jpg", "image": "data/raw/images/product_01800.jpg", "prompt": "最新款超低价全网最低绝对顶级时尚凉鞋，舒适百搭必备单品", "chosen": "{\n  \"category\": \"footwear\",\n  \"attributes\": {\n    \"color\": \"black and brown\",\n    \"material\": \"leather-like sole, beaded strap\",\n    \"style\": \"thong sandal\",\n    \"decoration\": \"beaded floral pattern\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反平台广告合规政策。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"款式\": \"人字拖\",\n    \"颜色\": \"黑色带珠饰\",\n    \"材质\": \"皮革鞋底，珠饰装饰\",\n    \"装饰\": \"花朵状珠饰图案，包含深蓝、棕色和白色珠子\",\n    \"鞋底\": \"棕色软木材质\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的为一款设计美观的人字拖，无违规宣传或违法信息，视觉属性符合正常商品描述。\"\n}"}
{"image_file": "product_01447.jpg", "image": "data/raw/images/product_01447.jpg", "prompt": "小香风原单条纹针织开衫，LV平替高端时尚女装，优雅气质必备", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"黑、紫、灰条纹\",\n    \"款式\": \"针织开衫\",\n    \"领型\": \"翻领\",\n    \"袖型\": \"长袖\",\n    \"装饰\": \"腰带系结\",\n    \"纽扣\": \"黑色圆形纽扣\",\n    \"材质\": \"针织\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'LV平替'字样，涉嫌虚假宣传和攀附知名品牌，违反平台关于禁止冒用或暗示关联奢侈品牌的规定。\"\n}", "rejected": "{\n  \"category\": \"女装-外套\",\n  \"attributes\": {\n    \"颜色\": \"黑、灰、紫红相间条纹\",\n    \"款式\": \"长袖开衫\",\n    \"领型\": \"V领\",\n    \"装饰\": \"系带腰封\",\n    \"材质\": \"针织\",\n    \"纽扣\": \"深色圆形纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'LV平替'字样，涉嫌虚假宣传和攀附知名品牌，违反平台关于禁用奢侈品名称进行营销的规则。同时，‘小香风’为特定品牌风格的表述，若未获授权易构成侵权风险。\"\n}"}
{"image_file": "product_01432.jpg", "image": "data/raw/images/product_01432.jpg", "prompt": "NIKE同款格子衬衫，小香风原单设计，时尚百搭男士上衣", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红、蓝、白格子\",\n    \"款式\": \"长袖衬衫，卷袖设计\",\n    \"材质\": \"棉质或混纺面料\",\n    \"细节\": \"胸前双口袋，纽扣开合，领口有品牌标志\",\n    \"图案\": \"经典格纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'NIKE同款'涉嫌虚假宣传和品牌侵权，图片中未见NIKE品牌标识，且实际为普通格子衬衫，存在误导消费者风险。\"\n}", "rejected": "{\n  \"category\": \"男士衬衫\",\n  \"attributes\": {\n    \"图案\": \"格子\",\n    \"颜色\": \"红、蓝、白\",\n    \"袖长\": \"短袖\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"双胸袋\",\n    \"品牌标识\": \"三角形徽标\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘NIKE同款’字样，暗示与NIKE品牌存在关联，但图片中未显示NIKE品牌标识，且产品设计风格与NIKE主流款式不符，涉嫌误导性宣传和虚假宣称，违反平台关于品牌授权和商品真实性的规定。\"\n}"}
{"image_file": "product_01261.jpg", "image": "data/raw/images/product_01261.jpg", "prompt": "灰蓝白格纹短袖衬衫男款休闲衬衣", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"灰、蓝、白\",\n    \"图案\": \"格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"双胸袋\",\n    \"材质\": \"棉质或混纺（视觉推测）\",\n    \"适用场景\": \"休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为常规男款休闲格纹短袖衬衫，无违规标识、不当内容或敏感图案，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"灰、蓝、白\",\n    \"图案\": \"格纹\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前双口袋\",\n    \"材质\": \"未明确，疑似棉质混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男款休闲格纹短袖衬衫，无违规标识或不当内容，符合平台销售规范。\"\n}"}
{"image_file": "product_00782.jpg", "image": "data/raw/images/product_00782.jpg", "prompt": "小香风原单质感包包，LV平替款，高级棕色皮质托特包", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather-like\",\n    \"style\": \"tote\",\n    \"features\": [\n      \"top handles\",\n      \"detachable shoulder strap\",\n      \"front pocket with brand label\",\n      \"metal hardware\"\n    ]\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'LV平替款'涉嫌虚假宣传和品牌冒用，可能构成对奢侈品牌的侵权或误导性宣传。图片中的包袋虽为棕色皮质托特包，但未见任何LV品牌标识，且描述暗示其为LV替代品，违反平台关于禁止仿冒及误导性营销的规定。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather-like\",\n    \"style\": \"tote\",\n    \"features\": [\n      \"top handles\",\n      \"adjustable shoulder strap\",\n      \"front pocket with brand label\",\n      \"metal hardware\"\n    ]\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'小香风原单质感包包，LV平替款'等字样，存在暗示与知名品牌（如Chanel、Louis Vuitton）关联的误导性表述，易引发消费者对品牌来源的误解，违反平台关于禁止虚假宣传和傍名牌的规则。\"\n}"}
{"image_file": "product_00784.jpg", "image": "data/raw/images/product_00784.jpg", "prompt": "这款时尚优雅的连衣裙采用高品质黑色丝绒面料，修身剪裁尽显女性魅力，适合多种场合穿着。", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"style\": \"satchel\",\n    \"hardware\": \"gold-tone\",\n    \"features\": [\"top handles\", \"front flap closure\", \"side straps\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款黑色皮革手提包，但商品描述中却声称是‘连衣裙’，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"style\": \"satchel\",\n    \"hardware\": \"gold-tone\",\n    \"features\": [\"double handles\", \"front flaps with buckles\", \"shoulder strap\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是一款黑色皮革手提包，而商品描述中提及的是‘连衣裙’，属于严重品类不符。描述中的‘丝绒面料’与实际商品材质不一致，构成虚假宣传。\"\n}"}
{"image_file": "product_02194.jpg", "image": "data/raw/images/product_02194.jpg", "prompt": "最新款Skechers运动鞋，超低价抢购，全网最低价，绝对顶级舒适体验！", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"品牌\": \"Skechers\",\n    \"颜色\": [\"黑色\", \"灰色\", \"黄色\", \"白色\"],\n    \"材质\": [\"网布\", \"皮革\", \"橡胶\"],\n    \"款式\": \"休闲运动鞋\",\n    \"鞋带\": \"白色\",\n    \"鞋底\": \"厚底，带有黄色装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价抢购’、‘全网最低价’等绝对化用语和夸大宣传词汇，违反了广告法及电商平台关于禁止虚假宣传的规定。同时，图片显示为Skechers品牌产品，若未获得授权可能涉及侵权风险。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"品牌\": \"Skechers\",\n    \"颜色\": \"黑色、灰色、黄色、白色\",\n    \"材质\": \"网布、合成革\",\n    \"款式\": \"低帮跑鞋\",\n    \"鞋带\": \"白色\",\n    \"鞋底\": \"橡胶，带有黄色装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘全网最低价’、‘绝对顶级舒适体验’等夸大宣传用语，涉嫌虚假宣传和违反广告法相关规定。\"\n}"}
{"image_file": "product_01096.jpg", "image": "data/raw/images/product_01096.jpg", "prompt": "最新款PUMA奢华手表，超低价抢购，全网最低价，绝对顶级时尚单品", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"PUMA\",\n    \"color\": \"黑色表带，金色表壳\",\n    \"material\": \"皮革表带，金属表壳，镶嵌仿钻\",\n    \"design\": \"矩形表盘，波浪纹表带，镶钻装饰\",\n    \"features\": \"数字刻度（12, 3, 6, 9），品牌LOGO位于表盘下方\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中显示的PUMA品牌手表存在夸大宣传嫌疑，描述中使用‘最新款’、‘超低价抢购’、‘全网最低价’、‘绝对顶级时尚单品’等绝对化用语，可能构成虚假或引人误解的商业宣传。此外，该商品为知名品牌PUMA产品，若未提供正规授权证明，可能存在侵权风险。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"PUMA\",\n    \"color\": \"黑色与金色\",\n    \"material\": \"皮革表带，金属表壳\",\n    \"design\": \"矩形表盘，镶嵌仿钻装饰\",\n    \"features\": \"表盘有PUMA标志，数字时标为12、3、6、9，金色指针\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的PUMA品牌手表，存在过度宣传‘最新款’‘超低价抢购’‘全网最低价’‘绝对顶级时尚单品’等夸大性描述，可能涉嫌虚假宣传。同时，品牌授权资质未在商品信息中明确体现，可能存在侵犯品牌知识产权或假冒风险。\"\n}"}
{"image_file": "product_01024.jpg", "image": "data/raw/images/product_01024.jpg", "prompt": "紫红色印花圆领短袖T恤，正面印有英文标语与问号图案", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫红色\",\n    \"款式\": \"圆领短袖T恤\",\n    \"图案\": \"英文标语与问号图案\",\n    \"材质\": \"棉质（推测）\",\n    \"设计元素\": \"印花文字、问号图形、品牌标识\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通印花T恤，图案内容为英文标语和问号，未发现政治敏感、暴力、色情或违法不良信息，符合平台合规要求。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"紫红色\",\n    \"款式\": \"圆领短袖T恤\",\n    \"图案\": \"英文标语与问号图案\",\n    \"材质\": \"棉质（推测）\",\n    \"设计元素\": \"文字艺术排版、蓝色问号轮廓、品牌标志\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通印花T恤，图案内容为英文标语和问号设计，未发现政治敏感、色情低俗、暴力恐怖或侵权等违规内容，符合平台合规要求。\"\n}"}
{"image_file": "product_00657.jpg", "image": "data/raw/images/product_00657.jpg", "prompt": "黑色印花短袖T恤，正面印有蓝色鞋底图案和黄色'RUN HARD'字样", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"蓝色鞋底图案\",\n    \"文字\": \"RUN HARD\",\n    \"文字颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通印花T恤，图案和文字内容无违规信息，未涉及敏感话题或不当表达。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"蓝色鞋底图案\",\n    \"文字\": \"RUN HARD\",\n    \"文字颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通印花T恤，图案为鞋底和激励性文字'RUN HARD'，无敏感或违规内容，符合平台规定。\"\n}"}
{"image_file": "product_00371.jpg", "image": "data/raw/images/product_00371.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"color\": \"蓝色\",\n    \"material\": \"编织表带\",\n    \"display_type\": \"数字显示屏\",\n    \"features\": [\"时间显示\", \"日期显示\", \"运动风格\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款Puma品牌的智能手表，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重品类与描述不符的问题。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"color\": \"蓝色\",\n    \"material\": \"编织表带\",\n    \"display_type\": \"数字显示屏\",\n    \"features\": [\"运动风格\", \"LED显示\", \"日历功能\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片为Puma品牌电子手表，但商品描述为'高端品牌商务皮鞋，真皮鞋面'，存在明显品类与描述不符的问题。\"\n}"}
{"image_file": "product_01930.jpg", "image": "data/raw/images/product_01930.jpg", "prompt": "这款时尚连衣裙采用金色亮片设计，搭配黑色腰带，尽显优雅气质，适合各种正式场合穿着。", "chosen": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"gold and black\",\n    \"material\": \"metal case, rubber strap\",\n    \"brand\": \"Puma\",\n    \"design\": \"sporty, modern\",\n    \"dial\": \"black with gold numerals and logo\",\n    \"strap\": \"black rubber with textured pattern\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一款金色表壳、黑色表盘的Puma品牌手表，而商品描述中却声称是‘时尚连衣裙’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"case_color\": \"金色\",\n    \"dial_color\": \"黑色\",\n    \"strap_material\": \"橡胶\",\n    \"strap_color\": \"黑色\",\n    \"numbers\": \"金色阿拉伯数字\",\n    \"logo\": \"Puma跳跃猫标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款Puma品牌的手表，但商品描述却为‘时尚连衣裙’，存在严重图文不符，属于虚假宣传。\"\n}"}
{"image_file": "product_01019.jpg", "image": "data/raw/images/product_01019.jpg", "prompt": "这款男士格子短袖衬衫采用100%纯棉材质，舒适透气，适合日常穿着。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红白格子\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"纯棉\",\n    \"设计元素\": \"胸前双口袋，纽扣开合，袖口可卷边\",\n    \"图案\": \"格纹\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一件男士格子短袖衬衫，符合描述中的100%纯棉材质和日常穿着用途，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红白格子\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质\",\n    \"图案\": \"格纹\",\n    \"口袋\": \"双胸袋\",\n    \"纽扣\": \"金色纽扣\",\n    \"领型\": \"标准翻领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，未发现虚假宣传或违规内容。视觉上确认为格子短袖衬衫，颜色为红白相间，材质从外观判断符合棉质描述，无敏感元素或侵权标识。\"\n}"}
{"image_file": "product_00775.jpg", "image": "data/raw/images/product_00775.jpg", "prompt": "橄榄绿菱格纹编织手提包", "chosen": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"橄榄绿\",\n    \"材质\": \"人造皮革\",\n    \"图案\": \"菱格纹\",\n    \"手柄类型\": \"编织手柄\",\n    \"五金件\": \"银色金属环\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示为一款橄榄绿色的菱格纹编织手提包，无违规标识或敏感内容，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"橄榄绿\",\n    \"材质\": \"人造皮革\",\n    \"图案\": \"菱格纹\",\n    \"设计\": \"编织手柄\",\n    \"五金件\": \"银色金属环和扣件\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，为橄榄绿色菱格纹手提包，具有编织手柄和金属配件，无侵权或违规元素。\"\n}"}
{"image_file": "product_00875.jpg", "image": "data/raw/images/product_00875.jpg", "prompt": "PUMA同款潮流短袖，小香风原单质感，NIKE平替必备单品", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"品牌标识\": \"PUMA\",\n    \"图案\": \"白色PUMA标志和跳跃猫图案\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"设计风格\": \"简约运动风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的T恤带有明显的PUMA品牌标识，但商品描述中使用了‘PUMA同款’、‘原单质感’等词汇，涉嫌虚假宣传和误导消费者，可能构成侵犯品牌知识产权及误导性营销。同时，描述中提及‘NIKE平替’属于不当类比，易引发误解，违反平台关于商品描述真实性和品牌合规的相关规定。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"品牌标识\": \"PUMA\",\n    \"材质\": \"棉质\",\n    \"设计风格\": \"简约运动风\",\n    \"图案位置\": \"胸前\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的T恤正面印有'PUMA'品牌标识及跳跃豹子图案，属于知名品牌商标。商品描述中使用'PUMA同款'、'原单质感'等表述可能构成对他人注册商标的冒用或暗示正品关联，存在误导消费者之嫌，违反了平台关于禁止虚假宣传和侵权模仿的相关规定。\"\n}"}
{"image_file": "product_00548.jpg", "image": "data/raw/images/product_00548.jpg", "prompt": "这款时尚连衣裙采用轻盈面料，适合日常穿搭，展现优雅气质。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"狐狸头像，带有Nike标志和数字34\",\n    \"款式\": \"短袖T恤\",\n    \"品牌标识\": \"Nike\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件印有Nike品牌标志的T恤，但商品描述中却称其为‘连衣裙’，存在品类与描述严重不符的问题。此外，该商品可能涉及未经授权的品牌标识使用，构成侵权风险。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"狐狸插画，带有Nike标志\",\n    \"款式\": \"短袖T恤\",\n    \"品牌\": \"Nike\",\n    \"数字\": \"34\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件带有Nike品牌标识的T恤，但商品描述中却称为‘连衣裙’，存在品类描述错误。此外，该商品实际为耐克品牌产品，而描述中未准确体现品牌信息，属于虚假或误导性描述。\"\n}"}
{"image_file": "product_01174.jpg", "image": "data/raw/images/product_01174.jpg", "prompt": "小香风原单ESPRIT手表，LV平替款，奢华镶钻设计，高级感十足", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘形状\": \"矩形\",\n    \"表带材质\": \"金属\",\n    \"表带设计\": \"镶钻链节\",\n    \"表盘颜色\": \"黑色\",\n    \"指针样式\": \"简约银色指针\",\n    \"表盘文字\": \"ESPRIT\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'小香风原单'和'LV平替款'等表述，暗示与奢侈品牌（如Chanel、Louis Vuitton）存在关联或替代关系，可能构成虚假宣传或误导性描述。同时，图片显示该手表为ESPRIT品牌，与‘原单’‘平替’等词汇结合易引发消费者误解其为高端品牌仿制品或正品，违反平台关于禁止误导性营销的规则。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"color\": \"银色\",\n    \"dial_color\": \"黑色\",\n    \"band_material\": \"金属\",\n    \"design\": \"镶钻\",\n    \"shape\": \"矩形\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'小香风原单'和'LV平替款'属于冒用知名品牌风格及误导性宣传，且图片中的手表品牌为ESPRIT，与描述存在明显不符，涉嫌虚假宣传和不当引流。\"\n}"}
{"image_file": "product_01060.jpg", "image": "data/raw/images/product_01060.jpg", "prompt": "这款黑色Polo衫宣称采用100%纯棉材质，实则为混纺面料，存在材质虚标问题。", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"领口设计\": \"翻领，带有白色条纹装饰\",\n    \"袖口设计\": \"短袖，袖口有白色包边\",\n    \"品牌标识\": \"左胸位置有Puma标志\",\n    \"材质外观\": \"表面平整，具有棉质纹理感\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中宣称采用100%纯棉材质，但根据图片显示的面料质感及常见混纺Polo衫特征，结合实际销售中此类产品多为棉涤混纺的情况，存在材质虚标问题。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"领口设计\": \"翻领，带有白色镶边\",\n    \"袖口设计\": \"短袖，袖口有白色镶边\",\n    \"品牌标识\": \"左胸位置有Puma品牌标志\",\n    \"材质外观\": \"表面平整，有细密纹理\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的Polo衫为黑色，带有白色领边和袖口镶边，左胸有Puma品牌标志。根据描述，该商品宣称采用100%纯棉材质，但实际为混纺面料，存在材质虚标问题，违反平台关于商品真实描述的规范。\"\n}"}
{"image_file": "product_00865.jpg", "image": "data/raw/images/product_00865.jpg", "prompt": "最新款超低价全网最低绝对顶级ESPRIT时尚腕表，奢华镶钻设计，尽显高贵气质", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘形状\": \"矩形\",\n    \"表带材质\": \"黑色皮革\",\n    \"表壳材质\": \"金属\",\n    \"装饰元素\": \"镶钻\",\n    \"指针数量\": \"2\",\n    \"表盘颜色\": \"银色\",\n    \"表盘纹理\": \"斜纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反平台广告合规规范。同时，图片显示为普通镶钻设计，未体现‘奢华’或‘顶级’的实际价值支撑，存在过度营销嫌疑。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘形状\": \"矩形\",\n    \"表带材质\": \"黑色皮革\",\n    \"表壳材质\": \"金属（银色）\",\n    \"装饰\": \"表耳处镶嵌多颗小钻\",\n    \"指针\": \"单指针设计\",\n    \"表盘纹理\": \"斜纹拉丝\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘最新款’‘超低价’‘全网最低’‘绝对顶级’等绝对化用语，涉嫌虚假宣传和夸大宣传，违反了平台广告审核规范。此外，虽有镶钻设计，但实际为人造水晶或仿钻，未标明材质可能构成误导性描述。\"\n}"}
{"image_file": "product_00877.jpg", "image": "data/raw/images/product_00877.jpg", "prompt": "这款PUMA智能手表采用100%纯棉表带，时尚运动风设计，适合日常佩戴", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"PUMA\",\n    \"display_type\": \"数字屏\",\n    \"case_color\": \"黑色\",\n    \"band_color\": \"蓝色\",\n    \"band_material\": \"编织材质\",\n    \"watch_face_design\": \"圆形环形进度条，绿色数字显示时间与日期\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称表带为'100%纯棉'，但图片显示表带为编织尼龙或类似合成纤维材质，与实际视觉特征不符，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"PUMA\",\n    \"表带材质\": \"蓝色编织织物\",\n    \"表壳颜色\": \"黑色\",\n    \"显示屏类型\": \"数字屏\",\n    \"显示内容\": \"时间、日期、星期\",\n    \"设计风格\": \"运动风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中称表带为'100%纯棉'，但图片显示表带为蓝色编织织物，视觉上更接近尼龙或聚酯纤维材质，与描述不符，存在虚假宣传嫌疑。\"\n}"}
{"image_file": "product_01747.jpg", "image": "data/raw/images/product_01747.jpg", "prompt": "深紫色V领无袖褶皱设计上衣", "chosen": "{\n  \"category\": \"女装上衣\",\n  \"attributes\": {\n    \"颜色\": \"深紫色\",\n    \"领型\": \"V领\",\n    \"袖型\": \"无袖\",\n    \"设计特点\": \"褶皱设计\",\n    \"材质\": \"光滑面料（疑似丝绸或缎面）\",\n    \"款式\": \"宽松剪裁\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示完整服装细节，无违规内容。颜色、款式和设计均符合平台规范，未发现虚假宣传或不当元素。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深紫色\",\n    \"领型\": \"V领\",\n    \"袖型\": \"无袖\",\n    \"设计特点\": \"褶皱设计\",\n    \"材质\": \"看起来为柔软垂坠的面料\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示完整衣物，无违规内容或不适当信息。视觉属性与描述一致，未发现虚假宣传或违禁内容。\"\n}"}
{"image_file": "product_01859.jpg", "image": "data/raw/images/product_01859.jpg", "prompt": "绿色系民族风印花短袖连衣裙", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"绿色系为主，搭配白色、紫色和黑色\",\n    \"图案\": \"民族风印花，包含几何图形和动物图案（如大象）\",\n    \"款式\": \"短袖连衣裙，V领设计，中长款\",\n    \"材质\": \"视觉上为棉质或混纺面料\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示完整服装细节，无违规内容。图案为传统民族风格，未涉及敏感元素，符合平台发布规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"绿色、白色、紫色、黑色\",\n    \"图案\": \"民族风印花，包含几何图案和动物图案（如大象）\",\n    \"款式\": \"短袖连衣裙\",\n    \"领型\": \"V领\",\n    \"长度\": \"及膝\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为绿色系民族风印花短袖连衣裙，图案为传统风格的几何与动物元素组合，未发现涉及敏感内容或违规信息，符合平台商品发布规范。\"\n}"}
{"image_file": "product_02410.jpg", "image": "data/raw/images/product_02410.jpg", "prompt": "最新款超低价全网最低绝对顶级黄色紧身裤，时尚百搭必备单品", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"紧身裤\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"长度\": \"长裤\",\n    \"设计特点\": \"修身剪裁，脚踝处有褶皱堆叠效果\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是常规服饰，无违规内容。描述中‘全网最低’‘绝对顶级’等用语存在夸大宣传嫌疑，但未在图片中体现，不构成视觉违规。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"紧身裤\",\n    \"材质\": \"棉质或类似弹性面料\",\n    \"搭配\": \"白色上衣，凉鞋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘全网最低’、‘绝对顶级’等绝对化用语和夸大宣传词汇，违反了广告法及电商平台关于禁止虚假宣传的相关规定。\"\n}"}
{"image_file": "product_02538.jpg", "image": "data/raw/images/product_02538.jpg", "prompt": "这款粉色衬衫包治百病，穿7天瘦10斤，一抹白，瞬间提升气质！", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"袖口\": \"白色袖口\",\n    \"口袋\": \"左侧胸前有一个贴袋\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"搭配\": \"黑色西裤和黑色皮带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含虚假宣传内容，如'包治百病'、'穿7天瘦10斤'等，属于夸大功效的违规表述，违反了广告法及电商平台关于商品宣传真实性的规定。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"袖口\": \"白色袖口\",\n    \"口袋\": \"左胸单口袋\",\n    \"材质\": \"棉质或混纺面料（视觉推断）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中存在虚假宣传和医疗效果宣称，如‘包治百病’、‘穿7天瘦10斤’等，属于夸大功效及误导性宣传，违反广告法及相关电商平台规范。实际图片仅为普通粉色衬衫，无任何功能性或健康相关特征支持此类说法。\"\n}"}
{"image_file": "product_00723.jpg", "image": "data/raw/images/product_00723.jpg", "prompt": "PUMA同款时尚帆布鞋，LV平替设计，小香风原单质感，潮流百搭必备", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"品牌标识\": \"PUMA\",\n    \"颜色\": \"黑白灰\",\n    \"材质\": \"帆布\",\n    \"款式\": \"低帮休闲鞋\",\n    \"图案\": \"抽象几何印花\",\n    \"鞋带\": \"白色\",\n    \"鞋底\": \"橡胶底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'PUMA同款'、'LV平替设计'等表述，涉嫌虚假宣传和误导消费者，且可能构成对知名品牌（如PUMA、LV）的侵权或仿冒暗示，违反平台关于品牌合规与广告真实性的规定。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"color\": \"black and white\",\n    \"material\": \"canvas\",\n    \"design\": \"low-top sneakers\",\n    \"pattern\": \"abstract print\",\n    \"lacing\": \"white laces\",\n    \"sole\": \"rubber with light brown edge\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'PUMA同款'和'LV平替设计'等词汇，存在暗示品牌仿冒或攀附知名品牌（如Puma、Louis Vuitton）的风险，可能误导消费者。同时，'小香风原单质感'涉及对奢侈品牌风格的不当借用，违反平台关于虚假宣传和品牌侵权的相关规则。\"\n}"}
{"image_file": "product_00415.jpg", "image": "data/raw/images/product_00415.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"gray\",\n    \"material\": \"leather\",\n    \"style\": \"casual sneaker\",\n    \"lacing\": \"lace-up\",\n    \"sole\": \"white rubber\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一双灰色皮质休闲鞋，而商品描述为'100%真丝连衣裙'，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"低帮系带休闲鞋\",\n    \"品牌\": \"Clarks\",\n    \"鞋底\": \"白色橡胶\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双灰色皮质休闲鞋，而商品描述为'100%真丝连衣裙'，图片与描述严重不符，属于虚假宣传。\"\n}"}
