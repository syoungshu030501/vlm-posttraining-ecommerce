{"image_file": "product_00000.jpg", "image": "data/raw/images/product_00000.jpg", "prompt": "经典款牛仔裤，修身显瘦", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"dark brown\",\n    \"material\": \"suede\",\n    \"style\": \"slip-on\",\n    \"sole\": \"rubber with speckled pattern\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双深棕色绒面革材质的休闲鞋，而商品描述为‘经典款牛仔裤，修身显瘦’，存在严重品类与描述不符的问题。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"一脚蹬\",\n    \"鞋底\": \"橡胶底，带有磨损痕迹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双深棕色绒面革男鞋，而商品描述为‘经典款牛仔裤，修身显瘦’，描述内容与实际商品严重不符，存在虚假宣传问题。\"\n}"}
{"image_file": "product_00002.jpg", "image": "data/raw/images/product_00002.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"设计元素\": \"布洛克雕花\",\n    \"鞋底\": \"橡胶平底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士正装鞋，无违规标识或敏感内容，符合平台销售规范。\"\n}", "rejected": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋型\": \"尖头\",\n    \"装饰\": \"雕花设计\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示了一双黑色绒面革材质的男士正装皮鞋，无明显违规信息，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00003.jpg", "image": "data/raw/images/product_00003.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"silver\",\n    \"material\": \"leather\",\n    \"style\": \"flat\",\n    \"design\": \"pleated toe\",\n    \"sole\": \"rubber\",\n    \"closure\": \"slip-on\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为银色平底鞋，材质为皮革，设计简洁，无违规元素。图片清晰展示产品细节，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"银色\",\n    \"材质\": \"金属光泽皮革\",\n    \"款式\": \"平底芭蕾舞鞋\",\n    \"细节\": \"编织缝线装饰，褶皱设计\",\n    \"鞋底\": \"浅棕色橡胶底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规款式的女性平底鞋，未发现违反平台规则的内容。图片清晰展示商品真实外观，无夸大宣传或虚假描述，符合‘时尚单品 手工制作 限量款’的描述，未涉及侵权或误导性信息。\"\n}"}
{"image_file": "product_00005.jpg", "image": "data/raw/images/product_00005.jpg", "prompt": "百搭连衣裙，适合日常出行", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"color\": \"棕色\",\n    \"material\": \"皮革\",\n    \"style\": \"系带皮鞋\",\n    \"design\": \"布洛克雕花\",\n    \"sole\": \"黑色橡胶底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双男士皮鞋，而商品描述为‘百搭连衣裙，适合日常出行’，存在严重品类与描述不符的问题。\"\n}", "rejected": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"正装皮鞋\",\n    \"鞋带\": \"系带式\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"细节\": \"雕花设计，翼尖款\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为男士正装皮鞋，而商品描述中提到'百搭连衣裙，适合日常出行'，描述内容与图片商品严重不符，属于虚假描述。\"\n}"}
{"image_file": "product_00006.jpg", "image": "data/raw/images/product_00006.jpg", "prompt": "经典款牛仔裤，修身显瘦", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"type\": \"Polo衫\",\n    \"color\": \"蓝绿白条纹\",\n    \"collar\": \"白色翻领\",\n    \"sleeve_length\": \"短袖\",\n    \"pattern\": \"横条纹\",\n    \"material\": \"棉质或混纺\",\n    \"brand_logo\": \"左胸有小标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件条纹Polo衫，但商品描述为‘经典款牛仔裤，修身显瘦’，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"女装上衣\",\n  \"attributes\": {\n    \"颜色\": \"蓝绿白条纹\",\n    \"款式\": \"短袖Polo衫\",\n    \"领型\": \"白色翻领\",\n    \"图案\": \"横向条纹\",\n    \"材质\": \"棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件条纹Polo衫，但商品描述为‘经典款牛仔裤，修身显瘦’，存在严重图文不符，违反平台商品信息真实性规则。\"\n}"}
{"image_file": "product_00007.jpg", "image": "data/raw/images/product_00007.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"灰色、红色、白色\",\n    \"材质\": \"网面、橡胶\",\n    \"款式\": \"跑鞋\",\n    \"品牌标识\": \"Reebok\",\n    \"鞋底设计\": \"波浪形中底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含'商场撤柜'、'专柜正品'、'便宜处理'等宣传用语，可能涉及虚假促销或误导性信息，且未提供具体品牌授权或正品证明，存在违规风险。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"灰色、红色、白色\",\n    \"材质\": \"网面、橡胶\",\n    \"款式\": \"跑步鞋\",\n    \"品牌标识\": \"Reebok\",\n    \"鞋底设计\": \"波浪形中底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含'商场撤柜'和'专柜正品'等可能误导消费者的信息，属于虚假宣传风险；且未提供具体品牌名称或授权证明，存在侵犯品牌权益的潜在风险。\"\n}"}
{"image_file": "product_00008.jpg", "image": "data/raw/images/product_00008.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"品牌标志\": \"Nike\",\n    \"材质\": \"合成纤维\",\n    \"款式\": \"棒球帽\",\n    \"细节\": \"帽檐边缘为黑色，侧面有Dri-FIT标识\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一顶蓝色Nike运动帽，而商品描述为‘简约设计衬衫，商务休闲两相宜’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"品牌标志\": \"Nike\",\n    \"材质\": \"运动面料\",\n    \"设计风格\": \"简约\",\n    \"款式\": \"棒球帽\",\n    \"细节\": \"帽檐边缘为黑色，侧面有'DRI-FIT'标识\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是蓝色Nike运动帽，但商品描述为'简约设计衬衫，商务休闲两相宜'，存在严重品类与描述不符的情况。\"\n}"}
{"image_file": "product_00009.jpg", "image": "data/raw/images/product_00009.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"白色印花，包含文字'La Coiffure'和玫瑰花图案\",\n    \"领型\": \"圆领\",\n    \"材质\": \"棉质（推测）\",\n    \"品牌标识\": \"FLAP DOODLE\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服饰，图案内容为艺术化文字与花卉设计，无违规信息或敏感元素，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"领型\": \"圆领\",\n    \"图案\": \"白色文字与玫瑰花组合印花，包含'La Coiffure'字样\",\n    \"品牌标识\": \"FLAP DOODLE\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服装，图案内容为品牌装饰性文字和花卉元素，未发现违法、违规或敏感信息，符合平台规范。\"\n}"}
{"image_file": "product_00010.jpg", "image": "data/raw/images/product_00010.jpg", "prompt": "高端羊毛面料，奢华质感", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"白色、红色、黑色\",\n    \"款式\": \"条纹Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"胸前有品牌标志，包含字母'FM'和翅膀图案\",\n    \"材质\": \"视觉上为棉质或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称使用'高端羊毛面料'，但图片显示的服装外观与典型羊毛材质不符，更接近棉质或化纤混纺面料。该描述存在虚假宣传嫌疑，违反了商品信息真实性原则。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"白底红黑条纹\",\n    \"款式\": \"短袖Polo衫\",\n    \"材质\": \"棉质（视觉判断）\",\n    \"图案\": \"胸前有品牌标志（TM Original）\",\n    \"领型\": \"翻领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称使用'高端羊毛面料，奢华质感'，但根据图片显示的织物纹理和光泽度判断，该服装为棉质或混纺面料，并非羊毛材质，存在材质虚假宣传。\"\n}"}
{"image_file": "product_00012.jpg", "image": "data/raw/images/product_00012.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"图案\": \"左胸有徽章刺绣\",\n    \"搭配\": \"浅色西裤、黑色皮带\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通男士休闲衬衫，无违规标识或敏感内容，符合平台销售规范。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"图案\": \"左胸有刺绣徽章\",\n    \"搭配\": \"卡其色裤子，黑色皮带\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述一致，展示为一件白色纯棉长袖衬衫，具备舒适透气的特点，未发现虚假宣传或违规内容。\"\n}"}
{"image_file": "product_00013.jpg", "image": "data/raw/images/product_00013.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"颜色\": \"白色与亮绿色拼接\",\n    \"款式\": \"短袖圆领\",\n    \"品牌标识\": \"Nike标志\",\n    \"材质\": \"运动面料（推测为速干透气材质）\",\n    \"设计风格\": \"运动休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为Nike品牌的运动T恤，具有明显的品牌标识和运动设计特征，而商品描述中称其为‘简约设计衬衫，商务休闲两相宜’，存在品类与描述不符的问题。该商品属于运动服饰，而非商务休闲衬衫，描述具有误导性。\"\n}", "rejected": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"颜色\": \"白色与荧光绿色拼接\",\n    \"款式\": \"短袖圆领\",\n    \"品牌标志\": \"Nike\",\n    \"材质\": \"透气运动面料\",\n    \"设计风格\": \"运动休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件带有Nike品牌标识的运动T恤，属于运动服饰类别，而商品描述为‘简约设计衬衫，商务休闲两相宜’，将运动服装错误描述为商务休闲衬衫，存在品类不符及误导性描述，违反了商品信息真实性的平台规则。\"\n}"}
{"image_file": "product_00014.jpg", "image": "data/raw/images/product_00014.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "chosen": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"黑色主体，绿色肩带和装饰\",\n    \"材质\": \"皮革\",\n    \"款式\": \"圆筒形手提包\",\n    \"五金件\": \"金色金属扣环和铆钉\",\n    \"缝线\": \"黄色缝线\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款黑色与绿色拼接的皮革手提包，而商品描述为‘运动休闲鞋，缓震耐磨橡胶底’，描述内容与图片严重不符，属于虚假描述。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": [\"black\", \"green\"],\n    \"material\": \"leather\",\n    \"hardware\": \"brass\",\n    \"style\": \"satchel\",\n    \"handle_type\": \"top_handle\",\n    \"stitching_color\": \"yellow\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一个黑色与绿色拼接的皮革手提包，而商品描述为'运动休闲鞋，缓震耐磨橡胶底'，存在严重图文不符，属于虚假描述。\"\n}"}
{"image_file": "product_00015.jpg", "image": "data/raw/images/product_00015.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"图案\": \"细条纹\",\n    \"款式\": \"正装西裤\",\n    \"材质\": \"羊毛混纺\",\n    \"搭配\": \"黑色皮带、黑色皮鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士正装西裤，无违规内容。图片展示清晰，符合平台对服装类商品的发布规范。\"\n}", "rejected": "{\n  \"category\": \"男装-西裤\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"图案\": \"细条纹\",\n    \"材质\": \"梭织面料\",\n    \"款式\": \"直筒\",\n    \"搭配\": \"白色衬衫、黑色皮带、黑色皮鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示灰色细条纹西裤，属于常规服装类目，无违规内容。描述中‘手工制作’‘限量款’等宣传语未在图中体现具体证据，但不构成虚假宣传，且未违反平台规则。\"\n}"}
{"image_file": "product_00017.jpg", "image": "data/raw/images/product_00017.jpg", "prompt": "欧美大牌设计 小众品牌", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"棉质或混纺面料\",\n    \"款式\": \"运动长裤\",\n    \"细节\": \"侧边绿色条纹装饰，腰部松紧设计，左腿有绿色品牌标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘欧美大牌设计’和‘小众品牌’等词汇可能构成虚假宣传或误导性描述，缺乏具体品牌信息支持，易误导消费者。同时，图片中可见品牌标识，但未提供合法授权证明，存在潜在侵权风险。\"\n}", "rejected": "{\n  \"category\": \"运动裤\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"侧边装饰\": \"绿色条纹\",\n    \"材质\": \"棉质或混纺面料\",\n    \"款式\": \"束脚休闲裤\",\n    \"品牌标识\": \"右腿上有绿色小logo\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘欧美大牌设计’和‘小众品牌’等可能误导消费者的宣传用语，易构成虚假或夸大宣传，违反平台关于商品描述真实性的规则。\"\n}"}
{"image_file": "product_00018.jpg", "image": "data/raw/images/product_00018.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"女装上衣\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"无袖\",\n    \"领型\": \"V领褶皱设计\",\n    \"材质\": \"纯棉\",\n    \"风格\": \"休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的为一件黑色无袖V领褶皱设计的休闲上衣，材质描述为纯棉，符合舒适透气的特性，未发现违规内容。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"无袖\",\n    \"领型\": \"V领褶皱设计\",\n    \"材质\": \"纯棉\",\n    \"长度\": \"中长款\",\n    \"搭配\": \"牛仔裤\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的为一件黑色无袖V领褶皱设计的上衣，材质标注为纯棉，符合休闲舒适类服装描述，未发现违规内容。\"\n}"}
{"image_file": "product_00020.jpg", "image": "data/raw/images/product_00020.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革表带，金属表壳，镶嵌装饰\",\n    \"款式\": \"矩形表盘，简约设计\",\n    \"品牌\": \"ESPRIT\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款手表，但描述中却标注为‘运动休闲鞋’，存在品类与描述严重不符的问题。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"black and silver\",\n    \"material\": \"leather strap, metal case with crystal embellishments\",\n    \"style\": \"rectangular face, minimalist design\",\n    \"brand\": \"ESPRIT\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款手表，但描述中却写着'运动休闲鞋，缓震耐磨橡胶底'，属于商品类别与实际图片严重不符，存在误导性描述。\"\n}"}
{"image_file": "product_00022.jpg", "image": "data/raw/images/product_00022.jpg", "prompt": "高端羊毛面料，奢华质感", "chosen": "{\n  \"category\": \"男装-西裤\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"图案\": \"细条纹\",\n    \"材质\": \"羊毛\",\n    \"款式\": \"直筒\",\n    \"搭配\": \"白色衬衫、黑色皮带、黑色皮鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规男士正装西裤，无违规内容。描述中提及的‘高端羊毛面料，奢华质感’与视觉呈现相符，未发现虚假宣传或敏感信息。\"\n}", "rejected": "{\n  \"category\": \"男装-西裤\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"材质\": \"羊毛\",\n    \"款式\": \"修身直筒\",\n    \"条纹\": \"细竖条纹\",\n    \"搭配\": \"黑色皮带、白色衬衫、黑色皮鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规男士西裤，无敏感图案或不当内容，描述中‘高端羊毛面料，奢华质感’符合实际视觉特征，未发现违规信息。\"\n}"}
{"image_file": "product_00023.jpg", "image": "data/raw/images/product_00023.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"类型\": \"计时码表\",\n    \"表盘颜色\": \"黑色\",\n    \"表带材质\": \"黑色皮革\",\n    \"表壳材质\": \"不锈钢\",\n    \"表圈\": \"单向旋转潜水刻度圈\",\n    \"功能\": [\"日期显示\", \"24小时制小表盘\", \"计时功能\"],\n    \"防水等级\": \"10BAR\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，为一款ESPRIT品牌的计时码表，具备清晰的品牌标识和功能性设计。描述中提及的‘时尚单品’、‘手工制作’、‘限量款’等宣传语未在图片中直接验证，但无明显虚假或误导性信息，不构成违规。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"type\": \"Chronograph\",\n    \"color\": \"黑色表盘，银色表壳，黑色皮质表带\",\n    \"features\": [\n      \"旋转表圈\",\n      \"三眼计时功能\",\n      \"日期显示\",\n      \"10巴防水\"\n    ],\n    \"material\": \"不锈钢表壳，皮革表带\",\n    \"design\": \"运动风格，现代简约\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述中的关键词‘时尚单品’相符，为品牌ESPRIT的正规产品，未发现冒用他人品牌、虚假宣传或侵权信息。‘手工制作’和‘限量款’等描述无直接证据支持，但未违反平台关于夸大宣传的核心规则。综合判断不构成违规。\"\n}"}
{"image_file": "product_00024.jpg", "image": "data/raw/images/product_00024.jpg", "prompt": "纯手工编织，限量发售", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"黑白复古风格女性舞蹈人物印花\",\n    \"材质\": \"棉质（推测）\",\n    \"设计元素\": \"圆领、修身剪裁\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'纯手工编织'，但图片显示该商品为普通印花T恤，无任何编织工艺特征，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"黑白复古风格的女性舞者插画\",\n    \"材质\": \"棉质（视觉推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘纯手工编织’，但图片显示为印花T恤，属于机器生产或印刷工艺，与‘手工编织’描述严重不符，构成虚假宣传。\"\n}"}
{"image_file": "product_00025.jpg", "image": "data/raw/images/product_00025.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"belt\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"buckle_type\": \"metallic square buckle\",\n    \"texture\": \"textured surface\",\n    \"style\": \"minimalist\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为黑色皮质腰带，搭配金属方形扣，整体设计简约，符合日系简约、ins风及学院风描述，无违规元素。\"\n}", "rejected": "{\n  \"category\": \"belt\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"buckle_type\": \"metallic square buckle\",\n    \"texture\": \"grainy surface\",\n    \"style\": \"minimalist\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为黑色皮革腰带，搭配金属方形扣，整体设计简洁，符合日系简约与学院风格描述，未发现违规元素。\"\n}"}
{"image_file": "product_00026.jpg", "image": "data/raw/images/product_00026.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"无袖连帽背心\",\n    \"图案\": \"数字63、1A和文字DIVI\",\n    \"材质\": \"棉质或混纺面料（推测）\",\n    \"设计元素\": \"运动风格印花，带有涂鸦效果\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通儿童运动服饰，图案和文字未涉及敏感内容，符合平台合规标准。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"无袖连帽背心\",\n    \"图案\": \"正面印有蓝色数字'63'和白色文字'DIVI 1A'，背景为深色涂鸦风格数字\",\n    \"材质\": \"棉质或混纺面料（推测）\",\n    \"适用人群\": \"儿童或青少年\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为常规儿童服装，无违规图案、文字或标识，符合平台内容规范。\"\n}"}
{"image_file": "product_00027.jpg", "image": "data/raw/images/product_00027.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"metallic bronze\",\n    \"material\": \"leather-like synthetic\",\n    \"style\": \"wedge sandal\",\n    \"design\": \"knotted strap\",\n    \"brand\": \"Clarks\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双金属色坡跟凉鞋，而商品描述为‘纯棉休闲上衣’，存在严重品类与描述不符的情况。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"品牌\": \"Clarks\",\n    \"款式\": \"楔形凉拖\",\n    \"材质\": \"金属光泽皮革\",\n    \"颜色\": \"古铜色\",\n    \"设计特点\": \"交叉绑带、蝴蝶结装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双Clarks品牌的金属色楔形凉拖，属于鞋类产品，而提供的商品描述为‘纯棉休闲上衣’，与实际商品类别严重不符，构成描述虚假或误导性信息。\"\n}"}
{"image_file": "product_00028.jpg", "image": "data/raw/images/product_00028.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"淡紫色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"世界地图及英文标语\",\n    \"文字内容\": \"LOOKING FOR A WORLD WITH NO BORDERS AND LIMITS\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件印有世界地图和英文标语的T恤，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"T恤\",\n  \"attributes\": {\n    \"颜色\": \"淡紫色\",\n    \"图案\": \"世界地图\",\n    \"文字\": \"LOOKING FOR A WORLD WITH NO BORDERS AND LIMITS\",\n    \"材质\": \"棉质\",\n    \"款式\": \"圆领短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件印有世界地图和标语的T恤，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重品类不符。图片中无任何皮鞋或相关商品信息，构成虚假宣传。\"\n}"}
{"image_file": "product_00029.jpg", "image": "data/raw/images/product_00029.jpg", "prompt": "高端羊毛面料，奢华质感", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"灰色、蓝色、黑色\",\n    \"材质\": \"合成材料\",\n    \"款式\": \"凉鞋\",\n    \"闭合方式\": \"魔术贴\",\n    \"鞋底\": \"厚底，防滑纹路\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为合成材料制成的运动凉鞋，而商品描述中声称使用‘高端羊毛面料’，存在材质描述与实际不符的虚假宣传问题。\"\n}", "rejected": "{\n  \"category\": \"sandals\",\n  \"attributes\": {\n    \"color\": \"gray and blue\",\n    \"material\": \"synthetic leather\",\n    \"closure_type\": \"velcro straps\",\n    \"sole_material\": \"rubber\",\n    \"design\": \"sporty\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为合成皮革材质的凉鞋，但描述中声称使用‘高端羊毛面料’，存在材质描述与实物严重不符的情况。\"\n}"}
{"image_file": "product_00030.jpg", "image": "data/raw/images/product_00030.jpg", "prompt": "韩版潮流服饰，时尚百搭", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色与棕色条纹\",\n    \"款式\": \"短袖Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"胸前有白色刺绣标志\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士Polo衫，无违规图案、文字或敏感元素，符合平台服装类目规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色底色，黑色和米色条纹\",\n    \"款式\": \"短袖Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"胸前有白色徽标图案\",\n    \"材质\": \"棉质或混纺面料（视觉推断）\",\n    \"适用性别\": \"男\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为常规男士Polo衫，无违禁内容、不当信息或侵权标识，符合平台对服饰类商品的合规要求。\"\n}"}
{"image_file": "product_00031.jpg", "image": "data/raw/images/product_00031.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"吊带连衣裙\",\n    \"领型\": \"抹胸式\",\n    \"装饰\": \"彩色条纹刺绣\",\n    \"裙摆\": \"荷叶边设计\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规女装连衣裙，无违规内容，符合平台销售规范。\"\n}", "rejected": "{\n  \"category\": \"女装-连衣裙\",\n  \"attributes\": {\n    \"颜色\": \"蓝色（牛仔布色调）\",\n    \"材质\": \"棉质/牛仔布\",\n    \"款式\": \"吊带、无袖、A字裙\",\n    \"领口设计\": \"抹胸式，胸前有彩色条纹绣花装饰\",\n    \"肩带\": \"细肩带，可调节系带\",\n    \"裙摆\": \"荷叶边下摆\",\n    \"图案\": \"领口区域为彩色几何刺绣条纹\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示连衣裙的完整外观，无夸大宣传或虚假描述。视觉上符合'2024新款'及'实体店同款'的合理性，未发现违规元素。\"\n}"}
{"image_file": "product_00032.jpg", "image": "data/raw/images/product_00032.jpg", "prompt": "百搭连衣裙，适合日常出行", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"suede\",\n    \"style\": \"lace-up\",\n    \"sole_color\": \"black\",\n    \"type\": \"men's dress shoe\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双男士棕色绒面皮鞋，而商品描述为‘百搭连衣裙，适合日常出行’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "```json\n{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋底\": \"黑色橡胶底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为男士棕色系带皮鞋，而商品描述中提到‘百搭连衣裙，适合日常出行’，描述内容与实际图片商品严重不符，构成虚假描述违规。\"\n}\n```"}
{"image_file": "product_00033.jpg", "image": "data/raw/images/product_00033.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "chosen": "{\n  \"category\": \"运动服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"斜向闪电状条纹\",\n    \"材质\": \"Dri-FIT面料\",\n    \"款式\": \"长袖半拉链运动上衣\",\n    \"品牌\": \"Nike\",\n    \"功能\": \"透气、速干\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件运动上衣，但商品描述为‘运动休闲鞋’，存在严重品类不符，属于虚假描述。\"\n}", "rejected": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"品牌\": \"Nike\",\n    \"颜色\": \"黑色\",\n    \"图案\": \"斜向闪电状条纹\",\n    \"材质\": \"Dri-FIT 技术面料\",\n    \"款式\": \"长袖半拉链运动上衣\",\n    \"功能\": \"透气、速干\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一件Nike品牌的黑色长袖运动上衣，而商品描述中却写的是‘运动休闲鞋’，属于图片与描述严重不符，违反平台真实性审核规则。\"\n}"}
{"image_file": "product_00037.jpg", "image": "data/raw/images/product_00037.jpg", "prompt": "国风刺绣上衣，传统工艺", "chosen": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"深紫色\",\n    \"材质\": \"皮革\",\n    \"图案\": \"格纹缝线\",\n    \"五金件\": \"金色金属扣\",\n    \"款式\": \"单肩包\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款深紫色皮革单肩包，带有格纹缝线和金色金属扣，与描述中的‘国风刺绣上衣’严重不符，存在虚假描述问题。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"purple\",\n    \"material\": \"leather\",\n    \"pattern\": \"grid\",\n    \"style\": \"shoulder_bag\",\n    \"hardware\": \"gold-tone_buckle\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片为一款紫色皮革手提包，带有格纹缝线和金属扣件，与描述中的‘国风刺绣上衣’完全不符，存在严重图文不符问题。\"\n}"}
{"image_file": "product_00039.jpg", "image": "data/raw/images/product_00039.jpg", "prompt": "欧美风格外套，时尚简约", "chosen": "{\n  \"category\": \"婴儿服装\",\n  \"attributes\": {\n    \"颜色\": \"粉色系\",\n    \"款式\": \"无袖连体衣\",\n    \"图案\": [\"蝴蝶\", \"卡通猫\", \"hug me\"],\n    \"材质\": \"棉质\",\n    \"适用年龄\": \"9-12个月\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是婴儿连体衣，与描述中的'欧美风格外套，时尚简约'严重不符，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"baby clothing\",\n  \"attributes\": {\n    \"color\": \"pink\",\n    \"pattern\": [\"striped\", \"polka dot\", \"solid\"],\n    \"design\": [\"butterfly\", \"cat\", \"hug me\"],\n    \"material\": \"cotton\",\n    \"size\": \"9-12 months\",\n    \"style\": \"onesie\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是婴儿连体衣（onesie），而商品描述为'欧美风格外套，时尚简约'，存在品类和描述严重不符的问题。\"\n}"}
{"image_file": "product_00040.jpg", "image": "data/raw/images/product_00040.jpg", "prompt": "欧美风格外套，时尚简约", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅橙色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"自行车插画及环保标语\",\n    \"材质\": \"棉质（推测）\",\n    \"设计风格\": \"休闲、环保主题\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件印有环保标语和自行车图案的短袖T恤，而商品描述为‘欧美风格外套，时尚简约’，存在明显品类与描述不符的问题。实际商品并非外套，且描述未准确反映产品特征，构成虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"浅橙色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"自行车插画与环保标语\",\n    \"材质\": \"棉质\",\n    \"设计风格\": \"休闲环保主题\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件印有环保标语和自行车图案的短袖T恤，而商品描述为'欧美风格外套，时尚简约'，存在严重品类与描述不符的问题。实际商品并非外套，且描述中的'外套'与图中所示的T恤类别不一致，构成虚假宣传。\"\n}"}
{"image_file": "product_00041.jpg", "image": "data/raw/images/product_00041.jpg", "prompt": "欧美大牌设计 小众品牌", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表盘形状\": \"矩形\",\n    \"表盘颜色\": \"银色\",\n    \"表带材质\": \"金属\",\n    \"表带颜色\": \"银色\",\n    \"表盘装饰\": \"镶钻边框\",\n    \"品牌标志\": \"Puma（彪马）\",\n    \"数字显示\": \"12\",\n    \"指针样式\": \"黑色镂空设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中清晰可见Puma（彪马）品牌标志，属于知名品牌，与商品描述中‘小众品牌’存在明显不符，涉嫌虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"银色\",\n    \"表盘形状\": \"矩形\",\n    \"表带材质\": \"金属质感\",\n    \"表圈装饰\": \"镶钻\",\n    \"品牌标志\": \"Puma（彪马）\",\n    \"表盘数字\": \"12\",\n    \"表盘设计\": \"简约时尚\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中清晰显示了Puma（彪马）的官方品牌标识，属于知名品牌。商品描述中使用“欧美大牌设计 小众品牌”可能构成虚假宣传或误导性描述，存在误导消费者风险，违反平台关于品牌真实性和广告合规的相关规则。\"\n}"}
{"image_file": "product_00042.jpg", "image": "data/raw/images/product_00042.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺\",\n    \"纽扣\": \"银色金属纽扣\",\n    \"图案\": \"细条纹纹理\",\n    \"搭配\": \"深色格纹西裤和黑色皮带\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为常规男士正装衬衫，无违规内容，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"color\": \"灰色\",\n    \"material\": \"棉质或混纺\",\n    \"style\": \"长袖衬衫\",\n    \"pattern\": \"细格纹\",\n    \"buttons\": \"单色纽扣\",\n    \"collar_type\": \"标准翻领\",\n    \"fit\": \"修身\"\n  },\n  \"violation\": false,\n  \"reason\": \"图片展示的商品为常规男式正装衬衫，无违规图案、文字或敏感元素，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00043.jpg", "image": "data/raw/images/product_00043.jpg", "prompt": "时尚秋冬外套，多色可选", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"粉色与蓝色条纹\",\n    \"款式\": \"短袖Polo衫\",\n    \"材质\": \"棉质或混纺面料\",\n    \"品牌标识\": \"Puma标志\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"红色纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件短袖Polo衫，而商品描述为‘时尚秋冬外套’，存在严重品类不符。图片中衣物为夏季款式，且无外套特征，与描述中的‘秋冬外套’明显矛盾。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"款式\": \"Polo衫\",\n    \"颜色\": \"粉红色与浅蓝色条纹\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"品牌标识\": \"Puma标志\",\n    \"材质\": \"棉质或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件夏季条纹Polo衫，但描述中称其为‘时尚秋冬外套’，存在品类与季节不符的问题，属于虚假宣传。\"\n}"}
{"image_file": "product_00044.jpg", "image": "data/raw/images/product_00044.jpg", "prompt": "纯手工编织，限量发售", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"材质\": \"牛仔布\",\n    \"款式\": \"A字短裙\",\n    \"颜色\": \"蓝色\",\n    \"装饰\": \"紫色花卉图案腰带\",\n    \"细节\": \"前口袋、金属纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'纯手工编织'，但图片显示为机织牛仔布材质的成品裙，无编织工艺特征，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"女装-裙子\",\n  \"attributes\": {\n    \"材质\": \"牛仔布\",\n    \"颜色\": \"蓝色\",\n    \"款式\": \"A字裙\",\n    \"装饰\": \"紫色花卉图案腰带\",\n    \"长度\": \"短款\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'纯手工编织'，但图片显示为机器缝制的牛仔裙，未体现编织工艺，存在虚假宣传。\"\n}"}
{"image_file": "product_00045.jpg", "image": "data/raw/images/product_00045.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"tan\",\n    \"material\": \"leather-like\",\n    \"style\": \"hobo\",\n    \"features\": [\n      \"two front zippered pockets\",\n      \"adjustable shoulder strap\",\n      \"top handle\",\n      \"metal hardware\"\n    ]\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘商场撤柜’、‘专柜正品’等宣传性用语，可能涉及虚假或夸大宣传，且未提供品牌信息或正品证明，存在误导消费者的风险。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"tan\",\n    \"material\": \"leather-like\",\n    \"design\": \"shoulder bag\",\n    \"features\": [\n      \"two front zippered pockets\",\n      \"yellow stitching\",\n      \"metal hardware\",\n      \"adjustable shoulder strap\"\n    ]\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含'商场撤柜'和'专柜正品'等宣传性用语，可能涉嫌虚假或夸大宣传，且未提供品牌授权证明，存在误导消费者的风险。\"\n}"}
{"image_file": "product_00047.jpg", "image": "data/raw/images/product_00047.jpg", "prompt": "国风刺绣上衣，传统工艺", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"style\": \"shoulder bag\",\n    \"features\": [\"double handles\", \"metal rings\", \"sewn panels\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款黑色皮质手提包，而商品描述为'国风刺绣上衣，传统工艺'，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "```json\n{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"style\": \"shoulder bag\",\n    \"handle_type\": \"dual handles\",\n    \"hardware\": \"metal rings\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为黑色皮质手提包，但描述中提到'国风刺绣上衣，传统工艺'，存在明显图文不符，属于虚假宣传。\"\n}\n```"}
{"image_file": "product_00048.jpg", "image": "data/raw/images/product_00048.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"color\": \"黑色与红色\",\n    \"display_type\": \"数字显示屏\",\n    \"features\": [\n      \"闹钟功能\",\n      \"心率监测图标\",\n      \"运动模式图标\"\n    ],\n    \"material\": \"橡胶表带，金属边框\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款Puma品牌智能手表，但商品描述为‘简约设计衬衫，商务休闲两相宜’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "```json\n{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"black and red\",\n    \"material\": \"plastic and metal\",\n    \"brand\": \"Puma\",\n    \"display_type\": \"digital\",\n    \"features\": [\"alarm\", \"heart rate monitor\", \"pause function\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款Puma品牌智能手表，而商品描述为'简约设计衬衫，商务休闲两相宜'，存在严重品类与描述不符的情况。\"\n}\n```"}
{"image_file": "product_00049.jpg", "image": "data/raw/images/product_00049.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"人字拖\",\n    \"装饰\": \"贝壳镶嵌、金属边框\",\n    \"品牌\": \"Chloe & Co\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘商场撤柜’‘专柜正品’‘便宜处理’等促销性用语，可能涉及虚假宣传或价格欺诈风险，且未提供具体来源证明，不符合平台对商品真实性和合规性的要求。\"\n}", "rejected": "{\n  \"category\": \"footwear\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather\",\n    \"style\": \"sandals\",\n    \"design\": \"embellished with shell-like inlays and beading\",\n    \"heel_type\": \"low heel\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'商场撤柜 专柜正品 便宜处理'等表述，暗示商品为库存清仓或低价促销，可能涉及虚假宣传或误导性信息。同时，图片展示的为品牌鞋履（Chloe Cushion），若未明确标注品牌来源或授权信息，存在侵犯知识产权风险。\"\n}"}
{"image_file": "product_00051.jpg", "image": "data/raw/images/product_00051.jpg", "prompt": "欧美大牌设计 小众品牌", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"印有运动鞋和文字'Walk Tight'\",\n    \"材质\": \"棉质（推测）\",\n    \"设计风格\": \"休闲潮流\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的T恤图案包含与知名品牌Puma相似的运动鞋设计，且文字'Walk Tight'与Puma品牌口号'Just Do It'存在视觉和语义上的混淆风险，可能构成侵权。此外，商品描述中使用'欧美大牌设计 小众品牌'易误导消费者认为其为高端或授权品牌产品，涉嫌虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"白色手写体文字 'Walk Tight'，下方是一双黑白粉相间的运动鞋图案\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的运动鞋图案设计与知名运动品牌Puma的鞋款高度相似，且鞋带部分巧妙地融入了文字设计，存在明显的模仿和潜在的商标侵权风险。结合描述中‘欧美大牌设计’和‘小众品牌’的表述，可能构成对知名品牌的设计抄袭及误导性宣传。\"\n}"}
{"image_file": "product_00052.jpg", "image": "data/raw/images/product_00052.jpg", "prompt": "欧美风格外套，时尚简约", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色和银色\",\n    \"表盘形状\": \"方形\",\n    \"表带材质\": \"皮革\",\n    \"品牌标志\": \"Puma\",\n    \"表盘设计\": \"现代简约风格，带有数字12和放射状刻度\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款Puma品牌的手表，而商品描述为'欧美风格外套，时尚简约'，存在严重品类与描述不符的情况。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"Puma\",\n    \"表盘形状\": \"方形\",\n    \"表带材质\": \"黑色皮革\",\n    \"表带颜色\": \"黑色\",\n    \"表盘颜色\": \"白色\",\n    \"指针样式\": \"简约设计\",\n    \"小表盘功能\": \"秒针\",\n    \"标志位置\": \"右下角\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款Puma品牌的腕表，但商品描述为'欧美风格外套，时尚简约'，存在严重的图文不符问题，违反平台商品信息真实性规范。\"\n}"}
{"image_file": "product_00053.jpg", "image": "data/raw/images/product_00053.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"fastrack\",\n    \"表盘形状\": \"三角形\",\n    \"表带材质\": \"金属\",\n    \"表盘颜色\": \"白色\",\n    \"指针颜色\": \"金色\",\n    \"设计风格\": \"现代简约\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'日系简约 ins风 学院风'等主观风格词汇，但图片显示的手表为fastrack品牌，具有明显的现代金属设计和三角形表盘，属于都市时尚风格，与'日系'、'学院风'等描述不符，存在误导性宣传。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"银色\",\n    \"材质\": \"金属\",\n    \"表盘形状\": \"三角形\",\n    \"表带设计\": \"交叉编织式\",\n    \"品牌\": \"fastrack\",\n    \"指针颜色\": \"金色\",\n    \"表盘背景\": \"白色\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的手表为fastrack品牌，属于特定品牌产品，而商品描述中使用‘日系简约 ins风 学院风’等泛化风格词汇可能误导消费者，未准确反映实际品牌属性，违反了平台关于商品描述真实性和品牌信息准确性的规则。\"\n}"}
{"image_file": "product_00054.jpg", "image": "data/raw/images/product_00054.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色表带，银色表壳\",\n    \"材质\": \"金属表壳，皮革表带\",\n    \"款式\": \"矩形表盘，简约设计\",\n    \"品牌\": \"ESPRIT\",\n    \"表盘图案\": \"几何纹理\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款手表，但商品描述为‘运动休闲鞋’，存在严重品类不符，属于虚假描述。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘形状\": \"矩形\",\n    \"表带材质\": \"黑色皮革\",\n    \"表壳材质\": \"金属\",\n    \"表盘颜色\": \"深蓝色\",\n    \"表盘图案\": \"几何纹路\",\n    \"指针样式\": \"简约银色指针\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款ESPRIT品牌的矩形金属表壳手表，而描述中却为‘运动休闲鞋，缓震耐磨橡胶底’，属于图文不符，严重违反平台商品描述真实性规则。\"\n}"}
{"image_file": "product_00055.jpg", "image": "data/raw/images/product_00055.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"color\": \"银色与蓝白格纹\",\n    \"material\": \"金属表壳，织物表带\",\n    \"design\": \"简约风格，圆形表盘，数字刻度\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款Puma品牌的手表，而商品描述为‘简约设计衬衫，商务休闲两相宜’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "```json\n{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"Puma\",\n    \"表盘颜色\": \"白色\",\n    \"表盘数字\": \"黑色\",\n    \"表带材质\": \"织物\",\n    \"表带图案\": \"蓝白格纹\",\n    \"表壳材质\": \"金属\",\n    \"表带扣类型\": \"金属搭扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款Puma品牌的手表，但商品描述为'简约设计衬衫，商务休闲两相宜'，描述与图片内容严重不符，属于虚假描述违规。\"\n}\n```"}
{"image_file": "product_00056.jpg", "image": "data/raw/images/product_00056.jpg", "prompt": "时尚秋冬外套，多色可选", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"olive green\",\n    \"material\": \"leather\",\n    \"style\": \"peep-toe slingback\",\n    \"heel_type\": \"medium heel\",\n    \"closure\": \"ankle strap with buckle\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双女士高跟鞋，而商品描述为‘时尚秋冬外套，多色可选’，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"metallic gray\",\n    \"material\": \"leather\",\n    \"style\": \"peep-toe slingback\",\n    \"heel_type\": \"medium heel\",\n    \"closure\": \"strap with buckle\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双金属灰色的女士高跟鞋，而商品描述为'时尚秋冬外套，多色可选'，存在严重品类与描述不符，属于虚假宣传。\"\n}"}
{"image_file": "product_00057.jpg", "image": "data/raw/images/product_00057.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"材质\": \"网眼布\",\n    \"品牌\": \"Reebok\",\n    \"鞋带颜色\": \"深蓝色\",\n    \"鞋底\": \"白色橡胶\",\n    \"设计风格\": \"运动休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为Reebok品牌运动鞋，属于知名品牌产品，但商品描述中声称‘手工制作’和‘限量款’，这与大众化量产运动鞋的实际情况不符，存在虚假宣传嫌疑。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"color\": \"蓝色\",\n    \"material\": \"网眼布\",\n    \"lacing\": \"深蓝色鞋带\",\n    \"sole\": \"白色橡胶底\",\n    \"brand\": \"Reebok\",\n    \"design\": \"透气网面，轻质跑鞋设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为Reebok品牌运动鞋，而描述中声称'手工制作'和'限量款'，这与主流品牌的批量生产模式存在明显矛盾，且可能构成虚假宣传。\"\n}"}
{"image_file": "product_00058.jpg", "image": "data/raw/images/product_00058.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "chosen": "{\n  \"category\": \"童装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"领口\": \"白色罗纹圆领\",\n    \"图案\": \"白色文字 'YES I AM AS SMART AS I LOOK'\",\n    \"品牌\": \"BeBorn\",\n    \"材质\": \"棉质（推测）\",\n    \"款式\": \"短袖T恤\",\n    \"适用年龄\": \"婴儿/幼儿\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为婴儿服装，但商品描述中使用了‘显瘦神器’等成人化、不适用于婴儿的营销话术，存在误导性宣传，违反平台关于儿童商品描述真实性的规定。\"\n}", "rejected": "{\n  \"category\": \"童装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"短袖T恤\",\n    \"领型\": \"圆领\",\n    \"印花文字\": \"YES I AM AS SMART AS I LOOK\",\n    \"品牌标识\": \"BeBorn\",\n    \"材质描述\": \"柔软面料\",\n    \"版型\": \"修身\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为儿童T恤，图文内容无违规信息，未涉及敏感话题或不当表述。文字内容属于幽默风格的自我表达，符合童装市场常见设计，不违反平台内容规范。\"\n}"}
{"image_file": "product_00059.jpg", "image": "data/raw/images/product_00059.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"女装上衣\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"款式\": \"无袖\",\n    \"领型\": \"交叉系带领\",\n    \"材质\": \"针织面料\",\n    \"设计特点\": \"前襟系带装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的服装为无袖背心式设计，与描述中‘衬衫’不符，存在品类描述不实的问题。\"\n}", "rejected": "{\n  \"category\": \"女装上衣\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"款式\": \"无袖\",\n    \"领型\": \"交叉系带领\",\n    \"材质\": \"针织面料\",\n    \"设计特点\": \"前部系带装饰\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一件深灰色无袖上衣，具有交叉系带领设计，整体风格简约时尚，符合商务休闲定位，未发现违规内容。\"\n}"}
{"image_file": "product_00060.jpg", "image": "data/raw/images/product_00060.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表壳形状\": \"矩形\",\n    \"表盘颜色\": \"黑色\",\n    \"表带材质\": \"黑色皮革\",\n    \"表盘数字\": \"银色阿拉伯数字\",\n    \"品牌标识\": \"ESPRIT\",\n    \"小表盘功能\": \"秒针显示\",\n    \"表壳材质\": \"金属（拉丝处理）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通时尚手表，无违规标识或内容，符合平台销售规范。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"case_shape\": \"rectangular\",\n    \"case_material\": \"stainless_steel\",\n    \"dial_color\": \"black\",\n    \"strap_material\": \"leather\",\n    \"strap_color\": \"black\",\n    \"features\": [\n      \"date_window\",\n      \"seconds_sub_dial\"\n    ],\n    \"design_style\": \"modern\",\n    \"movement_type\": \"quartz\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，为一款设计现代的ESPRIT品牌手表，具有黑色表盘、不锈钢矩形表壳和黑色皮革表带。'时尚单品'、'手工制作'及'限量款'等描述在图像中无直接证据支持，但未构成虚假宣传或违规，因这些术语在时尚产品中常见且未明确违反规则。\"\n}"}
{"image_file": "product_00061.jpg", "image": "data/raw/images/product_00061.jpg", "prompt": "经典款牛仔裤，修身显瘦", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"黑白格纹\",\n    \"款式\": \"短袖衬衫裙\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"图案\": \"格子\",\n    \"纽扣\": \"前排黑色纽扣\",\n    \"下摆\": \"A字型\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件黑白格纹短袖衬衫裙，而商品描述为‘经典款牛仔裤，修身显瘦’，描述与实际商品严重不符，存在虚假宣传问题。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"款式\": \"短袖格子衬衫\",\n    \"颜色\": \"黑白格纹\",\n    \"材质\": \"棉质或混纺\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"闭合方式\": \"前排纽扣\",\n    \"下摆\": \"不规则斜裁\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件黑白格子短袖衬衫，而商品描述为‘经典款牛仔裤，修身显瘦’，存在严重图文不符。图片中并未出现任何牛仔裤，因此该商品描述属于虚假宣传。\"\n}"}
{"image_file": "product_00062.jpg", "image": "data/raw/images/product_00062.jpg", "prompt": "国风刺绣上衣，传统工艺", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"红色与黑色\",\n    \"品牌\": \"Puma\",\n    \"类型\": \"电子表\",\n    \"显示内容\": \"时间、日期、秒数\",\n    \"材质\": \"塑料/硅胶\",\n    \"功能图标\": [\"太阳\", \"心率\", \"暂停\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款Puma品牌的电子手表，而商品描述为‘国风刺绣上衣，传统工艺’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "```json\n{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"color\": \"红色\",\n    \"material\": \"硅胶\",\n    \"brand\": \"Puma\",\n    \"display_type\": \"数字\",\n    \"features\": [\n      \"心率监测\",\n      \"运动模式\",\n      \"暂停功能\"\n    ]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款Puma品牌的智能手表，而商品描述为‘国风刺绣上衣，传统工艺’，描述与实际商品严重不符，存在误导消费者的风险。\"\n}\n```"}
{"image_file": "product_00063.jpg", "image": "data/raw/images/product_00063.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"绿色文字和图形，包含'STOP GLOBAL WARMING'字样及地球图案\",\n    \"材质\": \"棉质（推测）\",\n    \"款式\": \"短袖T恤\",\n    \"设计风格\": \"环保主题印花\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通环保主题T恤，图案内容无违法不良信息，未涉及政治、宗教、色情或暴力等敏感元素，符合平台合规要求。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"绿色文字和图形，包含 'STOP GLOBAL WARMING' 和 'It's a FLAP DOODLE planet'\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"未明确，但常见为棉质\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的图案包含环保口号'STOP GLOBAL WARMING'，但下方附加了'FLAP DOODLE'等无实际意义的词语，可能构成虚假或误导性宣传，易被误解为支持某种特定品牌或理念，违反平台对广告语真实性和合规性的要求。\"\n}"}
{"image_file": "product_00065.jpg", "image": "data/raw/images/product_00065.jpg", "prompt": "欧美风格外套，时尚简约", "chosen": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"米色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"单肩包\",\n    \"设计风格\": \"简约\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款手提包，但商品描述中却标注为'欧美风格外套，时尚简约'，存在品类与描述严重不符的问题。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"beige\",\n    \"material\": \"leather\",\n    \"style\": \"satchel\",\n    \"handle_type\": \"top_handle\",\n    \"closure\": \"snap_button\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为手提包，但描述中却标注为‘欧美风格外套’，存在品类与描述严重不符的问题。\"\n}"}
{"image_file": "product_00066.jpg", "image": "data/raw/images/product_00066.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色与白色拼接\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"数字'39'和文字'ATHLETIC DEP. DIV .IA'\",\n    \"材质\": \"棉质或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件儿童T恤，而商品描述为'高端品牌商务皮鞋，真皮鞋面'，存在严重品类不符。图片中无任何皮鞋或相关元素，属于虚假描述。\"\n}", "rejected": "```json\n{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色和白色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"数字'39'、'ATHLETIC DEP.'和'DIV. IA'的印花\",\n    \"材质\": \"未明确显示，但视觉上为棉质或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件儿童T恤，而描述中却声称是‘高端品牌商务皮鞋，真皮鞋面’，两者严重不符。商品图与文字描述存在明显不一致，构成虚假宣传，违反平台规范。\"\n}\n```"}
{"image_file": "product_00067.jpg", "image": "data/raw/images/product_00067.jpg", "prompt": "欧美风格外套，时尚简约", "chosen": "{\n  \"category\": \"T恤\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"PUMA品牌标志、'TRACK CHAMPIONS'、'CABANA RACER'、'85'、日文'スポーツウェア'、绿色和紫色线条设计\",\n    \"款式\": \"圆领短袖\",\n    \"材质\": \"棉质或混纺面料（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件印有PUMA品牌标志及文字的T恤，属于品牌服饰，但商品描述为'欧美风格外套，时尚简约'，存在品类与描述不符的问题。实际商品为T恤而非外套，且未体现'简约'风格，图案复杂，因此违反了商品描述真实性规则。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"PUMA品牌标识、'TRACK CHAMPIONS'、'CABANA RACER'、'85'、日文文字和彩色条纹\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"性别\": \"男款\",\n    \"设计风格\": \"运动休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件PUMA品牌的短袖T恤，属于运动服饰，而商品描述为'欧美风格外套，时尚简约'，存在品类和描述严重不符的问题。图片中并无外套，且该产品为印花T恤，并非简约风格，因此描述不实。\"\n}"}
{"image_file": "product_00068.jpg", "image": "data/raw/images/product_00068.jpg", "prompt": "欧美风格外套，时尚简约", "chosen": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"颜色\": \"红色主体，白色袖子\",\n    \"品牌\": \"Nike\",\n    \"球队标志\": \"Arsenal\",\n    \"赞助商\": \"Fly Emirates\",\n    \"款式\": \"短袖球衣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为阿森纳足球俱乐部的官方球衣，属于体育用品类别，而商品描述中将其归类为‘欧美风格外套’，存在品类与实际不符的情况，且可能涉及未经授权的品牌或球队标识使用，违反平台对商品信息真实性和合规性的要求。\"\n}", "rejected": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"颜色\": \"红色与白色拼接\",\n    \"品牌标志\": \"Nike\",\n    \"球队徽章\": \"Arsenal\",\n    \"赞助商字样\": \"Fly Emirates\",\n    \"款式\": \"短袖球衣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是阿森纳足球俱乐部的官方球衣，属于体育用品类别，但商品描述为'欧美风格外套，时尚简约'，存在品类和描述不符的问题。实际商品并非外套，且具有明确的体育团队标识，不能归类为普通时尚外套。\"\n}"}
{"image_file": "product_00069.jpg", "image": "data/raw/images/product_00069.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"拼贴艺术风格人脸图案，包含多个抽象人脸元素和文字说明\",\n    \"材质\": \"棉质或混纺面料\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士T恤，但商品描述为'运动休闲鞋，缓震耐磨橡胶底'，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"抽象拼贴画风格，包含人脸元素和文字\",\n    \"材质\": \"棉质\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男式印花T恤，但商品描述为'运动休闲鞋，缓震耐磨橡胶底'，属于品类与实物严重不符，存在虚假描述问题。\"\n}"}
{"image_file": "product_00070.jpg", "image": "data/raw/images/product_00070.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"红色建筑风格的NIKE标志设计\",\n    \"品牌标识\": \"NIKE\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中包含明显的NIKE品牌标识和标志性图案，属于知名品牌商标使用，未经授权可能构成侵权。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"建筑风格的Nike品牌字母组合图案，红色与白色为主色调\",\n    \"款式\": \"短袖T恤\",\n    \"品牌标识\": \"Nike\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图案中包含‘NIKE’品牌标识及明显的品牌LOGO元素，且整体设计具有品牌特定视觉特征，存在品牌侵权风险。尽管描述称‘正品保证’，但未提供正规授权证明，可能涉及仿冒或未经授权使用知名品牌标识。\"\n}"}
{"image_file": "product_00071.jpg", "image": "data/raw/images/product_00071.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅灰色\",\n    \"款式\": \"Polo衫\",\n    \"领口设计\": \"翻领，带有黄色和蓝色条纹装饰\",\n    \"袖口设计\": \"袖口有黄色和蓝色条纹\",\n    \"图案\": \"左胸位置有彩色刺绣图案，包含文字'FM BEAT CHAMP'和'LOGOS TEXT'\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"适用场景\": \"商务休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通Polo衫，无违规图案、文字或标识，符合平台关于服装类商品的合规要求。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"浅灰色\",\n    \"款式\": \"短袖Polo衫\",\n    \"领口\": \"翻领，带有黄蓝双色镶边\",\n    \"袖口\": \"黄蓝双色镶边\",\n    \"图案\": \"左胸位置有彩色徽标，包含文字'FM BEAT GRAP'和'LOGO TEXT'\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"适用场景\": \"商务休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通男装Polo衫，设计简约，无违规图文或敏感内容。左胸的徽标图案色彩鲜明但无政治、宗教或侵权标识，符合平台合规要求。\"\n}"}
{"image_file": "product_00072.jpg", "image": "data/raw/images/product_00072.jpg", "prompt": "欧美大牌设计 小众品牌", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表壳形状\": \"方形\",\n    \"表盘颜色\": \"黑色\",\n    \"表带颜色\": \"黄色\",\n    \"表带材质\": \"皮革\",\n    \"品牌标识\": \"CARRERA\",\n    \"防水标识\": \"100M\",\n    \"日期显示\": \"有\",\n    \"指针颜色\": \"白色和红色\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中表盘上标有'CARRERA'品牌标识，该品牌为知名手表品牌（如TAG Heuer旗下系列），使用其名称可能构成品牌侵权。此外，描述中‘欧美大牌设计’与‘小众品牌’存在矛盾，易误导消费者，涉嫌虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"yellow strap, black dial, silver case\",\n    \"style\": \"rectangular case, leather strap, analog display\",\n    \"brand\": \"Carrera\",\n    \"water_resistance\": \"100M\",\n    \"features\": [\"date window\", \"red second hand\", \"stitched strap\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中明确显示品牌名称'Carrera'，而商品描述中声称'小众品牌'，存在品牌信息不一致的虚假宣传问题。\"\n}"}
{"image_file": "product_00073.jpg", "image": "data/raw/images/product_00073.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"连帽拉链卫衣\",\n    \"图案\": \"黑白文字与图像拼贴设计\",\n    \"材质\": \"棉质或混纺面料\",\n    \"细节\": \"前袋、袖口罗纹、下摆罗纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件黑色连帽卫衣，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重品类不符。图片中无任何皮鞋或相关鞋类物品，属于虚假描述。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"连帽拉链卫衣\",\n    \"材质\": \"棉质\",\n    \"图案\": \"黑白文字拼贴设计\",\n    \"口袋\": \"前袋带缝线装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件黑色连帽卫衣，而商品描述为'高端品牌商务皮鞋，真皮鞋面'，存在严重品类与描述不符问题。\"\n}"}
{"image_file": "product_00074.jpg", "image": "data/raw/images/product_00074.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"套脚皮鞋\",\n    \"鞋头形状\": \"方头\",\n    \"鞋跟高度\": \"低跟\",\n    \"内里颜色\": \"棕色\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含'商场撤柜'、'专柜正品'、'便宜处理'等促销性用语，可能涉及虚假宣传或价格欺诈风险，且未提供品牌信息，存在误导消费者嫌疑。\"\n}", "rejected": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"套脚皮鞋\",\n    \"鞋头\": \"方头\",\n    \"鞋跟\": \"低跟\",\n    \"内里\": \"棕色衬里\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘商场撤柜’、‘专柜正品’、‘便宜处理’等表述，可能涉及虚假宣传或引导低价促销，不符合平台对商品信息真实性和合规性的要求。\"\n}"}
{"image_file": "product_00076.jpg", "image": "data/raw/images/product_00076.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"真皮\",\n    \"款式\": \"系带休闲皮鞋\",\n    \"鞋底\": \"白色橡胶底，棕色中底\",\n    \"缝线\": \"可见缝线工艺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一双深蓝色真皮系带休闲皮鞋，鞋面材质符合描述中的‘真皮鞋面’，整体风格偏向商务休闲，未发现虚假宣传或违规内容。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"真皮\",\n    \"款式\": \"系带商务休闲鞋\",\n    \"鞋底\": \"白色橡胶底，浅棕色内底\",\n    \"设计特点\": \"简约缝线装饰，低帮设计\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一双深蓝色真皮系带男鞋，外观符合商务休闲风格，未发现假冒品牌标识或违规宣传信息。商品描述中提到的‘高端品牌商务皮鞋，真皮鞋面’与图片内容相符，无虚假宣传问题。\"\n}"}
{"image_file": "product_00077.jpg", "image": "data/raw/images/product_00077.jpg", "prompt": "纯手工编织，限量发售", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"白色、蓝色、粉色、银色\",\n    \"品牌\": \"Puma\",\n    \"材质\": \"合成革、织物\",\n    \"款式\": \"低帮休闲运动鞋\",\n    \"设计元素\": \"粉色条纹、Puma标志、银色装饰条\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'纯手工编织'，但图片显示该鞋为机器制造的合成材料运动鞋，无编织工艺特征，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"品牌\": \"Puma\",\n    \"颜色\": [\"白色\", \"蓝色\", \"粉色\", \"银色\"],\n    \"材质\": \"合成革\",\n    \"款式\": \"低帮运动鞋\",\n    \"设计元素\": [\"Puma标志\", \"彩色条纹\", \"系带\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'纯手工编织'，但图片显示为典型的机器制造运动鞋，无任何编织工艺特征，存在虚假宣传。\"\n}"}
{"image_file": "product_00078.jpg", "image": "data/raw/images/product_00078.jpg", "prompt": "国风刺绣上衣，传统工艺", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"灰色、白色、棕色\",\n    \"材质\": \"网布、合成革\",\n    \"款式\": \"运动休闲\",\n    \"品牌标识\": \"FLINTONE\",\n    \"鞋带\": \"棕色\",\n    \"鞋底\": \"白色中底，黑色外底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双运动鞋，而商品描述为'国风刺绣上衣，传统工艺'，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"灰色、白色、棕色\",\n    \"材质\": \"网布、合成皮革、橡胶\",\n    \"款式\": \"跑鞋\",\n    \"设计元素\": \"几何图案、反光条\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为运动鞋，但描述为'国风刺绣上衣，传统工艺'，存在明显图文不符，属于虚假宣传。\"\n}"}
{"image_file": "product_00079.jpg", "image": "data/raw/images/product_00079.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘颜色\": \"白色\",\n    \"表带材质\": \"黑色皮革\",\n    \"表圈装饰\": \"镶嵌透明水晶与黑色方块交替\",\n    \"数字刻度\": \"12、6、9位置为镶钻数字，其余为矩形标记\",\n    \"日期显示\": \"3点钟位置有日期窗口，显示数字16\",\n    \"指针样式\": \"银色时分针，黑色秒针\",\n    \"表壳材质\": \"金属（银色）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示正品手表，无虚假宣传或侵权标识。描述中‘2024新款 正品保证 实体店同款’未发现夸大或误导性内容，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"dial_color\": \"white\",\n    \"case_material\": \"stainless steel\",\n    \"bezel\": \"diamond-studded with black accents\",\n    \"strap_material\": \"black leather\",\n    \"strap_pattern\": \"crocodile texture\",\n    \"hour_markers\": \"numeric at 12, 6, 9; stick indices elsewhere\",\n    \"date_display\": \"yes, at 3 o'clock position\",\n    \"movement_type\": \"quartz\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为一款正品ESPRIT手表，设计符合品牌风格，无仿冒标识或侵权元素，且描述中‘正品保证’与实物一致，未发现违规信息。\"\n}"}
{"image_file": "product_00080.jpg", "image": "data/raw/images/product_00080.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色与白色条纹\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"左胸有黄色'FM'字母标志\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\",\n    \"袖长\": \"短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘商场撤柜’‘专柜正品’‘便宜处理’等词汇，涉嫌虚假宣传和价格欺诈，可能误导消费者。同时，图片中未显示任何品牌授权或正品证明信息，存在冒用品牌或夸大宣传的风险。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色与白色条纹\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"左胸有黄色'FM'标志\",\n    \"材质\": \"棉质\",\n    \"袖长\": \"短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘商场撤柜’‘专柜正品’等词汇，暗示其为品牌专柜渠道流出商品，可能涉及虚假宣传或来源不明问题，且‘便宜处理’一词涉嫌低价诱导消费者，不符合平台关于商品真实性和合理定价的规范。\"\n}"}
{"image_file": "product_00081.jpg", "image": "data/raw/images/product_00081.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"设计元素\": \"布洛克雕花\",\n    \"鞋底\": \"黑色橡胶底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士正装鞋，无违规内容。图片清晰展示产品细节，描述中‘手工制作’‘限量款’等宣传语未违反广告法，且与商品风格相符。\"\n}", "rejected": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"系带皮鞋\",\n    \"设计元素\": \"布洛克雕花\",\n    \"鞋底\": \"黑色橡胶底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士正装鞋，视觉属性符合服装鞋帽类目规范，无违规信息。描述中的‘手工制作’和‘限量款’属于常见营销用语，未见虚假宣传或敏感内容。\"\n}"}
{"image_file": "product_00082.jpg", "image": "data/raw/images/product_00082.jpg", "prompt": "韩版潮流服饰，时尚百搭", "chosen": "{\n  \"category\": \"童装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"卡通公主与青蛙，配文'Princess and the frog...'及爱心元素\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质（推测）\",\n    \"设计风格\": \"可爱卡通风\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为儿童T恤，图案为卡通公主与青蛙，无不当内容或敏感信息，符合儿童服饰合规标准。\"\n}", "rejected": "{\n  \"category\": \"儿童服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"卡通女孩抱着青蛙，配文'Princess and the frog...'和爱心元素\",\n    \"款式\": \"短袖圆领T恤\",\n    \"材质\": \"棉质（推测）\",\n    \"适用人群\": \"女童\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为儿童T恤，图案内容为卡通公主与青蛙的童话主题，无违规元素，符合儿童服饰的正常审美和表达。\"\n}"}
{"image_file": "product_00083.jpg", "image": "data/raw/images/product_00083.jpg", "prompt": "时尚秋冬外套，多色可选", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色表带，白色表盘，红色数字和刻度\",\n    \"品牌标志\": \"Puma（彪马）标志\",\n    \"表盘设计\": \"大号数字12、6、0，红色秒针，外圈分钟刻度\",\n    \"材质\": \"橡胶表带，金属表冠\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是Puma品牌的手表，但商品描述为‘时尚秋冬外套，多色可选’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"black and white with red accents\",\n    \"brand\": \"Puma\",\n    \"dial_color\": \"white\",\n    \"strap_material\": \"rubber\",\n    \"design_style\": \"sporty\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是手表，但商品描述为‘时尚秋冬外套，多色可选’，存在明显的图文不符，属于虚假宣传或误导消费者行为。\"\n}"}
{"image_file": "product_00084.jpg", "image": "data/raw/images/product_00084.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"保龄球主题印花，包含'PUMA BOWLING CLUB'字样、保龄球瓶、保龄球和像素风格人物\",\n    \"品牌\": \"Puma\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"未明确，但视觉上为棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'手工制作'和'限量款'，但图片显示为批量生产的标准印花T恤，无任何手工制作痕迹，且设计风格与常见量产服饰一致，存在虚假宣传嫌疑。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"保龄球主题印花，包含\\\"STRIKE OUT\\\"字样、保龄球瓶、保龄球、像素风格人物和汽车\",\n    \"品牌\": \"PUMA\",\n    \"文字信息\": \"PUMA BOWLING CLUB\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中存在明显品牌标识'PUMA'，且图案设计为品牌联名风格，但商品描述声称'手工制作'和'限量款'，缺乏相关证明材料，涉嫌虚假宣传。此外，使用知名品牌商标（如PUMA）用于非官方授权商品，可能存在侵犯知识产权风险。\"\n}"}
{"image_file": "product_00085.jpg", "image": "data/raw/images/product_00085.jpg", "prompt": "时尚秋冬外套，多色可选", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"red\",\n    \"material\": \"leather\",\n    \"style\": \"tote\",\n    \"hardware\": \"gold-tone\",\n    \"stitching\": \"yellow\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是红色皮革手提包，而商品描述为‘时尚秋冬外套，多色可选’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"red\",\n    \"material\": \"leather\",\n    \"style\": \"shoulder bag\",\n    \"hardware\": \"gold-tone metal\",\n    \"stitching\": \"yellow thread\",\n    \"brand_logo\": \"square gold emblem with 'G' initial\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是红色皮革手提包，但商品描述为‘时尚秋冬外套，多色可选’，存在显著品类不符。实际商品与描述内容严重不一致，违反平台真实描述规范。\"\n}"}
{"image_file": "product_00086.jpg", "image": "data/raw/images/product_00086.jpg", "prompt": "韩版潮流服饰，时尚百搭", "chosen": "{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"图案\": \"红色刺绣字母'RF'\",\n    \"款式\": \"棒球帽\",\n    \"材质\": \"棉质或混纺面料\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通时尚帽子，无违规标识或敏感内容，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"材质\": \"棉质或混纺面料\",\n    \"款式\": \"棒球帽\",\n    \"图案\": \"红色刺绣字母'RF'\",\n    \"设计风格\": \"简约潮流\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通时尚帽子，图案为通用字母组合'RF'，无敏感标识或违法信息，符合平台发布规范。\"\n}"}
{"image_file": "product_00087.jpg", "image": "data/raw/images/product_00087.jpg", "prompt": "国风刺绣上衣，传统工艺", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"材质\": \"牛仔布\",\n    \"款式\": \"短裙\",\n    \"颜色\": \"深蓝色\",\n    \"装饰\": \"右侧口袋有绿色刺绣图案\",\n    \"设计元素\": \"金属纽扣、双口袋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一条牛仔短裙，而商品描述为'国风刺绣上衣，传统工艺'，存在严重描述不符。实际商品并非上衣，且无明显国风或传统工艺特征，仅在口袋处有简单绿色刺绣，不符合描述中的'国风刺绣'和'传统工艺'宣传。\"\n}", "rejected": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"type\": \"牛仔裙\",\n    \"color\": \"深蓝色\",\n    \"material\": \"牛仔布\",\n    \"design\": \"短款\",\n    \"features\": [\n      \"金属纽扣\",\n      \"后袋刺绣图案\",\n      \"绿色圆形刺绣标志\"\n    ]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是牛仔材质的短裙，带有绿色圆形刺绣标志，并无国风或传统工艺特征；而商品描述为‘国风刺绣上衣’，与实际商品类别、款式及设计风格严重不符，存在虚假宣传。\"\n}"}
{"image_file": "product_00088.jpg", "image": "data/raw/images/product_00088.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"黑白复古风格人物插画，包含吉他手形象和文字'loves the 80's'\",\n    \"材质\": \"棉质（推测）\",\n    \"性别\": \"女性\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通印花T恤，图案内容为复古风格艺术插画，无违法不良信息、敏感符号或侵权标识。符合平台对服饰类商品的合规要求。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"黑白复古风格照片印花，人物弹吉他，文字内容包含'80's'\",\n    \"材质\": \"棉质（推测）\",\n    \"性别\": \"女性\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为普通女装T恤，图案为复古风格的音乐主题插画，无政治敏感、色情低俗或侵权内容，符合平台商品发布规范。\"\n}"}
{"image_file": "product_00091.jpg", "image": "data/raw/images/product_00091.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"design\": \"floral decoration with tassels\",\n    \"style\": \"hobo bag\",\n    \"stitching\": \"yellow contrast stitching\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为黑色皮革手提包，带有花朵和流苏装饰，风格偏向成熟优雅，与描述中的'日系简约 ins风 学院风'不符，存在描述与实物风格不一致的问题。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"style\": \"hobo\",\n    \"features\": [\n      \"floral decoration\",\n      \"tassel details\",\n      \"contrast stitching\"\n    ],\n    \"handle_type\": \"top handle\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示为黑色皮革手提包，带有花朵装饰和流苏，整体风格偏向成熟优雅风，与描述中‘日系简约 ins风 学院风’存在明显不符，属于描述夸大或误导性宣传。\"\n}"}
{"image_file": "product_00092.jpg", "image": "data/raw/images/product_00092.jpg", "prompt": "韩版潮流服饰，时尚百搭", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"style\": \"tote\",\n    \"hardware\": \"gold-tone\",\n    \"stitching\": \"yellow contrast\",\n    \"brand_tag\": \"present\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款黑色皮革手提包，但商品描述中使用了'韩版潮流服饰'，属于品类不匹配。该商品并非服饰类，而是配饰类中的包袋，描述存在误导性。\"\n}", "rejected": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"托特包\",\n    \"装饰\": \"金色缝线、金属扣件、品牌标识牌\",\n    \"结构\": \"双提手、侧边拉链\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一个皮质手提包，而商品描述为‘韩版潮流服饰，时尚百搭’，属于品类不符。描述中的‘服饰’与实际商品‘包袋’不一致，涉嫌虚假或误导性宣传。\"\n}"}
{"image_file": "product_00093.jpg", "image": "data/raw/images/product_00093.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"type\": \"衬衫\",\n    \"pattern\": \"格子\",\n    \"color\": \"蓝白灰相间\",\n    \"sleeve_length\": \"长袖\",\n    \"collar_type\": \"翻领\",\n    \"buttons\": \"黑色纽扣\",\n    \"material\": \"棉质或混纺\",\n    \"fit\": \"修身\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士格子衬衫，而商品描述为‘运动休闲鞋，缓震耐磨橡胶底’，存在严重的图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白灰格纹\",\n    \"款式\": \"长袖衬衫\",\n    \"材质\": \"棉质或混纺\",\n    \"细节\": \"翻领、纽扣开合、袖口卷起\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是男士格纹衬衫，但商品描述为‘运动休闲鞋’，存在严重的图文不符，违反平台商品信息真实性规定。\"\n}"}
{"image_file": "product_00094.jpg", "image": "data/raw/images/product_00094.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"case_shape\": \"矩形\",\n    \"case_material\": \"金属\",\n    \"dial_color\": \"白色\",\n    \"strap_material\": \"皮革\",\n    \"strap_color\": \"棕色\",\n    \"design_style\": \"简约现代\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款ESPRIT品牌的手表，而商品描述中却声称是‘100%真丝连衣裙’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "```json\n{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表壳形状\": \"矩形\",\n    \"表带材质\": \"棕色皮革\",\n    \"表盘颜色\": \"银白色\",\n    \"表盘设计\": \"双层结构，上方为时分针，下方为秒针显示\",\n    \"表带颜色\": \"棕色\",\n    \"表壳材质\": \"金属（银色）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款ESPRIT品牌的腕表，而商品描述中提及的是‘100%真丝连衣裙’，两者类别严重不符，属于图文不符违规。\"\n}\n```"}
{"image_file": "product_00096.jpg", "image": "data/raw/images/product_00096.jpg", "prompt": "纯手工编织，限量发售", "chosen": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝色与白色竖条纹\",\n    \"款式\": \"长袖正装衬衫\",\n    \"领型\": \"标准翻领\",\n    \"纽扣\": \"黑色纽扣\",\n    \"袖口\": \"双色条纹袖口\",\n    \"材质外观\": \"光滑，疑似棉质或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘纯手工编织’，但图片显示为常规机织条纹衬衫，无任何手工编织的视觉特征，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色与白色竖条纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"棉质或混纺面料\",\n    \"图案\": \"竖条纹\",\n    \"纽扣\": \"黑色纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘纯手工编织’，但图片显示为常规机织衬衫，无任何手工编织的视觉特征（如不规则纹理、线头或特殊缝制痕迹），存在虚假宣传。\"\n}"}
{"image_file": "product_00097.jpg", "image": "data/raw/images/product_00097.jpg", "prompt": "百搭连衣裙，适合日常出行", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"white and blue\",\n    \"style\": \"sneaker\",\n    \"material\": \"leather-like\",\n    \"design\": \"paint splatter pattern\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双运动鞋，而商品描述为'百搭连衣裙'，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "```json\n{\n  \"category\": \"鞋子\",\n  \"attributes\": {\n    \"颜色\": \"白色与蓝色\",\n    \"款式\": \"低帮运动鞋\",\n    \"材质\": \"皮革或合成材料\",\n    \"设计元素\": \"蓝色泼墨图案\",\n    \"鞋带\": \"白色\",\n    \"鞋底\": \"白色，带有蓝色边缘\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双运动鞋，而商品描述为'百搭连衣裙，适合日常出行'，存在严重图文不符，违反平台商品信息真实性规则。\"\n}\n```"}
{"image_file": "product_00099.jpg", "image": "data/raw/images/product_00099.jpg", "prompt": "百搭连衣裙，适合日常出行", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"蓝色和黑色的豹子图案\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是男士短袖T恤，而商品描述为'百搭连衣裙，适合日常出行'，存在品类与描述严重不符的问题。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"蓝色和黑色的跳跃豹子图形\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士短袖T恤，而商品描述为'百搭连衣裙，适合日常出行'，品类与描述严重不符，属于误导性描述。\"\n}"}
{"image_file": "product_00100.jpg", "image": "data/raw/images/product_00100.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"设计元素\": \"布洛克雕花\",\n    \"鞋头形状\": \"尖头\",\n    \"鞋跟高度\": \"低跟\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士正装皮鞋，无违规标识或敏感内容，符合平台商品发布规范。\"\n}", "rejected": "```json\n{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带皮鞋\",\n    \"设计风格\": \"布洛克雕花\",\n    \"鞋头形状\": \"尖头\",\n    \"鞋跟高度\": \"低跟\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士正装皮鞋，无违规标识或内容，图片清晰展示产品细节，符合平台商品发布规范。\"\n}\n```"}
{"image_file": "product_00101.jpg", "image": "data/raw/images/product_00101.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带皮鞋\",\n    \"设计风格\": \"商务正装\",\n    \"鞋头形状\": \"尖头\",\n    \"装饰细节\": \"布洛克雕花\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘商场撤柜’‘专柜正品’‘便宜处理’等宣传用语，可能涉及虚假促销或误导性信息，且未提供品牌、型号等必要信息，不符合平台对商品描述真实性和完整性的要求。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"style\": \"brogue\",\n    \"type\": \"lace-up\",\n    \"sole\": \"rubber\",\n    \"gender\": \"male\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含'商场撤柜'、'专柜正品'、'便宜处理'等营销性用语，可能涉及虚假宣传或低价倾销暗示，不符合平台对商品信息真实性和合规性的要求。\"\n}"}
{"image_file": "product_00102.jpg", "image": "data/raw/images/product_00102.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"童装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案文字\": \"50% Mummy, 50% Daddy, 100% Me\",\n    \"品牌\": \"BeBorn\",\n    \"材质\": \"棉质（推测）\",\n    \"适用年龄\": \"婴儿/幼儿\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'商场撤柜'、'专柜正品'、'便宜处理'等词汇，涉嫌虚假宣传和价格欺诈，可能误导消费者。同时，该商品为儿童服装，其宣传语虽无直接违规内容，但结合描述存在夸大促销信息的问题。\"\n}", "rejected": "{\n  \"category\": \"童装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"文字内容\": \"50% Mummy, 50% Daddy, 100% Me\",\n    \"品牌\": \"BeBorn\",\n    \"材质\": \"棉质（推测）\",\n    \"装饰\": \"黑色缝线边、蓝色品牌标签\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘商场撤柜’、‘专柜正品’、‘便宜处理’等词汇，暗示该商品为清仓或非正规渠道销售的商品，可能涉及虚假宣传或误导性描述，违反平台关于商品信息真实性的规则。此外，虽无明显违规图文，但此类描述易误导消费者，构成营销违规。\"\n}"}
{"image_file": "product_00104.jpg", "image": "data/raw/images/product_00104.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"图案\": \"蓝色鞋底图案和紫色文字'RUN HARD'\",\n    \"款式\": \"圆领短袖T恤\",\n    \"风格\": \"运动休闲风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的T恤设计为运动风格，带有'RUN HARD'字样及鞋底图案，属于典型的运动休闲风，与描述中‘日系简约 ins风 学院风’不符，存在风格描述不实的问题。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"图案\": \"蓝色跑鞋轮廓与紫色文字'RUN HARD'\",\n    \"款式\": \"圆领短袖T恤\",\n    \"风格\": \"运动休闲风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的T恤设计包含英文标语'RUN HARD'及跑鞋图案，整体风格偏向运动休闲风，与描述中声称的'日系简约 ins风 学院风'不符，存在风格描述不实问题。\"\n}"}
{"image_file": "product_00105.jpg", "image": "data/raw/images/product_00105.jpg", "prompt": "高端羊毛面料，奢华质感", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"pink\",\n    \"material\": \"leather-like synthetic\",\n    \"style\": \"structured tote\",\n    \"features\": [\n      \"top handles\",\n      \"front zippered pockets\",\n      \"metal buckles\",\n      \"yellow stitching\"\n    ]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示包袋材质为皮革质感的人造材料，但描述中声称使用‘高端羊毛面料’，存在材质描述与实际视觉特征不符的虚假宣传问题。\"\n}", "rejected": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"材质\": \"人造革\",\n    \"款式\": \"双肩带手提包\",\n    \"装饰\": \"金属扣件、黄色缝线\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的包袋材质为人造革，表面具有皮革纹理，与描述中‘高端羊毛面料’严重不符，存在虚假宣传。\"\n}"}
{"image_file": "product_00106.jpg", "image": "data/raw/images/product_00106.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"DUCATI品牌标志\",\n    \"材质\": \"棉质\",\n    \"风格\": \"运动休闲风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的T恤印有'DUCATI'品牌标志，属于知名品牌商标，而商品描述为'日系简约 ins风 学院风'，存在风格与实际品牌属性不符的情况，可能构成误导性宣传。同时，未经授权使用知名品牌标识可能涉及知识产权侵权。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"圆领短袖T恤\",\n    \"图案\": \"DUCATI品牌字样\",\n    \"材质\": \"棉质（推测）\",\n    \"设计风格\": \"运动休闲风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的T恤印有'DUCATI'品牌标志，属于知名摩托车品牌商标，且为直接使用其官方标识的宣传性服装，不符合'日系简约 ins风 学院风'的描述，存在品牌侵权和描述不符风险。\"\n}"}
{"image_file": "product_00107.jpg", "image": "data/raw/images/product_00107.jpg", "prompt": "国风刺绣上衣，传统工艺", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"吊带背心\",\n    \"领型\": \"无领\",\n    \"袖型\": \"无袖\",\n    \"下摆设计\": \"荷叶边\",\n    \"肩带\": \"可调节细绳\",\n    \"材质\": \"棉质或类似轻薄面料\",\n    \"装饰\": \"无刺绣\",\n    \"品牌标签\": \"FLAP DOG\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称是'国风刺绣上衣'，但图片显示该商品为纯白色无任何刺绣图案的吊带背心，实际视觉特征与描述严重不符，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"吊带\",\n    \"材质\": \"棉质\",\n    \"装饰\": \"褶边\",\n    \"领口\": \"细绳调节肩带\",\n    \"品牌\": \"FLAP DOORSIDE\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中未见任何国风刺绣或传统工艺元素，与描述严重不符，属于虚假宣传。\"\n}"}
{"image_file": "product_00108.jpg", "image": "data/raw/images/product_00108.jpg", "prompt": "欧美风格外套，时尚简约", "chosen": "{\n  \"category\": \"T恤\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"印有英文标语和人物插画\",\n    \"文字内容\": \"STRIKE!! WHEN YOU'RE READY!!\",\n    \"款式\": \"短袖圆领\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一件T恤，但商品描述中称其为‘欧美风格外套’，存在品类描述不符的问题。实际商品并非外套，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"印有‘STRIKE!! WHEN YOU'RE READY!!’字样及人物插画\",\n    \"材质\": \"棉质（推测）\",\n    \"风格\": \"街头潮流\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为短袖T恤，而非描述中所述的‘外套’，品类描述与实际商品严重不符，属于虚假宣传。\"\n}"}
{"image_file": "product_00109.jpg", "image": "data/raw/images/product_00109.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅黄色\",\n    \"图案\": \"复古音响图案，包含价格标签和文字元素\",\n    \"款式\": \"短袖圆领T恤\",\n    \"材质\": \"棉质（推测）\",\n    \"设计风格\": \"街头潮流\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的T恤印有‘$59’等价格信息及‘DIRECT FACTORY PRICE’字样，属于虚假宣传或价格暗示，违反平台关于商品不得在图中展示非实际售价或促销信息的规定。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"复古音响图案，带有价格标签和文字元素\",\n    \"材质\": \"棉质（推测）\",\n    \"设计风格\": \"街头潮流\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中T恤图案包含'$5.9'的价格标签和'DIRECT FACTORY PRICE'等字样，构成虚假促销信息，违反平台关于不得在商品本身展示不当价格宣传的规则。\"\n}"}
{"image_file": "product_00110.jpg", "image": "data/raw/images/product_00110.jpg", "prompt": "百搭连衣裙，适合日常出行", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"棋盘格纹理\",\n    \"标志\": \"红色跃马徽标\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士短袖T恤，而商品描述为‘百搭连衣裙，适合日常出行’，存在品类与描述严重不符的问题。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"棋盘格纹\",\n    \"标志\": \"红色跃马徽标\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质或混纺面料（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士短袖T恤，而商品描述为'百搭连衣裙，适合日常出行'，存在严重品类与描述不符的情况。实际商品为男装上衣，非连衣裙，属于虚假宣传和误导消费者。\"\n}"}
{"image_file": "product_00111.jpg", "image": "data/raw/images/product_00111.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"绿色\",\n    \"表带材质\": \"橡胶\",\n    \"表盘设计\": \"八角形\",\n    \"品牌标识\": \"Carrera\",\n    \"表盘纹理\": \"波点纹理\",\n    \"指针样式\": \"银色条形指针\",\n    \"日期显示\": \"窗口式\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大宣传用语，可能构成虚假或引人误解的商业宣传，违反平台广告合规规范。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"color\": \"green\",\n    \"material\": \"rubber\",\n    \"brand\": \"Carrera\",\n    \"dial_pattern\": \"textured\",\n    \"case_shape\": \"octagonal\",\n    \"strap_type\": \"silicone\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'最新款 超低价 清仓大甩卖'等宣传性词汇，存在虚假或夸大宣传嫌疑，可能误导消费者。\"\n}"}
{"image_file": "product_00112.jpg", "image": "data/raw/images/product_00112.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"color\": \"蓝色\",\n    \"material\": \"网眼布\",\n    \"brand\": \"Reebok\",\n    \"sole_type\": \"白色橡胶底\",\n    \"design\": \"透气网面，轻便跑鞋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双蓝色的Reebok运动鞋，而商品描述为'100%真丝连衣裙，高贵典雅'，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"color\": \"蓝色\",\n    \"material\": \"网眼布\",\n    \"brand\": \"Reebok\",\n    \"sole\": \"白色橡胶\",\n    \"style\": \"跑步鞋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双蓝色运动鞋，而商品描述为'100%真丝连衣裙，高贵典雅'，存在严重的图文不符，涉嫌虚假宣传。\"\n}"}
{"image_file": "product_00113.jpg", "image": "data/raw/images/product_00113.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝、黑、白竖条纹\",\n    \"款式\": \"长袖\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"未明确，视觉上为棉质或混纺\",\n    \"图案\": \"竖条纹\",\n    \"适用场景\": \"商务休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，无违规内容。商品描述‘简约设计衬衫，商务休闲两相宜’与图片中蓝黑白竖条纹长袖衬衫的风格相符，未发现虚假宣传或不当信息。\"\n}", "rejected": "{\n  \"category\": \"男装-衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝、黑、白竖条纹\",\n    \"款式\": \"长袖\",\n    \"领型\": \"标准翻领\",\n    \"材质\": \"看似棉质或混纺面料\",\n    \"设计风格\": \"商务休闲\",\n    \"图案\": \"竖条纹\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰，展示的是常规男士条纹衬衫，符合商务休闲风格描述，无违规内容。\"\n}"}
{"image_file": "product_00115.jpg", "image": "data/raw/images/product_00115.jpg", "prompt": "经典款牛仔裤，修身显瘦", "chosen": "{\n  \"category\": \"belt\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather\",\n    \"buckle_type\": \"metallic square buckle\",\n    \"style\": \"classic\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一条皮带，但商品描述中提及‘经典款牛仔裤，修身显瘦’，与实际商品不符，存在描述虚假或误导性问题。\"\n}", "rejected": "```json\n{\n  \"category\": \"皮带\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"经典款\",\n    \"扣件类型\": \"金属针扣\",\n    \"表面纹理\": \"压纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为皮带，但商品描述中提及'经典款牛仔裤，修身显瘦'，存在商品图片与描述严重不符的问题。\"\n}\n```"}
{"image_file": "product_00117.jpg", "image": "data/raw/images/product_00117.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色和白色格子\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质或混纺面料\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"闭合方式\": \"纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件女性格子短袖衬衫，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"女装上衣\",\n  \"attributes\": {\n    \"颜色\": \"紫色与白色格子\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"材质\": \"棉质或混纺面料\",\n    \"图案\": \"格纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件女性格子短袖衬衫，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重品类不符，描述内容与实际商品不一致。\"\n}"}
{"image_file": "product_00118.jpg", "image": "data/raw/images/product_00118.jpg", "prompt": "高端羊毛面料，奢华质感", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"乐福鞋\",\n    \"设计特点\": \"无鞋带，缝线装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为皮革材质的乐福鞋，但描述中声称使用‘高端羊毛面料’，材质描述与实际视觉特征不符，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"乐福鞋\",\n    \"设计特点\": \"无带一脚蹬，缝线装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为黑色皮革材质的乐福鞋，但商品描述中声称使用'高端羊毛面料'，与实际视觉特征不符，存在材质描述虚假宣传问题。\"\n}"}
{"image_file": "product_00120.jpg", "image": "data/raw/images/product_00120.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"绿色\",\n    \"款式\": \"Polo衫\",\n    \"图案\": \"胸前印有白色数字'30'及小字标语\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"材质\": \"棉质或混纺面料（推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士Polo衫，设计简洁，无违规图案、文字或敏感元素。图片展示清晰，符合平台商品发布规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"绿色\",\n    \"款式\": \"Polo衫\",\n    \"图案\": \"胸前印有白色数字'30'及小字标语\",\n    \"材质\": \"棉质或混纺面料（推测）\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男装Polo衫，设计简约，无违规图案或文字。虽然描述中称‘简约设计衬衫’与实际视觉上带有数字图案存在轻微不符，但未构成严重误导，不违反平台规则。\"\n}"}
{"image_file": "product_00121.jpg", "image": "data/raw/images/product_00121.jpg", "prompt": "国风刺绣上衣，传统工艺", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": [\"白色\", \"红色\", \"蓝色\"],\n    \"图案\": \"英国国旗（米字旗）\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质\",\n    \"设计元素\": \"花卉纹样叠加\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为带有英国国旗图案的T恤，但商品描述为‘国风刺绣上衣，传统工艺’，存在严重描述不符。实际图案并非中国传统风格，且未见刺绣工艺，涉嫌虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"白色、红色、蓝色\",\n    \"图案\": \"英国国旗风格图案，带有花卉纹样\",\n    \"款式\": \"短袖圆领T恤\",\n    \"材质\": \"棉质或混纺面料（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为印有英国国旗元素的T恤，但商品描述称其为‘国风刺绣上衣，传统工艺’，存在严重描述不符。实际图案并非中国传统风格，也无刺绣工艺特征，属于误导性宣传。\"\n}"}
{"image_file": "product_00123.jpg", "image": "data/raw/images/product_00123.jpg", "prompt": "欧美大牌设计 小众品牌", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"V领短袖T恤\",\n    \"材质\": \"棉质\",\n    \"图案\": \"左胸有小logo\",\n    \"品牌标识\": \"小众品牌标志\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通款式的白色V领T恤，左胸有小尺寸品牌标识，无违规图案或文字。描述中提及‘欧美大牌设计’和‘小众品牌’属于主观宣传用语，但未涉及虚假宣传或侵权内容，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"白色\",\n    \"type\": \"V领短袖T恤\",\n    \"material\": \"棉质\",\n    \"logo\": \"左胸位置有黑色小刺绣标志\",\n    \"design\": \"简约风格，无图案\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘欧美大牌设计’和‘小众品牌’等词汇，可能涉嫌虚假宣传或误导消费者，属于夸大宣传行为。图片显示为普通白色V领T恤，无明显奢侈品牌标识或高端设计特征，与描述不符。\"\n}"}
{"image_file": "product_00124.jpg", "image": "data/raw/images/product_00124.jpg", "prompt": "纯手工编织，限量发售", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"品牌\": \"Reebok\",\n    \"款式\": \"凉鞋\",\n    \"材质\": \"合成材料\",\n    \"闭合方式\": \"魔术贴\",\n    \"鞋底\": \"厚底，防滑纹路\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为机器生产的Reebok品牌凉鞋，而描述中声称'纯手工编织'，存在虚假宣传；同时'限量发售'无法从图片中验证，涉嫌夸大宣传。\"\n}", "rejected": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"品牌\": \"Reebok\",\n    \"款式\": \"运动凉鞋\",\n    \"材质\": \"合成材料\",\n    \"闭合方式\": \"魔术贴\",\n    \"鞋底\": \"厚底，防滑纹路\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为机械化生产的Reebok品牌运动凉鞋，而描述中声称‘纯手工编织’，存在虚假宣传。此外，商品外观为批量生产特征，与‘限量发售’描述不符，可能构成误导性营销。\"\n}"}
{"image_file": "product_00125.jpg", "image": "data/raw/images/product_00125.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘颜色\": \"银色\",\n    \"表带材质\": \"棕色皮革与金属链条组合\",\n    \"表盘装饰\": \"镶嵌仿钻时标\",\n    \"表壳材质\": \"金属\",\n    \"款式\": \"时尚腕表\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大宣传用语，可能构成虚假或引人误解的商业宣传，违反平台广告合规规则。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"color\": \"silver and brown\",\n    \"material\": \"leather and metal chain\",\n    \"style\": \"wrap-around bracelet with chain detail\",\n    \"dial\": \"silver tone with crystal markers\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款 超低价 清仓大甩卖’等促销性词汇，可能涉及虚假宣传或价格欺诈风险，且图片未显示价格信息，无法验证其真实性。\"\n}"}
{"image_file": "product_00126.jpg", "image": "data/raw/images/product_00126.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色主体，绿色领口和袖口\",\n    \"品牌\": \"PUMA\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"正面印有绿色PUMA标志和跳跃猎豹图案\",\n    \"材质\": \"未明确显示，推测为棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的T恤带有PUMA品牌标识，但描述中声称‘正品保证’且‘实体店同款’，若该商品未经品牌授权，则构成品牌侵权。根据平台规则，未经授权销售带有知名品牌标识的商品属于违规行为。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"白色主体，绿色领口和袖口\",\n    \"brand\": \"PUMA\",\n    \"design\": \"短袖T恤，胸前有绿色PUMA标志和跳豹图案\",\n    \"material\": \"未明确显示，推测为棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示了PUMA品牌标志，但描述中宣称'正品保证'且与实体店同款，可能存在未经授权使用品牌商标进行销售的风险。未经品牌方授权展示其注册商标（如'PUMA®'及跳豹图案）可能构成商标侵权行为，违反平台关于品牌保护的规则。\"\n}"}
{"image_file": "product_00128.jpg", "image": "data/raw/images/product_00128.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"女装上衣\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"部分透明网纱与不透明面料拼接\",\n    \"款式\": \"短袖圆领\",\n    \"设计特点\": \"肩部和袖子采用透明网纱材质\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示该上衣肩部及袖子部分为透明网纱材质，与描述中‘纯棉’不符，存在材质虚假宣传问题。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"领型\": \"圆领\",\n    \"材质\": \"黑色不透明主体 + 半透明网纱肩部拼接\",\n    \"设计特点\": \"肩部带有透明网纱装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示该上衣肩部采用半透明网纱材质，与描述中‘纯棉’不符，存在材质描述虚假问题。\"\n}"}
{"image_file": "product_00129.jpg", "image": "data/raw/images/product_00129.jpg", "prompt": "经典款牛仔裤，修身显瘦", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"吊带背心\",\n    \"材质\": \"棉质或混纺\",\n    \"设计特点\": \"胸前褶皱设计，细肩带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为黑色吊带背心，而商品描述中提及的是‘经典款牛仔裤’，存在实物与描述严重不符的情况，违反了平台关于商品信息真实性的规定。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"吊带背心\",\n    \"材质\": \"未知\",\n    \"领型\": \"U型领\",\n    \"肩带\": \"细肩带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是黑色吊带背心，而商品描述为‘经典款牛仔裤，修身显瘦’，实际商品与描述严重不符，属于虚假宣传。\"\n}"}
{"image_file": "product_00131.jpg", "image": "data/raw/images/product_00131.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色底色，文字为蓝色、灰色、红色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"正面印有'SEE THE WIN'字样，字体为大号块状字母，色彩拼接设计\",\n    \"品牌标识\": \"领口内侧有Nike 'the athletic' 标志\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通运动服饰，图案内容积极向上，无违法不良信息或敏感元素，符合平台合规要求。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"正面印有彩色文字 'SEE THE WIN'\",\n    \"文字颜色\": [\"蓝色\", \"灰色\", \"红色\"],\n    \"品牌标识\": \"Nike the athletic\",\n    \"款式\": \"短袖T恤\",\n    \"领口\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示为一件黑色短袖T恤，正面印有' SEE THE WIN '的彩色字母图案，无违法或违规内容。品牌标识清晰且符合授权范围，未发现政治、宗教、色情或其他敏感信息。\"\n}"}
{"image_file": "product_00132.jpg", "image": "data/raw/images/product_00132.jpg", "prompt": "韩版潮流服饰，时尚百搭", "chosen": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"品牌\": \"PUMA\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"白色PUMA标志和文字\",\n    \"材质\": \"棉质或混纺面料（推测）\",\n    \"适用性别\": \"女性\",\n    \"设计风格\": \"运动休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的T恤带有明显的PUMA品牌标识，属于知名品牌商品。若该商品为非授权销售或仿冒品，则违反平台关于品牌侵权的规定。需核实品牌授权资质。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"品牌\": \"PUMA\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"白色PUMA标志及跳猫logo\",\n    \"材质\": \"棉质（推测）\",\n    \"适用性别\": \"女性\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的服装带有‘PUMA’品牌标识和跳猫logo，属于知名品牌商标，未经授权销售可能构成侵权。平台禁止销售未经授权的品牌商品。\"\n}"}
{"image_file": "product_00133.jpg", "image": "data/raw/images/product_00133.jpg", "prompt": "经典款牛仔裤，修身显瘦", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"款式\": \"无袖连帽背心\",\n    \"图案\": \"数字63、DIVI、14，带有涂鸦风格背景\",\n    \"材质\": \"未明确，推测为棉或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件浅蓝色无袖连帽背心，而商品描述为'经典款牛仔裤，修身显瘦'，存在严重图文不符。图片中无任何牛仔裤元素，属于虚假宣传。\"\n}", "rejected": "```json\n{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"款式\": \"无袖连帽背心\",\n    \"图案\": \"红色数字'63'，白色文字'DIVI'和'14'，蓝色背景图案\",\n    \"材质\": \"未明确，视觉上为轻薄织物\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件浅蓝色无袖连帽背心，与商品描述中‘经典款牛仔裤，修身显瘦’不符，存在描述与实物严重不一致的问题。\"\n}\n```"}
{"image_file": "product_00134.jpg", "image": "data/raw/images/product_00134.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"PUMA\",\n    \"color\": \"黑色\",\n    \"material\": \"皮革表带，金属表壳\",\n    \"design\": \"矩形表盘，数字刻度，白色缝线装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片为PUMA品牌手表，但商品描述中提及‘面料柔软 版型修身 显瘦神器’，该描述适用于服装类商品，与实际商品类别严重不符，存在误导性宣传。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"PUMA\",\n    \"表带材质\": \"黑色皮革\",\n    \"表带设计\": \"波浪纹路，白色缝线\",\n    \"表盘形状\": \"矩形\",\n    \"表盘颜色\": \"黑色\",\n    \"表盘数字\": \"12, 3, 6, 9 及 48, 18\",\n    \"指针颜色\": \"银色\",\n    \"表壳材质\": \"金属（银色）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片为PUMA品牌手表，但商品描述中提到'面料柔软 版型修身 显瘦神器'，属于服装类产品的描述，与实际商品类别不符，涉嫌虚假宣传或标题作弊。\"\n}"}
{"image_file": "product_00135.jpg", "image": "data/raw/images/product_00135.jpg", "prompt": "高端羊毛面料，奢华质感", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘颜色\": \"黑色\",\n    \"表壳材质\": \"银色金属\",\n    \"表带材质\": \"黑色皮革（鳄鱼纹）\",\n    \"表圈设计\": \"菱形纹理装饰\",\n    \"功能\": \"计时码表（Chronograph）\",\n    \"数字刻度\": \"白色阿拉伯数字\",\n    \"指针样式\": \"银色指针\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款手表，但商品描述中提及‘高端羊毛面料，奢华质感’，与实际商品属性严重不符，存在虚假宣传嫌疑。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"dial_color\": \"black\",\n    \"case_material\": \"metallic\",\n    \"bezel_design\": \"diamond-patterned\",\n    \"strap_material\": \"leather\",\n    \"strap_color\": \"black\",\n    \"features\": [\"chronograph\", \"three sub-dials\", \"large numerals\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款手表，但商品描述中提及'高端羊毛面料，奢华质感'，该描述与实际商品（手表）类别及材质严重不符，存在虚假或误导性描述。\"\n}"}
{"image_file": "product_00136.jpg", "image": "data/raw/images/product_00136.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"绿色与白色条纹\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质或混纺面料\",\n    \"图案\": \"胸前有品牌刺绣徽章\",\n    \"领型\": \"标准翻领\",\n    \"袖口\": \"卷起的短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男装条纹短袖衬衫，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"绿色、白色\",\n    \"图案\": \"竖条纹\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质\",\n    \"装饰\": \"左胸有徽章刺绣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士条纹短袖衬衫，而商品描述为'高端品牌商务皮鞋，真皮鞋面'，实际商品与描述严重不符，属于虚假描述违规。\"\n}"}
{"image_file": "product_00137.jpg", "image": "data/raw/images/product_00137.jpg", "prompt": "纯手工编织，限量发售", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"连帽拉链外套\",\n    \"图案\": \"胸前有浅蓝色爪印图案，内含'1972'和字母'N'\",\n    \"品牌标识\": \"Nike标志位于爪印图案下方\",\n    \"材质\": \"看似为棉质或混纺面料，非手工编织\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述声称'纯手工编织'，但图片显示该商品为机器生产的针织连帽衫，无任何手工编织的视觉特征，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"连帽拉链外套\",\n    \"图案\": \"左胸有蓝色爪印图案，内含'1972'和字母'N'\",\n    \"品牌标识\": \"Nike标志（勾形）位于图案下方\",\n    \"材质\": \"外观为棉质或混纺面料，非手工编织\",\n    \"设计特征\": \"前拉链、两侧口袋、白色抽绳\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述声称'纯手工编织'，但根据图片显示该商品为普通机织连帽衫，无手工编织痕迹，存在虚假宣传。\"\n}"}
{"image_file": "product_00138.jpg", "image": "data/raw/images/product_00138.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"棉质\",\n    \"款式\": \"棒球帽\",\n    \"图案\": \"绿色RF刺绣标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一顶带有绿色RF刺绣标志的白色棒球帽，而商品描述为‘纯棉休闲上衣，舒适透气’，描述内容与实际商品类别严重不符，属于虚假描述。\"\n}", "rejected": "```json\n{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"棉质\",\n    \"款式\": \"棒球帽\",\n    \"图案\": \"绿色刺绣RF标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一顶带有绿色RF刺绣标志的白色棒球帽，但商品描述中称其为‘纯棉休闲上衣’，品类与实际商品不符，属于描述错误。\"\n}\n```"}
{"image_file": "product_00139.jpg", "image": "data/raw/images/product_00139.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋头形状\": \"尖头\",\n    \"鞋底\": \"低跟平底\",\n    \"内里颜色\": \"棕色\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士正装皮鞋，无违规标识或内容，符合平台销售规范。\"\n}", "rejected": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋头形状\": \"尖头\",\n    \"内衬颜色\": \"棕色\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"品牌标识\": \"Clarks\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士正装皮鞋，外观符合平台销售规范，无仿冒、违禁或不当宣传内容。图片清晰展示商品真实形态，未发现虚假宣传或侵权风险。\"\n}"}
{"image_file": "product_00140.jpg", "image": "data/raw/images/product_00140.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝黄格子\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"白色纽扣\",\n    \"口袋\": \"胸前有两个口袋\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反平台广告合规规则。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝黄格子\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质或混纺\",\n    \"设计\": \"翻领、前扣、两个胸前口袋\",\n    \"适合场景\": \"休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘最新款’、‘超低价’、‘清仓大甩卖’等词汇，属于夸大宣传和诱导性营销语言，违反平台广告合规规范。同时未提供明确品牌、材质成分及尺寸信息，存在信息不完整问题。\"\n}"}
{"image_file": "product_00141.jpg", "image": "data/raw/images/product_00141.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"Polo衫\",\n    \"材质\": \"棉质\",\n    \"图案\": \"胸前有黑色字母'B'标志，左袖有徽章，下摆左侧有红色数字'2'\",\n    \"细节\": \"领口和袖口有红白条纹装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士Polo衫，而商品描述为'高端品牌商务皮鞋，真皮鞋面'，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "```json\n{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"Polo衫\",\n    \"材质\": \"棉质\",\n    \"图案\": \"胸前有黑色'B'字母标志，左袖有徽章，下摆有数字'2'\",\n    \"领口\": \"翻领，红色镶边\",\n    \"袖口\": \"红色镶边\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士Polo衫，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重图文不符。根据平台规则，商品描述必须与图片内容一致，因此该商品违反审核规定。\"\n}\n```"}
{"image_file": "product_00142.jpg", "image": "data/raw/images/product_00142.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"银色、灰色、绿色、黑色\",\n    \"材质\": \"网布、合成革、橡胶\",\n    \"款式\": \"低帮运动鞋\",\n    \"品牌标识\": \"Reebok\",\n    \"鞋底设计\": \"白色中底，绿色外底边缘\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大宣传用语，可能构成虚假或引人误解的商业宣传，违反平台广告合规规则。\"\n}", "rejected": "```json\n{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"color\": \"银色、灰色、绿色、黑色\",\n    \"material\": \"网布、合成革\",\n    \"style\": \"低帮运动鞋\",\n    \"brand\": \"Reebok\",\n    \"features\": \"透气网面、缓震中底、橡胶外底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘最新款’和‘超低价’等夸大性宣传用语，可能构成虚假或误导性宣传，且未提供具体价格信息或对比依据，不符合平台广告规范。\"\n}\n```"}
{"image_file": "product_00144.jpg", "image": "data/raw/images/product_00144.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘颜色\": \"银色\",\n    \"表带颜色\": \"深蓝色\",\n    \"表带材质\": \"硅胶\",\n    \"表圈装饰\": \"蓝宝石和水晶镶嵌\",\n    \"刻度类型\": \"罗马数字与三角形标记\",\n    \"指针样式\": \"简约银色指针\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片为手表，但商品描述中提及'面料柔软 版型修身 显瘦神器'，明显与实际商品类别不符，属于虚假或误导性描述。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"color\": \"蓝色\",\n    \"material\": \"硅胶表带，金属表壳\",\n    \"dial_color\": \"银色\",\n    \"markings\": \"罗马数字刻度（XII, IX, III, VI）\",\n    \"gemstones\": \"蓝宝石和水晶装饰表圈\",\n    \"watch_type\": \"石英表\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片为一款手表，但提供的商品描述‘面料柔软 版型修身 显瘦神器’适用于服装类商品，与实际商品类别严重不符，属于虚假或误导性描述。\"\n}"}
{"image_file": "product_00145.jpg", "image": "data/raw/images/product_00145.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"品牌标志\": \"Puma\",\n    \"材质\": \"棉质或混纺\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"纽扣\": \"三颗黑色纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大宣传用语，可能构成虚假促销或误导性营销，违反平台关于广告宣传真实性的规定。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖Polo衫\",\n    \"品牌标识\": \"Puma（右胸位置有银色标志）\",\n    \"材质\": \"棉质或混纺面料\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"黑色三粒纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等营销性夸大词汇，可能违反平台关于虚假宣传或价格欺诈的相关规定。此外，图片展示的是带有Puma品牌标识的商品，若未经授权销售可能涉及侵权问题。\"\n}"}
{"image_file": "product_00147.jpg", "image": "data/raw/images/product_00147.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "chosen": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝白格纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"标准翻领\",\n    \"口袋\": \"双胸袋\",\n    \"袖口\": \"白色翻边袖口\",\n    \"材质\": \"棉质或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男式格纹长袖衬衫，而商品描述为‘运动休闲鞋，缓震耐磨橡胶底’，存在严重的图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白格子\",\n    \"款式\": \"长袖衬衫\",\n    \"材质\": \"棉质或混纺\",\n    \"细节\": \"胸前两个口袋，白色袖口翻边\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是一件男士长袖格子衬衫，而商品描述为‘运动休闲鞋’，存在严重图文不符，违反平台商品描述真实性规范。\"\n}"}
{"image_file": "product_00148.jpg", "image": "data/raw/images/product_00148.jpg", "prompt": "百搭连衣裙，适合日常出行", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"品牌\": \"Puma\",\n    \"图案\": \"白色弧形条纹，左胸有Puma标志，左袖有格子图案\",\n    \"材质\": \"运动面料\",\n    \"领型\": \"翻领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士Polo衫，而商品描述为'百搭连衣裙，适合日常出行'，存在严重品类与描述不符的问题。\"\n}", "rejected": "{\"category\": \"男士短袖Polo衫\", \"attributes\": {\"颜色\": \"黑色\", \"品牌\": \"Puma\", \"款式\": \"Polo领\", \"图案\": \"白色弧形条纹，左胸有Puma标志，左袖有方格图案\"}, \"violation\": true, \"reason\": \"商品图片显示为男士短袖Polo衫，而商品描述中称其为'百搭连衣裙'，存在严重品类不符和误导性描述\"}"}
{"image_file": "product_00149.jpg", "image": "data/raw/images/product_00149.jpg", "prompt": "欧美风格外套，时尚简约", "chosen": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"白、黑、黄格纹\",\n    \"款式\": \"长袖格子衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前双口袋\",\n    \"袖口\": \"卷起\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一件格子衬衫，但商品描述中称其为'外套'，存在品类描述不符的问题。实际商品并非外套，属于衬衫类别，因此违反了商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"白、黑、黄格纹\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前双口袋\",\n    \"袖口\": \"卷袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为格纹长袖衬衫，但描述中称其为‘外套’，存在品类描述不符的虚假宣传问题。\"\n}"}
{"image_file": "product_00151.jpg", "image": "data/raw/images/product_00151.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"brand\": \"Nike\",\n    \"color\": \"黑色为主，荧光绿点缀\",\n    \"material\": \"皮革与合成材料\",\n    \"style\": \"低帮休闲运动鞋\",\n    \"sole\": \"白色橡胶底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'商场撤柜'、'专柜正品'、'便宜处理'等词汇，涉嫌虚假宣传和价格诱导，可能误导消费者。同时，图片展示为全新商品，但描述暗示为清仓或低价处理，存在信息不一致问题。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"brand\": \"Nike\",\n    \"color\": \"black with neon green accents\",\n    \"material\": \"leather and synthetic\",\n    \"style\": \"low-top sneaker\",\n    \"sole\": \"white rubber\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘商场撤柜’和‘便宜处理’等词汇，可能暗示该商品为清仓或非正规渠道销售，与图片展示的正品专柜商品存在信息不一致风险，涉嫌虚假宣传。\"\n}"}
{"image_file": "product_00152.jpg", "image": "data/raw/images/product_00152.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"胸前印有'Original'字样及'19 F.M. 80'数字标识\",\n    \"材质\": \"棉质\",\n    \"性别\": \"男款\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'最新款 超低价 清仓大甩卖'等夸大宣传用语，可能构成虚假或引人误解的商业宣传，违反平台广告合规规范。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"红色\",\n    \"type\": \"短袖T恤\",\n    \"print\": \"Original 19 F.M. 80\",\n    \"design\": \"圆领，正面印花，左袖有徽标\",\n    \"material\": \"棉质（推测）\",\n    \"fit\": \"合身\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘最新款’‘超低价’‘清仓大甩卖’等营销性用语，属于违规宣传，可能误导消费者。同时未提供具体产品信息如材质、尺码等，不符合平台对商品描述完整性的要求。\"\n}"}
{"image_file": "product_00153.jpg", "image": "data/raw/images/product_00153.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝绿白格纹\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"长袖衬衫\",\n    \"设计元素\": \"胸前双口袋，纽扣开合，翻领\",\n    \"袖口\": \"卷起\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，展示为一件纯棉材质的休闲格纹衬衫，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝绿色格子图案\",\n    \"材质\": \"棉质\",\n    \"款式\": \"长袖休闲衬衫\",\n    \"细节\": \"胸前有两个带纽扣的口袋，领口有紫色衬里\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是一件格子图案的纯棉休闲衬衫，符合描述中‘纯棉休闲上衣’的定位，无违规信息或虚假宣传。\"\n}"}
{"image_file": "product_00156.jpg", "image": "data/raw/images/product_00156.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "chosen": "{\n  \"category\": \"运动裤\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"品牌标志\": \"黄色耐克勾形标志\",\n    \"款式\": \"高腰阔腿裤\",\n    \"材质\": \"合成纤维（非真丝）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为深灰色运动裤，带有耐克品牌标志，实际材质为合成纤维，与描述中‘100%真丝连衣裙’严重不符，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"运动裤\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"材质\": \"合成纤维（非真丝）\",\n    \"品牌标志\": \"黄色Nike标志\",\n    \"款式\": \"高腰阔腿运动裤\",\n    \"长度\": \"七分裤\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为深灰色运动裤，带有Nike品牌标志，实际材质为合成纤维，与描述中的'100%真丝连衣裙'严重不符，存在虚假描述和误导性信息。\"\n}"}
{"image_file": "product_00157.jpg", "image": "data/raw/images/product_00157.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"麂皮\",\n    \"款式\": \"系带短靴\",\n    \"鞋底\": \"棕色橡胶底\",\n    \"设计细节\": \"缝线装饰，圆头\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双棕色麂皮短靴，属于鞋类商品，而描述中提及的是‘纯棉休闲上衣’，存在品类与描述严重不符的情况。\"\n}", "rejected": "{\n  \"category\": \"鞋子\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"翻毛皮\",\n    \"款式\": \"短靴\",\n    \"鞋带\": \"系带式\",\n    \"鞋底\": \"橡胶底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一双棕色翻毛皮短靴，但商品描述为‘纯棉休闲上衣’，描述与图片内容严重不符，属于虚假宣传。\"\n}"}
{"image_file": "product_00158.jpg", "image": "data/raw/images/product_00158.jpg", "prompt": "经典款牛仔裤，修身显瘦", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑白\",\n    \"款式\": \"高帮运动鞋\",\n    \"材质\": \"皮革/合成材料\",\n    \"设计元素\": \"滴墨图案\",\n    \"鞋带\": \"黑色\",\n    \"鞋底\": \"白色橡胶\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双高帮运动鞋，而商品描述为'经典款牛仔裤，修身显瘦'，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "```json\n{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"black and white\",\n    \"style\": \"high-top sneaker\",\n    \"design\": \"drip pattern\",\n    \"material\": \"leather-like upper, rubber sole\",\n    \"features\": \"strap at ankle, black laces\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为高帮运动鞋，而描述中提到的是经典款牛仔裤，存在严重图文不符。\"\n}\n```"}
{"image_file": "product_00159.jpg", "image": "data/raw/images/product_00159.jpg", "prompt": "欧美风格外套，时尚简约", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红白格子\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质\",\n    \"设计元素\": \"胸前双口袋、纽扣开合、领口翻领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件短袖格子衬衫，而商品描述中称其为‘欧美风格外套’，存在品类与描述不符的问题。该商品并非外套，而是衬衫，属于误导性描述。\"\n}", "rejected": "{\n  \"category\": \"男士衬衫\",\n  \"attributes\": {\n    \"颜色\": \"酒红、白色、黑色格纹\",\n    \"款式\": \"短袖\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"双胸袋\",\n    \"材质\": \"棉质混纺\",\n    \"图案\": \"格子\",\n    \"品牌标识\": \"右胸口有刺绣logo\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品实际为短袖格子衬衫，与描述中“外套”不符，属于类目和描述严重不一致。\"\n}"}
{"image_file": "product_00160.jpg", "image": "data/raw/images/product_00160.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "chosen": "{\n  \"category\": \"男装-裤子\",\n  \"attributes\": {\n    \"颜色\": \"深绿色\",\n    \"材质\": \"棉质或混纺面料\",\n    \"款式\": \"直筒修身款\",\n    \"细节\": \"有裤线，搭配黑色皮带和皮鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是常规男士正装裤，无违规内容。描述中‘显瘦神器’属于常见营销用语，未涉及虚假宣传或夸大功效，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"男装裤子\",\n  \"attributes\": {\n    \"颜色\": \"深橄榄绿\",\n    \"材质\": \"柔软面料\",\n    \"版型\": \"修身直筒\",\n    \"细节\": \"有褶设计，搭配黑色皮带和皮鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，无违禁内容，符合广告规范。描述中‘显瘦神器’属于常见营销话术，未发现夸大或误导性表述，且实物与描述相符，未涉及虚假宣传。\"\n}"}
{"image_file": "product_00163.jpg", "image": "data/raw/images/product_00163.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"品牌\": \"adidas\",\n    \"球队标志\": \"切尔西足球俱乐部\",\n    \"赞助商标志\": \"Samsung\",\n    \"颜色\": \"黑色为主，搭配白色条纹和蓝色图案\",\n    \"款式\": \"拉链夹克 + 运动长裤\",\n    \"材质\": \"合成纤维（疑似聚酯）\",\n    \"设计元素\": \"三道杠、队徽、像素化图案\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品为带有切尔西足球俱乐部和三星（Samsung）品牌标识的Adidas官方授权运动套装，属于品牌联名产品。商品描述中声称‘手工制作’和‘限量款’与实际批量生产的运动服装属性不符，存在虚假宣传嫌疑，违反平台关于商品描述真实性的规定。\"\n}", "rejected": "{\n  \"category\": \"运动服装\",\n  \"attributes\": {\n    \"品牌\": \"Adidas\",\n    \"球队标识\": \"切尔西足球俱乐部\",\n    \"赞助商标志\": \"Samsung\",\n    \"颜色\": \"黑色为主，白色条纹，蓝色图案\",\n    \"款式\": \"运动套装（夹克+长裤）\",\n    \"材质\": \"合成纤维（疑似涤纶）\",\n    \"设计元素\": \"三条纹设计、拉链开合、胸前徽章\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的是带有‘切尔西足球俱乐部’和‘Samsung’标志的官方授权运动套装，属于知名品牌及体育团队联名产品。而商品描述中标注为‘手工制作’和‘限量款’，存在误导性宣传，涉嫌虚假描述。该商品并非手工制作，且‘限量款’无法从图片中证实，可能违反平台关于真实性和品牌合规的相关规则。\"\n}"}
{"image_file": "product_00164.jpg", "image": "data/raw/images/product_00164.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"表盘类型\": \"数字显示\",\n    \"表带材质\": \"橡胶\",\n    \"品牌标识\": \"Puma\",\n    \"设计风格\": \"简约现代\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中可见Puma品牌标识，但商品描述使用'日系简约 ins风 学院风'等词汇，存在品牌与风格描述不符的情况，可能误导消费者。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"表盘样式\": \"数字显示屏\",\n    \"表带材质\": \"硅胶\",\n    \"品牌标志\": \"Puma\",\n    \"显示内容\": \"时间、日期、星期\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为Puma品牌手表，但商品描述中使用'日系简约 ins风 学院风'等风格标签，存在品牌与风格描述不一致的情况，可能导致消费者误导。\"\n}"}
{"image_file": "product_00165.jpg", "image": "data/raw/images/product_00165.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"托特包\",\n    \"细节\": \"金属铆钉、品牌标签、双提手、可拆卸肩带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一个棕色皮革手提包，而商品描述为‘简约设计衬衫，商务休闲两相宜’，描述内容与图片商品类别严重不符，属于图文不一致违规。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather\",\n    \"style\": \"tote\",\n    \"features\": [\n      \"top handles\",\n      \"removable shoulder strap\",\n      \"front pocket\",\n      \"metal hardware\",\n      \"brand label\"\n    ]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款棕色皮革手提包，而商品描述为‘简约设计衬衫，商务休闲两相宜’，存在严重图文不符。描述内容与实际商品类别不一致，违反了平台关于商品信息真实性的规定。\"\n}"}
{"image_file": "product_00166.jpg", "image": "data/raw/images/product_00166.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"type\": \"chronograph\",\n    \"color\": \"silver and black\",\n    \"material\": \"leather strap, metal case\",\n    \"dial\": \"white with black markings\",\n    \"features\": [\"three sub-dials\", \"red second hand\", \"date window\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款ESPRIT品牌的手表，但商品描述为‘简约设计衬衫，商务休闲两相宜’，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"type\": \"chronograph\",\n    \"color\": \"silver and black\",\n    \"material\": \"leather strap, stainless steel case\",\n    \"features\": [\"analog display\", \"three sub-dials\", \"red second hand\", \"Roman numeral markers\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一款手表，而商品描述为'简约设计衬衫，商务休闲两相宜'，描述内容与图片商品类别严重不符，构成虚假宣传或误导性描述。\"\n}"}
{"image_file": "product_00167.jpg", "image": "data/raw/images/product_00167.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather\",\n    \"style\": \"high-top sneaker\",\n    \"lacing\": \"white laces\",\n    \"sole\": \"white rubber\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一双棕色皮革高帮鞋，而商品描述为'100%真丝连衣裙'，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather\",\n    \"style\": \"high-top sneaker\",\n    \"sole\": \"white rubber\",\n    \"laces\": \"beige\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一双棕色皮质高帮鞋，但商品描述却为'100%真丝连衣裙，高贵典雅'，存在严重图文不符，违反平台真实描述规则。\"\n}"}
{"image_file": "product_00168.jpg", "image": "data/raw/images/product_00168.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "chosen": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"gold\",\n    \"material\": \"glitter fabric\",\n    \"style\": \"thong sandal\",\n    \"sole_type\": \"flat\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为金色闪亮材质的人字拖，与描述中的‘简约设计衬衫’严重不符，存在虚假描述问题。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"gold\",\n    \"material\": \"glitter fabric\",\n    \"style\": \"thong sandal\",\n    \"sole_type\": \"flat\",\n    \"brand\": \"CARL\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是金色亮片人字拖，与描述中‘简约设计衬衫’不匹配，存在商品信息虚假描述问题。\"\n}"}
{"image_file": "product_00169.jpg", "image": "data/raw/images/product_00169.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"color\": \"红色\",\n    \"display_type\": \"数字显示屏\",\n    \"features\": [\n      \"心率监测\",\n      \"计时功能\",\n      \"运动模式\"\n    ],\n    \"material\": \"硅胶表带\",\n    \"design\": \"运动风格\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'商场撤柜'、'专柜正品'、'便宜处理'等词汇，涉嫌虚假宣传和价格诱导，且未提供正品证明文件，存在误导消费者风险。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"color\": \"红色\",\n    \"display_type\": \"数字显示屏\",\n    \"material\": \"硅胶表带\",\n    \"features\": [\"心率监测\", \"计时功能\", \"运动模式\"],\n    \"design\": \"运动风格\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘商场撤柜’‘专柜正品’‘便宜处理’等词汇，可能涉及虚假宣传或低价倾销的违规信息，结合图片为品牌智能手表，可能存在未经授权的销售行为，违反平台对正品货源和营销话术的规范。\"\n}"}
{"image_file": "product_00170.jpg", "image": "data/raw/images/product_00170.jpg", "prompt": "百搭连衣裙，适合日常出行", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"type\": \"Polo衫\",\n    \"color\": \"蓝灰条纹\",\n    \"brand\": \"Puma\",\n    \"material\": \"棉质\",\n    \"design\": \"短袖，翻领，胸前有品牌标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士Polo衫，而商品描述为‘百搭连衣裙，适合日常出行’，存在严重品类不符。图片中无任何连衣裙元素，且为男性模特穿着上衣，与描述中的‘连衣裙’完全不一致。\"\n}", "rejected": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝灰条纹\",\n    \"款式\": \"Polo衫\",\n    \"品牌\": \"Puma\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男式Polo衫，但商品描述为'百搭连衣裙，适合日常出行'，与实际商品类型严重不符，存在虚假描述问题。\"\n}"}
{"image_file": "product_00171.jpg", "image": "data/raw/images/product_00171.jpg", "prompt": "百搭连衣裙，适合日常出行", "chosen": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"前排纽扣\",\n    \"口袋\": \"胸前单口袋，带装饰铆钉\",\n    \"袖口\": \"卷边设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件短袖牛仔衬衫，而非描述中所称的‘连衣裙’，存在品类与描述不符的问题。\"\n}", "rejected": "{\n  \"category\": \"衬衫\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"短袖、纽扣开襟\",\n    \"细节\": \"胸前有一个带装饰铆钉的口袋\",\n    \"领型\": \"翻领\",\n    \"长度\": \"中长款\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是一件牛仔衬衫，而非描述中的'连衣裙'，商品描述与实际商品不符，存在误导消费者的风险。\"\n}"}
{"image_file": "product_00172.jpg", "image": "data/raw/images/product_00172.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"color\": \"银色\",\n    \"material\": \"金属\",\n    \"shape\": \"矩形\",\n    \"dial_color\": \"黑色\",\n    \"band_style\": \"链式\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款ESPRIT品牌的金属手表，而商品描述为'100%真丝连衣裙，高贵典雅'，存在严重品类与描述不符的问题。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"color\": \"银色\",\n    \"case_shape\": \"矩形\",\n    \"dial_color\": \"黑色\",\n    \"bracelet_type\": \"金属链式\",\n    \"material\": \"金属\",\n    \"display_type\": \"模拟\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款金属材质的手表，而商品描述中提及的是'100%真丝连衣裙'，两者品类严重不符，属于描述与实物不一致的违规行为。\"\n}"}
{"image_file": "product_00174.jpg", "image": "data/raw/images/product_00174.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"BARÇA 字样及巴塞罗那俱乐部徽章\",\n    \"品牌标志\": \"Nike\",\n    \"材质\": \"棉质（推测）\",\n    \"款式\": \"短袖T恤\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一件印有巴塞罗那足球俱乐部（FC Barcelona）标志和名称的运动T恤，而商品描述却为‘高端品牌商务皮鞋，真皮鞋面’，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"Barça字样与巴塞罗那俱乐部徽章\",\n    \"品牌标志\": \"耐克（Nike）标志\",\n    \"材质\": \"棉质或合成纤维\",\n    \"领口\": \"圆领，内衬红色\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一件巴塞罗那足球俱乐部主题的运动T恤，但商品描述为'高端品牌商务皮鞋，真皮鞋面'，存在严重的图文不符问题。实际商品为服装类目中的T恤，而非皮鞋。\"\n}"}
{"image_file": "product_00175.jpg", "image": "data/raw/images/product_00175.jpg", "prompt": "2024新款 正品保证 实体店同款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"绿色回收标志、蝴蝶、文字标语\",\n    \"文字内容\": \"RECYCLE, PEACE, WAR IS NOT HEALTHY FOR CHILDREN AND OTHER LIVING THINGS\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片中展示的T恤图案包含环保主题的文字和图形，如‘RECYCLE’、‘PEACE’及‘WAR IS NOT HEALTHY FOR CHILDREN AND OTHER LIVING THINGS’等，属于倡导和平与环保的正面信息，未发现违法不良信息或敏感内容。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"环保主题印花，包含绿色循环标志、蝴蝶、文字‘RECYCLE’、‘PEACE’、‘WAR IS NOT HEALTHY FOR CHILDREN AND OTHER LIVING THINGS’\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质\": \"未明确，推测为棉质或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的T恤图案内容为环保与和平主题，无违法不良信息，符合平台审核规范。\"\n}"}
{"image_file": "product_00176.jpg", "image": "data/raw/images/product_00176.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"Carrera\",\n    \"表盘颜色\": \"黑色\",\n    \"表带材质\": \"橡胶\",\n    \"表壳材质\": \"金属\",\n    \"表盘设计\": \"八角形\",\n    \"功能\": \"日期显示\",\n    \"指针类型\": \"时针、分针、秒针\",\n    \"表带颜色\": \"黑色\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大宣传用语，可能构成虚假或引人误解的商业宣传，违反平台广告合规规范。\"\n}", "rejected": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Carrera\",\n    \"color\": \"黑色与银色\",\n    \"material\": \"橡胶表带，金属表壳\",\n    \"display_type\": \"指针式\",\n    \"features\": [\n      \"碳纤维纹理表盘\",\n      \"日期显示窗口\",\n      \"大数字12时标\"\n    ],\n    \"style\": \"运动型\",\n    \"case_shape\": \"八角形\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’‘超低价’‘清仓大甩卖’等涉嫌虚假宣传和诱导性营销用语，不符合平台广告合规规范。此外，图片中的手表为知名品牌Carrera，可能存在未经授权的仿品或盗版风险，需进一步核实品牌授权信息。\"\n}"}
{"image_file": "product_00177.jpg", "image": "data/raw/images/product_00177.jpg", "prompt": "欧美大牌设计 小众品牌", "chosen": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘颜色\": \"黑色\",\n    \"表壳材质\": \"不锈钢\",\n    \"表带材质\": \"黑色皮革\",\n    \"表盘设计\": \"三眼多功能（24小时、日期、星期）\",\n    \"指针样式\": \"银色细长指针\",\n    \"刻度\": \"数字与条形刻度结合\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'欧美大牌设计'和'小众品牌'等词汇，可能构成虚假宣传或误导性描述。图片显示品牌为ESPRIT，属于大众时尚品牌，并非‘小众品牌’，且‘大牌设计’易被理解为仿冒或关联高端奢侈品牌，存在误导消费者风险。\"\n}", "rejected": "{\n  \"category\": \"watch\",\n  \"attributes\": {\n    \"brand\": \"ESPRIT\",\n    \"color\": \"black and silver\",\n    \"dial_color\": \"black\",\n    \"strap_material\": \"leather\",\n    \"strap_color\": \"black\",\n    \"case_material\": \"stainless steel\",\n    \"features\": [\n      \"date display\",\n      \"day of week indicator\",\n      \"24-hour sub-dial\",\n      \"31-day date sub-dial\"\n    ],\n    \"design_style\": \"modern multi-functional\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘欧美大牌设计’和‘小众品牌’等模糊或夸大性宣传语，易误导消费者认为其为高端奢侈品牌，与实际品牌（ESPRIT）定位不符，违反平台关于广告宣传真实性的规定。\"\n}"}
{"image_file": "product_00178.jpg", "image": "data/raw/images/product_00178.jpg", "prompt": "高端羊毛面料，奢华质感", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"缝线\": \"浅色装饰缝线\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为皮革材质的皮鞋，但描述中声称使用‘高端羊毛面料’，材质描述与实际视觉特征严重不符，构成虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带皮鞋\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"设计\": \"商务正装风格\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为皮革材质的皮鞋，但商品描述中声称‘高端羊毛面料’，材质描述与实际视觉内容严重不符，构成虚假宣传。\"\n}"}
{"image_file": "product_00179.jpg", "image": "data/raw/images/product_00179.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "chosen": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"品牌\": \"New Balance\",\n    \"颜色\": [\"白色\", \"深蓝色\", \"荧光绿\"],\n    \"材质\": [\"网布\", \"合成革\", \"橡胶\"],\n    \"设计特点\": [\"透气网面\", \"缓震中底\", \"耐磨橡胶外底\", \"N字标志\"],\n    \"鞋型\": \"低帮运动鞋\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片清晰展示为New Balance品牌运动鞋，符合运动休闲鞋类别描述，无违规标识或虚假宣传内容。\"\n}", "rejected": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"品牌\": \"New Balance\",\n    \"颜色\": [\"白色\", \"深蓝色\", \"荧光绿\"],\n    \"材质\": [\"网面\", \"合成革\", \"橡胶底\"],\n    \"款式\": \"低帮\",\n    \"功能特点\": [\"缓震\", \"耐磨\", \"透气\"]\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的为正规品牌New Balance运动鞋，外观符合常规运动休闲鞋特征，无仿冒或违规标识。描述中提及的'缓震耐磨橡胶底'与鞋底设计相符，未发现虚假宣传或误导性信息。\"\n}"}
{"image_file": "product_00180.jpg", "image": "data/raw/images/product_00180.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"女装-上衣\",\n  \"attributes\": {\n    \"颜色\": \"粉红色\",\n    \"款式\": \"短袖\",\n    \"领型\": \"圆领\",\n    \"材质\": \"棉质或混纺\",\n    \"设计元素\": \"荷叶边、玫瑰印花\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用'商场撤柜'、'专柜正品'、'便宜处理'等词汇，涉嫌虚假宣传和价格诱导，可能误导消费者。同时，图片未显示品牌标识，无法验证其是否为专柜正品，存在信息不实风险。\"\n}", "rejected": "{\n  \"category\": \"女装-上衣\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"款式\": \"短袖荷叶边T恤\",\n    \"材质\": \"棉质或混纺面料\",\n    \"图案\": \"玫瑰印花\",\n    \"领型\": \"圆领\",\n    \"设计细节\": \"胸前荷叶边装饰，半透明蕾丝拼接\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含'商场撤柜'、'专柜正品'、'便宜处理'等涉嫌虚假宣传或价格诱导的敏感词，可能误导消费者。此外，图片中展示的是常规服饰产品，未涉及违规内容，但描述存在夸大和不实宣传嫌疑。\"\n}"}
{"image_file": "product_00182.jpg", "image": "data/raw/images/product_00182.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"亮黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"复古风格的交通标志印花，包含'NO STOPPING OR PARKING'字样和箭头符号\",\n    \"材质\": \"棉质或棉混纺（根据描述推断）\",\n    \"版型\": \"修身\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为普通服饰，图案为艺术化处理的交通标志，无政治、宗教、色情或暴力等违规内容，符合平台规范。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"亮黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"复古风格交通标志印花，包含'NO STOPPING OR PARKING'字样及箭头符号\",\n    \"领型\": \"圆领\",\n    \"版型\": \"修身\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的T恤为普通服饰，图案为艺术化处理的交通标志，并未涉及违法不良信息或侵权内容，符合平台发布规范。\"\n}"}
{"image_file": "product_00183.jpg", "image": "data/raw/images/product_00183.jpg", "prompt": "国风刺绣上衣，传统工艺", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白条纹\",\n    \"款式\": \"短袖衬衫\",\n    \"图案\": \"胸前有彩色徽章图案\",\n    \"材质\": \"棉质或混纺面料\",\n    \"设计元素\": \"竖条纹、翻领、纽扣开合、袖口卷起\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为蓝白条纹短袖衬衫，带有现代风格的徽章图案，不符合‘国风刺绣上衣，传统工艺’的描述。实际商品无明显传统刺绣元素，且整体设计偏向休闲时尚风格，与‘国风’和‘传统工艺’存在显著不符。\"\n}", "rejected": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"图案\": \"蓝白竖条纹\",\n    \"袖长\": \"短袖\",\n    \"领型\": \"翻领\",\n    \"装饰\": \"胸前有徽章式刺绣图案\",\n    \"材质\": \"棉质或混纺面料（视觉推断）\",\n    \"颜色\": \"蓝色、白色、黑色条纹，辅以红色和黄色刺绣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中称其为'国风刺绣上衣，传统工艺'，但图片显示的是一件现代风格的条纹衬衫，胸前刺绣图案具有明显的非中国传统元素特征（如几何星形与英文字母组合），不符合'国风'和'传统工艺'的描述，存在虚假宣传风险。\"\n}"}
{"image_file": "product_00184.jpg", "image": "data/raw/images/product_00184.jpg", "prompt": "欧美风格外套，时尚简约", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖T恤\",\n    \"领型\": \"圆领\",\n    \"材质\": \"棉质或混纺\",\n    \"图案\": \"左胸有小logo\",\n    \"搭配\": \"蓝色牛仔裤\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件白色短袖T恤，而商品描述为'欧美风格外套，时尚简约'，存在品类与描述严重不符的问题。图片中无任何外套特征，实际为上衣类基础款T恤，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"女装-上衣\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质\": \"棉质或棉混纺\",\n    \"图案\": \"左胸有小徽标\",\n    \"设计风格\": \"简约\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一件白色圆领短袖T恤，属于基础款上衣，并非描述中提及的'外套'，存在品类与描述不符的问题。\"\n}"}
{"image_file": "product_00185.jpg", "image": "data/raw/images/product_00185.jpg", "prompt": "纯手工编织，限量发售", "chosen": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"手提包\",\n    \"细节\": \"金属拉链、铆钉装饰、双侧口袋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘纯手工编织’，但图片显示该包为皮革材质且无编织工艺特征，存在虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"red\",\n    \"material\": \"leather\",\n    \"style\": \"structured tote\",\n    \"hardware\": \"metal zippers and buckles\",\n    \"stitching\": \"yellow contrast stitching\",\n    \"handle\": \"top handle\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'纯手工编织'，但图片显示为皮革材质的缝制手提包，不具备编织特征，存在虚假宣传。\"\n}"}
{"image_file": "product_00186.jpg", "image": "data/raw/images/product_00186.jpg", "prompt": "最新款 超低价 清仓大甩卖", "chosen": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"品牌\": \"Puma\",\n    \"颜色\": \"黑色、白色、灰色\",\n    \"材质\": \"帆布\",\n    \"款式\": \"低帮休闲鞋\",\n    \"图案\": \"星空/宇宙主题印花\",\n    \"鞋带\": \"白色\",\n    \"鞋底\": \"橡胶底，白色与棕色拼接\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’‘超低价’‘清仓大甩卖’等夸大宣传用语，可能构成虚假或引人误解的商业宣传，违反平台广告合规规范。\"\n}", "rejected": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"black and white\",\n    \"material\": \"canvas\",\n    \"design\": \"space-themed pattern\",\n    \"brand\": \"Puma\",\n    \"style\": \"low-top sneaker\",\n    \"sole_type\": \"rubber\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含'超低价'、'清仓大甩卖'等涉嫌虚假促销的宣传用语，可能误导消费者，违反平台关于广告真实性与合规性的规定。\"\n}"}
{"image_file": "product_00188.jpg", "image": "data/raw/images/product_00188.jpg", "prompt": "经典款牛仔裤，修身显瘦", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"type\": \"T恤\",\n    \"color\": \"橄榄绿\",\n    \"pattern\": \"涂鸦风格印花\",\n    \"material\": \"棉质\",\n    \"design\": \"短袖圆领\",\n    \"print_content\": \"包含地球、冰川、风暴、文字等环保主题图案\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件印有环保主题涂鸦图案的T恤，但商品描述为'经典款牛仔裤，修身显瘦'，存在严重图文不符，属于虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"type\": \"T恤\",\n    \"color\": \"橄榄绿\",\n    \"pattern\": \"涂鸦印花\",\n    \"material\": \"棉质\",\n    \"style\": \"短袖圆领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一件印花T恤，而商品描述中却声称是‘经典款牛仔裤’，存在图文不符的问题。\"\n}"}
{"image_file": "product_00189.jpg", "image": "data/raw/images/product_00189.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"品牌标志\": \"Puma\",\n    \"领口设计\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"材质\": \"棉质或混纺\",\n    \"细节\": \"左胸有白色Puma标志，领内和下摆有红色点缀\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为Puma品牌服饰，但商品描述中声称‘手工制作’和‘限量款’，这与大众化品牌批量生产的特性不符，存在虚假宣传嫌疑。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"品牌标志\": \"Puma\",\n    \"领口设计\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"细节\": \"左胸有白色Puma标识，领口内侧及下摆有红色点缀\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品为知名品牌Puma的授权产品，但描述中使用了'手工制作'和'限量款'等宣传语，可能构成误导性信息，违反平台关于品牌商品真实属性描述的规定。实际图片显示为标准量产款式，无明显手工痕迹或限量标识。\"\n}"}
{"image_file": "product_00192.jpg", "image": "data/raw/images/product_00192.jpg", "prompt": "韩版潮流服饰，时尚百搭", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"type\": \"牛仔裤\",\n    \"color\": \"深蓝色\",\n    \"style\": \"修身直筒\",\n    \"material\": \"棉质牛仔布\",\n    \"design_features\": [\n      \"水洗做旧效果\",\n      \"前袋有缝线装饰\",\n      \"金属纽扣\",\n      \"后袋有品牌标志\"\n    ],\n    \"fit\": \"中腰\",\n    \"occasion\": \"日常休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男式牛仔裤，无违规图案、文字或敏感元素，符合平台服饰类目规范。\"\n}", "rejected": "{\n  \"category\": \"男装-牛仔裤\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色渐变\",\n    \"款式\": \"修身直筒\",\n    \"材质\": \"牛仔布\",\n    \"设计细节\": \"水洗做旧、膝盖处磨损效果、对比色缝线\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男式牛仔裤，符合平台服装类目规范，无违规内容或不当标识。\"\n}"}
{"image_file": "product_00193.jpg", "image": "data/raw/images/product_00193.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"浅灰色\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"长袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前双口袋\",\n    \"袖口\": \"可卷袖\",\n    \"装饰\": \"袖子上有红色徽章\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，为纯棉材质的休闲上衣，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"男士衬衫\",\n  \"attributes\": {\n    \"颜色\": \"浅灰色\",\n    \"材质\": \"纯棉\",\n    \"款式\": \"长袖\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前双袋\",\n    \"纽扣\": \"白色\",\n    \"袖口\": \"卷袖\",\n    \"装饰\": \"左右袖上有红色徽章\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一件符合描述的纯棉休闲上衣，颜色为浅灰色，具备标准衬衫结构，无违规标识或敏感内容。\"\n}"}
{"image_file": "product_00194.jpg", "image": "data/raw/images/product_00194.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色为主，黄色点缀\",\n    \"款式\": \"V领长袖毛衣\",\n    \"图案\": \"胸前有大写字母'P'，袖口和下摆有黄黑条纹\",\n    \"材质\": \"针织面料\",\n    \"风格\": \"学院风\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是一件深蓝色V领毛衣，带有黄色字母'P'和条纹装饰，整体风格符合学院风描述，未发现违规元素。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色主体，黄色装饰条纹\",\n    \"款式\": \"V领毛衣\",\n    \"图案\": \"左胸有大写字母P，袖口有双色条纹\",\n    \"材质\": \"针织面料\",\n    \"设计风格\": \"学院风\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的为一件具有学院风格的V领毛衣，整体设计以深蓝与黄色为主色调，包含字母P和条纹元素，符合‘日系简约 ins风 学院风’的描述，无违规内容。\"\n}"}
{"image_file": "product_00195.jpg", "image": "data/raw/images/product_00195.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "chosen": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋头\": \"尖头\",\n    \"缝线\": \"浅色装饰缝线\",\n    \"鞋底\": \"棕色橡胶底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含'商场撤柜'、'专柜正品'、'便宜处理'等宣传性用语，可能涉及虚假促销或误导消费者，违反平台关于商品描述真实性的规定。\"\n}", "rejected": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带皮鞋\",\n    \"设计特点\": \"拼接缝线，尖头设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含‘商场撤柜’、‘专柜正品’、‘便宜处理’等表述，属于引导性或暗示性低价促销话术，可能误导消费者对商品来源和品质的认知，违反平台关于商品描述真实性和合规性的规定。\"\n}"}
{"image_file": "product_00196.jpg", "image": "data/raw/images/product_00196.jpg", "prompt": "时尚单品 手工制作 限量款", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"V领短袖T恤\",\n    \"图案\": \"白色字体'bubbles'，带有黑色泼墨效果，下方有'FLAP DOODLE'字样\",\n    \"品牌\": \"FLAP DOODLE\",\n    \"材质\": \"未明确显示，推测为棉质或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示的是一件红色儿童T恤，设计风格活泼，无违规图案、文字或敏感元素。商品描述中提及‘手工制作’和‘限量款’属于常见营销用语，未发现虚假宣传或违反平台规则的内容。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"红色\",\n    \"design\": \"印花T恤\",\n    \"print_text\": \"bubbles\",\n    \"brand\": \"FLAP DOODLE\",\n    \"neckline\": \"V领\",\n    \"sleeve_length\": \"短袖\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为普通儿童T恤，设计符合常规时尚服饰标准，未发现违法或不当内容。\"\n}"}
{"image_file": "product_00197.jpg", "image": "data/raw/images/product_00197.jpg", "prompt": "日系简约 ins风 学院风", "chosen": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"托特包\",\n    \"设计风格\": \"简约\",\n    \"装饰元素\": \"金属扣饰\",\n    \"肩带类型\": \"双提手\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，为一款棕色皮革托特包，具有简约设计风格，符合日系ins风和学院风的审美特征，未发现违规内容。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather\",\n    \"style\": \"structured tote\",\n    \"features\": [\n      \"top handle\",\n      \"front flap closure\",\n      \"metal hardware\"\n    ]\n  },\n  \"violation\": false,\n  \"reason\": \"商品为棕色皮革手提包，具有简约设计和金属五金件，符合日系简约ins风与学院风的描述，无违规内容。\"\n}"}
{"image_file": "product_00199.jpg", "image": "data/raw/images/product_00199.jpg", "prompt": "纯棉休闲上衣，舒适透气", "chosen": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"直筒牛仔裤\",\n    \"细节\": \"膝盖处有轻微磨损设计，金色纽扣，双侧口袋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是牛仔裤，但商品描述为'纯棉休闲上衣'，存在品类与描述严重不符的情况。\"\n}", "rejected": "{\n  \"category\": \"裤子\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"直筒牛仔裤\",\n    \"细节\": \"膝盖处有轻微磨损效果，黄色缝线\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是牛仔裤，而描述中却写为‘纯棉休闲上衣’，存在品类与描述严重不符的问题。\"\n}"}
{"image_file": "product_01304.jpg", "image": "data/raw/images/product_01304.jpg", "prompt": "卡其色Wrangler印花男士短袖T恤", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"卡其色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"Wrangler品牌印花，包含牛仔靴和星形图案\",\n    \"材质\": \"棉质（推测）\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士T恤，图案为品牌标识及西部风格元素，无违规内容。\"\n}", "rejected": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"卡其色\",\n    \"款式\": \"短袖T恤\",\n    \"品牌\": \"Wrangler\",\n    \"图案\": \"西部风格印花，包含靴子和星形图案\",\n    \"材质\": \"棉质（推测）\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通男士T恤，图案为品牌标志性西部元素，无敏感内容或违规标识，符合平台合规要求。\"\n}"}
