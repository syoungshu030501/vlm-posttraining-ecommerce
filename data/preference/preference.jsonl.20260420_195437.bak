{"image_file": "product_01070.jpg", "image": "data/raw/images/product_01070.jpg", "prompt": "玫红色女士短袖Polo衫，纯色简约设计", "chosen": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"玫红色\",\n    \"款式\": \"短袖Polo衫\",\n    \"性别\": \"女士\",\n    \"设计风格\": \"纯色简约\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"三颗同色系纽扣\",\n    \"品牌标识\": \"左胸有小logo\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片展示清晰，符合服装类目规范，无违规内容或敏感信息。\"\n}", "rejected": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"玫红色\",\n    \"款式\": \"短袖Polo衫\",\n    \"性别\": \"女士\",\n    \"设计风格\": \"纯色简约\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"三颗纽扣\",\n    \"品牌标识\": \"左胸有小logo\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规服饰，图片展示清晰，无违规信息或敏感内容，符合平台发布规范。\"\n}"}
{"image_file": "product_00374.jpg", "image": "data/raw/images/product_00374.jpg", "prompt": "高端羊毛面料，奢华质感", "chosen": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"purple\",\n    \"material\": \"leather-like synthetic\",\n    \"pattern\": \"quilted with circular stitching\",\n    \"handle\": \"braided, matching purple\",\n    \"hardware\": \"silver-tone metal rings and attachments\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称使用'高端羊毛面料'，但图片显示该包为绗缝皮革质感材料，无任何羊毛特征，存在材质虚假宣传。\"\n}", "rejected": "{\n  \"category\": \"handbag\",\n  \"attributes\": {\n    \"color\": \"purple\",\n    \"material\": \"leather-like synthetic\",\n    \"texture\": \"quilted pattern\",\n    \"handle\": \"braided, purple\",\n    \"hardware\": \"silver-colored metal rings and fittings\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称使用‘高端羊毛面料’，但图片显示商品为紫色绗缝皮革质感材料，无任何羊毛材质特征，存在虚假宣传。\"\n}"}
