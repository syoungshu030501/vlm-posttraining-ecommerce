{"image_file": "product_00243.jpg", "image": "data/raw/images/product_00243.jpg", "prompt": "纯手工编织，限量发售", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"图案\": \"机器人动漫风格印花\",\n    \"文字\": \"ROBOTICS FM ELECTRO ANIMATORS\",\n    \"材质\": \"棉质（视觉推断）\",\n    \"款式\": \"短袖圆领T恤\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'纯手工编织'，但图片显示该T恤为机器印刷的常规针织面料，无任何手工编织特征，存在虚假宣传。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00244.jpg", "image": "data/raw/images/product_00244.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质\",\n    \"图案\": \"左胸有彩色贴布图案，包含数字'8'和文字'ELP 12th'\",\n    \"细节\": \"右侧有一个带黑色缝线装饰的口袋，领标印有'FLAP DORISLE'品牌名\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服饰，无违规内容。视觉属性中包含的品牌标识和图案均为合法设计元素，未发现政治、宗教、色情或暴力等敏感信息。\"\n}", "violation": false, "category": "服装"}
{"image_file": "product_00245.jpg", "image": "data/raw/images/product_00245.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"荧光绿线条装饰\",\n    \"材质\": \"透气网眼面料\",\n    \"款式\": \"短袖T恤\",\n    \"品牌标识\": \"Nike标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为带有Nike品牌标识的运动T恤，而商品描述中称其为‘简约设计衬衫’，属于品类与描述严重不符。此外，该商品具有明显的运动风格设计（如网眼结构、荧光绿装饰线条），不符合‘商务休闲’的定位，存在误导性描述。\"\n}", "violation": true, "category": "运动服饰"}
{"image_file": "product_00246.jpg", "image": "data/raw/images/product_00246.jpg", "prompt": "纯手工编织，限量发售", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"银色\",\n    \"材质\": \"金属\",\n    \"表盘形状\": \"矩形\",\n    \"表带设计\": \"链式金属表带\",\n    \"表盘文字\": \"move on\",\n    \"指针颜色\": \"红色和蓝色\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘纯手工编织’，但图片显示该手表为金属材质的链式表带，无任何编织元素，与描述严重不符，构成虚假宣传。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00247.jpg", "image": "data/raw/images/product_00247.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"五金件\": \"金色金属环\",\n    \"缝线\": \"黄色\",\n    \"款式\": \"单肩/手提两用\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘商场撤柜’、‘专柜正品’、‘便宜处理’等宣传性词汇，可能涉及虚假或夸大宣传，且未提供品牌信息，存在误导消费者的风险。同时，图片中无法验证其是否为专柜正品，涉嫌违规营销。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00248.jpg", "image": "data/raw/images/product_00248.jpg", "prompt": "经典款牛仔裤，修身显瘦", "response": "{\n  \"category\": \"shoes\",\n  \"attributes\": {\n    \"color\": \"brown\",\n    \"material\": \"leather\",\n    \"style\": \"oxford\",\n    \"lacing\": \"lace-up\",\n    \"sole\": \"rubber\",\n    \"toe_shape\": \"cap_toe\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双棕色皮质男鞋，而商品描述为‘经典款牛仔裤，修身显瘦’，描述内容与实际商品类别严重不符，属于虚假描述。\"\n}", "violation": true, "category": "shoes"}
{"image_file": "product_00249.jpg", "image": "data/raw/images/product_00249.jpg", "prompt": "时尚秋冬外套，多色可选", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"米色\",\n    \"材质\": \"人造皮革\",\n    \"款式\": \"手提包\",\n    \"五金件\": \"银色金属环和扣件\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款米色手提包，而商品描述中提及的是‘时尚秋冬外套，多色可选’，存在明显的图文不符。根据平台规则，商品描述必须与实际商品一致，因此该商品违反了合规要求。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00250.jpg", "image": "data/raw/images/product_00250.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"鞋带\": \"白色\",\n    \"鞋底\": \"米白色\",\n    \"设计\": \"菱格纹缝线\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘商场撤柜’、‘专柜正品’、‘便宜处理’等表述，可能涉及虚假宣传或误导性营销。‘专柜正品’未提供相应证明，且‘便宜处理’暗示低价甩卖，可能影响消费者对商品价值的判断，违反平台关于商品描述真实性和合规性的规定。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00251.jpg", "image": "data/raw/images/product_00251.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红蓝格子\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"两个胸前口袋\",\n    \"材质\": \"棉质\",\n    \"图案\": \"格纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称是'纯棉休闲上衣'，但图片中无法验证其是否为100%纯棉材质，可能存在材质描述不实的风险。此外，该商品为短袖衬衫，属于常规服装品类，若未提供明确的成分标签或检测报告，易引发消费者对材质真实性的质疑，违反了电商平台关于商品信息真实性的规定。\"\n}", "violation": true, "category": "男装"}
{"image_file": "product_00252.jpg", "image": "data/raw/images/product_00252.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黄色、绿色、橙色\",\n    \"款式\": \"人字拖\",\n    \"图案\": \"包含中文字符和抽象图形\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双人字拖，而商品描述中却写的是‘简约设计衬衫，商务休闲两相宜’，存在严重品类与描述不符的违规问题。根据视觉属性，该商品属于鞋类，而非服装类中的衬衫，因此描述内容虚假且误导消费者。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00253.jpg", "image": "data/raw/images/product_00253.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"女装-半身裙\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"A字裙\",\n    \"长度\": \"中长款\",\n    \"材质\": \"光滑面料（疑似聚酯纤维或混纺）\",\n    \"细节\": \"高腰设计，无装饰\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规女装半身裙，视觉上无违规元素。描述中的'手工制作'和'限量款'未在图片中体现具体工艺或标识，但属于常见营销用语，不构成违规。\"\n}", "violation": false, "category": "女装-半身裙"}
{"image_file": "product_00254.jpg", "image": "data/raw/images/product_00254.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色、红色、白色格子图案\",\n    \"材质\": \"棉质或混纺面料\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"胸前两个带扣口袋\",\n    \"袖口\": \"深蓝色包边\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士格子短袖衬衫，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重品类不符。图片中未出现任何皮鞋或相关配件，描述内容与实际商品完全不一致，违反平台商品信息真实性规则。\"\n}", "violation": true, "category": "男装"}
{"image_file": "product_00255.jpg", "image": "data/raw/images/product_00255.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"套脚式休闲鞋\",\n    \"鞋底\": \"橡胶防滑底\",\n    \"品牌标识\": \"侧面有红色圆形标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示鞋面为绒面革材质，但描述中声称使用‘高端羊毛面料’，存在材质描述与实际视觉特征不符的情况，涉嫌虚假宣传。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00256.jpg", "image": "data/raw/images/product_00256.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"紫色鞋底，银色闪亮带\",\n    \"材质\": \"闪亮织物带，皮革鞋底\",\n    \"款式\": \"人字拖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是一双人字拖，而描述中提到的是'100%真丝连衣裙'，存在严重品类与描述不符的问题。\"\n}", "violation": true, "category": "鞋类"}
