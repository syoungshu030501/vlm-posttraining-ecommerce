{"image_file": "product_00155.jpg", "image": "data/raw/images/product_00155.jpg", "prompt": "韩版潮流服饰，时尚百搭", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"紫色天使剪影，带有翅膀和蝴蝶元素\",\n    \"文字\": \"Flap Doodle angel\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为儿童款粉色T恤，图案为卡通风格的天使剪影及英文文字，无敏感内容或违规标识。视觉属性符合普通童装设计规范，未发现违反平台规则的内容。\"\n}", "violation": false, "category": "服装"}
{"image_file": "product_00156.jpg", "image": "data/raw/images/product_00156.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"材质\": \"合成纤维（非真丝）\",\n    \"款式\": \"高腰阔腿运动裤\",\n    \"品牌标识\": \"黄色Nike标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一条深灰色的高腰阔腿运动裤，带有黄色Nike标志，材质为合成纤维，与描述中‘100%真丝连衣裙’严重不符。实际商品并非连衣裙，也非真丝材质，存在虚假描述和品类错误。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00157.jpg", "image": "data/raw/images/product_00157.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"系带短靴\",\n    \"鞋底\": \"棕色橡胶底\",\n    \"设计细节\": \"尖头、缝线装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双棕色绒面革材质的男士短靴，而商品描述中提及的是‘纯棉休闲上衣’，存在严重品类与描述不符的情况。根据平台规则，商品描述必须与实际商品一致，因此该商品违反了合规要求。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00158.jpg", "image": "data/raw/images/product_00158.jpg", "prompt": "经典款牛仔裤，修身显瘦", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑白配色\",\n    \"款式\": \"高帮运动鞋\",\n    \"材质\": \"皮革与织物混合\",\n    \"设计元素\": \"黑色滴墨图案\",\n    \"鞋带\": \"黑色鞋带\",\n    \"鞋底\": \"白色橡胶鞋底\",\n    \"装饰\": \"脚踝处黑色搭扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一双高帮运动鞋，而商品描述中提及的是‘经典款牛仔裤’，存在严重的图文不符，违反了平台关于商品信息真实性的规定。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00159.jpg", "image": "data/raw/images/product_00159.jpg", "prompt": "欧美风格外套，时尚简约", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"红白格子\",\n    \"款式\": \"短袖衬衫\",\n    \"材质\": \"棉质\",\n    \"设计元素\": \"胸前双口袋，纽扣开合，领口翻领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件短袖格子衬衫，而商品描述中称其为‘欧美风格外套’，存在品类与描述不符的问题。该商品并非外套，而是衬衫，属于误导性描述。\"\n}", "violation": true, "category": "男装"}
{"image_file": "product_00160.jpg", "image": "data/raw/images/product_00160.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "response": "{\n  \"category\": \"男装-裤子\",\n  \"attributes\": {\n    \"颜色\": \"深绿色\",\n    \"款式\": \"修身直筒裤\",\n    \"材质\": \"面料柔软\",\n    \"搭配\": \"黑色皮带、黑色皮鞋、浅色条纹衬衫\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘显瘦神器’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反了广告法相关规定。该表述暗示产品具有特殊瘦身效果，可能误导消费者，构成不实宣传。\"\n}", "violation": true, "category": "男装-裤子"}
{"image_file": "product_00161.jpg", "image": "data/raw/images/product_00161.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"鞋履\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"楔形凉拖\",\n    \"设计特点\": \"交叉绑带，蝴蝶结装饰\",\n    \"品牌标识\": \"Clarks Cushion Soft\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘手工制作’和‘限量款’，但图片显示为标准化生产的Clarks品牌鞋履，无任何手工制作或限量标识。该描述存在虚假宣传，可能误导消费者。\"\n}", "violation": true, "category": "鞋履"}
{"image_file": "product_00162.jpg", "image": "data/raw/images/product_00162.jpg", "prompt": "时尚秋冬外套，多色可选", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"金色\",\n    \"款式\": \"人字拖\",\n    \"材质\": \"金属质感皮革\",\n    \"鞋底\": \"平底\",\n    \"设计元素\": \"交叉带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双金色的人字拖，属于鞋类商品，而商品描述中却声称是‘时尚秋冬外套’，存在严重的品类与描述不符问题。根据平台规则，商品描述必须与实际商品一致，此行为构成虚假宣传和误导消费者，违反了电商商品合规要求。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00163.jpg", "image": "data/raw/images/product_00163.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"颜色\": \"黑色为主，搭配白色条纹和蓝色图案\",\n    \"品牌\": \"Adidas\",\n    \"款式\": \"拉链开衫运动外套与配套长裤\",\n    \"图案\": \"胸前有切尔西足球俱乐部徽章及三星（Samsung）标志，袖子和裤腿有三条白色条纹\",\n    \"材质\": \"合成纤维运动面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品为带有切尔西足球俱乐部和三星品牌标识的Adidas官方授权运动套装，属于品牌联名产品。商品描述中声称‘手工制作’和‘限量款’与实际商品属性不符，存在误导性宣传，违反平台关于商品真实性的合规要求。\"\n}", "violation": true, "category": "运动服饰"}
{"image_file": "product_00164.jpg", "image": "data/raw/images/product_00164.jpg", "prompt": "日系简约 ins风 学院风", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"表盘类型\": \"数字显示\",\n    \"表带材质\": \"橡胶\",\n    \"品牌标识\": \"Puma\",\n    \"设计风格\": \"现代简约\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中可见Puma品牌标识，但商品描述使用'日系简约 ins风 学院风'等词汇，存在品牌与风格描述不符的情况，可能误导消费者。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00165.jpg", "image": "data/raw/images/product_00165.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"托特包\",\n    \"细节\": \"金属铆钉、品牌标签、双提手、可拆卸肩带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款棕色皮革手提包，而商品描述中提及的是‘简约设计衬衫’，存在明显的图文不符，违反了平台关于商品信息真实性的规定。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00166.jpg", "image": "data/raw/images/product_00166.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"类型\": \"计时码表\",\n    \"表盘颜色\": \"银色\",\n    \"表带材质\": \"黑色皮革\",\n    \"表壳材质\": \"金属\",\n    \"指针颜色\": \"黑色和红色\",\n    \"表盘设计\": \"三眼计时\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款ESPRIT品牌的计时码表，而商品描述为'简约设计衬衫，商务休闲两相宜'，描述内容与实际商品类别严重不符，属于虚假描述，违反平台商品信息真实性规则。\"\n}", "violation": true, "category": "手表"}
