{"image_file": "product_00000.jpg", "image": "data/raw/images/product_00000.jpg", "prompt": "经典款牛仔裤，修身显瘦", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"套脚便鞋\",\n    \"鞋底\": \"橡胶底，有磨损痕迹\",\n    \"内衬\": \"浅灰色\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双深棕色绒面革套脚便鞋，而商品描述为'经典款牛仔裤，修身显瘦'，明显与实际商品不符，存在严重图文不符的违规行为。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00001.jpg", "image": "data/raw/images/product_00001.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色主体，红色图案和细节\",\n    \"品牌标识\": \"Nike标志位于左下角\",\n    \"图案设计\": \"正面有红色线条构成的立体文字图案，包含'THE GREATEST'字样及抽象图形\",\n    \"领口内衬\": \"红色内衬\",\n    \"材质外观\": \"表面光滑，疑似合成纤维\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称该T恤为'纯棉休闲上衣'，但根据图片显示，其面料具有光滑、紧致的视觉特征，更符合合成纤维（如聚酯纤维）的特性，且带有Nike运动品牌的典型功能性设计。此外，'纯棉'的描述与实际可能含化纤的材质不符，涉嫌虚假宣传，违反了电商商品信息真实性要求。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00002.jpg", "image": "data/raw/images/product_00002.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋头设计\": \"尖头\",\n    \"装饰细节\": \"布洛克雕花\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'正品保证'和'实体店同款'等宣传用语，涉嫌虚假或夸大宣传。根据平台规则，此类表述可能误导消费者，且缺乏可验证的证明材料，属于违规营销行为。\"\n}", "violation": true, "category": "男鞋"}
{"image_file": "product_00003.jpg", "image": "data/raw/images/product_00003.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"女鞋\",\n  \"attributes\": {\n    \"颜色\": \"银色\",\n    \"材质\": \"金属光泽皮革\",\n    \"款式\": \"平底芭蕾舞鞋\",\n    \"鞋头\": \"圆头\",\n    \"鞋底\": \"浅棕色橡胶底\",\n    \"装饰\": \"鞋面褶皱设计，鞋口编织缝线\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一款银色金属光泽皮革平底鞋，具有圆头、褶皱鞋面和编织缝线等细节，符合常规女鞋品类特征。商品描述中提及‘手工制作’‘限量款’等宣传语，未发现虚假或夸大宣传内容，且无违规标识或敏感图案，因此不构成违规。\"\n}", "violation": false, "category": "女鞋"}
{"image_file": "product_00004.jpg", "image": "data/raw/images/product_00004.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"品牌\": \"PUMA\",\n    \"图案\": \"蓝色渐变字母 'PUMA'，下方有日文 'スポーツウェア' 和绿色 'HZ' 标签\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'手工制作'和'限量款'，但图片显示为标准批量生产的PUMA品牌T恤，无任何手工制作或限量标识。该描述与视觉证据不符，涉嫌虚假宣传。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00005.jpg", "image": "data/raw/images/product_00005.jpg", "prompt": "百搭连衣裙，适合日常出行", "response": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"设计细节\": \"布洛克雕花\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双男士正装皮鞋，而商品描述为‘百搭连衣裙，适合日常出行’，存在严重的图文不符问题。图片中未出现任何连衣裙相关元素，属于虚假宣传。\"\n}", "violation": true, "category": "男鞋"}
{"image_file": "product_00006.jpg", "image": "data/raw/images/product_00006.jpg", "prompt": "经典款牛仔裤，修身显瘦", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白绿条纹\",\n    \"款式\": \"短袖Polo衫\",\n    \"领型\": \"白色翻领\",\n    \"图案\": \"横条纹\",\n    \"材质\": \"棉质或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件条纹Polo衫，而商品描述为‘经典款牛仔裤，修身显瘦’，存在严重描述不符。图片中并未出现牛仔裤，实际商品与描述不一致，违反平台商品信息真实性规则。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00007.jpg", "image": "data/raw/images/product_00007.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"灰色、红色、白色\",\n    \"材质\": \"网眼布、橡胶\",\n    \"款式\": \"透气跑鞋\",\n    \"设计特点\": \"波浪形鞋底、侧边红色条纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中包含'商场撤柜'和'便宜处理'等促销性用语，可能涉及低价倾销或非正规渠道销售，不符合平台对正品商品的规范展示要求。\"\n}", "violation": true, "category": "运动鞋"}
{"image_file": "product_00008.jpg", "image": "data/raw/images/product_00008.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"品牌标志\": \"Nike\",\n    \"材质\": \"合成纤维\",\n    \"款式\": \"棒球帽\",\n    \"细节\": \"帽檐边缘为黑色，侧面有Dri-FIT标识\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件蓝色Nike棒球帽，而商品描述为'简约设计衬衫，商务休闲两相宜'，描述内容与实际商品类别严重不符，属于虚假描述。\"\n}", "violation": true, "category": "帽子"}
{"image_file": "product_00009.jpg", "image": "data/raw/images/product_00009.jpg", "prompt": "日系简约 ins风 学院风", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"白色印花，包含文字'La Coiffure'和玫瑰花图案\",\n    \"领型\": \"圆领\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的印花内容包含'La Coiffure'字样及玫瑰花图案，具有明显的品牌标识特征，但未提供品牌授权信息。同时，商品描述中使用'日系简约 ins风 学院风'等流行风格词汇，可能涉及对特定风格或品牌的模仿，存在误导消费者的风险，违反平台关于未经授权的品牌元素使用及虚假宣传的规定。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00010.jpg", "image": "data/raw/images/product_00010.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"白色、红色、黑色条纹\",\n    \"款式\": \"Polo衫\",\n    \"图案\": \"胸前有'FM ORIGINAL'标志及翅膀图案\",\n    \"材质外观\": \"棉质或混纺面料，表面平滑\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称使用‘高端羊毛面料’，但根据图片显示的服装纹理和光泽，该Polo衫实际为棉质或化纤混纺面料，不具备羊毛特有的质感。因此存在虚假宣传，违反了电商商品描述真实性原则。\"\n}", "violation": true, "category": "男装"}
{"image_file": "product_00011.jpg", "image": "data/raw/images/product_00011.jpg", "prompt": "时尚秋冬外套，多色可选", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"图案\": \"胸前有徽标\",\n    \"材质\": \"棉质\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件粉色短袖Polo衫，而商品描述中称其为‘时尚秋冬外套’，存在严重品类不符。该商品为夏季穿着的短袖上衣，不具备外套特征，且无保暖设计，与‘秋冬外套’描述完全不符。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00012.jpg", "image": "data/raw/images/product_00012.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"长袖衬衫\",\n    \"材质\": \"纯棉\",\n    \"图案\": \"左胸有徽章刺绣\",\n    \"领型\": \"标准翻领\",\n    \"袖口\": \"常规扣袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的衬衫左胸位置带有品牌徽章刺绣，该徽章包含皇冠及红蓝配色设计，具有明显的品牌标识特征。结合商品描述‘纯棉休闲上衣’未提及品牌信息，存在误导消费者的风险，可能构成虚假宣传或侵犯他人商标权。同时，该徽章设计与知名运动品牌标志高度相似，涉嫌仿冒或未经授权使用他人注册商标，违反了《电子商务法》及《商标法》相关规定。\"\n}", "violation": true, "category": "男装"}
{"image_file": "product_00013.jpg", "image": "data/raw/images/product_00013.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"颜色\": \"白色与亮绿色拼接\",\n    \"款式\": \"短袖圆领\",\n    \"品牌标识\": \"Nike标志位于左胸\",\n    \"材质\": \"透气运动面料\",\n    \"设计风格\": \"运动休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为运动T恤，具有明显的Nike品牌标识和运动功能设计（如拼色、透气面料），而商品描述中称其为'简约设计衬衫，商务休闲两相宜'，存在品类与描述不符的虚假宣传问题。\"\n}", "violation": true, "category": "运动服饰"}
{"image_file": "product_00014.jpg", "image": "data/raw/images/product_00014.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"黑色主体，绿色肩带和装饰\",\n    \"材质\": \"皮革\",\n    \"款式\": \"圆筒形手提包\",\n    \"五金件\": \"金色金属扣环和铆钉\",\n    \"缝线\": \"黄色缝线\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的为一款黑色与绿色拼接的皮革手提包，而商品描述中提及的是‘运动休闲鞋’，存在明显品类不符。根据平台规则，商品描述必须与实际商品一致，因此该商品违反了合规要求。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00015.jpg", "image": "data/raw/images/product_00015.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"男装-西裤\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"图案\": \"细条纹\",\n    \"材质\": \"羊毛混纺\",\n    \"款式\": \"直筒\",\n    \"细节\": \"黑色皮带、黑色皮鞋搭配\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士正装西裤，无违规内容。图片中展示的服装为灰色细条纹西裤，搭配黑色皮带和皮鞋，属于正常服饰类商品，未发现虚假宣传或侵权问题。\"\n}", "violation": false, "category": "男装-西裤"}
{"image_file": "product_00016.jpg", "image": "data/raw/images/product_00016.jpg", "prompt": "最新款 超低价 清仓大甩卖", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"荧光黄\",\n    \"品牌标识\": \"PUMA\",\n    \"图案\": \"黑色和粉色的PUMA标志及文字\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的品牌为PUMA，属于知名品牌，而商品描述中使用‘最新款 超低价 清仓大甩卖’等宣传语可能暗示该商品为非正品或仿冒品，存在误导消费者的风险。同时，未经品牌授权的商品销售可能侵犯知识产权，违反平台关于品牌合规的规则。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00017.jpg", "image": "data/raw/images/product_00017.jpg", "prompt": "欧美大牌设计 小众品牌", "response": "{\n  \"category\": \"运动裤\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"棉质或混纺面料\",\n    \"款式\": \"直筒休闲裤\",\n    \"细节\": \"两侧绿色条纹装饰，右侧大腿处有绿色品牌标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘欧美大牌设计’和‘小众品牌’等词汇，可能构成虚假宣传或误导性描述。图片中未显示任何知名品牌标识或认证信息，无法证实其为‘大牌设计’，存在夸大宣传嫌疑。\"\n}", "violation": true, "category": "运动裤"}
{"image_file": "product_00018.jpg", "image": "data/raw/images/product_00018.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"女装上衣\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"无袖\",\n    \"领型\": \"V领褶皱设计\",\n    \"材质\": \"纯棉\",\n    \"版型\": \"宽松\",\n    \"长度\": \"中长款\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，展示为一件黑色无袖V领褶皱设计的休闲上衣，材质标注为纯棉，符合舒适透气的描述，未发现违规内容。\"\n}", "violation": false, "category": "女装上衣"}
{"image_file": "product_00019.jpg", "image": "data/raw/images/product_00019.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"运动短裤\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"合成纤维\",\n    \"款式\": \"紧身短裤\",\n    \"品牌\": \"Puma\",\n    \"设计细节\": \"侧面白色条纹，右腿有Puma标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'商场撤柜'、'专柜正品'、'便宜处理'等词汇，属于虚假宣传和价格诱导性表述，可能误导消费者。同时，图片中模特穿着的鞋子与短裤不配套，存在搭配混乱的问题，影响商品展示的专业性。\"\n}", "violation": true, "category": "运动短裤"}
{"image_file": "product_00020.jpg", "image": "data/raw/images/product_00020.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表盘形状\": \"矩形\",\n    \"表带材质\": \"黑色皮革\",\n    \"表壳装饰\": \"镶嵌闪亮小钻\",\n    \"品牌标识\": \"ESPRIT\",\n    \"指针样式\": \"简约银色指针\",\n    \"表盘颜色\": \"黑色\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是一款矩形表盘、镶嵌闪亮小钻的ESPRIT品牌手表，而商品描述为‘运动休闲鞋，缓震耐磨橡胶底’，与实际商品严重不符，存在虚假描述违规。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00021.jpg", "image": "data/raw/images/product_00021.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"品牌标识\": \"无明显品牌标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'商场撤柜'、'专柜正品'、'便宜处理'等宣传用语，可能涉及虚假或夸大宣传。根据平台规则，此类描述容易误导消费者，尤其是'专柜正品'未提供相应证明材料时，涉嫌违规。此外，图片中未显示品牌标识，无法验证其真实性，存在冒充正品的风险。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00022.jpg", "image": "data/raw/images/product_00022.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"男装-西裤\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"条纹\": \"细竖条纹\",\n    \"材质\": \"羊毛\",\n    \"款式\": \"直筒\",\n    \"搭配\": \"白色衬衫、黑色皮带、黑色皮鞋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘高端羊毛面料，奢华质感’，但图片中无法验证其材质是否为纯羊毛或是否具备所述的奢华质感。此类宣传可能构成虚假或夸大宣传，违反了电商平台上关于商品真实性和广告合规性的规定。\"\n}", "violation": true, "category": "男装-西裤"}
{"image_file": "product_00023.jpg", "image": "data/raw/images/product_00023.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘颜色\": \"黑色\",\n    \"表带材质\": \"黑色皮革\",\n    \"表壳材质\": \"不锈钢\",\n    \"功能\": \"计时码表\",\n    \"表圈\": \"单向旋转潜水刻度\",\n    \"日期显示\": \"有\",\n    \"表盘纹理\": \"碳纤维纹理\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘手工制作’和‘限量款’，但图片显示为标准量产款式，无任何标识或编号表明其手工或限量属性，存在虚假宣传嫌疑。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00024.jpg", "image": "data/raw/images/product_00024.jpg", "prompt": "纯手工编织，限量发售", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"黑白复古风格女性舞蹈图像\",\n    \"材质\": \"棉质（视觉推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘纯手工编织’，但图片显示该商品为普通印花T恤，无任何编织工艺特征，存在虚假宣传。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00025.jpg", "image": "data/raw/images/product_00025.jpg", "prompt": "日系简约 ins风 学院风", "response": "{\n  \"category\": \"皮带\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"扣头类型\": \"金属针扣\",\n    \"表面纹理\": \"压纹\",\n    \"风格\": \"简约\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为黑色皮革皮带，搭配银色金属针扣，整体设计简洁，符合‘日系简约 ins风 学院风’的描述，未发现违规内容。\"\n}", "violation": false, "category": "皮带"}
{"image_file": "product_00026.jpg", "image": "data/raw/images/product_00026.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"无袖连帽背心\",\n    \"图案\": \"正面印有蓝色数字'63'、白色文字'DIVI'和'1A'，背景为深色抽象涂鸦风格图案\",\n    \"材质\": \"棉质或混纺面料（推测）\",\n    \"细节\": \"帽子内衬为浅蓝色，肩部有白色缝线装饰\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为普通儿童服饰，未发现涉及政治、宗教、色情、暴力或其他违规内容。其设计元素如数字和字母均为常见时尚图案，不构成侵权或敏感信息。\"\n}", "violation": false, "category": "服装"}
{"image_file": "product_00027.jpg", "image": "data/raw/images/product_00027.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"金属色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"凉拖\",\n    \"鞋跟类型\": \"坡跟\",\n    \"品牌\": \"Clarks\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双金属色皮革材质的坡跟凉拖，而商品描述为'纯棉休闲上衣，舒适透气'，描述内容与实际商品类别和材质严重不符，构成虚假宣传。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00028.jpg", "image": "data/raw/images/product_00028.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"淡紫色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"世界地图及英文标语\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件印有世界地图和英文标语的淡紫色T恤，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，描述内容与实际图片严重不符，属于虚假宣传。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00029.jpg", "image": "data/raw/images/product_00029.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"灰色、蓝色、黑色\",\n    \"材质\": \"合成材料（非羊毛）\",\n    \"款式\": \"运动凉鞋\",\n    \"闭合方式\": \"魔术贴\",\n    \"鞋底\": \"厚实橡胶底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示该鞋为合成材料制成，无任何羊毛材质特征，但描述中声称使用‘高端羊毛面料’，存在虚假宣传。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00030.jpg", "image": "data/raw/images/product_00030.jpg", "prompt": "韩版潮流服饰，时尚百搭", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色与棕色条纹\",\n    \"款式\": \"短袖Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"左胸有白色刺绣标志\",\n    \"材质\": \"未明确标注，视觉上为棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中模特穿着的Polo衫左胸位置存在一个白色刺绣标志，该标志与知名品牌‘Ralph Lauren’的标志性小马图案高度相似，涉嫌侵犯他人注册商标权。此外，商品描述中使用‘韩版潮流服饰’等词汇可能构成虚假宣传，暗示其为韩国设计或品牌，但无任何证据支持该说法，属于误导性宣传。因此该商品存在商标侵权及虚假宣传双重违规问题。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00031.jpg", "image": "data/raw/images/product_00031.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"款式\": \"吊带连衣裙\",\n    \"领口设计\": \"方领\",\n    \"肩带\": \"细肩带\",\n    \"胸围装饰\": \"彩色条纹刺绣\",\n    \"裙摆\": \"荷叶边设计\",\n    \"材质\": \"牛仔布\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'正品保证'和'实体店同款'等宣传用语，但图片未提供任何品牌标识或认证信息，涉嫌虚假宣传。根据电商平台规定，此类未经证实的品质承诺属于违规行为。\"\n}", "violation": true, "category": "女装"}
{"image_file": "product_00032.jpg", "image": "data/raw/images/product_00032.jpg", "prompt": "百搭连衣裙，适合日常出行", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"磨砂皮\",\n    \"款式\": \"系带正装鞋\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"鞋型\": \"男士皮鞋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双男士棕色系带皮鞋，而商品描述为‘百搭连衣裙，适合日常出行’，描述内容与实际商品严重不符，属于虚假宣传或误导消费者的行为。\"\n}", "violation": true, "category": "鞋类"}
