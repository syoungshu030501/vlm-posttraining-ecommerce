{"image_file": "product_00198.jpg", "image": "data/raw/images/product_00198.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"V领短袖T恤\",\n    \"图案\": \"正面印有'ORIGINAL ATHLETIC'字样及闪电状字母'D'图案，图案采用迷彩与点状纹理设计\",\n    \"材质\": \"棉质（推测）\",\n    \"设计风格\": \"运动休闲风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'手工制作'和'限量款'等宣传用语，但图片显示为批量生产的标准T恤，无任何手工痕迹或限量标识，存在虚假宣传嫌疑。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00199.jpg", "image": "data/raw/images/product_00199.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"牛仔裤\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"材质\": \"牛仔布\",\n    \"款式\": \"直筒\",\n    \"细节\": \"膝盖处有轻微磨损设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是牛仔裤，但商品描述为'纯棉休闲上衣'，存在品类与描述不符的违规情况。\"\n}", "violation": true, "category": "牛仔裤"}
{"image_file": "product_00200.jpg", "image": "data/raw/images/product_00200.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"color\": \"银色、黄色、灰色\",\n    \"material\": \"网眼布、合成材料\",\n    \"design\": \"运动风格\",\n    \"features\": \"DMX RIDE+ 缓震技术，透气网面\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双运动鞋，但商品描述为‘简约设计衬衫，商务休闲两相宜’，描述内容与实际商品类别严重不符，属于虚假描述违规。\"\n}", "violation": true, "category": "运动鞋"}
{"image_file": "product_00201.jpg", "image": "data/raw/images/product_00201.jpg", "prompt": "时尚秋冬外套，多色可选", "response": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"图案\": \"格子\",\n    \"颜色\": \"蓝、白、黑\",\n    \"袖长\": \"短袖\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"双胸袋\",\n    \"材质\": \"棉质\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件格子短袖衬衫，而商品描述中称其为‘时尚秋冬外套’，存在品类与描述严重不符的问题。此外，该商品为短袖设计，不符合‘秋冬外套’的季节性及功能性特征，属于误导性描述。\"\n}", "violation": true, "category": "男装衬衫"}
{"image_file": "product_00202.jpg", "image": "data/raw/images/product_00202.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"白色为主，搭配黑色和银色装饰\",\n    \"材质\": \"网面与合成材料\",\n    \"品牌标识\": \"Reebok\",\n    \"设计风格\": \"运动休闲风\",\n    \"鞋底\": \"白色中底，黑色外底\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品为Reebok品牌运动鞋，属于知名品牌产品，但商品描述中声称‘手工制作’和‘限量款’，这与普通量产运动鞋的生产方式不符，存在虚假宣传嫌疑。同时，未提供任何证明其‘手工制作’或‘限量款’的依据，违反了电商平台上关于商品描述真实性的规定。\"\n}", "violation": true, "category": "运动鞋"}
{"image_file": "product_00203.jpg", "image": "data/raw/images/product_00203.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"女装-连衣裙\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"长袖\",\n    \"领型\": \"圆领\",\n    \"长度\": \"短款\",\n    \"设计元素\": \"竖条纹褶皱、腰带系结\",\n    \"材质\": \"看似柔软针织面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件带有竖条纹褶皱和腰带设计的连衣裙，而商品描述中称其为'简约设计衬衫'，存在品类与描述不符的问题。该商品并非衬衫，而是连衣裙，因此违反了平台关于商品描述准确性的规则。\"\n}", "violation": true, "category": "女装-连衣裙"}
{"image_file": "product_00204.jpg", "image": "data/raw/images/product_00204.jpg", "prompt": "时尚秋冬外套，多色可选", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"粉色芭蕾舞鞋和黑色文字\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件白色短袖T恤，带有粉色芭蕾舞鞋图案和文字，与描述中的‘时尚秋冬外套’不符，存在描述与实物严重不一致的问题。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00205.jpg", "image": "data/raw/images/product_00205.jpg", "prompt": "韩版潮流服饰，时尚百搭", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"抽象拼贴风格印花，包含字母和几何图形\",\n    \"材质\": \"棉质（推测）\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服饰，图案为抽象艺术设计，未发现政治、宗教、色情或侵权内容，符合平台合规要求。\"\n}", "violation": false, "category": "服装"}
{"image_file": "product_00206.jpg", "image": "data/raw/images/product_00206.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色与黄色\",\n    \"材质\": \"橡胶表带，金属表壳\",\n    \"款式\": \"运动风格计时码表\",\n    \"品牌\": \"Carrera\",\n    \"表盘设计\": \"多表盘结构，带有秒针、分针和时针，黄色指针突出\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款复杂设计的运动型手表，而商品描述为‘简约设计衬衫，商务休闲两相宜’，明显存在图文不符，属于虚假宣传。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00207.jpg", "image": "data/raw/images/product_00207.jpg", "prompt": "最新款 超低价 清仓大甩卖", "response": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"V领短袖T恤\",\n    \"材质\": \"棉质\",\n    \"图案\": \"无图案\",\n    \"品牌标识\": \"左胸有小logo\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大性宣传用语，属于虚假或引人误解的商业宣传，违反平台广告合规规则。\"\n}", "violation": true, "category": "女装"}
{"image_file": "product_00208.jpg", "image": "data/raw/images/product_00208.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"图案\": \"卡通忍者形象，蓝色背景，绿色头巾，手持武器\",\n    \"文字\": \"NINJA TEAM, STAY IN THE HONOUR, 2013\",\n    \"款式\": \"短袖圆领T恤\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品描述中声称‘手工制作’和‘限量款’，但图片显示为批量生产的印花T恤，无任何手工制作的视觉证据。此外，图案中的‘NINJA TEAM’及角色设计与知名动漫或游戏IP高度相似，存在侵犯知识产权的风险，不符合平台对原创性及虚假宣传的规定。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00209.jpg", "image": "data/raw/images/product_00209.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"材质\": \"棉质或混纺面料\",\n    \"款式\": \"长袖正装衬衫\",\n    \"领型\": \"标准翻领\",\n    \"口袋\": \"左侧胸前有一个贴袋\",\n    \"纽扣\": \"白色纽扣，前襟全开\",\n    \"袖口\": \"标准袖口，可调节\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为常规男士正装衬衫，无违规图案、文字或敏感元素，符合平台销售规范。\"\n}", "violation": false, "category": "男装衬衫"}
{"image_file": "product_00210.jpg", "image": "data/raw/images/product_00210.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "response": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"紫绿白格纹\",\n    \"款式\": \"长袖格子衬衫\",\n    \"材质\": \"棉质\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"双胸袋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士格子衬衫，而描述中声称是'100%真丝连衣裙'，存在严重品类与材质不符的虚假宣传问题。实际商品为男式衬衫，而非连衣裙，且材质并非真丝，属于误导性描述。\"\n}", "violation": true, "category": "男装衬衫"}
