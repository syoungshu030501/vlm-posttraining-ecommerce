{"image_file": "product_00088.jpg", "image": "data/raw/images/product_00088.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"黑白复古风格人物插画，包含吉他手形象和文字'loves the 80's'\",\n    \"材质\": \"棉质（推测）\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图案中包含‘loves the 80's’字样及复古人物形象，可能涉及对特定年代或文化符号的未经授权使用，存在侵犯版权或商标权的风险。此外，该图案设计风格与知名乐队或音乐人相关联，易引发混淆，违反平台关于知识产权保护的规定。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00089.jpg", "image": "data/raw/images/product_00089.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色和金色\",\n    \"材质\": \"黑色鳄鱼纹皮革，金色金属质感鞋底\",\n    \"款式\": \"人字拖\",\n    \"品牌\": \"CABO\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双人字拖，而商品描述为‘简约设计衬衫，商务休闲两相宜’，描述内容与实际商品类别严重不符，属于虚假描述。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00090.jpg", "image": "data/raw/images/product_00090.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"皮革与绒面革拼接\",\n    \"鞋带\": \"浅色系\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"款式\": \"低帮系带休闲鞋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款采用皮革和绒面革材质的低帮休闲鞋，其设计风格偏向商务休闲而非运动鞋。描述中称其为‘运动休闲鞋’存在误导性，可能误导消费者认为该鞋具备运动鞋的功能特性（如高缓震、透气性等），但视觉上无明显运动特征（如网眼布、支撑结构、专业鞋垫等）。因此，商品描述与实际视觉属性不符，构成违规。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00091.jpg", "image": "data/raw/images/product_00091.jpg", "prompt": "日系简约 ins风 学院风", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"装饰\": \"花朵造型与流苏\",\n    \"缝线\": \"黄色缝线\",\n    \"五金件\": \"银色金属扣环\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为黑色皮革手提包，带有明显的花朵和流苏装饰，整体风格偏向成熟优雅或复古风，而商品描述中使用了'日系简约 ins风 学院风'等词汇，存在风格描述与实际视觉特征不符的问题。该包款设计复杂、装饰性强，不符合'简约'和'学院风'的典型特征，易误导消费者。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00092.jpg", "image": "data/raw/images/product_00092.jpg", "prompt": "韩版潮流服饰，时尚百搭", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"缝线颜色\": \"黄色\",\n    \"五金件\": \"金色\",\n    \"品牌标识\": \"方形金属牌，带有字母G\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款手提包，但商品描述中使用了'韩版潮流服饰，时尚百搭'等与服饰相关的表述，存在品类不符的违规问题。该描述将非服饰类商品错误归类为服饰，可能导致消费者误解商品类别，违反电商平台对商品描述真实性的要求。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00093.jpg", "image": "data/raw/images/product_00093.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "response": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝白灰格纹\",\n    \"材质\": \"棉质\",\n    \"款式\": \"长袖格子衬衫\",\n    \"领型\": \"翻领\",\n    \"袖口\": \"卷起\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男装格子衬衫，而商品描述为‘运动休闲鞋，缓震耐磨橡胶底’，描述内容与图片实际商品严重不符，属于虚假描述违规。\"\n}", "violation": true, "category": "男装衬衫"}
{"image_file": "product_00094.jpg", "image": "data/raw/images/product_00094.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表壳形状\": \"矩形\",\n    \"表盘颜色\": \"银白色\",\n    \"表带材质\": \"棕色皮革\",\n    \"表带纹理\": \"鳄鱼纹\",\n    \"表盘设计\": \"双层结构，上层为时分显示，下层为秒针显示\",\n    \"表壳材质\": \"金属（疑似不锈钢）\",\n    \"表冠位置\": \"右侧\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一块ESPRIT品牌的矩形金属手表，搭配棕色皮革表带，而商品描述为'100%真丝连衣裙，高贵典雅'，描述内容与实际商品严重不符，属于虚假宣传或误导性描述。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00095.jpg", "image": "data/raw/images/product_00095.jpg", "prompt": "国风刺绣上衣，传统工艺", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革表带，金属表壳\",\n    \"款式\": \"方形表盘，三眼计时设计\",\n    \"品牌标识\": \"Puma标志\",\n    \"表盘特征\": \"大号数字12，红色秒针，白色刻度\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款Puma品牌的运动手表，而商品描述为'国风刺绣上衣，传统工艺'，存在严重品类与描述不符的情况。根据平台规则，商品描述必须与实际商品一致，该商品属于虚假描述违规。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00096.jpg", "image": "data/raw/images/product_00096.jpg", "prompt": "纯手工编织，限量发售", "response": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝色与白色竖条纹\",\n    \"材质\": \"棉质或混纺面料\",\n    \"款式\": \"长袖正装衬衫\",\n    \"领型\": \"标准翻领\",\n    \"纽扣\": \"黑色纽扣\",\n    \"袖口\": \"双色条纹袖口\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘纯手工编织’，但图片显示为常规机织条纹衬衫，无任何手工编织的视觉特征（如不规则纹理、手缝痕迹等），存在虚假宣传嫌疑。\"\n}", "violation": true, "category": "男装衬衫"}
{"image_file": "product_00097.jpg", "image": "data/raw/images/product_00097.jpg", "prompt": "百搭连衣裙，适合日常出行", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"白色与蓝色\",\n    \"材质\": \"皮革或合成材料\",\n    \"款式\": \"低帮运动鞋\",\n    \"设计元素\": \"蓝色泼墨图案\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双运动鞋，而商品描述为‘百搭连衣裙’，存在严重图文不符，违反平台商品信息真实性规则。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00098.jpg", "image": "data/raw/images/product_00098.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深紫色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"黑白自行车主题印花\",\n    \"材质\": \"棉质（推测）\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服饰，图案内容为自行车与人物的黑白艺术设计，无违法不良信息或敏感元素，符合平台合规标准。\"\n}", "violation": false, "category": "服装"}
{"image_file": "product_00099.jpg", "image": "data/raw/images/product_00099.jpg", "prompt": "百搭连衣裙，适合日常出行", "response": "{\n  \"category\": \"男装T恤\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"蓝色和黑色的豹子图案\",\n    \"款式\": \"短袖圆领T恤\",\n    \"材质\": \"棉质\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士短袖T恤，而商品描述中提到的是‘百搭连衣裙’，存在品类与描述严重不符的情况。此外，该T恤上印有Puma品牌标志性的豹子图案，可能涉及品牌侵权问题。\"\n}", "violation": true, "category": "男装T恤"}
{"image_file": "product_00100.jpg", "image": "data/raw/images/product_00100.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"设计元素\": \"布洛克雕花\",\n    \"鞋头形状\": \"尖头\",\n    \"鞋跟高度\": \"低跟\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘限量款’字样，但图片未提供任何与限量相关的标识或证明（如编号、特殊标签等），涉嫌虚假宣传。同时‘手工制作’在无明确工艺说明或认证的情况下，可能构成夸大宣传，违反电商广告真实性原则。\"\n}", "violation": true, "category": "男鞋"}
{"image_file": "product_00101.jpg", "image": "data/raw/images/product_00101.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"系带皮鞋\",\n    \"材质\": \"皮革\",\n    \"设计\": \"布洛克雕花\",\n    \"鞋底\": \"橡胶防滑底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'商场撤柜'、'专柜正品'、'便宜处理'等词汇，属于典型的促销性表述，可能涉及虚假宣传或价格误导。其中'专柜正品'未提供相关证明材料，涉嫌夸大宣传；'便宜处理'暗示商品存在瑕疵或过季问题，但图片展示为全新状态，存在信息不一致，违反电商平台关于商品描述真实性的规定。\"\n}", "violation": true, "category": "男鞋"}
{"image_file": "product_00102.jpg", "image": "data/raw/images/product_00102.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"童装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"图案文字\": \"50% Mummy, 50% Daddy, 100% Me\",\n    \"品牌标签\": \"BeBorn by Beanie\",\n    \"材质\": \"棉质\",\n    \"款式\": \"短袖T恤\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品描述中使用了‘商场撤柜’、‘专柜正品’、‘便宜处理’等宣传用语，可能涉及虚假或夸大宣传。同时，商品图片中的文字‘50% Mummy, 50% Daddy, 100% Me’虽为设计元素，但结合描述可能存在诱导消费者认为商品具有特殊身份认同价值的嫌疑，易引发误解，违反电商平台关于商品信息真实性和合规性的规定。\"\n}", "violation": true, "category": "童装"}
{"image_file": "product_00103.jpg", "image": "data/raw/images/product_00103.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝白条纹\",\n    \"款式\": \"短袖Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"左胸有圆形徽章图案，包含棕榈树、冲浪板和文字'FISHING MACHINE CALIFORNIA SURF ACADEMY'\",\n    \"材质\": \"未明确，推测为棉质或混纺\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为普通男式条纹Polo衫，无违规内容。徽章图案虽含英文及冲浪元素，但属于常见装饰性设计，不涉及敏感信息或侵权问题。\"\n}", "violation": false, "category": "男装"}
{"image_file": "product_00104.jpg", "image": "data/raw/images/product_00104.jpg", "prompt": "日系简约 ins风 学院风", "response": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"图案\": \"蓝色鞋底图案与紫色文字 'RUN HARD'\",\n    \"款式\": \"圆领短袖T恤\",\n    \"风格\": \"运动休闲风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中提及'日系简约 ins风 学院风'，但图片显示的T恤设计以运动元素（如'RUN HARD'字样和鞋底图案）为主，属于运动休闲风格，与描述中的'学院风'和'日系简约ins风'不符，存在风格描述不实的问题。\"\n}", "violation": true, "category": "服饰"}
{"image_file": "product_00105.jpg", "image": "data/raw/images/product_00105.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"材质\": \"人造皮革\",\n    \"款式\": \"双肩带手提包\",\n    \"细节\": \"金属扣件、黄色缝线、拉链口袋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示该包为粉色人造皮革材质，但描述中声称使用‘高端羊毛面料’，材质描述与实际视觉属性严重不符，构成虚假宣传。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00106.jpg", "image": "data/raw/images/product_00106.jpg", "prompt": "日系简约 ins风 学院风", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"DUCATI品牌标志\",\n    \"材质\": \"棉质\",\n    \"风格\": \"运动休闲风\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的T恤印有'DUCATI'品牌标志，属于明确的品牌标识，而商品描述为'日系简约 ins风 学院风'，存在风格与实际视觉属性不符的情况，且可能涉及未经授权的品牌使用，违反平台关于品牌合规及描述真实性的规定。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00107.jpg", "image": "data/raw/images/product_00107.jpg", "prompt": "国风刺绣上衣，传统工艺", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"吊带\",\n    \"材质\": \"棉质\",\n    \"设计元素\": \"荷叶边下摆\",\n    \"肩带\": \"可调节细绳\",\n    \"品牌标签\": \"FLAP DOG\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中未见任何刺绣图案或国风元素，与描述中的'国风刺绣上衣，传统工艺'不符，存在虚假宣传。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00108.jpg", "image": "data/raw/images/product_00108.jpg", "prompt": "欧美风格外套，时尚简约", "response": "{\n  \"category\": \"T恤\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"印有彩色文字和黑白人物插画\",\n    \"文字内容\": \"STRIKE!! WHEN YOU'RE READY!!\",\n    \"款式\": \"短袖圆领\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品实际为T恤，但描述中称其为'欧美风格外套'，存在品类不符。图片显示该商品为短袖上衣，不具备外套的结构特征，如长袖、拉链或纽扣等，因此描述与实物严重不符。\"\n}", "violation": true, "category": "T恤"}
{"image_file": "product_00109.jpg", "image": "data/raw/images/product_00109.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"图案\": \"复古音响印花\",\n    \"材质\": \"棉质\",\n    \"款式\": \"短袖T恤\",\n    \"设计元素\": \"价格标签风格文字、立体感印刷\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中T恤正面印有'$5.9'等价格信息及'DIRECT FACTORY PRICE'字样，属于虚假或误导性价格宣传，违反平台关于禁止在商品主图中展示非实际售价的规则。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00110.jpg", "image": "data/raw/images/product_00110.jpg", "prompt": "百搭连衣裙，适合日常出行", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"棋盘格纹\",\n    \"标志\": \"红色跃马徽标\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士短袖T恤，而商品描述中却写的是‘百搭连衣裙’，存在严重品类与实际商品不符的问题。此外，T恤上的红色跃马徽标（Ferrari标志）可能涉及品牌侵权，未经授权使用知名品牌标识属于违规行为。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00111.jpg", "image": "data/raw/images/product_00111.jpg", "prompt": "最新款 超低价 清仓大甩卖", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表盘颜色\": \"绿色\",\n    \"表带材质\": \"橡胶\",\n    \"表壳形状\": \"八角形\",\n    \"品牌标识\": \"Carrera\",\n    \"表盘设计\": \"带有纹理和圆形刻度\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大性宣传用语，可能误导消费者，违反了电商平台上关于禁止虚假或夸大宣传的相关规定。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00112.jpg", "image": "data/raw/images/product_00112.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"品牌标识\": \"Reebok\",\n    \"材质\": \"网眼布\",\n    \"鞋底\": \"白色橡胶\",\n    \"设计风格\": \"运动休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双蓝色的Reebok运动鞋，而商品描述为'100%真丝连衣裙，高贵典雅'，存在严重的图文不符。图片中的商品为鞋类，与描述中的服装品类完全不一致，属于虚假宣传和误导消费者的行为。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00113.jpg", "image": "data/raw/images/product_00113.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"蓝、黑、白竖条纹\",\n    \"款式\": \"长袖、翻领、纽扣式\",\n    \"材质\": \"未明确，推测为棉或混纺\",\n    \"设计风格\": \"商务休闲\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一件条纹长袖衬衫，颜色搭配为蓝色、黑色与白色竖条纹，符合商务休闲风格描述。无违规图案、文字或敏感元素，且未涉及虚假宣传或误导性信息。\"\n}", "violation": false, "category": "男装衬衫"}
{"image_file": "product_00114.jpg", "image": "data/raw/images/product_00114.jpg", "prompt": "时尚秋冬外套，多色可选", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深灰色\",\n    \"材质\": \"条纹面料\",\n    \"款式\": \"修身西裤\",\n    \"搭配\": \"黑色皮带、黑色皮鞋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是男士西裤，而商品描述为‘时尚秋冬外套’，存在明显品类不符。图片中未出现任何外套，实际商品与描述严重不一致。\"\n}", "violation": true, "category": "男装"}
{"image_file": "product_00115.jpg", "image": "data/raw/images/product_00115.jpg", "prompt": "经典款牛仔裤，修身显瘦", "response": "{\n  \"category\": \"皮带\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"经典款\",\n    \"扣件类型\": \"金属针扣\",\n    \"表面纹理\": \"压纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一条皮带，但商品描述中提及‘经典款牛仔裤，修身显瘦’，与实际商品类别严重不符，属于虚假描述。\"\n}", "violation": true, "category": "皮带"}
{"image_file": "product_00116.jpg", "image": "data/raw/images/product_00116.jpg", "prompt": "百搭连衣裙，适合日常出行", "response": "{\n  \"category\": \"上衣\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"材质\": \"棉质\",\n    \"装饰\": \"胸前有小徽标\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件黑色短袖Polo衫，而商品描述中称其为‘百搭连衣裙’，存在品类与实际商品不符的情况。根据视觉属性，该商品为上衣而非连衣裙，因此违反了平台关于商品描述真实性的规则。\"\n}", "violation": true, "category": "上衣"}
{"image_file": "product_00117.jpg", "image": "data/raw/images/product_00117.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "response": "{\n  \"category\": \"女装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"紫白格子\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"材质\": \"棉质或混纺面料\",\n    \"图案\": \"格纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件女性格子短袖衬衫，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，描述内容与实际商品严重不符，属于虚假宣传。\"\n}", "violation": true, "category": "女装衬衫"}
{"image_file": "product_00118.jpg", "image": "data/raw/images/product_00118.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"乐福鞋\",\n    \"设计特点\": \"无鞋带，缝线装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称使用'高端羊毛面料'，但图片显示该鞋为皮革材质，存在材质描述与实物不符的虚假宣传问题。\"\n}", "violation": true, "category": "男鞋"}
{"image_file": "product_00119.jpg", "image": "data/raw/images/product_00119.jpg", "prompt": "欧美大牌设计 小众品牌", "response": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"套脚式皮鞋\",\n    \"鞋头\": \"尖头\",\n    \"鞋底\": \"橡胶底\",\n    \"设计风格\": \"简约商务\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'欧美大牌设计'和'小众品牌'等宣传性词汇，可能构成虚假或夸大宣传。图片显示为普通黑色套脚皮鞋，无明显奢侈品牌标识或独特设计元素，无法支持'大牌设计'的宣称，存在误导消费者的风险。\"\n}", "violation": true, "category": "男鞋"}
{"image_file": "product_00120.jpg", "image": "data/raw/images/product_00120.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"绿色\",\n    \"款式\": \"Polo衫\",\n    \"图案\": \"数字'30'及英文文字\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中Polo衫正面印有数字'30'及英文文字，属于带有特定标识或宣传性质的图案设计。而商品描述为'简约设计衬衫，商务休闲两相宜'，存在夸大宣传和描述不符的问题，实际商品并非简约设计，且可能涉及未经授权的符号或数字使用，易引发误解或合规风险。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00121.jpg", "image": "data/raw/images/product_00121.jpg", "prompt": "国风刺绣上衣，传统工艺", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"图案\": \"英国国旗（米字旗）\",\n    \"颜色\": \"红、白、蓝\",\n    \"款式\": \"短袖T恤\",\n    \"设计元素\": \"花卉纹样叠加在国旗上\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是一件印有英国国旗图案的T恤，但商品描述为‘国风刺绣上衣，传统工艺’，存在严重描述不符。该商品图案与‘国风’或中国传统工艺无关联，属于虚假宣传。此外，使用他国国旗作为主要设计元素且未标明来源，可能涉及版权或文化符号滥用问题。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00122.jpg", "image": "data/raw/images/product_00122.jpg", "prompt": "国风刺绣上衣，传统工艺", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"深紫色\",\n    \"材质\": \"皮革\",\n    \"缝线\": \"金色\",\n    \"五金件\": \"金色金属扣\",\n    \"品牌标识\": \"正面有方形金属牌\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一款深紫色皮革手提包，具有金色缝线和金属五金件，属于皮具类产品；而商品描述为‘国风刺绣上衣，传统工艺’，描述内容与实际商品严重不符，存在虚假宣传和误导消费者的行为。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00123.jpg", "image": "data/raw/images/product_00123.jpg", "prompt": "欧美大牌设计 小众品牌", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"V领短袖T恤\",\n    \"材质\": \"棉质\",\n    \"图案\": \"左胸有小logo刺绣\",\n    \"品牌标识\": \"左胸位置有黑色小图标\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘欧美大牌设计’和‘小众品牌’等宣传用语，可能构成虚假或夸大宣传。图片中未显示任何知名品牌标识，仅有一个小图标，无法证实其为‘大牌设计’，存在误导消费者的风险。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00124.jpg", "image": "data/raw/images/product_00124.jpg", "prompt": "纯手工编织，限量发售", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"品牌\": \"Reebok\",\n    \"款式\": \"凉鞋\",\n    \"材质\": \"合成材料\",\n    \"闭合方式\": \"魔术贴\",\n    \"鞋底\": \"厚底，防滑纹路\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为机器生产的合成材料凉鞋，而描述中声称‘纯手工编织’，存在虚假宣传。此外，该商品外观为常规量产款式，与‘限量发售’的描述不符，涉嫌误导消费者。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00125.jpg", "image": "data/raw/images/product_00125.jpg", "prompt": "最新款 超低价 清仓大甩卖", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"ESPRIT\",\n    \"表盘颜色\": \"银色\",\n    \"表带材质\": \"棕色皮革与金属链条组合\",\n    \"表盘装饰\": \"镶嵌仿钻时标\",\n    \"表壳材质\": \"金属\",\n    \"款式\": \"时尚腕表\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大宣传用语，可能构成虚假或引人误解的商业宣传，违反平台关于广告合规性的规定。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00126.jpg", "image": "data/raw/images/product_00126.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色主体，绿色领口和袖口\",\n    \"品牌\": \"PUMA\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"胸前绿色PUMA标志及跳跃猎豹图案\",\n    \"材质\": \"未明确，推测为棉质或混纺\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品图片中展示的T恤带有PUMA品牌标志，属于知名品牌商品。根据平台规则，未经品牌授权的商品不得以‘正品保证’‘实体店同款’等宣传语进行销售，存在误导消费者的风险。因此，该商品描述涉嫌虚假宣传和侵犯品牌权益。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00127.jpg", "image": "data/raw/images/product_00127.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"淡紫色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"黑色女性头像印花，带有花卉元素\",\n    \"领型\": \"圆领\",\n    \"袖型\": \"短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘商场撤柜’‘专柜正品’‘便宜处理’等词汇，可能涉及虚假宣传或误导性营销。结合图片内容，该T恤为普通印花服饰，无明显品牌标识或高端特征，无法证实其为‘专柜正品’，存在夸大宣传嫌疑。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00128.jpg", "image": "data/raw/images/product_00128.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"女装上衣\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"部分透明网纱与不透明面料拼接\",\n    \"款式\": \"短袖圆领\",\n    \"设计特点\": \"肩部及袖子为透明网纱材质，主体为不透明布料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述声称‘纯棉休闲上衣’，但图片显示该上衣肩部和袖子部分使用了透明网纱材质，明显非纯棉，且存在视觉上的透视效果，可能涉及误导性宣传。此外，透明材质可能不符合平台对‘舒适透气’类商品的合规要求，存在夸大宣传风险。\"\n}", "violation": true, "category": "女装上衣"}
{"image_file": "product_00129.jpg", "image": "data/raw/images/product_00129.jpg", "prompt": "经典款牛仔裤，修身显瘦", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"吊带背心\",\n    \"材质\": \"棉质或混纺\",\n    \"设计特点\": \"胸前褶皱设计，细肩带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件黑色吊带背心，而商品描述为'经典款牛仔裤，修身显瘦'，描述与实际商品严重不符，存在误导消费者的风险。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00130.jpg", "image": "data/raw/images/product_00130.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"color\": \"紫色\",\n    \"design\": \"印有Pac-Man风格的卡通角色图案\",\n    \"text_elements\": [\n      \"ULTIMATE BOARD GAMING\",\n      \"30 YEARS\",\n      \"80's MIX\"\n    ],\n    \"brand_label\": \"80's MIX\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中的T恤设计包含与经典游戏Pac-Man高度相似的视觉元素（如黄色吃豆人、彩色幽灵等），且文字标注'ULTIMATE BOARD GAMING'和'30 YEARS'暗示其为特定游戏IP的纪念款。该设计存在明显的版权侵权风险，未经授权使用受保护的知名游戏形象属于违规行为。\"\n}", "violation": true, "category": "服饰"}
{"image_file": "product_00131.jpg", "image": "data/raw/images/product_00131.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"图案\": \"SEE THE WIN 字样，采用蓝、灰、红三色拼接设计\",\n    \"品牌标识\": \"领口处有 'the athletic' 字样及耐克标志\",\n    \"款式\": \"短袖T恤\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品图片中显示的T恤带有耐克（Nike）品牌标志和‘the athletic’字样，属于知名品牌标识。商品描述中声称‘正品保证’且‘实体店同款’，但未提供授权证明或官方销售渠道信息，存在冒用品牌名义进行销售的风险，涉嫌侵犯品牌知识产权，违反平台关于未经授权使用品牌标识的合规规定。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00132.jpg", "image": "data/raw/images/product_00132.jpg", "prompt": "韩版潮流服饰，时尚百搭", "response": "{\n  \"category\": \"服饰\",\n  \"attributes\": {\n    \"品牌\": \"PUMA\",\n    \"颜色\": \"粉色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"白色PUMA标志和文字\",\n    \"材质\": \"棉质或混纺面料（推测）\",\n    \"适用人群\": \"女性\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品为PUMA品牌服饰，属于知名品牌产品。商品描述中使用‘韩版潮流服饰，时尚百搭’等宣传语，未明确标注品牌信息且存在误导性描述，可能构成对品牌权益的侵犯或误导消费者。同时，未经品牌授权销售此类商品可能涉及知识产权侵权问题。\"\n}", "violation": true, "category": "服饰"}
{"image_file": "product_00133.jpg", "image": "data/raw/images/product_00133.jpg", "prompt": "经典款牛仔裤，修身显瘦", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色\",\n    \"款式\": \"无袖连帽背心\",\n    \"图案\": \"数字63、DIVI、14，带有涂鸦风格背景\",\n    \"材质\": \"未明确，推测为棉质或混纺面料\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件浅蓝色无袖连帽背心，而商品描述为'经典款牛仔裤，修身显瘦'，两者品类和款式严重不符，存在虚假描述问题。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00134.jpg", "image": "data/raw/images/product_00134.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"品牌\": \"PUMA\",\n    \"表带颜色\": \"黑色\",\n    \"表带材质\": \"皮革\",\n    \"表盘形状\": \"矩形\",\n    \"表盘颜色\": \"黑色\",\n    \"表盘数字\": \"12, 3, 6, 9\",\n    \"指针颜色\": \"银色\",\n    \"表壳材质\": \"金属\",\n    \"缝线颜色\": \"白色\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款PUMA品牌的手表，但商品描述中提及'面料柔软 版型修身 显瘦神器'，这些描述适用于服装类商品，与实际商品类别（手表）严重不符，属于虚假或误导性描述。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00135.jpg", "image": "data/raw/images/product_00135.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色表盘，银色表壳，黑色表带\",\n    \"材质\": \"金属表壳，皮革表带\",\n    \"款式\": \"计时码表，大数字刻度，多指针设计\",\n    \"品牌\": \"ESPRIT\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款手表，而商品描述中提到'高端羊毛面料，奢华质感'，这与实际商品属性严重不符。该描述可能误导消费者，属于虚假宣传。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00136.jpg", "image": "data/raw/images/product_00136.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "response": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"绿色与白色条纹\",\n    \"材质\": \"棉质\",\n    \"款式\": \"短袖衬衫\",\n    \"图案\": \"胸前有品牌徽章刺绣\",\n    \"领型\": \"标准翻领\",\n    \"袖口\": \"卷起设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男装条纹短袖衬衫，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重品类不符。图片中未出现任何皮鞋或相关产品，描述内容与实际商品完全不一致，违反平台商品信息真实性规则。\"\n}", "violation": true, "category": "男装衬衫"}
{"image_file": "product_00137.jpg", "image": "data/raw/images/product_00137.jpg", "prompt": "纯手工编织，限量发售", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"连帽拉链外套\",\n    \"材质\": \"针织面料\",\n    \"图案\": \"胸前有蓝色爪印图案，内含'1972'和字母'N'\",\n    \"品牌标识\": \"Nike标志位于图案下方\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'纯手工编织'，但图片显示该商品为机器生产的针织连帽衫，无任何手工编织的视觉特征，存在虚假宣传。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00138.jpg", "image": "data/raw/images/product_00138.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"帽子\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"棉质\",\n    \"款式\": \"棒球帽\",\n    \"图案\": \"绿色RF刺绣标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一顶白色棒球帽，带有绿色RF刺绣标志，属于帽子类商品，而商品描述中却写为‘纯棉休闲上衣’，与实际商品类别严重不符，存在虚假描述。\"\n}", "violation": true, "category": "帽子"}
{"image_file": "product_00139.jpg", "image": "data/raw/images/product_00139.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋头形状\": \"尖头\",\n    \"内里颜色\": \"棕色\",\n    \"鞋底类型\": \"低跟平底\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为常规男士正装皮鞋，无违规标识或敏感内容，符合平台商品发布规范。\"\n}", "violation": false, "category": "男鞋"}
{"image_file": "product_00140.jpg", "image": "data/raw/images/product_00140.jpg", "prompt": "最新款 超低价 清仓大甩卖", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"蓝黄格子\",\n    \"款式\": \"短袖衬衫\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"白色纽扣\",\n    \"口袋\": \"两个胸前口袋\",\n    \"图案\": \"格纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反了电商平台上关于广告合规的相关规定。\"\n}", "violation": true, "category": "男装"}
{"image_file": "product_00141.jpg", "image": "data/raw/images/product_00141.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"图案\": \"胸前有黑色'B'字母标志，左袖有圆形徽章，下摆左侧有红色数字'2'\",\n    \"装饰\": \"红色包边细节\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件男士白色Polo衫，但商品描述为'高端品牌商务皮鞋，真皮鞋面'，存在严重品类不符。实际商品为服装类，而非鞋类，描述与实物完全不一致，违反了商品信息真实性原则。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00142.jpg", "image": "data/raw/images/product_00142.jpg", "prompt": "最新款 超低价 清仓大甩卖", "response": "{\n  \"category\": \"运动鞋\",\n  \"attributes\": {\n    \"颜色\": \"银色、灰色、绿色、黑色\",\n    \"品牌标识\": \"Reebok\",\n    \"鞋型\": \"低帮运动鞋\",\n    \"材质\": \"网布与合成革\",\n    \"设计特点\": \"透气孔、支撑结构、橡胶外底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’‘超低价’‘清仓大甩卖’等夸大宣传用语，属于虚假或误导性宣传，违反了电商平台关于广告合规的规定。此外，图片中未显示任何促销标签或价格信息，但描述中的促销词汇可能误导消费者，构成违规。\"\n}", "violation": true, "category": "运动鞋"}
