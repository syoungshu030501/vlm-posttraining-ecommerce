{"image_file": "product_00330.jpg", "image": "data/raw/images/product_00330.jpg", "prompt": "百搭连衣裙，适合日常出行", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"无袖双排扣连衣裙\",\n    \"领型\": \"翻领\",\n    \"长度\": \"及膝\",\n    \"材质\": \"未明确\",\n    \"设计元素\": \"腰带、双排扣、口袋\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品图片中模特穿着的连衣裙为无袖设计，且整体风格偏向正式或商务场合，与描述中的'百搭连衣裙，适合日常出行'存在明显不符。此外，该款连衣裙的设计较为修身，可能不适合所有体型用户，宣传‘百搭’可能存在夸大宣传之嫌。同时，商品描述未提及关键属性如材质、尺码范围等，信息不完整，违反了电商商品描述需真实、全面的要求。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00331.jpg", "image": "data/raw/images/product_00331.jpg", "prompt": "欧美风格外套，时尚简约", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"Polo衫\",\n    \"品牌标志\": \"Puma\",\n    \"图案\": \"黑色弧形条纹，袖口有几何图案\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品实际为Puma品牌的Polo衫，属于运动休闲类上衣，而非描述中所称的‘外套’。此外，商品描述中的‘欧美风格外套’与实际商品类型不符，存在误导性描述，违反了商品信息真实性原则。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00332.jpg", "image": "data/raw/images/product_00332.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带休闲皮鞋\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"设计风格\": \"简约商务休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双深棕色皮革系带休闲皮鞋，而商品描述中却写的是‘简约设计衬衫，商务休闲两相宜’，存在明显的图文不符。描述内容与实际商品类别（服装 vs 鞋类）严重不一致，属于违规行为。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00333.jpg", "image": "data/raw/images/product_00333.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"红白蓝格纹\",\n    \"材质\": \"棉质\",\n    \"款式\": \"长袖格子衬衫\",\n    \"设计元素\": \"胸前双口袋，纽扣开合，翻领\",\n    \"袖口\": \"卷起\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘手工制作’和‘限量款’，但图片中无法提供任何视觉证据支持这些主张，如标签、工艺细节或限量标识。此类宣传可能构成虚假宣传，违反平台关于商品真实性的规定。\"\n}", "violation": true, "category": "男装衬衫"}
{"image_file": "product_00334.jpg", "image": "data/raw/images/product_00334.jpg", "prompt": "欧美风格外套，时尚简约", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色与灰色条纹\",\n    \"款式\": \"Polo衫\",\n    \"材质\": \"棉质或混纺面料\",\n    \"品牌标识\": \"Puma标志\",\n    \"领型\": \"翻领\",\n    \"图案\": \"横向条纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品实际为Polo衫，而非描述中的‘外套’，且风格偏向休闲运动风，不符合‘欧美风格外套，时尚简约’的描述，存在品类和风格不符的问题。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00335.jpg", "image": "data/raw/images/product_00335.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"卡其色\",\n    \"款式\": \"短袖Polo衫\",\n    \"领型\": \"翻领\",\n    \"图案\": \"左胸蓝色刺绣标志，左袖有蓝色文字和图案\",\n    \"材质\": \"棉质或混纺面料（视觉上柔软）\",\n    \"版型\": \"修身\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为常规男式Polo衫，无违规内容。描述中‘显瘦神器’属于常见营销用语，未涉及虚假宣传或敏感信息，符合平台规范。\"\n}", "violation": false, "category": "男装"}
{"image_file": "product_00336.jpg", "image": "data/raw/images/product_00336.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"Polo衫\",\n    \"图案\": \"横条纹\",\n    \"品牌标志\": \"Nike\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的是一件红色条纹Polo衫，而商品描述为'高端品牌商务皮鞋，真皮鞋面'，描述与图片内容严重不符，属于虚假描述。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00337.jpg", "image": "data/raw/images/product_00337.jpg", "prompt": "纯手工编织，限量发售", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"绿色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"单肩包\",\n    \"装饰\": \"花朵造型挂饰，流苏\",\n    \"缝线\": \"黄色缝线\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'纯手工编织'，但图片显示该包为皮革材质，且无编织纹理，实际为压纹皮革制品，与描述严重不符，构成虚假宣传。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00338.jpg", "image": "data/raw/images/product_00338.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色与亮蓝色拼接\",\n    \"款式\": \"短袖Polo衫\",\n    \"图案\": \"几何条纹与点阵图案\",\n    \"品牌标识\": \"Nike标志位于左胸位置\",\n    \"材质\": \"运动面料（推测为速干透气材质）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用‘商场撤柜’‘专柜正品’‘便宜处理’等词汇，涉嫌虚假宣传和价格诱导，可能误导消费者认为该商品为清仓或低价促销品，而图片显示为全新正品运动服饰，存在夸大或不实描述风险。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00339.jpg", "image": "data/raw/images/product_00339.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "response": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"材质\": \"棉质或混纺面料\",\n    \"款式\": \"长袖衬衫\",\n    \"设计细节\": \"胸前双口袋、纽扣开合、袖口可卷起、左臂有品牌徽章\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片与描述相符，展示的衬衫为灰色长袖款式，具有修身版型和柔软质感，符合‘显瘦神器’的宣传定位，未发现虚假宣传或违规内容。\"\n}", "violation": false, "category": "男装衬衫"}
{"image_file": "product_00340.jpg", "image": "data/raw/images/product_00340.jpg", "prompt": "欧美大牌设计 小众品牌", "response": "{\n  \"category\": \"鞋履\",\n  \"attributes\": {\n    \"品牌\": \"Clarks\",\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"凉拖\",\n    \"鞋底\": \"黑色橡胶\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘欧美大牌设计 小众品牌’，但图片显示的品牌为‘Clarks’，该品牌为国际知名大众品牌，并非小众品牌，存在虚假宣传和误导消费者的行为。\"\n}", "violation": true, "category": "鞋履"}
{"image_file": "product_00341.jpg", "image": "data/raw/images/product_00341.jpg", "prompt": "最新款 超低价 清仓大甩卖", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带休闲鞋\",\n    \"鞋底\": \"白色橡胶底\",\n    \"设计风格\": \"简约休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’、‘超低价’、‘清仓大甩卖’等夸大宣传用语，属于虚假或引人误解的商业宣传，违反了电商平台关于广告合规的规定。此类表述可能误导消费者对商品实际价值和库存状态的认知，存在违规风险。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00342.jpg", "image": "data/raw/images/product_00342.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深绿色\",\n    \"款式\": \"V领短袖\",\n    \"材质\": \"纯棉\",\n    \"图案\": \"左胸有小logo\",\n    \"搭配\": \"蓝色牛仔裤\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品图片中模特穿着的上衣为V领设计，领口较低，可能暴露过多身体区域，不符合平台关于服装类商品需保持适度保守、避免低胸或暴露性设计的合规要求。此外，尽管描述中称‘纯棉休闲上衣’，但未提供具体材质成分证明，存在虚假宣传风险。\"\n}", "violation": true, "category": "服装"}
