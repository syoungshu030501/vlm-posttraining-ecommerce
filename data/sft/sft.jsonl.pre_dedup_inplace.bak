{"image_file": "product_00351.jpg", "image": "data/raw/images/product_00351.jpg", "prompt": "百搭连衣裙，适合日常出行", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"低帮系带休闲鞋\",\n    \"品牌\": \"Clarks\",\n    \"鞋底\": \"白色橡胶底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双棕色皮革休闲鞋，而商品描述为‘百搭连衣裙，适合日常出行’，存在严重品类不符。图片中的商品为鞋类，描述却指向服装类商品，属于虚假描述或错放商品信息，违反了电商平台的商品信息真实性规范。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00352.jpg", "image": "data/raw/images/product_00352.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"五金件\": \"金色金属扣\",\n    \"设计风格\": \"复古风\",\n    \"把手\": \"双提手\",\n    \"肩带\": \"可拆卸肩带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘正品保证’和‘实体店同款’等宣传用语，但图片中未显示任何品牌标识或认证信息，可能构成虚假宣传或误导性描述，违反电商平台关于商品真实性和广告合规性的规定。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00353.jpg", "image": "data/raw/images/product_00353.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"领型\": \"翻领\",\n    \"袖口设计\": \"白色包边\",\n    \"品牌标识\": \"Puma标志\",\n    \"材质\": \"棉质或混纺面料\",\n    \"款式\": \"短袖Polo衫\",\n    \"版型\": \"修身\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一件黑色Polo衫，带有白色领边和袖口包边，左胸有Puma品牌标志，整体设计符合常规服装规范。描述中提到的‘面料柔软’‘版型修身’‘显瘦神器’等均为常见服装宣传用语，未发现夸大或误导性内容，且无违规图案、文字或敏感元素。因此该商品不违反平台规则。\"\n}", "violation": false, "category": "男装"}
{"image_file": "product_00354.jpg", "image": "data/raw/images/product_00354.jpg", "prompt": "欧美大牌设计 小众品牌", "response": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"套脚皮鞋\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"设计风格\": \"商务休闲\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'欧美大牌设计'和'小众品牌'等宣传用语，可能构成虚假或夸大宣传。根据平台规则，不得使用未被证实的品牌关联或暗示高端定位的表述。该鞋款为普通皮质套脚鞋，无明显奢侈品牌标识或设计特征支持此类描述。\"\n}", "violation": true, "category": "男鞋"}
{"image_file": "product_00355.jpg", "image": "data/raw/images/product_00355.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带休闲鞋\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"设计特点\": \"缓震结构，耐磨橡胶底\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一双棕色皮革材质的系带休闲鞋，搭配黑色橡胶鞋底，符合描述中的‘运动休闲鞋，缓震耐磨橡胶底’，无虚假宣传或违规内容。\"\n}", "violation": false, "category": "鞋类"}
{"image_file": "product_00356.jpg", "image": "data/raw/images/product_00356.jpg", "prompt": "韩版潮流服饰，时尚百搭", "response": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"红色\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"材质\": \"棉质或混纺\",\n    \"装饰\": \"胸前有小刺绣标志\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为常规女装Polo衫，颜色为红色，设计简洁，无违规图案或文字，符合平台对服饰类商品的合规要求。\"\n}", "violation": false, "category": "女装"}
{"image_file": "product_00357.jpg", "image": "data/raw/images/product_00357.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"手提包\",\n    \"细节\": \"双拉链口袋，金属扣件，黄色缝线\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示的为一款蓝色皮革手提包，而商品描述中提及的是‘运动休闲鞋’，存在明显的品类不符。根据平台规则，商品描述必须与实际商品一致，因此该商品违反了合规要求。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00358.jpg", "image": "data/raw/images/product_00358.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"女装-上衣\",\n  \"attributes\": {\n    \"颜色\": \"深灰色底色，搭配蓝色、粉色、绿色和黄色图案\",\n    \"款式\": \"短袖圆领T恤\",\n    \"图案\": \"瓶状物与几何图形组合的抽象印花\",\n    \"装饰\": \"胸前及两侧有黑色纽扣点缀\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片中未发现违规内容，如政治敏感、色情低俗、暴力恐怖或侵权标识等。图案为抽象艺术设计，符合平台对正常服饰类商品的展示规范。\"\n}", "violation": false, "category": "女装-上衣"}
{"image_file": "product_00359.jpg", "image": "data/raw/images/product_00359.jpg", "prompt": "最新款 超低价 清仓大甩卖", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"环保主题印花，包含回收标志、蝴蝶和文字标语\",\n    \"文字内容\": \"RECYCLE, WAR IS NOT HEALING FOR CHILDREN AND OTHER LIVING THINGS\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘最新款’‘超低价’‘清仓大甩卖’等夸大宣传用语，可能构成虚假或引人误解的商业宣传。同时，T恤上的文字‘WAR IS NOT HEALING FOR CHILDREN AND OTHER LIVING THINGS’虽为环保主题，但结合‘Flying Machine’品牌及整体设计风格，存在潜在的政治或社会敏感性表达，需进一步审核是否违反平台关于政治言论或不当信息的规定。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00360.jpg", "image": "data/raw/images/product_00360.jpg", "prompt": "100%真丝连衣裙，高贵典雅", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"表壳形状\": \"方形\",\n    \"表带材质\": \"黑色橡胶\",\n    \"显示类型\": \"数字显示屏\",\n    \"屏幕内容\": \"时间、日期、星期\",\n    \"颜色\": \"白色表壳，黑色表带\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一款电子手表，而商品描述为‘100%真丝连衣裙，高贵典雅’，存在严重图文不符。图片中的商品为手表，与描述中的服装类商品完全不一致，属于虚假宣传或误导性描述，违反了电商商品信息真实性的规定。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00361.jpg", "image": "data/raw/images/product_00361.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"黑色底色，正面印有灰白色月球图案\",\n    \"款式\": \"长袖连衣裙\",\n    \"领型\": \"圆领\",\n    \"图案\": \"月球表面纹理印花\",\n    \"长度\": \"中长款，及大腿中部\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品为孕妇装，其设计通过月球图案巧妙地模仿孕妇腹部轮廓，可能涉及对特定人群身体特征的夸张或戏谑性表达。虽然图案本身为天文主题，但整体视觉效果容易引发关于孕期身体形象的不当联想，存在潜在的不尊重或物化风险，不符合平台对健康、积极商品展示的要求。\"\n}", "violation": true, "category": "女装"}
{"image_file": "product_00362.jpg", "image": "data/raw/images/product_00362.jpg", "prompt": "时尚秋冬外套，多色可选", "response": "{\n  \"category\": \"女装上衣\",\n  \"attributes\": {\n    \"颜色\": \"黑白条纹与黑色拼接\",\n    \"款式\": \"V领短袖针织衫\",\n    \"材质\": \"针织面料\",\n    \"图案\": \"竖条纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件V领短袖针织衫，属于春夏款式的上衣，而商品描述中称其为‘时尚秋冬外套’，存在品类和季节性严重不符，误导消费者。\"\n}", "violation": true, "category": "女装上衣"}
{"image_file": "product_00363.jpg", "image": "data/raw/images/product_00363.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"女装-半身裙\",\n  \"attributes\": {\n    \"颜色\": \"灰色格纹\",\n    \"材质\": \"梭织面料\",\n    \"款式\": \"高腰A字裙\",\n    \"长度\": \"中长款（及小腿）\",\n    \"设计细节\": \"侧开叉、格子图案\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一条格纹半身裙，而商品描述中却称其为‘简约设计衬衫’，存在严重品类与描述不符的问题。根据平台规则，商品描述必须真实反映商品实际属性，此行为构成虚假宣传。\"\n}", "violation": true, "category": "女装-半身裙"}
{"image_file": "product_00364.jpg", "image": "data/raw/images/product_00364.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"红黑白格纹\",\n    \"款式\": \"短袖格子衬衫\",\n    \"材质\": \"棉质（视觉判断）\",\n    \"细节\": \"胸前双口袋，金色纽扣，左胸有品牌标识\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称使用‘高端羊毛面料’，但根据图片显示的面料纹理、光泽和整体外观，该衬衫更符合棉质或混纺材质特征，不具备羊毛特有的质感。因此存在虚假宣传，违反平台关于商品真实性的规定。\"\n}", "violation": true, "category": "男装衬衫"}
{"image_file": "product_00365.jpg", "image": "data/raw/images/product_00365.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"灰色底色，绿色和蓝色印花\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"环保主题印花，包含'GO GREEN FELLAS'字样、叶子图案、油漆桶和刷子插图\",\n    \"材质\": \"棉质或棉混纺（推测）\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通服饰，图案内容为环保主题宣传语，未涉及政治、宗教、色情、暴力等敏感内容，符合平台合规要求。\"\n}", "violation": false, "category": "服装"}
{"image_file": "product_00366.jpg", "image": "data/raw/images/product_00366.jpg", "prompt": "时尚秋冬外套，多色可选", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"北极熊戴礼帽、眼镜和领结，手持茶杯，旁边有茶点\",\n    \"材质\": \"棉质（推测）\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件黄色短袖T恤，而商品描述为‘时尚秋冬外套，多色可选’，存在明显品类不符。图片中无外套特征，且为短袖设计，不符合‘秋冬外套’的定义。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00367.jpg", "image": "data/raw/images/product_00367.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"单肩包\",\n    \"细节\": \"两侧有拉链口袋，金属铆钉装饰\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款棕色皮革手提包，而商品描述中提及的是‘纯棉休闲上衣’，存在严重的图文不符，违反了平台关于商品信息真实性的规定。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00368.jpg", "image": "data/raw/images/product_00368.jpg", "prompt": "韩版潮流服饰，时尚百搭", "response": "{\n  \"category\": \"运动短裤\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"针织面料\",\n    \"款式\": \"修身剪裁\",\n    \"细节\": \"右侧裤腿有白色Nike标志，侧边有蓝色条纹装饰\",\n    \"腰围\": \"松紧腰设计\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中可见明显的Nike品牌标志（白色勾形logo），属于知名品牌标识，而商品描述中使用‘韩版潮流服饰’等模糊表述可能构成虚假宣传或误导消费者，违反平台关于品牌真实性与描述准确性的规则。\"\n}", "violation": true, "category": "运动短裤"}
{"image_file": "product_00369.jpg", "image": "data/raw/images/product_00369.jpg", "prompt": "百搭连衣裙，适合日常出行", "response": "{\n  \"category\": \"运动上衣\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"材质\": \"Dri-FIT\",\n    \"款式\": \"长袖半拉链\",\n    \"品牌\": \"Nike\",\n    \"设计元素\": \"胸前小logo，左袖反光条\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件白色长袖运动上衣，带有Nike品牌标识和Dri-FIT字样，属于运动服饰类别。但商品描述中称其为‘百搭连衣裙’，与实际商品类型严重不符，存在误导性描述，违反平台商品信息真实性规则。\"\n}", "violation": true, "category": "运动上衣"}
{"image_file": "product_00370.jpg", "image": "data/raw/images/product_00370.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"仿皮\",\n    \"图案\": \"菱格纹+花卉压花\",\n    \"提手\": \"编织式手柄\",\n    \"五金件\": \"银色金属环\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘正品保证’和‘实体店同款’等表述，但图片中未显示任何品牌标识或官方认证信息，涉嫌虚假宣传。此类描述可能误导消费者认为该商品为某知名品牌正品，而实际无证据支持其真实性，违反了电商平台关于商品真实性和广告合规的相关规定。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00371.jpg", "image": "data/raw/images/product_00371.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"brand\": \"Puma\",\n    \"color\": \"蓝色\",\n    \"band_material\": \"编织材质\",\n    \"display_type\": \"数字显示屏\",\n    \"case_color\": \"黑色\",\n    \"features\": [\"时间显示\", \"日期显示\", \"运动风格设计\"]\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一款Puma品牌的智能手表，具有数字显示屏和编织表带，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，与实际商品类别严重不符，存在虚假描述和误导消费者的风险。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00372.jpg", "image": "data/raw/images/product_00372.jpg", "prompt": "纯手工编织，限量发售", "response": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"材质\": \"牛仔布\",\n    \"款式\": \"衬衫裙\",\n    \"袖长\": \"短袖\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"前排纽扣\",\n    \"腰带\": \"系带设计\",\n    \"口袋\": \"两侧斜插袋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘纯手工编织’，但图片显示该商品为机织牛仔布制成的衬衫裙，无任何手工编织特征，存在虚假宣传。此外，‘限量发售’无法从图片中验证，可能构成误导性营销信息。\"\n}", "violation": true, "category": "女装"}
{"image_file": "product_00373.jpg", "image": "data/raw/images/product_00373.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"套脚便鞋\",\n    \"鞋底\": \"厚底\",\n    \"缝线\": \"浅棕色\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘商场撤柜’、‘专柜正品’、‘便宜处理’等宣传性用语，可能涉及虚假促销或误导消费者，违反平台关于商品描述真实性的规定。\"\n}", "violation": true, "category": "男鞋"}
{"image_file": "product_00374.jpg", "image": "data/raw/images/product_00374.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"材质\": \"人造皮革\",\n    \"款式\": \"绗缝图案\",\n    \"手柄\": \"编织设计\",\n    \"五金件\": \"银色金属环\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称使用‘高端羊毛面料’，但图片显示该包为绗缝人造皮革材质，无任何羊毛特征，存在虚假宣传。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00375.jpg", "image": "data/raw/images/product_00375.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"颜色\": \"紫色为主，肩部和袖子为米白色\",\n    \"品牌\": \"Reebok\",\n    \"赞助商\": \"Nokia\",\n    \"款式\": \"短袖半拉链运动衫\",\n    \"图案\": \"胸前有火焰头盔标志，左右袖上有多个徽标\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示该服装为带有‘NOKIA’和‘Reebok’等品牌标识的运动队服，属于特定球队或赛事的官方装备。根据平台规则，未经授权销售带有第三方品牌标识的商品可能构成侵权。此外，描述中‘商场撤柜 专柜正品 便宜处理’暗示其为非正规渠道流出的库存商品，存在售假或未经授权分销的风险，因此违反平台合规政策。\"\n}", "violation": true, "category": "运动服饰"}
{"image_file": "product_00376.jpg", "image": "data/raw/images/product_00376.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"鞋类\",\n  \"attributes\": {\n    \"颜色\": \"深绿色\",\n    \"材质\": \"绒面革\",\n    \"款式\": \"系带皮鞋\",\n    \"鞋底\": \"浅色橡胶底\",\n    \"设计细节\": \"布洛克雕花\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一双深绿色绒面革材质的男士皮鞋，而商品描述为‘纯棉休闲上衣，舒适透气’，描述内容与实际商品类别严重不符，属于虚假描述。\"\n}", "violation": true, "category": "鞋类"}
{"image_file": "product_00377.jpg", "image": "data/raw/images/product_00377.jpg", "prompt": "经典款牛仔裤，修身显瘦", "response": "{\n  \"category\": \"女装上衣\",\n  \"attributes\": {\n    \"颜色\": \"浅粉色底色，带有灰黑色和粉红色花卉图案\",\n    \"款式\": \"短袖圆领宽松T恤\",\n    \"材质\": \"看似轻薄柔软的印花面料\",\n    \"图案\": \"抽象花卉印花\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件印有花卉图案的短袖上衣，而商品描述中却称其为‘经典款牛仔裤，修身显瘦’，这与实际商品严重不符，属于虚假描述。\"\n}", "violation": true, "category": "女装上衣"}
{"image_file": "product_00378.jpg", "image": "data/raw/images/product_00378.jpg", "prompt": "简约设计衬衫，商务休闲两相宜", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"银色和白色\",\n    \"材质\": \"金属表壳，白色皮革表带，金属链条装饰\",\n    \"款式\": \"圆形表盘，镶钻时标，双层表带设计\",\n    \"品牌\": \"ESPRIT\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款手表，而商品描述中提及的是‘简约设计衬衫’，存在严重的图文不符问题。根据平台规则，商品描述必须与实际商品一致，因此该商品违反了合规要求。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00379.jpg", "image": "data/raw/images/product_00379.jpg", "prompt": "百搭连衣裙，适合日常出行", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"粉色\",\n    \"款式\": \"无袖背心裙\",\n    \"材质\": \"棉质或混纺面料\",\n    \"装饰\": \"胸前有银色亮片点缀\",\n    \"长度\": \"中长款，及臀部\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品为无袖背心式上衣，搭配牛仔裤穿着，并非连衣裙。商品描述中称其为‘百搭连衣裙’存在误导性，与实际视觉属性不符，违反了平台关于商品真实描述的规则。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00380.jpg", "image": "data/raw/images/product_00380.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"蓝色\",\n    \"款式\": \"短袖T恤\",\n    \"领型\": \"圆领\",\n    \"图案\": \"左胸有小logo\",\n    \"材质\": \"棉质或混纺\",\n    \"搭配\": \"搭配牛仔裤\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘商场撤柜’‘专柜正品’‘便宜处理’等宣传用语，属于虚假或夸大宣传，可能误导消费者。根据电商平台规则，此类表述未经证实易构成违规，尤其是‘专柜正品’缺乏凭证支持，且‘便宜处理’暗示折扣促销，但未提供原价对比，涉嫌价格欺诈风险。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00381.jpg", "image": "data/raw/images/product_00381.jpg", "prompt": "时尚秋冬外套，多色可选", "response": "{\n  \"category\": \"童装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"图案\": \"猴子头像\",\n    \"文字\": \"Cheeky Monkey\",\n    \"品牌\": \"BeBorn\",\n    \"尺寸\": \"12M\",\n    \"领口\": \"红色内衬\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件婴儿T恤，但商品描述为‘时尚秋冬外套，多色可选’，存在严重描述不符。实际商品为短袖T恤，不具备外套特征，且季节属性与‘秋冬’不匹配，属于虚假宣传。\"\n}", "violation": true, "category": "童装"}
{"image_file": "product_00382.jpg", "image": "data/raw/images/product_00382.jpg", "prompt": "欧美风格外套，时尚简约", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"灰色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"印有'ROADTRIP'字样、一辆房车和'FLAPDOODLE TRAVELS'文字\",\n    \"材质\": \"棉质混纺\",\n    \"领型\": \"圆领\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件短袖T恤，而商品描述中称其为'欧美风格外套'，存在品类描述错误。此外，该商品并非外套，而是T恤，属于严重描述不符。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00383.jpg", "image": "data/raw/images/product_00383.jpg", "prompt": "日系简约 ins风 学院风", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"表盘形状\": \"方形\",\n    \"表带材质\": \"皮革\",\n    \"表盘设计\": \"多表盘复杂设计\",\n    \"品牌标识\": \"Carrera\",\n    \"风格\": \"运动风、科技感\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款具有复杂多表盘设计、红色指针和品牌标识'Carrera'的方形运动手表，整体风格偏向科技感与运动风，与商品描述中‘日系简约 ins风 学院风’存在明显不符。视觉属性中的复杂表盘结构、品牌标识及硬朗造型不符合简约或学院风格特征，构成描述与实际商品不符的违规行为。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00384.jpg", "image": "data/raw/images/product_00384.jpg", "prompt": "商场撤柜 专柜正品 便宜处理", "response": "{\n  \"category\": \"运动短裤\",\n  \"attributes\": {\n    \"颜色\": \"黑色为主，侧边有蓝色条纹\",\n    \"品牌标识\": \"右腿下方有白色耐克（Nike）标志\",\n    \"材质\": \"看起来为轻质透气的合成纤维面料\",\n    \"款式\": \"松紧腰带设计，适合运动穿着\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'商场撤柜'、'专柜正品'、'便宜处理'等词汇，可能暗示该商品为清仓或非正常渠道销售的商品，存在误导消费者的风险。此外，图片显示为知名品牌耐克产品，若未提供正规授权证明，可能存在售假或侵犯品牌权益的嫌疑。\"\n}", "violation": true, "category": "运动短裤"}
{"image_file": "product_00385.jpg", "image": "data/raw/images/product_00385.jpg", "prompt": "百搭连衣裙，适合日常出行", "response": "{\n  \"category\": \"男装裤子\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"款式\": \"直筒西裤\",\n    \"材质\": \"混纺面料\",\n    \"搭配\": \"白色条纹衬衫、黑色皮带、黑色皮鞋\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为男士黑色西裤，而商品描述中称其为‘百搭连衣裙’，存在严重品类与描述不符的问题。根据平台规则，商品描述必须真实反映商品属性，该描述属于误导性信息，违反了商品合规要求。\"\n}", "violation": true, "category": "男装裤子"}
{"image_file": "product_00386.jpg", "image": "data/raw/images/product_00386.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"材质\": \"棉质（视觉上为普通针织面料）\",\n    \"图案\": \"左胸有蓝色刺绣标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称使用'高端羊毛面料，奢华质感'，但根据图片显示，该Polo衫的面料外观为普通棉质针织纹理，无羊毛特有的光泽或厚重感，存在虚假宣传嫌疑。\"\n}", "violation": true, "category": "男装"}
