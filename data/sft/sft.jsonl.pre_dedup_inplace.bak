{"image_file": "product_00436.jpg", "image": "data/raw/images/product_00436.jpg", "prompt": "经典款牛仔裤，修身显瘦", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"长袖衬衫\",\n    \"材质\": \"棉质\",\n    \"领型\": \"翻领\",\n    \"口袋\": \"左胸有一个贴袋\",\n    \"品牌标识\": \"左胸口袋上方有小logo\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件白色长袖衬衫，而商品描述中却称其为'经典款牛仔裤，修身显瘦'，这与实际商品严重不符。根据视觉属性，该商品为上衣类服装，而非牛仔裤，存在虚假描述问题。\"\n}", "violation": true, "category": "男装"}
{"image_file": "product_00437.jpg", "image": "data/raw/images/product_00437.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"白色\",\n    \"款式\": \"无袖背心\",\n    \"图案\": \"和平符号由粉色和绿色花朵组成，周围有灰色藤蔓花纹\",\n    \"材质\": \"棉质或混纺面料\",\n    \"设计细节\": \"后领有镂空设计，下摆带有抽绳\"\n  },\n  \"violation\": false,\n  \"reason\": \"该商品为普通服饰，图案为和平符号与花卉结合，无违法不良信息或敏感内容，符合平台合规标准。\"\n}", "violation": false, "category": "服装"}
{"image_file": "product_00438.jpg", "image": "data/raw/images/product_00438.jpg", "prompt": "高端品牌商务皮鞋，真皮鞋面", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色表盘，黄色数字和指针，银色表壳\",\n    \"材质\": \"金属表壳，黑色橡胶或碳纤维纹理表带\",\n    \"款式\": \"多功能计时码表，带有测速仪刻度\",\n    \"品牌\": \"Carrera\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一款手表，而商品描述为‘高端品牌商务皮鞋，真皮鞋面’，存在严重品类与描述不符的问题。图片中无任何皮鞋元素，实际商品为手表，属于虚假描述。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00439.jpg", "image": "data/raw/images/product_00439.jpg", "prompt": "日系简约 ins风 学院风", "response": "{\n  \"category\": \"男装衬衫\",\n  \"attributes\": {\n    \"颜色\": \"浅绿色与深蓝色格纹\",\n    \"款式\": \"长袖翻领衬衫\",\n    \"图案\": \"格子图案\",\n    \"口袋\": \"胸前双口袋\",\n    \"袖口\": \"卷起袖口\",\n    \"材质\": \"棉质或混纺面料（视觉推测）\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品图片显示为一件格纹长袖衬衫，风格偏向休闲商务，符合常见的男装品类描述。商品描述中提到的‘日系简约 ins风 学院风’虽为风格化表达，但未涉及虚假宣传或违规内容，且无敏感元素或不当信息，因此不构成违规。\"\n}", "violation": false, "category": "男装衬衫"}
{"image_file": "product_00440.jpg", "image": "data/raw/images/product_00440.jpg", "prompt": "2024新款 正品保证 实体店同款", "response": "{\n  \"category\": \"运动服饰\",\n  \"attributes\": {\n    \"品牌\": \"Nike\",\n    \"颜色\": \"黑色、蓝色、灰色\",\n    \"材质\": \"Dri-FIT\",\n    \"款式\": \"短袖运动T恤\",\n    \"图案\": \"白色Nike标志，斜向灰色条纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了‘正品保证’和‘实体店同款’等宣传用语，但未提供任何可验证的正品证明（如授权证书、防伪标识或官方渠道信息），涉嫌虚假宣传。此外，‘2024新款’缺乏具体发布依据，可能构成误导性描述，违反电商平台关于商品真实性和广告合规的相关规定。\"\n}", "violation": true, "category": "运动服饰"}
{"image_file": "product_00441.jpg", "image": "data/raw/images/product_00441.jpg", "prompt": "时尚秋冬外套，多色可选", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"米白色\",\n    \"材质\": \"人造皮革\",\n    \"图案\": \"格纹缝线\",\n    \"五金件\": \"金色金属扣\",\n    \"肩带\": \"可调节长肩带\",\n    \"款式\": \"单肩包\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一款米白色的单肩包，具有格纹缝线和金色金属扣等特征，属于手提包品类。然而商品描述中却标注为‘时尚秋冬外套，多色可选’，与实际商品类别严重不符，存在虚假宣传和误导消费者的行为，违反了电商商品信息真实性原则。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00442.jpg", "image": "data/raw/images/product_00442.jpg", "prompt": "经典款牛仔裤，修身显瘦", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅紫色、深紫色、灰色、白色\",\n    \"款式\": \"条纹毛衣\",\n    \"领型\": \"圆领\",\n    \"袖型\": \"长袖\",\n    \"图案\": \"横向波浪形条纹\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件条纹毛衣，而商品描述为'经典款牛仔裤，修身显瘦'，描述与实际商品严重不符，属于虚假宣传。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00443.jpg", "image": "data/raw/images/product_00443.jpg", "prompt": "欧美大牌设计 小众品牌", "response": "{\n  \"category\": \"手提包\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"人造皮革\",\n    \"图案\": \"扇形波浪纹\",\n    \"手柄\": \"编织设计\",\n    \"拉链\": \"金色金属拉链\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'欧美大牌设计'和'小众品牌'等可能误导消费者的表述，且图片未显示任何品牌标识，存在虚假宣传风险。\"\n}", "violation": true, "category": "手提包"}
{"image_file": "product_00444.jpg", "image": "data/raw/images/product_00444.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"品牌标志\": \"PUMA\",\n    \"标志颜色\": \"荧光绿\",\n    \"款式\": \"圆领短袖T恤\",\n    \"材质视觉表现\": \"光滑，类似棉质或合成纤维\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称使用‘高端羊毛面料’，但图片显示的T恤表面光滑且具有典型棉质或合成纤维的外观特征，无羊毛特有的纹理和质感。此外，PUMA品牌通常不以纯羊毛作为此类T恤的主要材料，因此该描述存在虚假宣传嫌疑。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00445.jpg", "image": "data/raw/images/product_00445.jpg", "prompt": "欧美风格外套，时尚简约", "response": "{\n  \"category\": \"belt\",\n  \"attributes\": {\n    \"color\": \"black\",\n    \"material\": \"leather\",\n    \"buckle_type\": \"metallic square buckle\",\n    \"style\": \"minimalist\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一条黑色皮质腰带，而商品描述中提及的是'欧美风格外套'，存在严重品类不符。根据平台规则，商品描述必须与实际商品一致，此情况构成虚假描述违规。\"\n}", "violation": true, "category": "belt"}
{"image_file": "product_00446.jpg", "image": "data/raw/images/product_00446.jpg", "prompt": "韩版潮流服饰，时尚百搭", "response": "{\n  \"category\": \"女装\",\n  \"attributes\": {\n    \"颜色\": \"淡紫色\",\n    \"款式\": \"V领短袖T恤\",\n    \"装饰\": \"左侧胸前有立体玫瑰花刺绣\",\n    \"材质\": \"棉质或棉混纺\",\n    \"版型\": \"修身\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通女装T恤，无违规图案、文字或敏感元素，符合平台对服饰类商品的合规要求。\"\n}", "violation": false, "category": "女装"}
{"image_file": "product_00447.jpg", "image": "data/raw/images/product_00447.jpg", "prompt": "高端羊毛面料，奢华质感", "response": "{\n  \"category\": \"女鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"楔形凉鞋\",\n    \"设计特点\": \"交叉带、后跟搭扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示该鞋为皮革材质，但商品描述中声称使用‘高端羊毛面料’，存在材质描述与实际不符的虚假宣传问题。\"\n}", "violation": true, "category": "女鞋"}
{"image_file": "product_00448.jpg", "image": "data/raw/images/product_00448.jpg", "prompt": "欧美大牌设计 小众品牌", "response": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"深棕色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"乐福鞋\",\n    \"缝线\": \"浅色对比缝线\",\n    \"内里\": \"浅灰色衬里\",\n    \"鞋底\": \"黑色平底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中使用了'欧美大牌设计'和'小众品牌'等可能误导消费者的表述，暗示其为知名品牌或高端定位，但图片未提供任何品牌标识或认证信息，存在虚假宣传风险。\"\n}", "violation": true, "category": "男鞋"}
{"image_file": "product_00449.jpg", "image": "data/raw/images/product_00449.jpg", "prompt": "最新款 超低价 清仓大甩卖", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"紫色\",\n    \"款式\": \"V领短袖T恤\",\n    \"图案\": \"PUMA品牌标志，采用渐变色设计（粉色、蓝色、白色）\",\n    \"材质\": \"棉质或混纺面料（推测）\",\n    \"性别\": \"女性\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片中展示的T恤印有‘PUMA’品牌标志，属于知名品牌商标。在未获得授权的情况下销售此类带有品牌标识的商品，可能构成侵犯知识产权的行为。此外，商品描述中使用‘最新款 超低价 清仓大甩卖’等宣传语，易引发消费者对商品真实性和来源的质疑，存在误导性营销风险。\"\n}", "violation": true, "category": "服装"}
