{"image_file": "product_00417.jpg", "image": "data/raw/images/product_00417.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"黄色\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"卡通人物演奏乐器，文字'SING IT!'及'with FLAP DOODLERS 5.00pm onwards school backyard'\",\n    \"材质\": \"棉质\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一件儿童T恤，但商品描述为'运动休闲鞋，缓震耐磨橡胶底'，存在严重品类不符。根据视觉属性，该商品为服装类T恤，而非鞋子，违反了平台商品信息真实性规则。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00418.jpg", "image": "data/raw/images/product_00418.jpg", "prompt": "纯手工编织，限量发售", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深棕色、酒红色、白色条纹\",\n    \"款式\": \"短袖Polo衫\",\n    \"材质\": \"针织面料\",\n    \"品牌标识\": \"Nike标志（红色）\",\n    \"领型\": \"翻领\",\n    \"纽扣\": \"两个深色纽扣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称'纯手工编织'，但图片显示为机器织造的条纹针织Polo衫，且带有Nike品牌标识，属于批量生产的运动服饰，与'纯手工'和'限量发售'的描述严重不符，构成虚假宣传。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00419.jpg", "image": "data/raw/images/product_00419.jpg", "prompt": "欧美风格外套，时尚简约", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"绿色\",\n    \"款式\": \"Polo衫\",\n    \"领型\": \"翻领\",\n    \"袖长\": \"短袖\",\n    \"材质\": \"棉质（推测）\",\n    \"图案\": \"左胸有小刺绣标志\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的是一件绿色短袖Polo衫，属于上衣类别，而非描述中所称的‘外套’。商品描述中的‘外套’与实际商品品类不符，构成虚假宣传。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00420.jpg", "image": "data/raw/images/product_00420.jpg", "prompt": "面料柔软 版型修身 显瘦神器", "response": "{\n  \"category\": \"手表\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"表盘形状\": \"方形\",\n    \"表带材质\": \"橡胶\",\n    \"表盘设计\": \"多指针、三眼计时\",\n    \"品牌标识\": \"Carrera\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款手表，但商品描述中提及'面料柔软 版型修身 显瘦神器'，明显与实际商品品类不符，属于虚假描述，误导消费者。\"\n}", "violation": true, "category": "手表"}
{"image_file": "product_00421.jpg", "image": "data/raw/images/product_00421.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"男装\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"领型\": \"V领\",\n    \"袖口设计\": \"罗纹袖口\",\n    \"内衬\": \"格子衬衫领\",\n    \"材质\": \"针织面料\",\n    \"款式\": \"长袖毛衣\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称‘手工制作’和‘限量款’，但图片未提供任何可验证的工艺细节或限量标识，存在虚假宣传嫌疑。此外，该商品为常规款式毛衣，不具备显著独特性，无法支持‘限量款’的宣称。\"\n}", "violation": true, "category": "男装"}
{"image_file": "product_00422.jpg", "image": "data/raw/images/product_00422.jpg", "prompt": "时尚单品 手工制作 限量款", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"深蓝色\",\n    \"图案\": \"白色钥匙图案\",\n    \"款式\": \"短袖T恤\",\n    \"材质\": \"棉质\",\n    \"设计元素\": \"钥匙挂绳图案\"\n  },\n  \"violation\": true,\n  \"reason\": \"该商品T恤上的图案为两把钥匙，且钥匙通过挂绳连接，可能被误解为具有开锁或非法入侵的暗示，存在潜在违规风险。尽管是印花图案，但其视觉表现形式可能引发对安全或隐私问题的联想，不符合平台关于避免敏感符号或潜在不当暗示的规定。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00423.jpg", "image": "data/raw/images/product_00423.jpg", "prompt": "纯棉休闲上衣，舒适透气", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"浅蓝色与白色拼接\",\n    \"款式\": \"短袖T恤\",\n    \"图案\": \"正面印有数字'39'和文字'ATHLETIC DEP. DIV .IA'\",\n    \"材质\": \"纯棉\"\n  },\n  \"violation\": false,\n  \"reason\": \"商品为普通休闲T恤，图案内容为运动风格设计，未发现违规元素。\"\n}", "violation": false, "category": "服装"}
{"image_file": "product_00424.jpg", "image": "data/raw/images/product_00424.jpg", "prompt": "运动休闲鞋，缓震耐磨橡胶底", "response": "{\n  \"category\": \"正装皮鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装鞋\",\n    \"鞋底\": \"黑色橡胶底\",\n    \"内衬\": \"棕色\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片显示为一款黑色皮革系带正装皮鞋，具有典型的商务正式风格，而商品描述中称其为‘运动休闲鞋’，且强调‘缓震耐磨橡胶底’，这与实际视觉特征不符。该鞋款不具备运动鞋的外观设计（如网面、厚底、透气结构等），因此存在描述与实物严重不符的违规行为。\"\n}", "violation": true, "category": "正装皮鞋"}
{"image_file": "product_00425.jpg", "image": "data/raw/images/product_00425.jpg", "prompt": "国风刺绣上衣，传统工艺", "response": "{\n  \"category\": \"服装\",\n  \"attributes\": {\n    \"颜色\": \"绿色\",\n    \"款式\": \"Polo衫\",\n    \"材质\": \"棉质\",\n    \"图案\": \"彩色刺绣徽标\",\n    \"领口\": \"翻领，带有浅色条纹装饰\",\n    \"袖口\": \"带有浅色条纹装饰\",\n    \"品牌标识\": \"左下角有黑色标签，印有'SID'字样\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品描述中声称是‘国风刺绣上衣，传统工艺’，但图片显示的是一件现代风格的Polo衫，其刺绣图案为抽象风格的彩色徽标，并非具有中国传统元素的刺绣设计。因此，商品描述与实际视觉内容不符，存在虚假宣传嫌疑。\"\n}", "violation": true, "category": "服装"}
{"image_file": "product_00426.jpg", "image": "data/raw/images/product_00426.jpg", "prompt": "韩版潮流服饰，时尚百搭", "response": "{\n  \"category\": \"男鞋\",\n  \"attributes\": {\n    \"颜色\": \"黑色\",\n    \"材质\": \"皮革\",\n    \"款式\": \"系带正装皮鞋\",\n    \"鞋头\": \"圆头\",\n    \"鞋底\": \"橡胶平底\"\n  },\n  \"violation\": true,\n  \"reason\": \"商品图片展示的为一款男士正装皮鞋，属于鞋类商品，而商品描述中使用‘韩版潮流服饰，时尚百搭’等词汇，将鞋类商品归类为‘服饰’，存在品类描述不一致的问题，违反了平台对商品分类和描述准确性的要求。\"\n}", "violation": true, "category": "男鞋"}
